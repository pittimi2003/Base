@page "/operations"

<MxPageHeader Title="Operaciones"
              Description="Vista inicial para coordinación diaria de equipos y servicios en campo.">
    <Actions>
        <MxBadge Variant="MxBadgeVariant.Brand" Text="Adoption Validation" />
        <MxBadge Variant="MxBadgeVariant.Neutral" Text="Mx* Standard" />
    </Actions>
</MxPageHeader>

<MxPanel Variant="SurfaceVariant.Outlined">
    <div class="ms-grid ms-grid--2">
        <AppMenuTile Title="Turnos"
                     Description="Planificación de cobertura y asignación por franja horaria."
                     Href="#"
                     Icon="🕒" />
        <AppMenuTile Title="Incidencias"
                     Description="Registro y seguimiento operativo con prioridad y estado."
                     Href="#"
                     Icon="🚨"
                     Variant="TileVariant.Muted" />
    </div>

    <MxCard Title="Estado del workspace" Variant="SurfaceVariant.Muted">
        <p class="ms-text-sm">Operaciones, branding y layout se personalizan en el host mientras Foundation y tokens permanecen compartidos en <strong>MachSoft.Template.Core</strong>.</p>
    </MxCard>
</MxPanel>
