@page "/settings"

<PageContainer Title="Configuración" Description="Configuraciones base del portal para equipos de operaciones.">
    <FormSection>
        <SectionTitle Title="Preferencias del workspace" Description="Formulario mínimo para validar primitives de formulario." />

        <FieldGroup Label="Zona horaria" Hint="Usado para reportes y agenda de turnos.">
            <select>
                <option>UTC-5 (Bogotá)</option>
                <option>UTC-3 (Buenos Aires)</option>
                <option>UTC+1 (Madrid)</option>
            </select>
        </FieldGroup>
    </FormSection>
</PageContainer>
