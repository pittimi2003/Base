@page "/demo"

<div class="ms-page-container">
    <MxPageHeader Title="Sample Demo" Description="Aplicación demostrativa para validar adopción real de Mx* en escenarios enterprise." />

    <div class="ms-grid ms-grid--2">
        <MxCard Title="KPIs" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <ul>
                    <li>Orders Today: 128</li>
                    <li>Utilization: 87%</li>
                    <li>Alerts: 3</li>
                </ul>
            </ChildContent>
        </MxCard>
        <MxCard Title="Quick Actions" Variant="SurfaceVariant.Muted">
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <AppMenuTile Title="New Order" Description="Crear orden" Icon="➕" />
                    <AppMenuTile Title="Assign Team" Description="Asignación rápida" Icon="👥" />
                </div>
            </ChildContent>
        </MxCard>
    </div>
</div>
