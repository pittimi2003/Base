<Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="_additionalAssemblies">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(MachSoft.Template.Core.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(MachSoft.Template.Core.Layout.MainLayout)">
            <div class="ms-page-container">
                <MxPageHeader Title="Not Found" Description="La ruta no existe en el starter WASM." />
                <MxCard Title="Navegación" Variant="SurfaceVariant.Outlined" IsCompact="true">
                    <ChildContent>
                        <p class="ms-text-sm">Vuelve al <a href="/">inicio</a>.</p>
                    </ChildContent>
                </MxCard>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private readonly IEnumerable<System.Reflection.Assembly> _additionalAssemblies = [typeof(MachSoft.Template.Core.Pages.Home).Assembly];
}
