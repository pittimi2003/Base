@page "/wasm-demo"

<div class="ms-page-container">
    <MxPageHeader Title="Starter WASM Demo"
                  Description="Escenario WebAssembly con composición real Mx* para operación enterprise y validación de adopción cross-host.">
        <Metadata>
            <MxBadge Variant="MxBadgeVariant.Brand" Text="WASM" />
            <MxBadge Variant="MxBadgeVariant.Neutral" Text="Core Shared" />
            <MxBadge Variant="MxBadgeVariant.Success" Text="Operational Demo" />
        </Metadata>
        <Actions>
            <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Sincronizar</MxButton>
            <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Ejecutar despacho</MxButton>
        </Actions>
    </MxPageHeader>

    <MxSearchPanel Title="Búsqueda rápida de lote" Variant="SurfaceVariant.Outlined">
        <Actions>
            <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Limpiar</MxButton>
            <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Aplicar</MxButton>
        </Actions>
        <ChildContent>
            <div class="ms-grid ms-grid--2">
                <MxTextField Label="Orden" Placeholder="SO-13051" Value="@OrderQuery" ValueChanged="@(v => OrderQuery = v)" />
                <MxSelect Label="Estado" Value="@SelectedStatus" ValueChanged="@(v => SelectedStatus = v)" Options="@StatusOptions" Placeholder="Selecciona estado" />
            </div>
        </ChildContent>
    </MxSearchPanel>

    <MxDashboardSection Title="KPIs runtime cliente" Description="Métricas operativas renderizadas en WebAssembly usando catálogo Mx* compartido.">
        <div class="ms-grid ms-grid--3">
            <MxStatCard Title="Órdenes activas" Value="142" SupportingText="Turno actual" TrendText="+9" TrendStatus="MxStatusVariant.Success" />
            <MxStatCard Title="Pendientes críticas" Value="11" SupportingText="Cierre en 45 min" TrendText="-1" TrendStatus="MxStatusVariant.Success" />
            <MxStatCard Title="SLA" Value="98.1%" SupportingText="Últimas 24h" TrendText="+0.3%" TrendStatus="MxStatusVariant.Success" />
        </div>
    </MxDashboardSection>

    <MxMasterDetail>
        <MasterContent>
            <MxDataGrid Items="@Orders" Columns="@OrderColumns" AriaLabel="Órdenes en host WASM" />
        </MasterContent>
        <DetailContent>
            <MxCard Title="Detalle de selección" Variant="SurfaceVariant.Muted" IsCompact="true">
                <ChildContent>
                    <p class="ms-text-sm">Orden: <strong>@SelectedOrderId</strong></p>
                    <p class="ms-text-sm">Nodo: East Terminal · Operación de alistamiento en curso.</p>
                    <MxProgress Value="72" Max="100" Variant="MxProgressVariant.Brand" ShowLabel="true" AriaLabel="Progreso de preparación" />
                </ChildContent>
            </MxCard>
        </DetailContent>
    </MxMasterDetail>
</div>

@code {
    private string? OrderQuery { get; set; }
    private string? SelectedStatus { get; set; }
    private string SelectedOrderId { get; set; } = "SO-13051";

    private IEnumerable<MxSelectOption> StatusOptions { get; } =
    [
        new("ready", "Ready"),
        new("picking", "Picking"),
        new("blocked", "Blocked")
    ];

    private sealed record WasmOrder(string OrderId, string Node, string Status, string Eta);

    private IReadOnlyList<WasmOrder> Orders { get; } =
    [
        new("SO-13051", "East Terminal", "Picking", "18 min"),
        new("SO-13054", "North Hub", "Ready", "12 min"),
        new("SO-13057", "LATAM Node", "Blocked", "41 min")
    ];

    private IReadOnlyList<MxDataGridColumn<WasmOrder>> OrderColumns { get; } =
    [
        new("Order", x => x.OrderId, "24%"),
        new("Node", x => x.Node, "32%"),
        new("Status", x => x.Status, "22%"),
        new("ETA", x => x.Eta, "22%")
    ];
}
