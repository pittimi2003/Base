{
  "$schema": "http://json.schemastore.org/template",
  "author": "MachSoft",
  "classifications": ["Web", "Blazor", "MachSoft", "Enterprise"],
  "identity": "MachSoft.Template.Official.Server",
  "name": "MachSoft Corporate Blazor Server App",
  "shortName": "machsoft-app",
  "description": "Plantilla corporativa oficial MachSoft para iniciar aplicaciones Blazor Server con shell, theming y wiring de MachSoft.Template.Core.",
  "sourceName": "MachSoft.Template.App",
  "preferNameDirectory": true,
  "symbols": {
    "CorePackageVersion": {
      "type": "parameter",
      "datatype": "text",
      "description": "Version de MachSoft.Template.Core consumida por la app generada.",
      "defaultValue": "1.0.0-internal",
      "replaces": "1.0.0-internal"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**",
            "**/*.user",
            "**/*.lock.json"
          ]
        }
      ]
    }
  ]
}
