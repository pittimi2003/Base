@using MachSoft.Template.Core.Models
@inject NavigationManager NavigationManager

@{
    var panels = BuildPanels();
}

<aside id="@NavigationId"
       class="ms-shell__nav @(IsOpen ? "is-open" : string.Empty)"
       style="@($"--ms-nav-open-panels:{panels.Count};")"
       role="navigation"
       aria-label="Main navigation"
       aria-hidden="@(IsOpen ? "false" : "true")"
       tabindex="-1"
       @ref="NavigationElementRef">
    <div class="ms-shell__nav-header">
        <div class="ms-brand">@BrandTitle</div>
        <button type="button"
                class="ms-shell__nav-close"
                @onclick="HandleCloseNavigation"
                aria-label="Cerrar navegación lateral">
            <span aria-hidden="true">✕</span>
        </button>
    </div>
    <div class="ms-shell__nav-divider"></div>

    <nav class="ms-nav ms-nav--panels" aria-label="Main navigation sections">
        <div class="ms-nav__panels">
            @foreach (var panel in panels)
            {
                @RenderNavigationPanel(panel)
            }
        </div>
    </nav>
</aside>

@code {
    private const string DefaultSectionTitle = "General";
    private ElementReference NavigationElementRef;
    private bool _wasOpen;
    private readonly List<NavItem> _openBranch = [];

    [Parameter] public string BrandTitle { get; set; } = "MachSoft Template";
    [Parameter] public string NavigationId { get; set; } = "ms-app-navigation";
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool FocusOnOpen { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<NavItem> NavigationItems { get; set; } = [];
    [Parameter] public EventCallback OnNavigationItemSelected { get; set; }

    protected override void OnParametersSet()
    {
        SyncOpenBranchWithCurrentRoute();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (FocusOnOpen && !_wasOpen)
        {
            await NavigationElementRef.FocusAsync();
        }

        _wasOpen = FocusOnOpen;
    }

    private IReadOnlyList<NavigationPanel> BuildPanels()
    {
        var panels = new List<NavigationPanel>
        {
            new(0, "Main", NavigationItems)
        };

        for (var depth = 0; depth < _openBranch.Count; depth++)
        {
            var node = _openBranch[depth];
            if (node.Children is { Count: > 0 })
            {
                panels.Add(new NavigationPanel(depth + 1, node.Text, node.Children));
            }
        }

        return panels;
    }

    private static IReadOnlyList<NavigationSection> BuildSections(IReadOnlyList<NavItem> items)
    {
        var orderedSections = new List<NavigationSection>();
        var sectionMap = new Dictionary<string, NavigationSection>(StringComparer.Ordinal);

        foreach (var item in items)
        {
            var sectionTitle = string.IsNullOrWhiteSpace(item.Section)
                ? DefaultSectionTitle
                : item.Section!;

            if (!sectionMap.TryGetValue(sectionTitle, out var section))
            {
                section = new NavigationSection(sectionTitle, []);
                sectionMap[sectionTitle] = section;
                orderedSections.Add(section);
            }

            section.Items.Add(item);
        }

        return orderedSections;
    }

    private static bool HasChildren(NavItem item) => item.Children is { Count: > 0 };

    private bool IsBranchSelected(int depth, NavItem item)
        => depth < _openBranch.Count && _openBranch[depth] == item;

    private void HandleBranchSelected(int depth, NavItem item)
    {
        TrimBranch(depth);
        _openBranch.Add(item);
    }

    private async Task HandleTerminalSelected(int depth)
    {
        TrimBranch(depth);
        await OnNavigationItemSelected.InvokeAsync();
    }

    private Task HandleCloseNavigation() => OnNavigationItemSelected.InvokeAsync();

    private void TrimBranch(int depth)
    {
        if (_openBranch.Count > depth)
        {
            _openBranch.RemoveRange(depth, _openBranch.Count - depth);
        }
    }

    private void SyncOpenBranchWithCurrentRoute()
    {
        _openBranch.Clear();
        var currentPath = ToRelativePath(NavigationManager.Uri);
        _ = TryFindBranch(NavigationItems, currentPath, _openBranch);
    }

    private static bool TryFindBranch(IReadOnlyList<NavItem> items, string currentPath, List<NavItem> branch)
    {
        foreach (var item in items)
        {
            if (HasChildren(item) && TryFindBranch(item.Children!, currentPath, branch))
            {
                branch.Insert(0, item);
                return true;
            }

            if (!HasChildren(item) && IsCurrentRoute(item.Href, currentPath))
            {
                return true;
            }
        }

        return false;
    }

    private static bool IsCurrentRoute(string href, string currentPath)
    {
        var normalizedHref = ToRelativePath(href);
        if (string.IsNullOrWhiteSpace(normalizedHref))
        {
            return string.IsNullOrWhiteSpace(currentPath);
        }

        return currentPath.Equals(normalizedHref, StringComparison.OrdinalIgnoreCase)
               || currentPath.StartsWith(normalizedHref + "/", StringComparison.OrdinalIgnoreCase);
    }

    private static string ToRelativePath(string uriOrPath)
    {
        if (string.IsNullOrWhiteSpace(uriOrPath))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(uriOrPath, UriKind.Absolute, out var absolute))
        {
            uriOrPath = absolute.PathAndQuery;
        }

        var path = uriOrPath;
        var queryIndex = path.IndexOf('?', StringComparison.Ordinal);
        if (queryIndex >= 0)
        {
            path = path[..queryIndex];
        }

        return path.Trim('/');
    }

    private sealed record NavigationPanel(int Depth, string Title, IReadOnlyList<NavItem> Items);

    private sealed record NavigationSection(string Title, List<NavItem> Items);

    private RenderFragment RenderNavigationPanel(NavigationPanel panel) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "ms-nav__panel-column");
        builder.AddAttribute(sequence++, "data-ms-nav-depth", panel.Depth);

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "ms-nav__panel");
        builder.AddAttribute(sequence++, "role", "group");
        builder.AddAttribute(sequence++, "aria-label", panel.Title);

        builder.OpenElement(sequence++, "p");
        builder.AddAttribute(sequence++, "class", "ms-nav__panel-title");
        builder.AddContent(sequence++, panel.Title);
        builder.CloseElement();

        foreach (var section in BuildSections(panel.Items))
        {
            builder.AddContent(sequence++, RenderNavigationSection(panel.Depth, section));
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RenderNavigationSection(int depth, NavigationSection section) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "ms-nav__section");

        if (!string.IsNullOrWhiteSpace(section.Title))
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "ms-nav__section-title");
            builder.AddContent(sequence++, section.Title);
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "ul");
        builder.AddAttribute(sequence++, "class", "ms-nav__list");

        foreach (var item in section.Items)
        {
            builder.OpenElement(sequence++, "li");
            builder.AddAttribute(sequence++, "class", "ms-nav__entry");
            builder.AddContent(sequence++, RenderNavigationItem(depth, item));
            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RenderNavigationItem(int depth, NavItem item) => builder =>
    {
        var sequence = 0;
        if (HasChildren(item))
        {
            var isBranchSelected = IsBranchSelected(depth, item);
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(
                sequence++,
                "class",
                $"ms-nav__item ms-nav__item--branch {(isBranchSelected ? "is-open" : string.Empty)}");
            builder.AddAttribute(sequence++, "aria-expanded", isBranchSelected);
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => HandleBranchSelected(depth, item)));
            builder.AddContent(sequence++, RenderNavigationItemLeadingIcon(depth, item));

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "ms-nav__text");
            builder.AddContent(sequence++, item.Text);
            builder.CloseElement();

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "ms-nav__child-indicator");
            builder.AddAttribute(sequence++, "aria-hidden", "true");
            builder.AddContent(sequence++, "›");
            builder.CloseElement();
            builder.CloseElement();
            return;
        }

        builder.OpenComponent<NavLink>(sequence++);
        builder.AddAttribute(sequence++, "href", item.Href);
        builder.AddAttribute(sequence++, "class", "ms-nav__item ms-nav__item--terminal");
        builder.AddAttribute(sequence++, "Match", NavLinkMatch.Prefix);
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => HandleTerminalSelected(depth)));
        builder.AddAttribute(
            sequence++,
            "ChildContent",
            (RenderFragment)(contentBuilder =>
            {
                var contentSequence = 0;
                contentBuilder.AddContent(contentSequence++, RenderNavigationItemLeadingIcon(depth, item));
                contentBuilder.OpenElement(contentSequence++, "span");
                contentBuilder.AddAttribute(contentSequence++, "class", "ms-nav__text");
                contentBuilder.AddContent(contentSequence++, item.Text);
                contentBuilder.CloseElement();
            }));
        builder.CloseComponent();
    };

    private RenderFragment RenderNavigationItemLeadingIcon(int depth, NavItem item) => builder =>
    {
        var resolvedIcon = ResolveItemIcon(depth, item);
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"ms-nav__icon {(string.IsNullOrWhiteSpace(item.Icon) ? "ms-nav__icon--fallback" : string.Empty)}");
        builder.AddAttribute(2, "aria-hidden", "true");
        builder.AddContent(3, resolvedIcon);
        builder.CloseElement();
    };

    private static string ResolveItemIcon(int depth, NavItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.Icon))
        {
            return item.Icon;
        }

        return depth >= 1 ? "↳" : "◈";
    }
}
