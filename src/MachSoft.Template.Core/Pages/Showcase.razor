@page "/showcase"

<div class="ms-page-container">
    <MxPageHeader Title="MachSoft Design System Showcase"
                  Description="Consolidación del lenguaje oficial Mx* con visual tuning de branding MachSoft en hosts Server y WebAssembly.">
        <Metadata>
            <MxBadge Variant="MxBadgeVariant.Brand" Text="v1.0.0-internal" />
            <MxBadge Variant="MxBadgeVariant.Neutral" Text="Adoption Ready" />
            <MxBadge Variant="MxBadgeVariant.Success" Text="Visual tuned" />
        </Metadata>
    </MxPageHeader>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">FOUNDATIONS</h2>

        <MxCard Title="Tokens, color, typography, spacing" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <p class="ms-text-sm"><strong>Tokens:</strong> variables <code>--mx-*</code> para color, densidad, radios y sombras.</p>
                    <p class="ms-text-sm"><strong>Color:</strong> paleta semántica en light/dark mode con contraste base enterprise.</p>
                    <p class="ms-text-sm"><strong>Typography:</strong> escalas desde <code>--ms-font-size-sm</code> hasta títulos de página.</p>
                    <p class="ms-text-sm"><strong>Spacing:</strong> grilla y stack a través de utilidades <code>ms-grid</code> y espacios tokenizados.</p>
                </div>
            </ChildContent>
        </MxCard>

        <h3 class="ms-showcase-group__title">Core components</h3>

        <MxPageHeader Title="MachSoft Component Catalog"
                      Description="Primer lote de componentes públicos Mx* con soporte de tema, accesibilidad y contratos estables.">
            <Metadata>
                <MxBadge Variant="MxBadgeVariant.Brand" Text="Group 1" />
                <MxBadge Variant="MxBadgeVariant.Neutral" Text="Light/Dark ready" />
            </Metadata>
            <Actions>
                <MxButton Variant="MxButtonVariant.Primary" LeadingIcon="➕">Nueva orden</MxButton>
                <MxButton Variant="MxButtonVariant.Secondary" TrailingIcon="↗">Exportar</MxButton>
                <MxIconButton Icon="⚙️" AriaLabel="Abrir configuración" Variant="MxButtonVariant.Tertiary" />
            </Actions>
        </MxPageHeader>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">COMPONENTS</h2>

        <h3 class="ms-showcase-group__title">Form components</h3>

        <MxFormSection Title="MxFormSection + MxFieldGroup"
                       Description="Base enterprise de formularios con contratos Mx*, estados y mensajes de ayuda/error.">
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Cancelar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Guardar</MxButton>
            </Actions>
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <MxTextField Label="Nombre del almacén" Placeholder="North Hub" Value="@WarehouseName" ValueChanged="@(v => WarehouseName = v)" HelperText="Usa un nombre corto y descriptivo." />
                    <MxSelect Label="Región" Value="@Region" ValueChanged="@(v => Region = v)" Options="@RegionOptions" Placeholder="Selecciona una región" Required="true" ErrorText="@(string.IsNullOrWhiteSpace(Region) ? "Campo obligatorio" : null)" />
                </div>
            </ChildContent>
        </MxFormSection>
    </section>

    <section class="ms-showcase-group">
        <h3 class="ms-showcase-group__title">Navigation & overlays</h3>
        <MxBreadcrumb Items="@BreadcrumbItems" />
        <MxCard Title="MxTabs + Content" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <MxTabs Items="@TabsItems" ActiveValue="@ActiveTab" ActiveValueChanged="OnTabChanged" Variant="MxTabsVariant.Underline" AriaLabel="Secciones operativas">
                    <ActiveContent>
                        <p class="ms-text-sm">@ActiveTabMessage</p>
                    </ActiveContent>
                </MxTabs>
            </ChildContent>
        </MxCard>

        <div class="ms-mx-page-header__actions">
            <MxButton Variant="MxButtonVariant.Secondary" OnClick="OpenDialog">Abrir dialog</MxButton>
            <MxButton Variant="MxButtonVariant.Tertiary" OnClick="OpenDrawer">Abrir drawer</MxButton>
            <MxButton Variant="MxButtonVariant.Primary" OnClick="ShowToast">Mostrar toast</MxButton>
        </div>

        <MxDialog Open="@IsDialogOpen" OpenChanged="OnDialogOpenChanged" Title="Confirmar actualización" Size="MxDialogSize.Medium">
            <ChildContent><p class="ms-text-sm">¿Deseas aplicar la nueva configuración de operación al turno actual?</p></ChildContent>
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small" OnClick="CloseDialog">Cancelar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small" OnClick="CloseDialog">Confirmar</MxButton>
            </Actions>
        </MxDialog>

        <MxDrawer Open="@IsDrawerOpen" OpenChanged="OnDrawerOpenChanged" Title="Filtros avanzados" Side="MxDrawerSide.End" Width="360px">
            <ChildContent>
                <MxFormSection IsCompact="true" Title="Scope">
                    <ChildContent>
                        <MxCheckbox Label="Solo pendientes" Checked="@OnlyPending" CheckedChanged="@(v => OnlyPending = v)" />
                        <MxSwitch Label="Modo detallado" Checked="@DetailedMode" CheckedChanged="@(v => DetailedMode = v)" />
                    </ChildContent>
                </MxFormSection>
            </ChildContent>
        </MxDrawer>

        <MxToast Visible="@IsToastVisible" VisibleChanged="OnToastVisibleChanged" Variant="MxToastVariant.Success" Title="Cambios guardados" Message="La configuración se aplicó correctamente." DurationMs="4500" Dismissible="true" />
    </section>

    <section class="ms-showcase-group">
        <h3 class="ms-showcase-group__title">Data display</h3>

        <MxCard Title="MxTag + MxStatusIndicator" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <div class="ms-mx-page-header__actions">
                    <MxTag Variant="MxTagVariant.Brand" Text="Lote A-102" />
                    <MxTag Variant="MxTagVariant.Warning" Text="Revisión" />
                    <MxTag Variant="MxTagVariant.Success" Text="Completado" />
                    <MxStatusIndicator Status="MxStatusVariant.Success" Label="Conectado" />
                    <MxStatusIndicator Status="MxStatusVariant.Warning" Label="Degradado" />
                    <MxStatusIndicator Status="MxStatusVariant.Offline" Label="Offline" />
                </div>
            </ChildContent>
        </MxCard>

        <div class="ms-grid ms-grid--3">
            <MxStatCard Title="Orders processed" Value="18,420" SupportingText="Últimas 24h" TrendText="+8.2%" TrendStatus="MxStatusVariant.Success">
                <Status>
                    <MxStatusIndicator Status="MxStatusVariant.Success" Label="Healthy" />
                </Status>
            </MxStatCard>
            <MxStatCard Title="Pending picks" Value="246" SupportingText="SLA 2h" TrendText="+14" TrendStatus="MxStatusVariant.Warning">
                <Status>
                    <MxTag Variant="MxTagVariant.Warning" Text="Atención" />
                </Status>
            </MxStatCard>
            <MxStatCard Title="Import failures" Value="7" SupportingText="Último ciclo" TrendText="-3" TrendStatus="MxStatusVariant.Success">
                <Status>
                    <MxStatusIndicator Status="MxStatusVariant.Danger" Label="Incidentes" />
                </Status>
            </MxStatCard>
        </div>

        <MxCard Title="MxProgress" Variant="SurfaceVariant.Outlined" IsCompact="true">
            <ChildContent>
                <div class="ms-stack-sm">
                    <MxProgress Value="67" Max="100" Variant="MxProgressVariant.Brand" ShowLabel="true" AriaLabel="Avance de importación de catálogo" />
                    <MxProgress Value="39" Max="100" Variant="MxProgressVariant.Warning" ShowLabel="true" AriaLabel="Avance de reconciliación de inventario" />
                    <MxProgress Value="92" Max="100" Variant="MxProgressVariant.Success" ShowLabel="true" AriaLabel="Avance de sincronización WMS" />
                </div>
            </ChildContent>
        </MxCard>

        <MxEmptyState Title="No hay datos para el turno seleccionado"
                      Description="Todavía no se registran movimientos en este rango de tiempo. Ajusta filtros o inicia una nueva importación."
                      Icon="📭">
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Cambiar filtros</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Iniciar carga</MxButton>
            </Actions>
        </MxEmptyState>
    </section>


    <section class="ms-showcase-group">
        <h3 class="ms-showcase-group__title">Enterprise inputs</h3>

        <MxFormSection Title="Filtros operativos avanzados"
                       Description="Selección de fechas, catálogos y carga de evidencia en un flujo enterprise.">
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <MxDatePicker Label="Fecha operativa"
                                  Value="@OperationDate"
                                  ValueChanged="@(v => OperationDate = v)"
                                  HelperText="Fecha principal para corte diario." />

                    <MxDateRangePicker Label="Rango de análisis"
                                       StartValue="@RangeStart"
                                       StartValueChanged="@(v => RangeStart = v)"
                                       EndValue="@RangeEnd"
                                       EndValueChanged="@(v => RangeEnd = v)"
                                       HelperText="Usado para consultas históricas de productividad." />
                </div>

                <div class="ms-grid ms-grid--2">
                    <MxAutocomplete Label="Almacén"
                                    SearchText="@WarehouseSearch"
                                    SearchTextChanged="@(v => WarehouseSearch = v)"
                                    Value="@WarehouseValue"
                                    ValueChanged="@(v => WarehouseValue = v)"
                                    Items="@WarehouseOptions"
                                    Placeholder="Buscar almacén por nombre" />

                    <MxMultiSelect Label="Estados incluidos"
                                   SelectedValues="@SelectedStatuses"
                                   SelectedValuesChanged="OnStatusesChanged"
                                   Options="@StatusOptions"
                                   Placeholder="Selecciona uno o más estados" />
                </div>

                <MxFileUpload Label="Evidencias del lote"
                              Accept=".pdf,.png,.jpg,.csv"
                              Multiple="true"
                              FilesChanged="OnFilesChanged"
                              HelperText="Adjunta evidencia documental del proceso (máx. validación del backend)." />
            </ChildContent>
        </MxFormSection>

        <MxCard Title="Resumen de selección" Variant="SurfaceVariant.Muted" IsCompact="true">
            <ChildContent>
                <p class="ms-text-sm">Fecha: @(OperationDate?.ToString("yyyy-MM-dd") ?? "-")</p>
                <p class="ms-text-sm">Rango: @(RangeStart?.ToString("yyyy-MM-dd") ?? "-") → @(RangeEnd?.ToString("yyyy-MM-dd") ?? "-")</p>
                <p class="ms-text-sm">Almacén: @WarehouseSearch (@WarehouseValue)</p>
                <p class="ms-text-sm">Estados: @(SelectedStatuses.Count == 0 ? "Sin selección" : string.Join(", ", SelectedStatuses))</p>
                <p class="ms-text-sm">Archivos: @(UploadedFileNames.Count == 0 ? "Sin adjuntos" : string.Join(", ", UploadedFileNames))</p>
            </ChildContent>
        </MxCard>
    </section>
    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">ENTERPRISE DATA</h2>

        <MxDataGrid TItem="OrderRow"
                    Items="@Orders"
                    Columns="@OrderColumns"
                    EmptyText="Sin órdenes para el criterio seleccionado."
                    AriaLabel="Órdenes operativas" />

        <MxTreeGrid Items="@ProcessTree"
                    EmptyText="Sin jerarquía de procesos"
                    AriaLabel="Jerarquía de almacenes y procesos" />

        <div class="ms-grid ms-grid--2">
            <MxChart Title="Throughput por turno"
                     Type="MxChartType.Bar"
                     Categories="@ChartCategories"
                     Series="@ChartSeries"
                     AriaLabel="Chart de throughput" />

            <MxChart Title="Errores por día"
                     Type="MxChartType.Line"
                     Categories="@ChartCategories"
                     Series="@ErrorSeries"
                     AriaLabel="Chart de errores" />
        </div>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">PATTERNS</h2>

        <MxSearchPanel Title="Buscar orden" Variant="SurfaceVariant.Outlined">
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Limpiar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Buscar</MxButton>
            </Actions>
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <MxTextField Label="ID de orden" Placeholder="SO-13002" Value="@PatternOrderId" ValueChanged="@(v => PatternOrderId = v)" />
                    <MxSelect Label="Prioridad" Value="@PatternPriority" ValueChanged="@(v => PatternPriority = v)" Options="@PatternPriorityOptions" Placeholder="Selecciona prioridad" />
                </div>
            </ChildContent>
        </MxSearchPanel>

        <MxFilterBar IsCompact="true">
            <Filters>
                <MxSwitch Label="Solo críticas" Checked="@PatternOnlyCritical" CheckedChanged="@(v => PatternOnlyCritical = v)" />
                <MxCheckbox Label="Con incidencia" Checked="@PatternWithIncident" CheckedChanged="@(v => PatternWithIncident = v)" />
            </Filters>
            <Summary>
                <p class="ms-text-sm">@(PatternOnlyCritical ? "Mostrando solo órdenes críticas" : "Mostrando todas las prioridades")</p>
            </Summary>
            <Actions>
                <MxButton Variant="MxButtonVariant.Tertiary" Size="MxButtonSize.Small">Aplicar</MxButton>
            </Actions>
        </MxFilterBar>

        <MxDashboardSection Title="Resumen operativo" Description="Composición de KPIs y alertas con patrón reusable.">
            <div class="ms-grid ms-grid--3">
                <MxStatCard Title="Pedidos activos" Value="264" SupportingText="Turno actual" TrendText="+12" TrendStatus="MxStatusVariant.Success" />
                <MxStatCard Title="Órdenes bloqueadas" Value="18" SupportingText="Última hora" TrendText="+3" TrendStatus="MxStatusVariant.Warning" />
                <MxStatCard Title="SLA cumplido" Value="98.4%" SupportingText="Últimas 24h" TrendText="+0.6%" TrendStatus="MxStatusVariant.Success" />
            </div>
        </MxDashboardSection>

        <MxMasterDetail>
            <MasterContent>
                <MxDataGrid Items="@PatternOrders" Columns="@PatternOrderColumns" AriaLabel="Listado master de órdenes" />
            </MasterContent>
            <DetailContent>
                <MxCard Title="Detalle de orden" Variant="SurfaceVariant.Muted" IsCompact="true">
                    <ChildContent>
                        <p class="ms-text-sm">Orden seleccionada: <strong>@PatternSelectedOrderId</strong></p>
                        <p class="ms-text-sm">Estado: Bloqueada por validación de inventario.</p>
                    </ChildContent>
                </MxCard>
            </DetailContent>
        </MxMasterDetail>

        <MxSettingsPage Title="Configuración de operación" Description="Patrón para vistas de configuración enterprise.">
            <Categories>
                <MxTabs Items="@PatternSettingsTabs" ActiveValue="@PatternSettingsTab" ActiveValueChanged="OnPatternSettingsTabChanged" AriaLabel="Categorías de ajustes" />
            </Categories>
            <Sections>
                <MxFormSection IsCompact="true" Title="Ajustes de notificación">
                    <ChildContent>
                        <MxSwitch Label="Alertas por correo" Checked="@PatternEmailAlerts" CheckedChanged="@(v => PatternEmailAlerts = v)" />
                        <MxSwitch Label="Alertas por SMS" Checked="@PatternSmsAlerts" CheckedChanged="@(v => PatternSmsAlerts = v)" />
                    </ChildContent>
                </MxFormSection>
            </Sections>
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary">Cancelar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary">Guardar configuración</MxButton>
            </Actions>
        </MxSettingsPage>
    </section>

</div>

@code {
    private string? WarehouseName { get; set; }
    private string? Region { get; set; }
    private bool IsDialogOpen { get; set; }
    private bool IsDrawerOpen { get; set; }
    private bool IsToastVisible { get; set; }
    private bool OnlyPending { get; set; }
    private bool DetailedMode { get; set; }
    private string ActiveTab { get; set; } = "overview";

    private string ActiveTabMessage => ActiveTab switch
    {
        "activity" => "Actividad reciente con eventos de recepciones y despacho.",
        "alerts" => "Panel de alertas y excepciones activas.",
        _ => "Vista general de operación logística y KPIs del turno."
    };

    private IEnumerable<MxSelectOption> RegionOptions { get; } =
    [
        new("emea", "EMEA"),
        new("latam", "LATAM"),
        new("na", "North America")
    ];

    private IEnumerable<MxTabItem> TabsItems { get; } =
    [
        new("overview", "Overview"),
        new("activity", "Activity"),
        new("alerts", "Alerts")
    ];

    private IEnumerable<MxBreadcrumbItem> BreadcrumbItems { get; } =
    [
        new("Home", "/"),
        new("Showcase", "/showcase"),
        new("Group 3", IsCurrent: true)
    ];

    private Task OnTabChanged(string value) { ActiveTab = value; return Task.CompletedTask; }
    private Task OnDialogOpenChanged(bool open) { IsDialogOpen = open; return Task.CompletedTask; }
    private Task OnDrawerOpenChanged(bool open) { IsDrawerOpen = open; return Task.CompletedTask; }
    private Task OnToastVisibleChanged(bool visible) { IsToastVisible = visible; return Task.CompletedTask; }
    private Task OpenDialog() { IsDialogOpen = true; return Task.CompletedTask; }
    private Task CloseDialog() { IsDialogOpen = false; return Task.CompletedTask; }
    private Task OpenDrawer() { IsDrawerOpen = true; return Task.CompletedTask; }
    private Task ShowToast() { IsToastVisible = true; return Task.CompletedTask; }

    private DateOnly? OperationDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? RangeStart { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly? RangeEnd { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private string? WarehouseSearch { get; set; } = "North Hub";
    private string? WarehouseValue { get; set; } = "north-hub";
    private IReadOnlyList<string> SelectedStatuses { get; set; } = ["active", "blocked"];
    private IReadOnlyList<string> UploadedFileNames { get; set; } = Array.Empty<string>();

    private IEnumerable<MxInputOption> WarehouseOptions { get; } =
    [
        new("north-hub", "North Hub"),
        new("east-terminal", "East Terminal"),
        new("latam-node", "LATAM Node")
    ];

    private IEnumerable<MxInputOption> StatusOptions { get; } =
    [
        new("active", "Active"),
        new("blocked", "Blocked"),
        new("review", "Review"),
        new("closed", "Closed")
    ];

    private Task OnStatusesChanged(IReadOnlyList<string> values)
    {
        SelectedStatuses = values;
        return Task.CompletedTask;
    }

    private Task OnFilesChanged(IReadOnlyList<Microsoft.AspNetCore.Components.Forms.IBrowserFile> files)
    {
        UploadedFileNames = files.Select(f => f.Name).ToArray();
        return Task.CompletedTask;
    }


    private sealed record OrderRow(string OrderId, string Warehouse, string Status, string Priority);

    private IReadOnlyList<OrderRow> Orders { get; } =
    [
        new("SO-12991", "North Hub", "Picking", "High"),
        new("SO-13002", "East Terminal", "Blocked", "Critical"),
        new("SO-13008", "LATAM Node", "Ready", "Normal")
    ];

    private IReadOnlyList<MxDataGridColumn<OrderRow>> OrderColumns { get; } =
    [
        new("Order", x => x.OrderId, "18%"),
        new("Warehouse", x => x.Warehouse, "30%"),
        new("Status", x => x.Status, "26%"),
        new("Priority", x => x.Priority, "26%")
    ];

    private IReadOnlyList<MxTreeGridItem> ProcessTree { get; } =
    [
        new MxTreeGridItem
        {
            Id = "north",
            Label = "North Hub",
            Meta = "3 procesos",
            Children =
            [
                new MxTreeGridItem { Id = "north-in", Label = "Inbound", Meta = "12 tareas" },
                new MxTreeGridItem { Id = "north-pick", Label = "Picking", Meta = "35 tareas" },
                new MxTreeGridItem { Id = "north-out", Label = "Outbound", Meta = "7 tareas" }
            ]
        },
        new MxTreeGridItem
        {
            Id = "east",
            Label = "East Terminal",
            Meta = "2 procesos",
            Children =
            [
                new MxTreeGridItem { Id = "east-in", Label = "Inbound", Meta = "8 tareas" },
                new MxTreeGridItem { Id = "east-out", Label = "Outbound", Meta = "11 tareas" }
            ]
        }
    ];

    private IReadOnlyList<string> ChartCategories { get; } = ["Mon", "Tue", "Wed", "Thu", "Fri"];
    private IReadOnlyList<MxChartSeries> ChartSeries { get; } = [new("Orders/hour", [85, 92, 88, 97, 104])];
    private IReadOnlyList<MxChartSeries> ErrorSeries { get; } = [new("Errors", [7, 5, 6, 4, 3])];

    private string? PatternOrderId { get; set; }
    private string? PatternPriority { get; set; }
    private bool PatternOnlyCritical { get; set; }
    private bool PatternWithIncident { get; set; }
    private string PatternSelectedOrderId { get; set; } = "SO-13002";
    private bool PatternEmailAlerts { get; set; } = true;
    private bool PatternSmsAlerts { get; set; }
    private string PatternSettingsTab { get; set; } = "notifications";

    private IEnumerable<MxSelectOption> PatternPriorityOptions { get; } =
    [
        new("critical", "Crítica"),
        new("high", "Alta"),
        new("normal", "Normal")
    ];

    private IEnumerable<MxTabItem> PatternSettingsTabs { get; } =
    [
        new("notifications", "Notificaciones"),
        new("security", "Seguridad"),
        new("integrations", "Integraciones")
    ];

    private IReadOnlyList<OrderRow> PatternOrders { get; } =
    [
        new("SO-13002", "East Terminal", "Blocked", "Critical"),
        new("SO-13008", "LATAM Node", "Ready", "High"),
        new("SO-13021", "North Hub", "Picking", "Normal")
    ];

    private IReadOnlyList<MxDataGridColumn<OrderRow>> PatternOrderColumns { get; } =
    [
        new("Order", x => x.OrderId, "30%"),
        new("Warehouse", x => x.Warehouse, "40%"),
        new("Priority", x => x.Priority, "30%")
    ];

    private Task OnPatternSettingsTabChanged(string value)
    {
        PatternSettingsTab = value;
        return Task.CompletedTask;
    }
}
