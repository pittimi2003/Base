@page "/showcase"

<PageContainer Title="Core Technical Showcase" Description="Esta vista valida la base técnica de Core: layout, theming, utilidades y componentes legacy no-Mx.">
    <div class="ms-grid ms-grid--2">
        <BaseCard Title="Alcance de Core" Variant="SurfaceVariant.Outlined">
            <p class="ms-text-sm">MachSoft.Template.Core mantiene únicamente infraestructura base, tokens y layout compartido.</p>
            <p class="ms-text-sm">El catálogo oficial Mx* está en MachSoft.Template.Core.Control.</p>
        </BaseCard>

        <BaseCard Title="Consumo correcto" Variant="SurfaceVariant.Elevated">
            <ul class="ms-text-sm">
                <li>Core = shell, theming, assets y utilidades.</li>
                <li>Core.Control = controles UI públicos Mx*.</li>
                <li>Core.Control.Showcase = validación visual/funcional del catálogo.</li>
            </ul>
        </BaseCard>
    </div>
</PageContainer>
