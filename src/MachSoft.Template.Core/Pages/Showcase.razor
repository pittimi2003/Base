@page "/showcase"

<PageContainer Title="Foundation Showcase" Description="Vitrina visual del Design System base para hosts Server y WebAssembly.">
    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Grupo 1 · Componentes MachSoft</h2>

        <MxPageHeader Title="MachSoft Component Catalog"
                      Description="Primer lote de componentes públicos Mx* con soporte de tema, accesibilidad y contratos estables.">
            <Metadata>
                <MxBadge Variant="MxBadgeVariant.Brand" Text="Group 1" />
                <MxBadge Variant="MxBadgeVariant.Neutral" Text="Light/Dark ready" />
            </Metadata>
            <Actions>
                <MxButton Variant="MxButtonVariant.Primary" LeadingIcon="➕">Nueva orden</MxButton>
                <MxButton Variant="MxButtonVariant.Secondary" TrailingIcon="↗">Exportar</MxButton>
                <MxIconButton Icon="⚙️" AriaLabel="Abrir configuración" Variant="MxButtonVariant.Tertiary" />
            </Actions>
        </MxPageHeader>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Grupo 2 · Formularios MachSoft</h2>

        <MxFormSection Title="MxFormSection + MxFieldGroup"
                       Description="Base enterprise de formularios con contratos Mx*, estados y mensajes de ayuda/error.">
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Cancelar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Guardar</MxButton>
            </Actions>
            <ChildContent>
                <div class="ms-grid ms-grid--2">
                    <MxTextField Label="Nombre del almacén" Placeholder="North Hub" Value="@WarehouseName" ValueChanged="@(v => WarehouseName = v)" HelperText="Usa un nombre corto y descriptivo." />
                    <MxSelect Label="Región" Value="@Region" ValueChanged="@(v => Region = v)" Options="@RegionOptions" Placeholder="Selecciona una región" Required="true" ErrorText="@(string.IsNullOrWhiteSpace(Region) ? "Campo obligatorio" : null)" />
                </div>
            </ChildContent>
        </MxFormSection>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Grupo 3 · Navegación y Overlays</h2>
        <MxBreadcrumb Items="@BreadcrumbItems" />
        <MxCard Title="MxTabs + Content" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <MxTabs Items="@TabsItems" ActiveValue="@ActiveTab" ActiveValueChanged="OnTabChanged" Variant="MxTabsVariant.Underline" AriaLabel="Secciones operativas">
                    <ActiveContent>
                        <p class="ms-text-sm">@ActiveTabMessage</p>
                    </ActiveContent>
                </MxTabs>
            </ChildContent>
        </MxCard>

        <div class="ms-mx-page-header__actions">
            <MxButton Variant="MxButtonVariant.Secondary" OnClick="OpenDialog">Abrir dialog</MxButton>
            <MxButton Variant="MxButtonVariant.Tertiary" OnClick="OpenDrawer">Abrir drawer</MxButton>
            <MxButton Variant="MxButtonVariant.Primary" OnClick="ShowToast">Mostrar toast</MxButton>
        </div>

        <MxDialog Open="@IsDialogOpen" OpenChanged="OnDialogOpenChanged" Title="Confirmar actualización" Size="MxDialogSize.Medium">
            <ChildContent><p class="ms-text-sm">¿Deseas aplicar la nueva configuración de operación al turno actual?</p></ChildContent>
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small" OnClick="CloseDialog">Cancelar</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small" OnClick="CloseDialog">Confirmar</MxButton>
            </Actions>
        </MxDialog>

        <MxDrawer Open="@IsDrawerOpen" OpenChanged="OnDrawerOpenChanged" Title="Filtros avanzados" Side="MxDrawerSide.End" Width="360px">
            <ChildContent>
                <MxFormSection IsCompact="true" Title="Scope">
                    <ChildContent>
                        <MxCheckbox Label="Solo pendientes" Checked="@OnlyPending" CheckedChanged="@(v => OnlyPending = v)" />
                        <MxSwitch Label="Modo detallado" Checked="@DetailedMode" CheckedChanged="@(v => DetailedMode = v)" />
                    </ChildContent>
                </MxFormSection>
            </ChildContent>
        </MxDrawer>

        <MxToast Visible="@IsToastVisible" VisibleChanged="OnToastVisibleChanged" Variant="MxToastVariant.Success" Title="Cambios guardados" Message="La configuración se aplicó correctamente." DurationMs="4500" Dismissible="true" />
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Grupo 4 · Data Display & Feedback</h2>

        <MxCard Title="MxTag + MxStatusIndicator" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <div class="ms-mx-page-header__actions">
                    <MxTag Variant="MxTagVariant.Brand" Text="Lote A-102" />
                    <MxTag Variant="MxTagVariant.Warning" Text="Revisión" />
                    <MxTag Variant="MxTagVariant.Success" Text="Completado" />
                    <MxStatusIndicator Status="MxStatusVariant.Success" Label="Conectado" />
                    <MxStatusIndicator Status="MxStatusVariant.Warning" Label="Degradado" />
                    <MxStatusIndicator Status="MxStatusVariant.Offline" Label="Offline" />
                </div>
            </ChildContent>
        </MxCard>

        <div class="ms-grid ms-grid--3">
            <MxStatCard Title="Orders processed" Value="18,420" SupportingText="Últimas 24h" TrendText="+8.2%" TrendStatus="MxStatusVariant.Success">
                <Status>
                    <MxStatusIndicator Status="MxStatusVariant.Success" Label="Healthy" />
                </Status>
            </MxStatCard>
            <MxStatCard Title="Pending picks" Value="246" SupportingText="SLA 2h" TrendText="+14" TrendStatus="MxStatusVariant.Warning">
                <Status>
                    <MxTag Variant="MxTagVariant.Warning" Text="Atención" />
                </Status>
            </MxStatCard>
            <MxStatCard Title="Import failures" Value="7" SupportingText="Último ciclo" TrendText="-3" TrendStatus="MxStatusVariant.Success">
                <Status>
                    <MxStatusIndicator Status="MxStatusVariant.Danger" Label="Incidentes" />
                </Status>
            </MxStatCard>
        </div>

        <MxCard Title="MxProgress" Variant="SurfaceVariant.Outlined" IsCompact="true">
            <ChildContent>
                <div class="ms-stack-sm">
                    <MxProgress Value="67" Max="100" Variant="MxProgressVariant.Brand" ShowLabel="true" AriaLabel="Avance de importación de catálogo" />
                    <MxProgress Value="39" Max="100" Variant="MxProgressVariant.Warning" ShowLabel="true" AriaLabel="Avance de reconciliación de inventario" />
                    <MxProgress Value="92" Max="100" Variant="MxProgressVariant.Success" ShowLabel="true" AriaLabel="Avance de sincronización WMS" />
                </div>
            </ChildContent>
        </MxCard>

        <MxEmptyState Title="No hay datos para el turno seleccionado"
                      Description="Todavía no se registran movimientos en este rango de tiempo. Ajusta filtros o inicia una nueva importación."
                      Icon="📭">
            <Actions>
                <MxButton Variant="MxButtonVariant.Secondary" Size="MxButtonSize.Small">Cambiar filtros</MxButton>
                <MxButton Variant="MxButtonVariant.Primary" Size="MxButtonSize.Small">Iniciar carga</MxButton>
            </Actions>
        </MxEmptyState>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Foundation Components previos</h2>
        <div class="ms-grid ms-grid--2">
            <BaseCard Title="Card Variants" BadgeText="BaseCard" Variant="SurfaceVariant.Elevated">
                <div class="ms-grid ms-grid--2">
                    <BaseCard Title="Default" IsCompact="true"><p class="ms-text-sm">Superficie base de contenido.</p></BaseCard>
                    <BaseCard Title="Elevated" Variant="SurfaceVariant.Elevated" IsCompact="true"><p class="ms-text-sm">Mayor prioridad visual.</p></BaseCard>
                    <BaseCard Title="Outlined" Variant="SurfaceVariant.Outlined" IsCompact="true"><p class="ms-text-sm">Contenedor estructural neutro.</p></BaseCard>
                    <BaseCard Title="Muted" Variant="SurfaceVariant.Muted" IsCompact="true"><p class="ms-text-sm">Contexto secundario.</p></BaseCard>
                </div>
            </BaseCard>

            <BaseCard Title="Navigation Tiles" BadgeText="AppMenuTile" Variant="SurfaceVariant.Muted">
                <div class="ms-grid ms-grid--2">
                    <AppMenuTile Title="Starter" Description="Host Server" Href="/demo" Icon="🚀" Variant="TileVariant.Default" />
                    <AppMenuTile Title="WASM" Description="Host WebAssembly" Href="/wasm-demo" Icon="🌐" Variant="TileVariant.Elevated" />
                    <AppMenuTile Title="Showcase" Description="Catálogo visual" Href="/showcase" Icon="🧩" Variant="TileVariant.Muted" />
                </div>
            </BaseCard>
        </div>
    </section>
</PageContainer>

@code {
    private string? WarehouseName { get; set; }
    private string? Region { get; set; }
    private bool IsDialogOpen { get; set; }
    private bool IsDrawerOpen { get; set; }
    private bool IsToastVisible { get; set; }
    private bool OnlyPending { get; set; }
    private bool DetailedMode { get; set; }
    private string ActiveTab { get; set; } = "overview";

    private string ActiveTabMessage => ActiveTab switch
    {
        "activity" => "Actividad reciente con eventos de recepciones y despacho.",
        "alerts" => "Panel de alertas y excepciones activas.",
        _ => "Vista general de operación logística y KPIs del turno."
    };

    private IEnumerable<MxSelectOption> RegionOptions { get; } =
    [
        new("emea", "EMEA"),
        new("latam", "LATAM"),
        new("na", "North America")
    ];

    private IEnumerable<MxTabItem> TabsItems { get; } =
    [
        new("overview", "Overview"),
        new("activity", "Activity"),
        new("alerts", "Alerts")
    ];

    private IEnumerable<MxBreadcrumbItem> BreadcrumbItems { get; } =
    [
        new("Home", "/"),
        new("Showcase", "/showcase"),
        new("Group 3", IsCurrent: true)
    ];

    private Task OnTabChanged(string value) { ActiveTab = value; return Task.CompletedTask; }
    private Task OnDialogOpenChanged(bool open) { IsDialogOpen = open; return Task.CompletedTask; }
    private Task OnDrawerOpenChanged(bool open) { IsDrawerOpen = open; return Task.CompletedTask; }
    private Task OnToastVisibleChanged(bool visible) { IsToastVisible = visible; return Task.CompletedTask; }
    private Task OpenDialog() { IsDialogOpen = true; return Task.CompletedTask; }
    private Task CloseDialog() { IsDialogOpen = false; return Task.CompletedTask; }
    private Task OpenDrawer() { IsDrawerOpen = true; return Task.CompletedTask; }
    private Task ShowToast() { IsToastVisible = true; return Task.CompletedTask; }
}
