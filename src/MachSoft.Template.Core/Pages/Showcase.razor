@page "/showcase"

<PageContainer Title="Foundation Showcase" Description="Vitrina visual del Design System base para hosts Server y WebAssembly.">
    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Core Visual System</h2>
        <div class="ms-grid ms-grid--3 ms-showcase-grid-tight">
            <BaseCard Title="Tipografía" BadgeText="typography.css" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-stack-sm">
                    <p class="ms-title">Título principal</p>
                    <p class="ms-text-lg">Subtítulo jerárquico</p>
                    <p>Texto base reusable para contenido estándar.</p>
                    <p class="ms-text-sm">Texto auxiliar / metadata</p>
                    <p class="ms-token-inline">display/h1/h2/body/caption/mono tokenizados</p>
                </div>
            </BaseCard>

            <BaseCard Title="Spacing Scale" BadgeText="primitives + semantic" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-stack-sm">
                    <div class="ms-surface">xs: var(--mx-space-semantic-xs)</div>
                    <div class="ms-surface">sm: var(--mx-space-semantic-sm)</div>
                    <div class="ms-surface">md/lg/xl: layout spacing</div>
                </div>
            </BaseCard>

            <BaseCard Title="Paleta MachSoft" BadgeText="brand + accent + semantic" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-color-row">
                    <span class="ms-color-swatch ms-color-swatch--brand" title="Brand"></span>
                    <span class="ms-color-swatch ms-color-swatch--accent" title="Accent"></span>
                    <span class="ms-color-swatch ms-color-swatch--success" title="Success"></span>
                    <span class="ms-color-swatch ms-color-swatch--warning" title="Warning"></span>
                    <span class="ms-color-swatch ms-color-swatch--danger" title="Danger"></span>
                    <span class="ms-color-swatch ms-color-swatch--surface" title="Surface"></span>
                    <span class="ms-color-swatch ms-color-swatch--text" title="Text"></span>
                </div>
                <div class="ms-divider"></div>
                <p class="ms-text-sm">Paleta enterprise sobria para dashboards y aplicaciones operativas.</p>
            </BaseCard>

            <BaseCard Title="Elevation + Border" BadgeText="shadow + stroke tokens" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-stack-sm">
                    <BaseCard Title="shadow-1" IsCompact="true"><p class="ms-text-sm">Superficie base</p></BaseCard>
                    <BaseCard Title="shadow-2" Variant="SurfaceVariant.Elevated" IsCompact="true"><p class="ms-text-sm">Bloque prioritario</p></BaseCard>
                </div>
            </BaseCard>

            <BaseCard Title="Arquitectura de tokens" BadgeText="design-system/*" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-stack-sm">
                    <p class="ms-text-sm"><strong>primitives</strong>: escalas base de color, spacing, radius, border, elevation.</p>
                    <p class="ms-text-sm"><strong>semantic</strong>: intención UI (surface, text, border, brand, states, z-index).</p>
                    <p class="ms-text-sm"><strong>themes</strong>: light/dark con overrides semánticos.</p>
                </div>
            </BaseCard>

            <BaseCard Title="Theme / Color Mode" BadgeText="light + dark activo" Variant="SurfaceVariant.Outlined" IsCompact="true">
                <div class="ms-stack-sm">
                    <p class="ms-text-sm">Usa el botón 🌙/☀️ del header para alternar tema.</p>
                    <p class="ms-text-sm">Persistencia por <span class="ms-token-inline">localStorage(mx-theme)</span>.</p>
                    <p class="ms-text-sm">Se aplica al root vía <span class="ms-token-inline">data-mx-theme</span>.</p>
                </div>
            </BaseCard>
        </div>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Foundation Components</h2>
        <div class="ms-grid ms-grid--2">
            <BaseCard Title="Card Variants" BadgeText="BaseCard" Variant="SurfaceVariant.Elevated">
                <div class="ms-grid ms-grid--2">
                    <BaseCard Title="Default" IsCompact="true"><p class="ms-text-sm">Superficie base de contenido.</p></BaseCard>
                    <BaseCard Title="Elevated" Variant="SurfaceVariant.Elevated" IsCompact="true"><p class="ms-text-sm">Mayor prioridad visual.</p></BaseCard>
                    <BaseCard Title="Outlined" Variant="SurfaceVariant.Outlined" IsCompact="true"><p class="ms-text-sm">Contenedor estructural neutro.</p></BaseCard>
                    <BaseCard Title="Muted" Variant="SurfaceVariant.Muted" IsCompact="true"><p class="ms-text-sm">Contexto secundario.</p></BaseCard>
                </div>
            </BaseCard>

            <BaseCard Title="Navigation Tiles" BadgeText="AppMenuTile" Variant="SurfaceVariant.Muted">
                <div class="ms-grid ms-grid--2">
                    <AppMenuTile Title="Starter" Description="Host Server" Href="/demo" Icon="🚀" Variant="TileVariant.Default" />
                    <AppMenuTile Title="WASM" Description="Host WebAssembly" Href="/wasm-demo" Icon="🌐" Variant="TileVariant.Elevated" />
                    <AppMenuTile Title="Showcase" Description="Catálogo visual" Href="/showcase" Icon="🧩" Variant="TileVariant.Muted" />
                </div>
            </BaseCard>
        </div>
    </section>

    <section class="ms-showcase-group">
        <h2 class="ms-showcase-group__title">Composición y Formularios</h2>
        <div class="ms-grid ms-grid--2">
            <BaseCard Title="Form Foundation" BadgeText="FormSection + FieldGroup" Variant="SurfaceVariant.Outlined">
                <FormSection Title="Create Warehouse" Description="Patrón mínimo para formularios corporativos.">
                    <FieldGroup Label="Warehouse name" FieldId="warehouse-name" Hint="Usar nombre corto y descriptivo.">
                        <input id="warehouse-name" type="text" placeholder="North Hub" />
                    </FieldGroup>

                    <FieldGroup Label="Region" FieldId="warehouse-region">
                        <select id="warehouse-region">
                            <option>EMEA</option>
                            <option>LATAM</option>
                            <option>NA</option>
                        </select>
                    </FieldGroup>
                </FormSection>
            </BaseCard>

            <BaseCard Title="Composición recomendada" BadgeText="PageContainer + BaseCard + FormSection" Variant="SurfaceVariant.Outlined">
                <PageContainer IsCompact="true" Title="Subsección" Description="Combinación equilibrada para contenido + formulario.">
                    <div class="ms-grid ms-grid--2">
                        <BaseCard IsCompact="true" Title="Resumen" Variant="SurfaceVariant.Muted">
                            <p class="ms-text-sm">Bloque informativo en modo compacto.</p>
                        </BaseCard>

                        <FormSection Title="Quick update" Description="Edición rápida sin romper jerarquía visual.">
                            <FieldGroup Label="Status" FieldId="status-field">
                                <input id="status-field" type="text" value="Active" />
                            </FieldGroup>
                        </FormSection>
                    </div>
                </PageContainer>
            </BaseCard>
        </div>
    </section>
</PageContainer>
