@page "/showcase"

<div class="ms-page-container">
    <MxPageHeader Title="MachSoft.Template.Core Showcase"
                  Description="Esta vista muestra la base de theming, layout y foundation shared del paquete Core.">
        <Metadata>
            <MxBadge Variant="MxBadgeVariant.Brand" Text="Core base" />
            <MxBadge Variant="MxBadgeVariant.Neutral" Text="Shared tokens" />
        </Metadata>
    </MxPageHeader>

    <section class="ms-showcase-group">
        <MxCard Title="Boundary architecture" Variant="SurfaceVariant.Outlined">
            <ChildContent>
                <p class="ms-text-sm"><strong>MachSoft.Template.Core</strong> se mantiene como capa base reusable (tokens, theming, layout y primitivas).</p>
                <p class="ms-text-sm"><strong>MachSoft.Template.Core.Control</strong> contiene el catálogo público de controles Mx*.</p>
                <p class="ms-text-sm"><strong>MachSoft.Template.Core.Control.Showcase</strong> es el host de validación visual/funcional de controles.</p>
            </ChildContent>
        </MxCard>
    </section>
</div>
