<section class="ms-brand-hero">
    @if (!string.IsNullOrWhiteSpace(Eyebrow))
    {
        <p class="ms-brand-hero__eyebrow">@Eyebrow</p>
    }

    <div class="ms-brand-hero__content">
        <div>
            <h1 class="ms-brand-hero__title">@Heading</h1>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="ms-brand-hero__description">@Description</p>
            }
        </div>

        @if (Actions is not null)
        {
            <div class="ms-brand-hero__actions">
                @Actions
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string? Eyebrow { get; set; }

    [Parameter, EditorRequired] public string Heading { get; set; } = string.Empty;

    [Parameter] public string? Description { get; set; }

    [Parameter] public RenderFragment? Actions { get; set; }
}
