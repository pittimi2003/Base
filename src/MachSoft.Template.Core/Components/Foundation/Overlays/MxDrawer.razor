@namespace MachSoft.Template.Core.Components.Foundation

@if (Open)
{
    <div class="ms-mx-overlay" @onclick="CloseFromOverlay">
        <aside class="@DrawerClass"
               style="@DrawerStyle"
               role="dialog"
               aria-modal="true"
               aria-labelledby="@TitleId"
               tabindex="0"
               @onkeydown="OnDrawerKeyDown"
               @onclick:stopPropagation="true">
            @if (!string.IsNullOrWhiteSpace(Title) || ShowCloseButton)
            {
                <header class="ms-mx-drawer__header">
                    @if (!string.IsNullOrWhiteSpace(Title))
                    {
                        <h3 id="@TitleId">@Title</h3>
                    }
                    @if (ShowCloseButton)
                    {
                        <MxIconButton Icon="✕" AriaLabel="Cerrar panel lateral" Variant="MxButtonVariant.Tertiary" Size="MxButtonSize.Small" OnClick="CloseAsync" />
                    }
                </header>
            }

            <div class="ms-mx-drawer__body">
                @ChildContent
            </div>
        </aside>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public MxDrawerSide Side { get; set; } = MxDrawerSide.End;
    [Parameter] public string Width { get; set; } = "340px";
    [Parameter] public bool CloseOnOverlayClick { get; set; } = true;
    [Parameter] public bool CloseOnEscape { get; set; } = true;
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private readonly string _titleId = $"mx-drawer-title-{Guid.NewGuid():N}";
    private string TitleId => _titleId;
    private string DrawerClass => $"ms-mx-drawer ms-mx-drawer--{Side.ToString().ToLowerInvariant()}";
    private string DrawerStyle => $"--mx-drawer-width: {Width};";

    private Task CloseAsync() => OpenChanged.InvokeAsync(false);

    private Task CloseFromOverlay()
    {
        if (!CloseOnOverlayClick)
        {
            return Task.CompletedTask;
        }

        return CloseAsync();
    }

    private Task OnDrawerKeyDown(KeyboardEventArgs args)
    {
        if (CloseOnEscape && args.Key == "Escape")
        {
            return CloseAsync();
        }

        return Task.CompletedTask;
    }
}
