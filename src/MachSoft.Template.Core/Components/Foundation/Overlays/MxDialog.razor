@namespace MachSoft.Template.Core.Components.Foundation

@if (Open)
{
    <div class="ms-mx-overlay" @onclick="CloseFromOverlay">
        <section class="@DialogClass"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@TitleId"
                 tabindex="0"
                 @onkeydown="OnDialogKeyDown"
                 @onclick:stopPropagation="true">
            <header class="ms-mx-dialog__header">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h3 id="@TitleId">@Title</h3>
                }
                @if (ShowCloseButton)
                {
                    <MxIconButton Icon="✕" AriaLabel="Cerrar diálogo" Variant="MxButtonVariant.Tertiary" Size="MxButtonSize.Small" OnClick="CloseAsync" />
                }
            </header>

            <div class="ms-mx-dialog__body">
                @ChildContent
            </div>

            @if (Actions is not null)
            {
                <footer class="ms-mx-dialog__actions">
                    @Actions
                </footer>
            }
        </section>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public MxDialogSize Size { get; set; } = MxDialogSize.Medium;
    [Parameter] public bool CloseOnOverlayClick { get; set; } = true;
    [Parameter] public bool CloseOnEscape { get; set; } = true;
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;
    [Parameter] public RenderFragment? Actions { get; set; }

    private readonly string _titleId = $"mx-dialog-title-{Guid.NewGuid():N}";
    private string TitleId => _titleId;
    private string DialogClass => $"ms-mx-dialog ms-mx-dialog--{Size.ToString().ToLowerInvariant()}";

    private Task CloseAsync() => OpenChanged.InvokeAsync(false);

    private Task CloseFromOverlay()
    {
        if (!CloseOnOverlayClick)
        {
            return Task.CompletedTask;
        }

        return CloseAsync();
    }

    private Task OnDialogKeyDown(KeyboardEventArgs args)
    {
        if (CloseOnEscape && args.Key == "Escape")
        {
            return CloseAsync();
        }

        return Task.CompletedTask;
    }
}
