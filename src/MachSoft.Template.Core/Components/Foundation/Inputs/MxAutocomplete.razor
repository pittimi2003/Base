@namespace MachSoft.Template.Core.Components.Foundation

<MxFieldGroup Label="@Label"
              FieldId="@ResolvedId"
              Required="@Required"
              HelperText="@HelperText"
              ErrorText="@ErrorText"
              IsCompact="@IsCompact">
    <input id="@ResolvedId"
           class="@InputClass"
           list="@ListId"
           value="@SearchText"
           placeholder="@Placeholder"
           disabled="@Disabled"
           required="@Required"
           aria-required="@Required"
           aria-invalid="@HasError"
           aria-describedby="@DescribedBy"
           @oninput="OnSearchInput"
           @onchange="OnSelectionChanged" />

    <datalist id="@ListId">
        @foreach (var item in Items)
        {
            <option value="@item.Text"></option>
        }
    </datalist>
</MxFieldGroup>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? SearchText { get; set; }
    [Parameter] public EventCallback<string?> SearchTextChanged { get; set; }
    [Parameter] public IEnumerable<MxInputOption> Items { get; set; } = Array.Empty<MxInputOption>();
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public bool IsCompact { get; set; }

    private readonly string _fallbackId = $"mx-autocomplete-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private string ListId => $"{ResolvedId}-list";
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string? DescribedBy => !string.IsNullOrWhiteSpace(HelperText) || HasError ? $"{ResolvedId}-message" : null;
    private string InputClass => $"ms-mx-input{(IsCompact ? " ms-mx-input--compact" : string.Empty)}{(HasError ? " ms-mx-input--error" : string.Empty)}";

    private async Task OnSearchInput(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString();
        await SearchTextChanged.InvokeAsync(SearchText);
    }

    private async Task OnSelectionChanged(ChangeEventArgs args)
    {
        var text = args.Value?.ToString();
        SearchText = text;
        await SearchTextChanged.InvokeAsync(text);

        var selected = Items.FirstOrDefault(i => string.Equals(i.Text, text, StringComparison.OrdinalIgnoreCase));
        Value = selected?.Value;
        await ValueChanged.InvokeAsync(Value);
    }
}
