@namespace MachSoft.Template.Core.Components.Foundation
@using Microsoft.AspNetCore.Components.Forms

<MxFieldGroup Label="@Label"
              FieldId="@ResolvedId"
              HelperText="@HelperText"
              ErrorText="@ErrorText"
              IsCompact="@IsCompact">
    <InputFile id="@ResolvedId"
               class="@InputClass"
               OnChange="OnFilesChanged"
               multiple="@Multiple"
               accept="@Accept"
               disabled="@Disabled" />

    @if (SelectedFileNames.Count > 0)
    {
        <ul class="ms-mx-file-upload__list">
            @foreach (var fileName in SelectedFileNames)
            {
                <li>@fileName</li>
            }
        </ul>
    }
</MxFieldGroup>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public EventCallback<IReadOnlyList<IBrowserFile>> FilesChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Accept { get; set; }
    [Parameter] public bool Multiple { get; set; } = true;
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public bool IsCompact { get; set; }

    private readonly string _fallbackId = $"mx-fileupload-{Guid.NewGuid():N}";
    private readonly List<string> _selectedFileNames = [];

    private string ResolvedId => Id ?? _fallbackId;
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string InputClass => $"ms-mx-input{(IsCompact ? " ms-mx-input--compact" : string.Empty)}{(HasError ? " ms-mx-input--error" : string.Empty)}";
    private IReadOnlyList<string> SelectedFileNames => _selectedFileNames;

    private async Task OnFilesChanged(InputFileChangeEventArgs args)
    {
        var files = args.GetMultipleFiles();
        _selectedFileNames.Clear();
        _selectedFileNames.AddRange(files.Select(f => f.Name));
        await FilesChanged.InvokeAsync(files);
    }
}
