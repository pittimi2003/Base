@namespace MachSoft.Template.Core.Components.Foundation

<MxFieldGroup Label="@Label"
              FieldId="@ResolvedId"
              Required="@Required"
              HelperText="@HelperText"
              ErrorText="@ErrorText"
              IsCompact="@IsCompact">
    <div class="ms-mx-date-range">
        <input id="@ResolvedId"
               class="@InputClass"
               type="date"
               value="@StartFormatted"
               disabled="@Disabled"
               required="@Required"
               aria-label="Fecha inicial"
               aria-invalid="@HasError"
               aria-describedby="@DescribedBy"
               @onchange="OnStartChanged" />

        <span class="ms-mx-date-range__separator" aria-hidden="true">→</span>

        <input class="@InputClass"
               type="date"
               value="@EndFormatted"
               disabled="@Disabled"
               required="@Required"
               aria-label="Fecha final"
               aria-invalid="@HasError"
               aria-describedby="@DescribedBy"
               @onchange="OnEndChanged" />
    </div>
</MxFieldGroup>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public DateOnly? StartValue { get; set; }
    [Parameter] public EventCallback<DateOnly?> StartValueChanged { get; set; }
    [Parameter] public DateOnly? EndValue { get; set; }
    [Parameter] public EventCallback<DateOnly?> EndValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public bool IsCompact { get; set; }

    private readonly string _fallbackId = $"mx-daterange-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string? DescribedBy => !string.IsNullOrWhiteSpace(HelperText) || HasError ? $"{ResolvedId}-message" : null;
    private string InputClass => $"ms-mx-input{(IsCompact ? " ms-mx-input--compact" : string.Empty)}{(HasError ? " ms-mx-input--error" : string.Empty)}";
    private string StartFormatted => StartValue?.ToString("yyyy-MM-dd") ?? string.Empty;
    private string EndFormatted => EndValue?.ToString("yyyy-MM-dd") ?? string.Empty;

    private async Task OnStartChanged(ChangeEventArgs args)
    {
        DateOnly? parsed = null;
        if (DateOnly.TryParse(args.Value?.ToString(), out var date)) parsed = date;
        StartValue = parsed;
        await StartValueChanged.InvokeAsync(parsed);
    }

    private async Task OnEndChanged(ChangeEventArgs args)
    {
        DateOnly? parsed = null;
        if (DateOnly.TryParse(args.Value?.ToString(), out var date)) parsed = date;
        EndValue = parsed;
        await EndValueChanged.InvokeAsync(parsed);
    }
}
