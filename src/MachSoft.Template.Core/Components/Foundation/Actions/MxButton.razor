@namespace MachSoft.Template.Core.Components.Foundation

<button type="@Type"
        class="@ButtonClass"
        disabled="@Disabled"
        @onclick="OnClick">
    @if (!string.IsNullOrWhiteSpace(LeadingIcon))
    {
        <span class="ms-mx-button__icon" aria-hidden="true">@LeadingIcon</span>
    }

    <span class="ms-mx-button__label">@ChildContent</span>

    @if (!string.IsNullOrWhiteSpace(TrailingIcon))
    {
        <span class="ms-mx-button__icon" aria-hidden="true">@TrailingIcon</span>
    }
</button>

@code {
    [Parameter] public MxButtonVariant Variant { get; set; } = MxButtonVariant.Primary;
    [Parameter] public MxButtonSize Size { get; set; } = MxButtonSize.Medium;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? LeadingIcon { get; set; }
    [Parameter] public string? TrailingIcon { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private string ButtonClass =>
        $"ms-mx-button ms-mx-button--{Variant.ToString().ToLowerInvariant()} ms-mx-button--{Size.ToString().ToLowerInvariant()}";
}
