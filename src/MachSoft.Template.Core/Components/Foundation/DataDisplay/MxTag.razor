@namespace MachSoft.Template.Core.Components.Foundation

<span class="@TagClass">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @Text
    }

    @if (Dismissible)
    {
        <button type="button" class="ms-mx-tag__dismiss" aria-label="Quitar etiqueta" @onclick="OnDismiss">×</button>
    }
</span>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public MxTagVariant Variant { get; set; } = MxTagVariant.Neutral;
    [Parameter] public bool Dismissible { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }

    private string TagClass => $"ms-mx-tag ms-mx-tag--{Variant.ToString().ToLowerInvariant()}{(Dismissible ? " ms-mx-tag--dismissible" : string.Empty)}";
}
