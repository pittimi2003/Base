@namespace MachSoft.Template.Core.Components.Foundation

<div class="@ProgressClass"
     role="progressbar"
     aria-valuemin="0"
     aria-valuemax="@Max"
     aria-valuenow="@CurrentValue"
     aria-label="@AriaLabel">
    <div class="ms-mx-progress__track">
        <div class="ms-mx-progress__bar" style="width: @ProgressPercent%;"></div>
    </div>

    @if (ShowLabel)
    {
        <span class="ms-mx-progress__label">@CurrentValue / @Max (@ProgressPercent%)</span>
    }
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public MxProgressVariant Variant { get; set; } = MxProgressVariant.Brand;
    [Parameter] public bool ShowLabel { get; set; } = true;
    [Parameter] public bool IsInline { get; set; }
    [Parameter] public string AriaLabel { get; set; } = "Progress";

    private double CurrentValue => Math.Clamp(Value, 0, Max <= 0 ? 100 : Max);
    private int ProgressPercent => Max <= 0 ? 0 : (int)Math.Round((CurrentValue / Max) * 100);
    private string ProgressClass => $"ms-mx-progress ms-mx-progress--{Variant.ToString().ToLowerInvariant()}{(IsInline ? " ms-mx-progress--inline" : string.Empty)}";
}
