<a href="@Href" class="@TileClass">
    <div class="ms-menu-tile__icon">@Icon</div>
    <div>
        <h3>@Title</h3>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p>@Description</p>
        }
    </div>
</a>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Href { get; set; } = "#";
    [Parameter] public string Icon { get; set; } = "📦";
    [Parameter] public string Variant { get; set; } = "default"; // default|elevated|muted

    private string TileClass => $"ms-menu-tile ms-menu-tile--{Variant.ToLowerInvariant()}";
}
