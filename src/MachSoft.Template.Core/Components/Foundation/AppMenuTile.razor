<a href="@Href" class="@TileClass" aria-label="@Title">
    <div class="ms-menu-tile__icon">@Icon</div>
    <div>
        <h3>@Title</h3>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p>@Description</p>
        }
    </div>
</a>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string Href { get; set; } = "#";
    [Parameter] public string Icon { get; set; } = "📦";
    [Parameter] public TileVariant Variant { get; set; } = TileVariant.Default;

    private string TileClass => $"ms-menu-tile ms-menu-tile--{Variant.ToString().ToLowerInvariant()}";
}
