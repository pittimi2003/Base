@namespace MachSoft.Template.Core.Components.Foundation

<MxFieldGroup Label="@Label"
              FieldId="@ResolvedId"
              Required="@Required"
              HelperText="@HelperText"
              ErrorText="@ErrorText"
              IsCompact="@IsCompact">
    <textarea id="@ResolvedId"
              class="@TextAreaClass"
              rows="@Rows"
              placeholder="@Placeholder"
              disabled="@Disabled"
              readonly="@ReadOnly"
              required="@Required"
              aria-required="@Required"
              aria-invalid="@HasError"
              aria-describedby="@DescribedBy"
              @oninput="OnInputChanged">@Value</textarea>
</MxFieldGroup>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public int Rows { get; set; } = 4;
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool IsCompact { get; set; }
    [Parameter] public string? Id { get; set; }

    private readonly string _fallbackId = $"mx-textarea-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string MessageId => $"{ResolvedId}-message";
    private string? DescribedBy => !string.IsNullOrWhiteSpace(HelperText) || HasError ? MessageId : null;
    private string TextAreaClass => $"ms-mx-input ms-mx-input--textarea{(IsCompact ? " ms-mx-input--compact" : string.Empty)}{(HasError ? " ms-mx-input--error" : string.Empty)}";

    private async Task OnInputChanged(ChangeEventArgs args)
    {
        var nextValue = args.Value?.ToString();
        if (nextValue == Value)
        {
            return;
        }

        Value = nextValue;
        await ValueChanged.InvokeAsync(nextValue);
    }
}
