@namespace MachSoft.Template.Core.Components.Foundation

<div class="@FieldGroupClass">
    <label class="ms-mx-field-group__label" for="@FieldId">
        @Label
        @if (Required)
        {
            <span aria-hidden="true"> *</span>
        }
    </label>

    <div class="ms-mx-field-group__control">
        @ChildContent
    </div>

    @if (!string.IsNullOrWhiteSpace(CurrentMessage))
    {
        <p id="@MessageId" class="@MessageClass">@CurrentMessage</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string FieldId { get; set; } = string.Empty;
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool IsCompact { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    public string MessageId => $"{FieldId}-message";
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string? CurrentMessage => HasError ? ErrorText : HelperText;
    private string FieldGroupClass => $"ms-mx-field-group{(IsCompact ? " ms-mx-field-group--compact" : string.Empty)}{(HasError ? " ms-mx-field-group--error" : string.Empty)}";
    private string MessageClass => HasError ? "ms-mx-field-group__message ms-mx-field-group__message--error" : "ms-mx-field-group__message";
}
