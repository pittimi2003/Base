@namespace MachSoft.Template.Core.Components.Foundation

<MxFieldGroup Label="@Label"
              FieldId="@ResolvedId"
              Required="@Required"
              HelperText="@HelperText"
              ErrorText="@ErrorText"
              IsCompact="@IsCompact">
    <select id="@ResolvedId"
            class="@SelectClass"
            value="@Value"
            disabled="@Disabled"
            required="@Required"
            aria-required="@Required"
            aria-invalid="@HasError"
            aria-describedby="@DescribedBy"
            @onchange="OnValueChanged">
        @if (!string.IsNullOrWhiteSpace(Placeholder))
        {
            <option value="" disabled="@Required">@Placeholder</option>
        }

        @foreach (var option in Options)
        {
            <option value="@option.Value" disabled="@option.Disabled">@option.Text</option>
        }
    </select>
</MxFieldGroup>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public IEnumerable<MxSelectOption> Options { get; set; } = Array.Empty<MxSelectOption>();
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool IsCompact { get; set; }
    [Parameter] public string? Id { get; set; }

    private readonly string _fallbackId = $"mx-select-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorText);
    private string MessageId => $"{ResolvedId}-message";
    private string? DescribedBy => !string.IsNullOrWhiteSpace(HelperText) || HasError ? MessageId : null;
    private string SelectClass => $"ms-mx-input ms-mx-input--select{(IsCompact ? " ms-mx-input--compact" : string.Empty)}{(HasError ? " ms-mx-input--error" : string.Empty)}";

    private async Task OnValueChanged(ChangeEventArgs args)
    {
        var nextValue = args.Value?.ToString();
        if (nextValue == Value)
        {
            return;
        }

        Value = nextValue;
        await ValueChanged.InvokeAsync(nextValue);
    }
}
