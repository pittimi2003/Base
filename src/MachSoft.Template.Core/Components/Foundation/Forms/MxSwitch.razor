@namespace MachSoft.Template.Core.Components.Foundation

<label class="@SwitchClass" for="@ResolvedId">
    <input id="@ResolvedId"
           type="checkbox"
           role="switch"
           checked="@Checked"
           disabled="@Disabled"
           @onchange="OnCheckedChanged" />
    <span class="ms-mx-switch__track" aria-hidden="true">
        <span class="ms-mx-switch__thumb"></span>
    </span>
    <span class="ms-mx-switch__label-block">
        <span class="ms-mx-switch__label-row">
            <span class="ms-mx-switch__label">@Label</span>
            <span class="ms-mx-switch__state" aria-hidden="true">@(Checked ? "ON" : "OFF")</span>
        </span>
        @if (!string.IsNullOrWhiteSpace(HelperText))
        {
            <span class="ms-mx-switch__helper">@HelperText</span>
        }
    </span>
</label>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Id { get; set; }

    private readonly string _fallbackId = $"mx-switch-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private string SwitchClass => $"ms-mx-switch{(Disabled ? " ms-mx-switch--disabled" : string.Empty)}";

    private async Task OnCheckedChanged(ChangeEventArgs args)
    {
        var isChecked = args?.Value is bool value && value;
        if (isChecked == Checked)
        {
            return;
        }

        Checked = isChecked;
        await CheckedChanged.InvokeAsync(isChecked);
    }
}
