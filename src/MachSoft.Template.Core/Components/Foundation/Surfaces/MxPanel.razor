@namespace MachSoft.Template.Core.Components.Foundation

<section class="@PanelClass">
    @if (HasHeader)
    {
        <header class="ms-mx-panel__header">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <h2>@Title</h2>
            }

            @if (HeaderActions is not null)
            {
                <div class="ms-mx-panel__actions">
                    @HeaderActions
                </div>
            }
        </header>
    }

    <div class="ms-mx-panel__body">
        @ChildContent
    </div>
</section>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public SurfaceVariant Variant { get; set; } = SurfaceVariant.Outlined;
    [Parameter] public bool IsCompact { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private bool HasHeader => !string.IsNullOrWhiteSpace(Title) || HeaderActions is not null;
    private string PanelClass =>
        $"ms-mx-panel ms-mx-panel--{Variant.ToString().ToLowerInvariant()}{(IsCompact ? " ms-mx-panel--compact" : string.Empty)}";
}
