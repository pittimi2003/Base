@namespace MachSoft.Template.Core.Components.Foundation

<div class="@TabsClass" role="tablist" aria-label="@AriaLabel" @onkeydown="OnTabsKeyDown">
    @foreach (var item in Items)
    {
        var isActive = item.Value == ActiveValue;
        <button type="button"
                role="tab"
                class="@(isActive ? "ms-mx-tabs__tab ms-mx-tabs__tab--active" : "ms-mx-tabs__tab")"
                aria-selected="@isActive"
                aria-controls="@GetPanelId(item)"
                id="@GetTabId(item)"
                disabled="@item.Disabled"
                tabindex="@(isActive ? 0 : -1)"
                @onclick="() => SetActiveAsync(item.Value)">
            @item.Text
        </button>
    }
</div>

@if (ActiveContent is not null)
{
    <section id="@GetPanelIdByValue(ActiveValue)"
             role="tabpanel"
             class="ms-mx-tabs__panel"
             aria-labelledby="@GetTabIdByValue(ActiveValue)">
        @ActiveContent
    </section>
}

@code {
    [Parameter] public IEnumerable<MxTabItem> Items { get; set; } = Array.Empty<MxTabItem>();
    [Parameter, EditorRequired] public string ActiveValue { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ActiveValueChanged { get; set; }
    [Parameter] public MxTabsVariant Variant { get; set; } = MxTabsVariant.Underline;
    [Parameter] public string AriaLabel { get; set; } = "Tabs";
    [Parameter] public RenderFragment? ActiveContent { get; set; }

    private string TabsClass => $"ms-mx-tabs ms-mx-tabs--{Variant.ToString().ToLowerInvariant()}";

    private Task SetActiveAsync(string value)
    {
        if (value == ActiveValue)
        {
            return Task.CompletedTask;
        }

        ActiveValue = value;
        return ActiveValueChanged.InvokeAsync(value);
    }

    private async Task OnTabsKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is not ("ArrowRight" or "ArrowLeft" or "Home" or "End"))
        {
            return;
        }

        var enabled = Items.Where(i => !i.Disabled).ToList();
        if (enabled.Count == 0)
        {
            return;
        }

        var index = enabled.FindIndex(i => i.Value == ActiveValue);
        if (index < 0)
        {
            index = 0;
        }

        index = args.Key switch
        {
            "ArrowRight" => (index + 1) % enabled.Count,
            "ArrowLeft" => (index - 1 + enabled.Count) % enabled.Count,
            "Home" => 0,
            "End" => enabled.Count - 1,
            _ => index
        };

        await SetActiveAsync(enabled[index].Value);
    }

    private static string Normalize(string value) => string.Join('-', value.ToLowerInvariant().Split(' ', StringSplitOptions.RemoveEmptyEntries));
    private string GetTabId(MxTabItem item) => $"mx-tab-{Normalize(item.Value)}";
    private string GetPanelId(MxTabItem item) => $"mx-tabpanel-{Normalize(item.Value)}";
    private string GetTabIdByValue(string value) => $"mx-tab-{Normalize(value)}";
    private string GetPanelIdByValue(string value) => $"mx-tabpanel-{Normalize(value)}";
}
