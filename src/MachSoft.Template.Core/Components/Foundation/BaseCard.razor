<article class="@CardClass">
    @if (ShowHeader)
    {
        <header class="ms-card__header">
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(BadgeText))
            {
                <span class="ms-badge">@BadgeText</span>
            }
        </header>
    }

    <div class="ms-card__content">
        @ChildContent
    </div>
</article>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? BadgeText { get; set; }
    [Parameter] public SurfaceVariant Variant { get; set; } = SurfaceVariant.Default;
    [Parameter] public bool IsCompact { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private bool ShowHeader => !string.IsNullOrWhiteSpace(Title);
    private string CardClass =>
        $"ms-card ms-card--{Variant.ToString().ToLowerInvariant()}{(IsCompact ? " ms-card--compact" : string.Empty)}";
}
