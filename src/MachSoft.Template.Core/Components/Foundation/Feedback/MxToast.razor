@namespace MachSoft.Template.Core.Components.Foundation

@if (Visible)
{
    <section class="@ToastClass" role="status" aria-live="polite">
        <div class="ms-mx-toast__content">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <h4>@Title</h4>
            }
            <p>@Message</p>
        </div>

        @if (Dismissible)
        {
            <MxIconButton Icon="✕" AriaLabel="Cerrar notificación" Variant="MxButtonVariant.Tertiary" Size="MxButtonSize.Small" OnClick="DismissAsync" />
        }
    </section>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public MxToastVariant Variant { get; set; } = MxToastVariant.Info;
    [Parameter] public string? Title { get; set; }
    [Parameter, EditorRequired] public string Message { get; set; } = string.Empty;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public int? DurationMs { get; set; }

    private string ToastClass => $"ms-mx-toast ms-mx-toast--{Variant.ToString().ToLowerInvariant()}";

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && DurationMs is > 0)
        {
            var delay = DurationMs.Value;
            await Task.Delay(delay);

            if (Visible)
            {
                await VisibleChanged.InvokeAsync(false);
            }
        }
    }

    private Task DismissAsync() => VisibleChanged.InvokeAsync(false);
}
