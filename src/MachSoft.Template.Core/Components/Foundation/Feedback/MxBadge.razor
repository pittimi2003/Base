@namespace MachSoft.Template.Core.Components.Foundation

<span class="@BadgeClass" role="status">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @Text
    }
</span>

@code {
    [Parameter] public MxBadgeVariant Variant { get; set; } = MxBadgeVariant.Neutral;
    [Parameter] public MxBadgeSize Size { get; set; } = MxBadgeSize.Medium;
    [Parameter] public string? Text { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string BadgeClass =>
        $"ms-mx-badge ms-mx-badge--{Variant.ToString().ToLowerInvariant()} ms-mx-badge--{Size.ToString().ToLowerInvariant()}";
}
