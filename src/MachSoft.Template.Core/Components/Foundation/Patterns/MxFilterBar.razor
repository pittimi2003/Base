@namespace MachSoft.Template.Core.Components.Foundation

<section class="@FilterClass" aria-label="Barra de filtros">
    <div class="ms-mx-filter-bar__filters">
        @Filters
    </div>

    @if (Summary is not null)
    {
        <div class="ms-mx-filter-bar__summary">
            @Summary
        </div>
    }

    @if (Actions is not null)
    {
        <div class="ms-mx-filter-bar__actions">
            @Actions
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public RenderFragment Filters { get; set; } = default!;
    [Parameter] public RenderFragment? Summary { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public bool IsCompact { get; set; }

    private string FilterClass => $"ms-mx-filter-bar{(IsCompact ? " ms-mx-filter-bar--compact" : string.Empty)}";
}
