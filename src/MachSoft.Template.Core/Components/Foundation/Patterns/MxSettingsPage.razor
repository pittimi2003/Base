@namespace MachSoft.Template.Core.Components.Foundation

<PageContainer Title="@Title" Description="@Description" IsCompact="@IsCompact">
    @if (Categories is not null)
    {
        <div class="ms-mx-settings-page__categories">
            @Categories
        </div>
    }

    <div class="ms-mx-settings-page__sections">
        @Sections
    </div>

    @if (Actions is not null)
    {
        <div class="ms-mx-settings-page__actions">
            @Actions
        </div>
    }
</PageContainer>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? Categories { get; set; }
    [Parameter, EditorRequired] public RenderFragment Sections { get; set; } = default!;
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public bool IsCompact { get; set; }
}
