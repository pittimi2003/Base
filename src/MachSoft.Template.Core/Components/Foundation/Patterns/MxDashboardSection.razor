@namespace MachSoft.Template.Core.Components.Foundation

<section class="@SectionClass">
    <header class="ms-mx-dashboard-section__header">
        <div>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p>@Description</p>
            }
        </div>

        @if (Actions is not null)
        {
            <div class="ms-mx-dashboard-section__actions">
                @Actions
            </div>
        }
    </header>

    <div class="ms-mx-dashboard-section__body">
        @ChildContent
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public SurfaceVariant Variant { get; set; } = SurfaceVariant.Outlined;
    [Parameter] public bool IsCompact { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private string SectionClass => $"ms-mx-dashboard-section ms-mx-dashboard-section--{Variant.ToString().ToLowerInvariant()}{(IsCompact ? " ms-mx-dashboard-section--compact" : string.Empty)}";
}
