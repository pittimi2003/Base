@* LEGACY COMPONENT *@
@attribute [Obsolete("LEGACY: replaced by MxPageHeader + MxPanel/MxCard composition. This component will be removed in future versions.")]

<section class="@ContainerClass">
    @if (ShowHeader)
    {
        <header class="ms-page-header">
            <h2>@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p>@Description</p>
            }
        </header>
    }

    <div class="ms-page-body">
        @ChildContent
    </div>
</section>

@code {
    /// <summary>
    /// LEGACY: replaced by MxPageHeader + MxPanel/MxCard composition.
    /// This component will be removed in future versions.
    /// </summary>
    [Parameter] public string? Title { get; set; }

    [Parameter] public string? Description { get; set; }
    [Parameter] public bool IsCompact { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private bool ShowHeader => !string.IsNullOrWhiteSpace(Title);
    private string ContainerClass => $"ms-page-container{(IsCompact ? " ms-page-container--compact" : string.Empty)}";
}
