@using MachSoft.Template.Core.Models

<nav class="ms-nav" aria-label="Primary">
    @foreach (var item in Items)
    {
        <NavLink href="@item.Href" class="ms-nav__item" Match="NavLinkMatch.Prefix" @onclick="HandleItemSelected">
            @if (!string.IsNullOrWhiteSpace(item.Icon))
            {
                <span class="ms-nav__icon">@item.Icon</span>
            }
            <span>@item.Text</span>
        </NavLink>
    }
</nav>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<NavItem> Items { get; set; } = [];
    [Parameter] public EventCallback OnItemSelected { get; set; }

    private Task HandleItemSelected() => OnItemSelected.InvokeAsync();
}
