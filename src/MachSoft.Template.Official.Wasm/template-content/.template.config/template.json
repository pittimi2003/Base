{
  "$schema": "http://json.schemastore.org/template",
  "author": "MachSoft",
  "classifications": [
    "Web",
    "Blazor",
    "WebAssembly",
    "MachSoft"
  ],
  "identity": "MachSoft.Template.Official.Wasm",
  "name": "MachSoft Official WebAssembly Template",
  "shortName": "machsoft-wasm",
  "sourceName": "MachSoft.Template.Official.WasmHost",
  "preferNameDirectory": true,
  "symbols": {
    "CompanyName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "TemplateCompanyName",
      "description": "Company label used in configuration defaults.",
      "replaces": "TemplateCompanyName"
    },
    "RootNamespace": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "",
      "description": "Optional root namespace override. If empty, the generated project name is used."
    },
    "EffectiveRootNamespace": {
      "type": "generated",
      "generator": "coalesce",
      "parameters": {
        "sourceVariableName": "RootNamespace",
        "fallbackVariableName": "name"
      },
      "replaces": "TemplateRootNamespace"
    },
    "CorePackageVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "1.0.0-internal",
      "description": "MachSoft.Template.Core package version to restore.",
      "replaces": "0.0.0-core-version"
    },
    "PrivateFeedUrl": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "https://machsoftprivatenuget-adfkctf7h5bddhaa.mexicocentral-01.azurewebsites.net/v3/index.json",
      "description": "Private NuGet feed that hosts MachSoft packages.",
      "replaces": "https://machsoftprivatenuget-adfkctf7h5bddhaa.mexicocentral-01.azurewebsites.net/v3/index.json"
    },
    "CoreControlPackageVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "1.0.0-internal",
      "description": "MachSoft.Template.Core.Control package version to restore.",
      "replaces": "0.0.0-core-control-version"
    }
  },
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "primaryOutputs": [
    {
      "path": "MachSoft.Template.Official.WasmHost.csproj"
    }
  ],
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**"
          ]
        }
      ]
    }
  ]
}
