@page "/"
@inject IConfiguration Configuration

<PageTitle>Home</PageTitle>

<BrandHero Eyebrow="MachSoft official WebAssembly template"
           Heading="Start from a browser-first corporate baseline"
           Description="This template gives teams a clean .NET 8 Blazor WebAssembly host that restores MachSoft.Template.Core from an internal package source.">
    <Actions>
        <a class="page-action-link" href="packages">Review dependencies</a>
    </Actions>
</BrandHero>

<div class="page-grid">
    <TemplateFeatureCard Title="NuGet baseline"
                         BadgeText="Reusable"
                         Description="The shared corporate design baseline stays in MachSoft.Template.Core so browser apps stay lightweight and consistent." />
    <TemplateFeatureCard Title="Internal distribution"
                         BadgeText="Feed"
                         Description="The generated app includes a placeholder NuGet.config to connect safely to the approved internal package source." />
    <TemplateFeatureCard Title="WebAssembly host"
                         BadgeText="Browser"
                         Description="The template is optimized for isolated client-side execution without hybrid host-specific conditionals." />
</div>

<section class="page-panel">
    <h2>Configuration baseline</h2>
    <p><strong>Company:</strong> @Configuration["MachSoft:CompanyName"]</p>
    <p><strong>Support:</strong> @Configuration["MachSoft:SupportEmail"]</p>
    <p><strong>Documentation:</strong> @Configuration["MachSoft:DocumentationUrl"]</p>
</section>
