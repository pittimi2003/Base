@namespace MachSoft.Template.Core.Control.Components.Forms

<div class="@ContainerClass">
    <label class="@CheckboxClass" for="@ResolvedId">
        <input id="@ResolvedId"
               type="checkbox"
               checked="@Checked"
               disabled="@Disabled"
               required="@Required"
               aria-label="@AriaLabel"
               aria-invalid="@AriaInvalid"
               aria-describedby="@DescribedBy"
               @attributes="AdditionalAttributes"
               @onchange="OnCheckedChanged" />
        <span class="ms-mx-check__label-block">
            <span class="ms-mx-check__label">@Label</span>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <span id="@DescriptionId" class="ms-mx-check__description">@Description</span>
            }
        </span>
    </label>

    @if (HasError)
    {
        <p id="@ErrorId" class="ms-mx-check__message ms-mx-check__message--error">@ErrorText</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _fallbackId = $"mx-checkbox-{Guid.NewGuid():N}";
    private string ResolvedId => Id ?? _fallbackId;
    private string DescriptionId => $"{ResolvedId}-description";
    private string ErrorId => $"{ResolvedId}-error";
    private bool HasError => Invalid || !string.IsNullOrWhiteSpace(ErrorText);
    private string? DescribedBy
    {
        get
        {
            var ids = new List<string>(2);
            if (!string.IsNullOrWhiteSpace(Description)) ids.Add(DescriptionId);
            if (HasError) ids.Add(ErrorId);
            return ids.Count > 0 ? string.Join(' ', ids) : null;
        }
    }

    private string? AriaInvalid => HasError ? "true" : null;
    private string ContainerClass => $"ms-mx-check-group{(HasError ? " ms-mx-check-group--invalid" : string.Empty)}";
    private string CheckboxClass => $"ms-mx-check{(Disabled ? " ms-mx-check--disabled" : string.Empty)}";

    private async Task OnCheckedChanged(ChangeEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        var isChecked = args?.Value is bool value && value;
        if (isChecked == Checked)
        {
            return;
        }

        Checked = isChecked;
        await CheckedChanged.InvokeAsync(isChecked);
    }
}
