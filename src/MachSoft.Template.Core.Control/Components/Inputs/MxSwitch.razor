@namespace MachSoft.Template.Core.Control

<div class="@RootClass">
    <label class="mx-switch" for="@ResolvedId">
        <input id="@ResolvedId"
               class="mx-switch__input"
               type="checkbox"
               role="switch"
               checked="@Checked"
               disabled="@Disabled"
               required="@Required"
               aria-required="@Required"
               aria-checked="@Checked.ToString().ToLowerInvariant()"
               aria-invalid="@AriaInvalid"
               aria-describedby="@DescribedBy"
               @onchange="HandleChange"
               @attributes="AdditionalAttributes" />
        <span class="mx-switch__track" aria-hidden="true">
            <span class="mx-switch__thumb"></span>
        </span>
        <span class="mx-switch__content">
            <span class="mx-switch__label">@Label</span>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <span class="mx-switch__description">@Description</span>
            }
        </span>
    </label>

    @if (!string.IsNullOrWhiteSpace(ValidationText))
    {
        <span id="@ValidationId" class="mx-input-message mx-input-message--invalid">@ValidationText</span>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <span id="@HelperId" class="mx-input-message">@HelperText</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ValidationText { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _instanceId = $"mx-switch-{Guid.NewGuid():N}";

    private string ResolvedId => Id ?? _instanceId;
    private string HelperId => $"{ResolvedId}-helper";
    private string ValidationId => $"{ResolvedId}-validation";
    private string? AriaInvalid => Invalid ? "true" : null;
    private string? DescribedBy => !string.IsNullOrWhiteSpace(ValidationText)
        ? ValidationId
        : !string.IsNullOrWhiteSpace(HelperText)
            ? HelperId
            : null;

    private string RootClass =>
        $"mx-input-root mx-input-root--switch {(Invalid ? "mx-input-root--invalid" : string.Empty)} {(Disabled ? "mx-input-root--disabled" : string.Empty)} {(Required ? "mx-input-root--required" : string.Empty)} {Class}";

    private Task HandleChange(ChangeEventArgs args)
    {
        var value = args.Value is bool checkedValue && checkedValue;
        return CheckedChanged.InvokeAsync(value);
    }
}
