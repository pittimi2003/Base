@namespace MachSoft.Template.Core.Control
@using MachSoft.Template.Core.Control.Models

<div class="@RootClass" @onfocusout="HandleFocusOut">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="mx-input-label" for="@ResolvedId">@Label</label>
    }

    <div class="mx-adv-select mx-multiselect">
        <div class="mx-multiselect__control" @onclick="OpenDropdown">
            @if (SelectedItems.Count == 0)
            {
                <span class="mx-multiselect__placeholder">@Placeholder</span>
            }
            else
            {
                <div class="mx-multiselect__chips">
                    @foreach (var selected in SelectedItems)
                    {
                        <span class="mx-multiselect__chip">
                            @selected.Text
                            @if (!Disabled)
                            {
                                <button type="button"
                                        class="mx-multiselect__chip-remove"
                                        aria-label="Quitar @selected.Text"
                                        @onmousedown:preventDefault="true"
                                        @onclick="() => RemoveSelectionAsync(selected.Value)">
                                    ×
                                </button>
                            }
                        </span>
                    }
                </div>
            }

            <input id="@ResolvedId"
                   class="mx-input-control mx-input-control--text mx-multiselect__input"
                   type="text"
                   value="@CurrentSearchText"
                   placeholder="@SearchPlaceholder"
                   disabled="@Disabled"
                   role="combobox"
                   aria-expanded="@DropdownOpen"
                   aria-controls="@ListboxId"
                   aria-autocomplete="list"
                   aria-activedescendant="@ActiveDescendantId"
                   aria-invalid="@AriaInvalid"
                   aria-busy="@AriaBusy"
                   aria-required="@Required"
                   aria-describedby="@DescribedBy"
                   @oninput="HandleInput"
                   @onkeydown="HandleKeyDown"
                   @onfocus="OpenDropdownFromFocus"
                   @attributes="AdditionalAttributes" />
        </div>

        @if (DropdownOpen)
        {
            <ul id="@ListboxId" class="mx-adv-select__list" role="listbox" aria-multiselectable="true">
                @if (Loading)
                {
                    <li class="mx-adv-select__state" role="status">@LoadingText</li>
                }
                else if (FilteredOptions.Count == 0)
                {
                    <li class="mx-adv-select__state">@NoResultsText</li>
                }
                else
                {
                    @for (var index = 0; index < FilteredOptions.Count; index++)
                    {
                        var option = FilteredOptions[index];
                        var isSelected = SelectedValues.Contains(option.Value);
                        var isActive = index == ActiveIndex;
                        var optionId = $"{ListboxId}-option-{index}";
                        <li id="@optionId"
                            class="@GetOptionClass(option.Disabled, isSelected, isActive)"
                            role="option"
                            aria-selected="@isSelected"
                            aria-disabled="@option.Disabled">
                            <button type="button"
                                    class="mx-adv-select__option-button"
                                    disabled="@option.Disabled"
                                    @onmousedown:preventDefault="true"
                                    @onclick="() => ToggleOptionAsync(option.Value)">
                                <span class="mx-multiselect__check">@(isSelected ? "✓" : string.Empty)</span>
                                <span>@option.Text</span>
                            </button>
                        </li>
                    }
                }
            </ul>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ValidationText))
    {
        <span id="@ValidationId" class="mx-input-message mx-input-message--invalid">@ValidationText</span>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <span id="@HelperId" class="mx-input-message">@HelperText</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public IReadOnlyList<string> SelectedValues { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<IReadOnlyList<string>> SelectedValuesChanged { get; set; }
    [Parameter] public IReadOnlyList<MxInputOption> Options { get; set; } = Array.Empty<MxInputOption>();
    [Parameter] public string? Placeholder { get; set; } = "Selecciona una o más opciones";
    [Parameter] public string? SearchPlaceholder { get; set; } = "Buscar...";
    [Parameter] public string SearchText { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Cargando opciones...";
    [Parameter] public string NoResultsText { get; set; } = "Sin resultados.";
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ValidationText { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _instanceId = $"mx-multiselect-{Guid.NewGuid():N}";
    private string _searchTextInternal = string.Empty;
    private bool DropdownOpen { get; set; }
    private int ActiveIndex { get; set; } = -1;

    private string ResolvedId => Id ?? _instanceId;
    private string ListboxId => $"{ResolvedId}-listbox";
    private string HelperId => $"{ResolvedId}-helper";
    private string ValidationId => $"{ResolvedId}-validation";
    private string? AriaInvalid => Invalid ? "true" : null;
    private string? AriaBusy => Loading ? "true" : null;
    private string? ActiveDescendantId => ActiveIndex >= 0 && ActiveIndex < FilteredOptions.Count
        ? $"{ListboxId}-option-{ActiveIndex}"
        : null;
    private string? DescribedBy => !string.IsNullOrWhiteSpace(ValidationText)
        ? ValidationId
        : !string.IsNullOrWhiteSpace(HelperText)
            ? HelperId
            : null;

    private string RootClass =>
        $"mx-input-root mx-adv-select-root {(Invalid ? "mx-input-root--invalid" : string.Empty)} {(Disabled ? "mx-input-root--disabled" : string.Empty)} {(Loading ? "mx-adv-select-root--loading" : string.Empty)} {(Required ? "mx-input-root--required" : string.Empty)} {Class}";

    private IReadOnlyList<MxInputOption> FilteredOptions => string.IsNullOrWhiteSpace(CurrentSearchText)
        ? Options
        : Options.Where(option => option.Text.Contains(CurrentSearchText.Trim(), StringComparison.OrdinalIgnoreCase)).ToArray();
    private string CurrentSearchText => _searchTextInternal;

    private IReadOnlyList<MxInputOption> SelectedItems => Options.Where(option => SelectedValues.Contains(option.Value)).ToArray();

    protected override void OnParametersSet()
    {
        _searchTextInternal = SearchText;
        NormalizeActiveIndex();
    }

    private Task OpenDropdown()
    {
        if (Disabled)
        {
            return Task.CompletedTask;
        }

        DropdownOpen = true;
        NormalizeActiveIndex();
        return Task.CompletedTask;
    }

    private Task OpenDropdownFromFocus(FocusEventArgs _) => OpenDropdown();

    private async Task HandleInput(ChangeEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        var nextText = args.Value?.ToString() ?? string.Empty;
        _searchTextInternal = nextText;
        await SearchTextChanged.InvokeAsync(nextText);
        NormalizeActiveIndex();
        DropdownOpen = true;
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        if (args.Key == "Escape")
        {
            DropdownOpen = false;
        }
        else if (args.Key == "ArrowDown")
        {
            DropdownOpen = true;
            ActiveIndex = FindNextEnabledIndex(ActiveIndex, 1);
        }
        else if (args.Key == "ArrowUp")
        {
            DropdownOpen = true;
            ActiveIndex = FindNextEnabledIndex(ActiveIndex, -1);
        }
        else if (args.Key == "Enter" && ActiveIndex >= 0 && ActiveIndex < FilteredOptions.Count)
        {
            await ToggleOptionAsync(FilteredOptions[ActiveIndex].Value);
        }
        else if (args.Key == "Backspace" && string.IsNullOrWhiteSpace(CurrentSearchText) && SelectedValues.Count > 0)
        {
            await RemoveSelectionAsync(SelectedValues[^1]);
        }
    }

    private async Task ToggleOptionAsync(string value)
    {
        if (Disabled)
        {
            return;
        }

        var next = SelectedValues.ToList();

        if (!next.Remove(value))
        {
            next.Add(value);
        }

        await SelectedValuesChanged.InvokeAsync(next);
        _searchTextInternal = string.Empty;
        await SearchTextChanged.InvokeAsync(string.Empty);
        NormalizeActiveIndex();
    }

    private async Task RemoveSelectionAsync(string value)
    {
        if (Disabled)
        {
            return;
        }

        var next = SelectedValues.Where(selected => selected != value).ToList();
        await SelectedValuesChanged.InvokeAsync(next);
    }

    private async Task HandleFocusOut(FocusEventArgs _)
    {
        await Task.Delay(120);
        DropdownOpen = false;
    }

    private static string GetOptionClass(bool isDisabled, bool isSelected, bool isActive)
    {
        return $"mx-adv-select__option {(isDisabled ? "is-disabled" : string.Empty)} {(isSelected ? "is-selected" : string.Empty)} {(isActive ? "is-active" : string.Empty)}";
    }

    private void NormalizeActiveIndex()
    {
        if (FilteredOptions.Count == 0)
        {
            ActiveIndex = -1;
            return;
        }

        if (ActiveIndex < 0 || ActiveIndex >= FilteredOptions.Count || FilteredOptions[ActiveIndex].Disabled)
        {
            ActiveIndex = FindNextEnabledIndex(-1, 1);
        }
    }

    private int FindNextEnabledIndex(int startIndex, int direction)
    {
        if (FilteredOptions.Count == 0)
        {
            return -1;
        }

        var index = startIndex;
        for (var attempt = 0; attempt < FilteredOptions.Count; attempt++)
        {
            index = (index + direction + FilteredOptions.Count) % FilteredOptions.Count;
            if (!FilteredOptions[index].Disabled)
            {
                return index;
            }
        }

        return -1;
    }
}
