@namespace MachSoft.Template.Core.Control
@using System.Globalization

<div class="@RootClass">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="mx-input-label" id="@LabelId">@Label</label>
    }

    <div class="mx-date-range" role="group" aria-labelledby="@AriaLabelledBy" aria-describedby="@DescribedBy">
        <input id="@StartId"
               class="mx-input-control mx-input-control--date"
               type="date"
               value="@StartFormatted"
               min="@StartMinFormatted"
               max="@StartMaxFormatted"
               disabled="@Disabled"
               readonly="@ReadOnly"
               required="@Required"
               aria-label="Fecha inicial"
               aria-invalid="@AriaInvalid"
               aria-readonly="@AriaReadOnly"
               aria-describedby="@DescribedBy"
               @onchange="HandleStartChanged"
               @attributes="StartInputAttributes" />

        <span class="mx-date-range__separator" aria-hidden="true">→</span>

        <input id="@EndId"
               class="mx-input-control mx-input-control--date"
               type="date"
               value="@EndFormatted"
               min="@EndMinFormatted"
               max="@EndMaxFormatted"
               disabled="@Disabled"
               readonly="@ReadOnly"
               required="@Required"
               aria-label="Fecha final"
               aria-invalid="@AriaInvalid"
               aria-readonly="@AriaReadOnly"
               aria-describedby="@DescribedBy"
               @onchange="HandleEndChanged"
               @attributes="EndInputAttributes" />
    </div>

    @if (!string.IsNullOrWhiteSpace(ValidationText))
    {
        <span id="@ValidationId" class="mx-input-message mx-input-message--invalid">@ValidationText</span>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <span id="@HelperId" class="mx-input-message">@HelperText</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public DateOnly? StartValue { get; set; }
    [Parameter] public EventCallback<DateOnly?> StartValueChanged { get; set; }
    [Parameter] public DateOnly? EndValue { get; set; }
    [Parameter] public EventCallback<DateOnly?> EndValueChanged { get; set; }
    [Parameter] public DateOnly? Min { get; set; }
    [Parameter] public DateOnly? Max { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ValidationText { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _instanceId = $"mx-date-range-{Guid.NewGuid():N}";

    private string ResolvedId => Id ?? _instanceId;
    private string StartId => $"{ResolvedId}-start";
    private string EndId => $"{ResolvedId}-end";
    private string LabelId => $"{ResolvedId}-label";
    private string HelperId => $"{ResolvedId}-helper";
    private string ValidationId => $"{ResolvedId}-validation";
    private string StartFormatted => StartValue?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty;
    private string EndFormatted => EndValue?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty;
    private string? StartMinFormatted => Min?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? EndMaxFormatted => Max?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? StartMaxFormatted => ResolveStartMax()?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? EndMinFormatted => ResolveEndMin()?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? AriaInvalid => Invalid ? "true" : null;
    private string? AriaReadOnly => ReadOnly ? "true" : null;
    private string? AriaLabelledBy => !string.IsNullOrWhiteSpace(Label) ? LabelId : null;
    private string? DescribedBy => !string.IsNullOrWhiteSpace(ValidationText)
        ? ValidationId
        : !string.IsNullOrWhiteSpace(HelperText)
            ? HelperId
            : null;

    private IReadOnlyDictionary<string, object> StartInputAttributes => BuildInputAttributes("start");
    private IReadOnlyDictionary<string, object> EndInputAttributes => BuildInputAttributes("end");

    private string RootClass => string.Join(' ', new[]
    {
        "mx-input-root",
        "mx-input-root--date-range",
        Invalid ? "mx-input-root--invalid" : null,
        Disabled ? "mx-input-root--disabled" : null,
        ReadOnly ? "mx-input-root--readonly" : null,
        Required ? "mx-input-root--required" : null,
        HasInconsistentRange ? "mx-input-root--range-conflict" : null,
        Class
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));

    private bool HasInconsistentRange => StartValue.HasValue && EndValue.HasValue && StartValue > EndValue;

    private Task HandleStartChanged(ChangeEventArgs args)
    {
        if (ReadOnly || Disabled)
        {
            return Task.CompletedTask;
        }

        return StartValueChanged.InvokeAsync(ParseDate(args.Value?.ToString()));
    }

    private Task HandleEndChanged(ChangeEventArgs args)
    {
        if (ReadOnly || Disabled)
        {
            return Task.CompletedTask;
        }

        return EndValueChanged.InvokeAsync(ParseDate(args.Value?.ToString()));
    }

    private DateOnly? ResolveStartMax()
    {
        if (!EndValue.HasValue)
        {
            return Max;
        }

        if (!Max.HasValue)
        {
            return EndValue;
        }

        return EndValue < Max ? EndValue : Max;
    }

    private DateOnly? ResolveEndMin()
    {
        if (!StartValue.HasValue)
        {
            return Min;
        }

        if (!Min.HasValue)
        {
            return StartValue;
        }

        return StartValue > Min ? StartValue : Min;
    }

    private IReadOnlyDictionary<string, object> BuildInputAttributes(string slot)
    {
        var attributes = new Dictionary<string, object>(StringComparer.Ordinal);
        if (AdditionalAttributes is null)
        {
            return attributes;
        }

        foreach (var entry in AdditionalAttributes)
        {
            if (string.Equals(entry.Key, "id", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.Key, "aria-label", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.Key, "min", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.Key, "max", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(entry.Key, "value", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            attributes[entry.Key] = entry.Value;
        }

        attributes["data-mx-range-slot"] = slot;
        return attributes;
    }

    private static DateOnly? ParseDate(string? rawValue)
    {
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return null;
        }

        return DateOnly.TryParseExact(rawValue, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed)
            ? parsed
            : null;
    }
}
