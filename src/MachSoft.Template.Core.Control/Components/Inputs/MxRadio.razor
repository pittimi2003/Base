@namespace MachSoft.Template.Core.Control

<div class="@RootClass">
    <label class="mx-choice mx-choice--radio" for="@ResolvedId">
        <input id="@ResolvedId"
               class="mx-choice__input"
               type="radio"
               name="@Name"
               value="@Value"
               checked="@IsChecked"
               disabled="@Disabled"
               required="@Required"
               aria-required="@Required"
               aria-invalid="@AriaInvalid"
               aria-describedby="@DescribedBy"
               @onchange="HandleChange"
               @attributes="AdditionalAttributes" />
        <span class="mx-choice__control" aria-hidden="true"></span>
        <span class="mx-choice__content">
            <span class="mx-choice__label">@Label</span>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <span class="mx-choice__description">@Description</span>
            }
        </span>
    </label>

    @if (!string.IsNullOrWhiteSpace(ValidationText))
    {
        <span id="@ValidationId" class="mx-input-message mx-input-message--invalid">@ValidationText</span>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <span id="@HelperId" class="mx-input-message">@HelperText</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public string Name { get; set; } = $"mx-radio-group-{Guid.NewGuid():N}";
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = string.Empty;
    [Parameter] public string? SelectedValue { get; set; }
    [Parameter] public EventCallback<string?> SelectedValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ValidationText { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _instanceId = $"mx-radio-{Guid.NewGuid():N}";

    private string ResolvedId => Id ?? _instanceId;
    private bool IsChecked => string.Equals(SelectedValue, Value, StringComparison.Ordinal);
    private string HelperId => $"{ResolvedId}-helper";
    private string ValidationId => $"{ResolvedId}-validation";
    private string? AriaInvalid => Invalid ? "true" : null;
    private string? DescribedBy => !string.IsNullOrWhiteSpace(ValidationText)
        ? ValidationId
        : !string.IsNullOrWhiteSpace(HelperText)
            ? HelperId
            : null;

    private string RootClass =>
        $"mx-input-root mx-input-root--choice {(Invalid ? "mx-input-root--invalid" : string.Empty)} {(Disabled ? "mx-input-root--disabled" : string.Empty)} {(Required ? "mx-input-root--required" : string.Empty)} {Class}";

    private Task HandleChange(ChangeEventArgs args)
    {
        if (args.Value is null)
        {
            return Task.CompletedTask;
        }

        return SelectedValueChanged.InvokeAsync(args.Value.ToString());
    }
}
