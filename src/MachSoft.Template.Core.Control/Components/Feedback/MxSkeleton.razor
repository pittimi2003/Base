@namespace MachSoft.Template.Core.Control.Components.Feedback

<div class="@SkeletonClass" style="@InlineStyle" aria-hidden="true"></div>

@code {
    [Parameter] public string Variant { get; set; } = "line";
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "1rem";
    [Parameter] public bool Animated { get; set; } = true;

    private string SkeletonClass => $"ms-mx-skeleton ms-mx-skeleton--{NormalizedVariant}{(Animated ? " ms-mx-skeleton--animated" : string.Empty)}";

    private string InlineStyle => $"width: {Width}; height: {Height};";

    private string NormalizedVariant => Variant.ToLowerInvariant() switch
    {
        "circle" => "circle",
        "card" => "card",
        _ => "line"
    };
}
