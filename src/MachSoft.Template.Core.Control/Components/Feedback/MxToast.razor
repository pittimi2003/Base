@namespace MachSoft.Template.Core.Control
@implements IDisposable

@if (Visible)
{
    <section class="@CssClassValue" role="@ResolvedRole" aria-live="@AriaLive" aria-atomic="true">
        <div class="mx-toast__content">
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <h4 class="mx-toast__title">@Title</h4>
            }
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <p class="mx-toast__message">@Message</p>
            }
            @if (ChildContent is not null)
            {
                @ChildContent
            }
        </div>

        @if (Dismissible)
        {
            <MxIconButton Icon="✕"
                          AriaLabel="Cerrar notificación"
                          Variant="MxButtonVariant.Text"
                          Size="MxButtonSize.Small"
                          OnClick="DismissAsync" />
        }
    </section>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public MxToastVariant Variant { get; set; } = MxToastVariant.Info;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public int DurationMs { get; set; }
    [Parameter] public string AriaLive { get; set; } = "polite";
    [Parameter] public string? Role { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private CancellationTokenSource? _lifetimeCts;
    private string CssClassValue => $"mx-toast mx-toast--{Variant.ToString().ToLowerInvariant()}";
    private string ResolvedRole => !string.IsNullOrWhiteSpace(Role)
        ? Role
        : Variant is MxToastVariant.Danger or MxToastVariant.Warning
            ? "alert"
            : "status";

    protected override async Task OnParametersSetAsync()
    {
        _lifetimeCts?.Cancel();

        if (!Visible || DurationMs <= 0)
        {
            return;
        }

        _lifetimeCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(DurationMs, _lifetimeCts.Token);
            if (!_lifetimeCts.Token.IsCancellationRequested)
            {
                await DismissInternalAsync();
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private Task DismissAsync(MouseEventArgs _) => DismissInternalAsync();

    private async Task DismissInternalAsync()
    {
        await OnDismiss.InvokeAsync();
        await VisibleChanged.InvokeAsync(false);
    }

    public void Dispose()
    {
        _lifetimeCts?.Cancel();
        _lifetimeCts?.Dispose();
    }
}
