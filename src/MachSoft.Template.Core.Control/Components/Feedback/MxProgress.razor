@namespace MachSoft.Template.Core.Control.Components.Feedback

<div class="@ContainerClass">
    @if (IsCircular)
    {
        <div class="ms-mx-progress-circular"
             role="progressbar"
             aria-label="@AriaLabel"
             aria-valuemin="0"
             aria-valuemax="@Max"
             aria-valuenow="@ClampedValue"
             style="--mx-progress-ratio: @ProgressRatio; --mx-progress-size: @SizePx;">
            <svg viewBox="0 0 36 36" class="ms-mx-progress-circular__svg" aria-hidden="true">
                <circle class="ms-mx-progress-circular__track" cx="18" cy="18" r="15.5"></circle>
                <circle class="ms-mx-progress-circular__value" cx="18" cy="18" r="15.5"></circle>
            </svg>
            @if (ShowLabel)
            {
                <span class="ms-mx-progress-circular__label">@PercentLabel</span>
            }
        </div>
    }
    else
    {
        @if (ShowLabel)
        {
            <div class="ms-mx-progress__meta">
                <span class="ms-mx-progress__label">@Label</span>
                <span class="ms-mx-progress__value">@PercentLabel</span>
            </div>
        }

        <div class="ms-mx-progress__track"
             role="progressbar"
             aria-label="@AriaLabel"
             aria-valuemin="0"
             aria-valuemax="@Max"
             aria-valuenow="@ClampedValue">
            <span class="ms-mx-progress__fill" style="width: @ProgressPercent%;"></span>
        </div>
    }
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public string Label { get; set; } = "Progress";
    [Parameter] public string AriaLabel { get; set; } = "Progress";
    [Parameter] public bool ShowLabel { get; set; }
    [Parameter] public bool IsCircular { get; set; }
    [Parameter] public int CircularSize { get; set; } = 72;

    private double ClampedValue => Math.Clamp(Value, 0, EffectiveMax);
    private double EffectiveMax => Max <= 0 ? 100 : Max;
    private double ProgressPercent => Math.Round((ClampedValue / EffectiveMax) * 100, 1);
    private string ProgressRatio => (ClampedValue / EffectiveMax).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
    private string PercentLabel => $"{Math.Round(ProgressPercent):0}%";
    private string ContainerClass => $"ms-mx-progress{(IsCircular ? " ms-mx-progress--circular" : string.Empty)}";
    private string SizePx => $"{Math.Max(40, CircularSize)}px";
}
