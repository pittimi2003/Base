@namespace MachSoft.Template.Core.Control.Components.Navigation
@using MachSoft.Template.Core.Control.Models

<div class="ms-mx-menu" @onkeydown="OnKeyDown">
    <button type="button"
            id="@ButtonId"
            class="ms-mx-menu__trigger"
            aria-haspopup="menu"
            aria-expanded="@IsOpen.ToString().ToLowerInvariant()"
            aria-controls="@MenuId"
            @onclick="ToggleMenu">
        @TriggerText
    </button>

    @if (IsOpen)
    {
        <ul id="@MenuId" class="ms-mx-menu__panel" role="menu" aria-labelledby="@ButtonId">
            @foreach (var item in Items)
            {
                <li role="none">
                    <button type="button"
                            role="menuitem"
                            class="ms-mx-menu__item"
                            disabled="@item.Disabled"
                            @onclick="() => OnSelect(item)">
                        <span class="ms-mx-menu__text">@item.Text</span>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span class="ms-mx-menu__description">@item.Description</span>
                        }
                    </button>
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public string TriggerText { get; set; } = "Open menu";
    [Parameter] public IReadOnlyList<MxMenuItem> Items { get; set; } = Array.Empty<MxMenuItem>();
    [Parameter] public EventCallback<MxMenuItem> ItemSelected { get; set; }

    private readonly string _id = Guid.NewGuid().ToString("N");
    private bool IsOpen { get; set; }
    private string ButtonId => $"mx-menu-btn-{_id}";
    private string MenuId => $"mx-menu-panel-{_id}";

    private void ToggleMenu() => IsOpen = !IsOpen;

    private async Task OnSelect(MxMenuItem item)
    {
        if (item.Disabled)
        {
            return;
        }

        IsOpen = false;
        await ItemSelected.InvokeAsync(item);
    }

    private void OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Escape")
        {
            IsOpen = false;
        }
    }
}
