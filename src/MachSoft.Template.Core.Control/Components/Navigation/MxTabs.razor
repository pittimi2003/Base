@namespace MachSoft.Template.Core.Control.Components.Navigation
@using MachSoft.Template.Core.Control.Models

<div class="ms-mx-tabs">
    <div class="ms-mx-tabs__list" role="tablist" aria-label="@AriaLabel" @onkeydown="OnKeyDown">
        @for (var index = 0; index < Items.Count; index++)
        {
            var item = Items[index];
            var selected = item.Value == ActiveValue;
            <button type="button"
                    id="@GetTabId(item.Value)"
                    class="ms-mx-tabs__tab@(selected ? " is-active" : string.Empty)"
                    role="tab"
                    aria-selected="@selected.ToString().ToLowerInvariant()"
                    aria-controls="@GetPanelId(item.Value)"
                    tabindex="@(selected ? 0 : -1)"
                    disabled="@item.Disabled"
                    @onclick="() => SelectTab(item.Value)">
                @item.Label
            </button>
        }
    </div>

    <section class="ms-mx-tabs__panel" id="@GetPanelId(ActiveValue)" role="tabpanel" aria-labelledby="@GetTabId(ActiveValue)">
        @if (ActiveContent is not null)
        {
            @ActiveContent(ActiveValue)
        }
    </section>
</div>

@code {
    [Parameter] public IReadOnlyList<MxTabItem> Items { get; set; } = Array.Empty<MxTabItem>();
    [Parameter] public string ActiveValue { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ActiveValueChanged { get; set; }
    [Parameter] public string AriaLabel { get; set; } = "Tabs";
    [Parameter] public RenderFragment<string>? ActiveContent { get; set; }

    private readonly string _instanceId = Guid.NewGuid().ToString("N");

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(ActiveValue) && Items.Count > 0)
        {
            ActiveValue = Items[0].Value;
        }
    }

    private async Task SelectTab(string value)
    {
        if (value == ActiveValue)
        {
            return;
        }

        ActiveValue = value;
        await ActiveValueChanged.InvokeAsync(value);
    }

    private async Task OnKeyDown(KeyboardEventArgs args)
    {
        if (Items.Count == 0 || args.Key is not ("ArrowRight" or "ArrowLeft"))
        {
            return;
        }

        var currentIndex = Math.Max(0, Items.ToList().FindIndex(x => x.Value == ActiveValue));

        for (var step = 1; step <= Items.Count; step++)
        {
            var candidate = args.Key == "ArrowRight"
                ? (currentIndex + step) % Items.Count
                : (currentIndex - step + Items.Count) % Items.Count;

            if (!Items[candidate].Disabled)
            {
                await SelectTab(Items[candidate].Value);
                break;
            }
        }
    }

    private string GetTabId(string value) => $"mx-tab-{_instanceId}-{value}";
    private string GetPanelId(string value) => $"mx-panel-{_instanceId}-{value}";
}
