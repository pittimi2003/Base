@namespace MachSoft.Template.Core.Control

@if (IsLink)
{
    <a href="@Href"
       target="@Target"
       rel="@Rel"
       class="@CssClassValue"
       aria-label="@AriaLabel"
       aria-disabled="@IsDisabledOrLoading"
       aria-busy="@Loading"
       tabindex="@(IsDisabledOrLoading ? -1 : 0)"
       @onclick="HandleClickAsync"
       @onclick:preventDefault="@IsDisabledOrLoading">
        @if (Loading)
        {
            <span class="mx-btn__loader" aria-hidden="true"></span>
            <span class="mx-visually-hidden">@LoadingText</span>
        }
        @if (!string.IsNullOrWhiteSpace(LeadingIcon))
        {
            <span class="mx-btn__icon" aria-hidden="true">@LeadingIcon</span>
        }
        <span class="mx-btn__label">@ChildContent</span>
        @if (!string.IsNullOrWhiteSpace(TrailingIcon))
        {
            <span class="mx-btn__icon" aria-hidden="true">@TrailingIcon</span>
        }
    </a>
}
else
{
    <button type="@Type"
            class="@CssClassValue"
            aria-label="@AriaLabel"
            aria-busy="@Loading"
            disabled="@IsDisabledOrLoading"
            @onclick="HandleClickAsync">
        @if (Loading)
        {
            <span class="mx-btn__loader" aria-hidden="true"></span>
            <span class="mx-visually-hidden">@LoadingText</span>
        }
        @if (!string.IsNullOrWhiteSpace(LeadingIcon))
        {
            <span class="mx-btn__icon" aria-hidden="true">@LeadingIcon</span>
        }
        <span class="mx-btn__label">@ChildContent</span>
        @if (!string.IsNullOrWhiteSpace(TrailingIcon))
        {
            <span class="mx-btn__icon" aria-hidden="true">@TrailingIcon</span>
        }
    </button>
}

@code {
    [Parameter] public MxButtonVariant Variant { get; set; } = MxButtonVariant.Filled;
    [Parameter] public MxButtonSize Size { get; set; } = MxButtonSize.Medium;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Rel { get; set; }
    [Parameter] public string? LeadingIcon { get; set; }
    [Parameter] public string? TrailingIcon { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Cargando";
    [Parameter] public string? Class { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    private bool IsLink => !string.IsNullOrWhiteSpace(Href);
    private bool IsDisabledOrLoading => Disabled || Loading;

    private string CssClassValue =>
        $"mx-btn mx-btn--{Variant.ToString().ToLowerInvariant()} mx-btn--{Size.ToString().ToLowerInvariant()} {(Loading ? "mx-btn--loading" : string.Empty)} {Class}";

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (IsDisabledOrLoading)
        {
            return;
        }

        await OnClick.InvokeAsync(args);
    }
}
