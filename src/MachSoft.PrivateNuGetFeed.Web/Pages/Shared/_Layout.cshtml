@using MachSoft.PrivateNuGetFeed.Web.Options
@using Microsoft.Extensions.Options
@inject IOptions<PortalOptions> PortalOptionsAccessor
@{
    var portal = PortalOptionsAccessor.Value;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @portal.CompanyName</title>
    <meta name="description" content="Portal corporativo para operar un feed privado de NuGet con BaGet y ASP.NET Core 8 sobre Azure App Service Windows." />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="ms-shell">
        <header class="ms-header">
            <div class="ms-brandbar">
                <a class="ms-brand" asp-page="/Index" aria-label="Volver al portal principal MachSoft">
                    <span class="ms-brand-mark">M</span>
                    <span>
                        <strong>@portal.CompanyName</strong>
                        <small>Private NuGet Platform</small>
                    </span>
                </a>
                <div class="ms-header-meta">
                    <span class="ms-pill">@portal.InternalUseBadgeText</span>
                    <span class="ms-version">@portal.PortalVersion</span>
                </div>
            </div>
        </header>

        <main role="main" class="ms-main">
            @RenderBody()
        </main>

        <footer class="ms-footer">
            <div>
                <strong>@portal.CompanyName</strong>
                <span>@portal.FooterUsageText</span>
            </div>
            <div>
                <span>Uso interno · Versión @portal.PortalVersion · @DateTime.UtcNow.Year</span>
            </div>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
