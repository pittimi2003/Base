<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <!-- Sustituir con la URL pública final del App Service si no se desea detección dinámica por request. -->
    <add key="PortalBaseUrl" value="https://__APP_SERVICE_URL__" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <!-- Configurar la API key real desde App Settings o Key Vault references tras publicar. -->
    <add key="apiKey" value="__API_KEY__" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <!-- Repositorio persistente recomendado para Azure App Service Windows. -->
    <add key="packagesPath" value="D:\home\data\MachSoft.PrivateNuGetFeed\Packages" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
  </appSettings>
</configuration>
