@model HomeViewModel
@{
    ViewData["Title"] = Model.PortalTitle;
}

<section class="ms-hero">
    <div class="ms-hero-copy">
        <span class="ms-eyebrow">@Model.PortalSubtitle</span>
        <h1>@Model.PortalTitle</h1>
        <p>@Model.HeroDescription</p>
        <div class="ms-hero-actions">
            <span class="ms-pill ms-pill-strong">@Model.InternalUseBadgeText</span>
            <a class="ms-link-chip" href="#consumir">Consumir paquetes</a>
            <a class="ms-link-chip" href="#publicar">Publicar paquetes</a>
        </div>
    </div>
    <aside class="ms-hero-panel">
        <div class="ms-stat">
            <span class="ms-stat-label">Feed v3</span>
            <strong>@Model.ServiceIndexUrl</strong>
        </div>
        <div class="ms-stat">
            <span class="ms-stat-label">Push endpoint</span>
            <strong>@Model.PackagePublishUrl</strong>
        </div>
        <div class="ms-stat">
            <span class="ms-stat-label">Portal base</span>
            <strong>@Model.PortalBaseUrl</strong>
        </div>
    </aside>
</section>

<section id="consumir" class="ms-section">
    <div class="ms-section-heading">
        <h2>Consumir paquetes</h2>
        <p>Comandos listos para copiar para configurar el source privado y consumir paquetes desde herramientas compatibles con NuGet.</p>
    </div>
    <div class="ms-command-grid">
        @foreach (var item in Model.ConsumeCommands)
        {
            <article class="ms-command-card">
                <div class="ms-command-header">
                    <h3>@item.Label</h3>
                    <button type="button" class="ms-copy-button" data-copy-target="@item.Command">Copiar</button>
                </div>
                <p>@item.Description</p>
                <pre><code>@item.Command</code></pre>
            </article>
        }
    </div>
</section>

<section id="publicar" class="ms-section">
    <div class="ms-section-heading">
        <h2>Publicar paquetes</h2>
        <p>El feed técnico permanece desacoplado del portal y expone el endpoint de publicación compatible con clientes NuGet.</p>
    </div>
    <div class="ms-command-grid">
        @foreach (var item in Model.PublishCommands)
        {
            <article class="ms-command-card ms-command-card-accent">
                <div class="ms-command-header">
                    <h3>@item.Label</h3>
                    <button type="button" class="ms-copy-button" data-copy-target="@item.Command">Copiar</button>
                </div>
                <p>@item.Description</p>
                <pre><code>@item.Command</code></pre>
            </article>
        }
    </div>
</section>

<section class="ms-section">
    <div class="ms-section-heading">
        <h2>Paquetes destacados</h2>
        <p>Ejemplos de paquetes corporativos que el equipo puede publicar y consumir desde el feed privado.</p>
    </div>
    <div class="ms-package-grid">
        @foreach (var package in Model.FeaturedPackages)
        {
            <article class="ms-package-card">
                <div class="ms-package-meta">
                    <h3>@package.Name</h3>
                    <span class="ms-package-version">v@(package.Version)</span>
                </div>
                <p>@package.Description</p>
                <pre><code>@package.InstallCommand</code></pre>
            </article>
        }
    </div>
</section>

<section class="ms-section ms-two-column">
    <article class="ms-card">
        <div class="ms-section-heading">
            <h2>Guía rápida</h2>
            <p>Flujo operativo sugerido para desarrollo local, pipelines y validación posterior al despliegue.</p>
        </div>
        <ol class="ms-steps">
            @foreach (var step in Model.QuickGuideSteps)
            {
                <li>
                    <span class="ms-step-number">@step.Number</span>
                    <div>
                        <strong>@step.Title</strong>
                        <p>@step.Detail</p>
                    </div>
                </li>
            }
        </ol>
    </article>

    <article class="ms-card">
        <div class="ms-section-heading">
            <h2>Notas internas</h2>
            <p>Buenas prácticas mínimas para operar el feed como herramienta interna seria y mantenible.</p>
        </div>
        <ul class="ms-notes">
            @foreach (var note in Model.InternalNotes)
            {
                <li>@note</li>
            }
        </ul>
    </article>
</section>
