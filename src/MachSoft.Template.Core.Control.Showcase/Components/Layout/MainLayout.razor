@inherits LayoutComponentBase

<div class="ms-control-shell mx-control-host" data-mx-theme="@CurrentTheme">
    <div class="ms-showcase-layout">
        <aside class="ms-showcase-layout__nav" role="navigation" aria-label="Navegación de catálogo">
            <NavMenu CurrentTheme="@CurrentTheme" OnThemeChanged="OnThemeChanged" />
        </aside>

        <div class="ms-showcase-layout__workspace">
            <header class="ms-showcase-layout__header">
                <div>
                    <p class="ms-showcase-layout__kicker">MachSoft Design System</p>
                    <strong>Core.Control Showcase</strong>
                </div>
                <span class="ms-showcase-layout__theme-pill">Theme: @CurrentThemeLabel</span>
            </header>

            <main class="ms-showcase-layout__content">
                @Body
            </main>
        </div>
    </div>
</div>

@code {
    private string CurrentTheme { get; set; } = "light";

    private string CurrentThemeLabel => CurrentTheme == "light" ? "Light" : "Dark";

    private Task OnThemeChanged(bool isDarkTheme)
    {
        CurrentTheme = isDarkTheme ? "dark" : "light";
        return Task.CompletedTask;
    }
}
