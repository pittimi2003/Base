@inherits LayoutComponentBase
@using MachSoft.Template.Core.Models
@inject IJSRuntime JSRuntime

<div class="ms-control-shell mx-control-host"
     data-mx-theme="@CurrentTheme">
    <AppShell BrandTitle="MachSoft"
              Title="Core.Control Showcase"
              Subtitle="Host oficial para validación visual y funcional del catálogo Mx*."
              FooterText="MachSoft.Template.Core.Control.Showcase"
              NavigationItems="_navigationItems"
              ShowFooter="@ShowFooter">
        <div class="ms-showcase-toolbar">
            <MxSwitch Id="mx-showcase-theme-switch"
                      Label="Tema oscuro"
                      Description="Control Mx* para validar cambio de tema en runtime."
                      Checked="@IsDarkTheme"
                      CheckedChanged="OnThemeChanged" />
        </div>

        @Body
    </AppShell>
</div>

@code {
    [Parameter] public bool ShowFooter { get; set; } = true;

    private static readonly IReadOnlyList<NavItem> _navigationItems =
    [
        new("Home", "/", "🏠"),
        new("Foundations", "/foundations", "🎨"),
        new(
            "Families",
            "/families",
            "🧩",
            Children:
            [
                .. ControlCatalogRegistry.Families.Select(
                    family => new NavItem($"Family - {family.Name}", family.Route, "↳"))
            ])
    ];

    private string CurrentTheme { get; set; } = "light";

    private bool IsDarkTheme => string.Equals(CurrentTheme, "dark", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var activeTheme = await JSRuntime.InvokeAsync<string>("machsoftTheme.getActiveTheme");
            CurrentTheme = activeTheme == "dark" ? "dark" : "light";
            StateHasChanged();
        }
        catch (JSException)
        {
            CurrentTheme = "light";
        }
    }

    private async Task OnThemeChanged(bool isDarkTheme)
    {
        CurrentTheme = isDarkTheme ? "dark" : "light";
        var appliedTheme = await JSRuntime.InvokeAsync<string>("machsoftTheme.setTheme", CurrentTheme);
        CurrentTheme = appliedTheme == "dark" ? "dark" : "light";
    }
}
