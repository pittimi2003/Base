@using MachSoft.Template.Core.Control.Showcase.Services

<section class="ms-control-catalog-roadmap" aria-label="Roadmap de familias del catálogo oficial">
    @foreach (var family in ControlCatalogRegistry.Families)
    {
        <article class="ms-control-catalog-roadmap__item">
            <header>
                <h3>@family.Name</h3>
                <span class="ms-control-catalog-roadmap__status">@family.Status</span>
            </header>
            <p>@family.Description</p>
            <p class="ms-control-catalog-roadmap__scope">@family.Scope</p>
            <MxButton Variant="MxButtonVariant.Outlined" Href="@family.Route">Abrir plantilla</MxButton>
        </article>
    }
</section>
