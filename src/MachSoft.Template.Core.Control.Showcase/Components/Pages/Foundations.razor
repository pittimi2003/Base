@page "/foundations"

<PageTitle>Fundamentos visuales</PageTitle>

<MxPageHeader Title="Fundamentos visuales"
              Description="Vista de validación para tokens, superficies y tipografía base aplicada al catálogo.">
    <Metadata>
        <MxBadge Variant="MxBadgeVariant.Neutral" Text="Light/Dark" />
    </Metadata>
</MxPageHeader>

<div class="ms-showcase-foundations-grid">
    <MxCard Title="Color y superficie" Variant="SurfaceVariant.Outlined">
        <ChildContent>
            <p>Validar contraste de fondo, borde y texto en ambos temas.</p>
            <div class="ms-showcase-swatch"></div>
        </ChildContent>
    </MxCard>

    <MxCard Title="Spacing y densidad" Variant="SurfaceVariant.Outlined">
        <ChildContent>
            <p>Escala de espacios tokenizada para composición consistente.</p>
            <div class="ms-showcase-spacing"></div>
        </ChildContent>
    </MxCard>
</div>
