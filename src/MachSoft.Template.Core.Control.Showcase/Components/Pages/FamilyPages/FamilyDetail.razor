@page "/families/{FamilyKey}"

<PageTitle>@PageTitleValue</PageTitle>

@if (CurrentFamily is null)
{
    <ShowcasePageTemplate Eyebrow="Catalog · Families"
                          Title="Familia no encontrada"
                          Description="La familia solicitada no existe en el registro actual del catálogo.">
        <ChildContent>
            <div class="ms-showcase-preview-block">
                <p>Vuelve a la vista de familias para continuar con la validación por categorías.</p>
                <MxButton Variant="MxButtonVariant.Outlined" Href="/families">Volver a familias</MxButton>
            </div>
        </ChildContent>
    </ShowcasePageTemplate>
}
else
{
    <ShowcasePageTemplate Eyebrow="Catalog · Families"
                          Title="@CurrentFamily.Name"
                          Description="@CurrentFamily.Description">
        <Metadata>
            <span class="ms-showcase-chip">@CurrentFamily.Status</span>
            <span class="ms-showcase-chip">@CurrentFamily.Scope</span>
            <span class="ms-showcase-chip">Template ready</span>
        </Metadata>
        <ChildContent>
            @if (string.Equals(CurrentFamily.Key, "actions", StringComparison.OrdinalIgnoreCase))
            {
                @RenderActionsFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "feedback", StringComparison.OrdinalIgnoreCase))
            {
                @RenderFeedbackFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "overlays", StringComparison.OrdinalIgnoreCase))
            {
                @RenderOverlaysFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "inputs", StringComparison.OrdinalIgnoreCase))
            {
                @RenderInputsFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "selection", StringComparison.OrdinalIgnoreCase))
            {
                @RenderSelectionFamily()
            }
            else
            {
                <ShowcaseSection Title="Ejemplo base"
                                 Description="Espacio estándar para renderizar el caso principal de la familia.">
                    <ShowcasePreviewBlock Title="Escenario básico"
                                          Caption="Usa este bloque para validar markup, espaciado y comportamiento principal.">
                        <p>Área reservada para el primer ejemplo funcional de la familia <strong>@CurrentFamily.Name</strong>.</p>
                    </ShowcasePreviewBlock>
                </ShowcaseSection>
            }
        </ChildContent>
    </ShowcasePageTemplate>
}

@code {
    [Parameter] public string? FamilyKey { get; set; }

    private bool _dialogOpen;
    private bool _popupOpen;
    private bool _toastVisible;
    private bool _toastVisibleSecondary;
    private bool _alertVisible = true;
    private bool _tooltipForcedOpen;

    private string? _textFieldValue = "Valor inicial";
    private string? _textAreaValue = "Notas iniciales del operador";
    private bool _checkboxChecked = true;
    private string? _radioValue = "email";
    private bool _switchChecked;
    private string? _selectValue;
    private string? _autocompleteValue;
    private string? _autocompleteText;
    private string? _comboValue;
    private string? _comboText;
    private string _multiSearch = string.Empty;
    private IReadOnlyList<string> _multiSelected = ["alpha", "gamma"];

    private readonly IReadOnlyList<MxSelectOption> _selectOptions =
    [
        new("critical", "Crítico"),
        new("high", "Alta"),
        new("medium", "Media"),
        new("low", "Baja", true)
    ];

    private readonly IReadOnlyList<MxInputOption> _selectionOptions =
    [
        new("alpha", "Alpha"),
        new("beta", "Beta"),
        new("gamma", "Gamma"),
        new("delta", "Delta"),
        new("epsilon", "Epsilon", true),
        new("zeta", "Zeta"),
        new("theta", "Theta")
    ];

    private ControlFamilyDefinition? CurrentFamily => ControlCatalogRegistry.FindByKey(FamilyKey);

    private string PageTitleValue => CurrentFamily is null
        ? "Familia no encontrada"
        : $"{CurrentFamily.Name} · Showcase";

    private RenderFragment RenderActionsFamily() => @<>
        <ShowcaseSection Title="MxButton"
                         Description="Botones oficiales con variantes, estados disabled/loading y soporte de iconografía ligera.">
            <ShowcasePreviewBlock Title="Variantes principales"
                                  Caption="Filled, outlined, text y fab con una API unificada.">
                <div class="ms-showcase-inline-wrap">
                    <MxButton>Filled</MxButton>
                    <MxButton Variant="MxButtonVariant.Outlined">Outlined</MxButton>
                    <MxButton Variant="MxButtonVariant.Text">Text</MxButton>
                    <MxButton Variant="MxButtonVariant.Fab" LeadingIcon="＋">Nuevo</MxButton>
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="Estados"
                                  Caption="Disabled, loading, feedback accesible y soporte de íconos al inicio/fin.">
                <div class="ms-showcase-inline-wrap">
                    <MxButton Disabled="true">Disabled</MxButton>
                    <MxButton Loading="true" LoadingText="Guardando cambios">Guardando</MxButton>
                    <MxButton LeadingIcon="🛈" TrailingIcon="→">Con iconos</MxButton>
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="MxIconButton"
                         Description="Acción icon-only con etiqueta accesible y estados consistentes.">
            <ShowcasePreviewBlock Title="Básico y estados"
                                  Caption="El aria-label es obligatorio; soporta estado pressed para toggles.">
                <div class="ms-showcase-inline-wrap">
                    <MxIconButton Icon="✎" AriaLabel="Editar" />
                    <MxIconButton Icon="🗑" AriaLabel="Eliminar" Variant="MxButtonVariant.Outlined" />
                    <MxIconButton Icon="⚙" AriaLabel="Configuración" Disabled="true" />
                    <MxIconButton Icon="★" AriaLabel="Favorito" Pressed="true" />
                    <MxIconButton Icon="↻" AriaLabel="Cargando" Loading="true" LoadingText="Actualizando" />
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="Notas de límites actuales"
                                  Caption="Se documentan límites reales para sostener evolución limpia hacia Selection avanzada.">
                <ul class="ms-showcase-notes-list">
                    <li>Radio: se mantiene agrupación mínima por <code>Name</code>; no hay contenedor <code>RadioGroup</code> dedicado en esta iteración.</li>
                    <li>Select: <code>ReadOnly</code> se implementa como no interactivo (disabled + <code>aria-readonly</code>) por limitación nativa del elemento <code>select</code>.</li>
                </ul>
            </ShowcasePreviewBlock>
        </ShowcaseSection>
    </>;

    private RenderFragment RenderFeedbackFamily() => @<>
        <ShowcaseSection Title="MxAlert"
                         Description="Alertas con severidad y contenido flexible listo para integrarse con validaciones.">
            <ShowcasePreviewBlock Title="Severidades"
                                  Caption="Variantes info/success/warning/danger con rol adaptativo según criticidad.">
                <div class="ms-showcase-stack-sm">
                    @if (_alertVisible)
                    {
                        <MxAlert Variant="MxAlertVariant.Info" Title="Información" Message="Tu configuración fue sincronizada." Dismissible="true" OnDismiss="OnDismissAlert" />
                    }
                    <MxAlert Variant="MxAlertVariant.Success" Title="Éxito">
                        <p class="ms-showcase-inline-message">Despliegue completado sin errores.</p>
                    </MxAlert>
                    <MxAlert Variant="MxAlertVariant.Warning" Title="Atención" Message="Hay cambios sin publicar." />
                    <MxAlert Variant="MxAlertVariant.Danger" Title="Error" Message="No se pudo procesar la solicitud." />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="MxProgress y MxToast"
                         Description="Base de feedback operativa para procesos y notificaciones.">
            <ShowcasePreviewBlock Title="MxProgress"
                                  Caption="Incluye aria-valuetext y modo indeterminado para tareas largas.">
                <div class="ms-showcase-stack-sm">
                    <MxProgress Value="42" ValueText="42 por ciento completado" />
                    <MxProgress Value="76" Variant="MxProgressVariant.Success" />
                    <MxProgress Indeterminate="true" ShowLabel="false" Variant="MxProgressVariant.Warning" />
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="MxToast"
                                  Caption="Notificaciones reutilizables, autocierre opcional y visualización en stack simple.">
                <div class="ms-showcase-inline-wrap">
                    <MxButton Variant="MxButtonVariant.Outlined" OnClick="ShowToast">Mostrar toast éxito</MxButton>
                    <MxButton Variant="MxButtonVariant.Text" OnClick="ShowSecondaryToast">Mostrar toast warning</MxButton>
                </div>
                <div class="ms-showcase-stack-sm">
                    <MxToast Visible="_toastVisible"
                             VisibleChanged="OnToastChanged"
                             Variant="MxToastVariant.Success"
                             Title="Operación completada"
                             Message="El registro se actualizó correctamente."
                             DurationMs="4500" />
                    <MxToast Visible="_toastVisibleSecondary"
                             VisibleChanged="OnSecondaryToastChanged"
                             Variant="MxToastVariant.Warning"
                             Title="Pendiente de confirmación"
                             Message="Todavía faltan aprobadores."
                             DurationMs="0" />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>
    </>;

    private RenderFragment RenderOverlaysFamily() => @<>
        <ShowcaseSection Title="MxTooltip"
                         Description="Implementación base sólida para hover/focus con activación manual opcional.">
            <ShowcasePreviewBlock Title="Interacción tooltip"
                                  Caption="Disponible para texto breve; preparado para evolucionar a plantillas enriquecidas.">
                <div class="ms-showcase-inline-wrap">
                    <MxTooltip Text="Guardar cambios" Placement="MxTooltipPlacement.Top">
                        <MxIconButton Icon="💾" AriaLabel="Guardar" Variant="MxButtonVariant.Outlined" />
                    </MxTooltip>

                    <MxTooltip Text="Exportación programada" Placement="MxTooltipPlacement.Right">
                        <MxButton Variant="MxButtonVariant.Text">Hover/Foco</MxButton>
                    </MxTooltip>

                    <MxTooltip Text="Tooltip forzado para QA" Open="_tooltipForcedOpen" Placement="MxTooltipPlacement.Bottom">
                        <MxButton Variant="MxButtonVariant.Outlined" OnClick="ToggleTooltipOpen">Toggle Open</MxButton>
                    </MxTooltip>
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="MxDialog y MxPopup"
                         Description="Base de overlays controlables y compatibles cross-hosting.">
            <ShowcasePreviewBlock Title="MxDialog"
                                  Caption="Foco inicial en shell, cierre por Escape/overlay y slots de header/body/actions.">
                <MxButton OnClick="OpenDialog">Abrir dialog</MxButton>
                <MxDialog Open="_dialogOpen"
                          OpenChanged="OnDialogChanged"
                          Title="Aprobar publicación"
                          Size="MxDialogSize.Medium">
                    <ChildContent>
                        <p class="ms-showcase-inline-message">Confirma la publicación del lote en producción.</p>
                    </ChildContent>
                    <Actions>
                        <MxButton Variant="MxButtonVariant.Text" OnClick="CloseDialog">Cancelar</MxButton>
                        <MxButton OnClick="CloseDialog">Confirmar</MxButton>
                    </Actions>
                </MxDialog>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="MxPopup"
                                  Caption="Popup liviano público y base reusable para overlays contextuales simples.">
                <MxPopup Open="_popupOpen"
                         OpenChanged="OnPopupChanged"
                         Controlled="true"
                         CloseOnEscape="true"
                         ShowBackdrop="true"
                         Placement="MxPopupPlacement.BottomStart">
                    <TriggerContent>
                        <MxButton Variant="MxButtonVariant.Outlined">Abrir popup</MxButton>
                    </TriggerContent>
                    <ChildContent>
                        <div class="ms-showcase-stack-sm">
                            <strong>Acciones rápidas</strong>
                            <MxButton Variant="MxButtonVariant.Text">Duplicar</MxButton>
                            <MxButton Variant="MxButtonVariant.Text">Archivar</MxButton>
                        </div>
                    </ChildContent>
                </MxPopup>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="Límites actuales de overlays"
                                  Caption="Se documentan explícitamente para evitar sobreventa funcional en esta iteración.">
                <ul class="ms-showcase-notes-list">
                    <li>Dialog: foco inicial en shell y cierre por Escape/overlay; sin focus trap completo aún.</li>
                    <li>Popup: overlay contextual reusable para acciones simples; no reemplaza un menú enterprise.</li>
                    <li>Tooltip: base simple textual con modo open opcional para QA.</li>
                </ul>
            </ShowcasePreviewBlock>
        </ShowcaseSection>
    </>;


    private RenderFragment RenderInputsFamily() => @<>
        <ShowcaseSection Title="Campos textuales"
                         Description="MxTextField y MxTextArea comparten foundation visual, helper/validation text y estados base.">
            <ShowcasePreviewBlock Title="MxTextField"
                                  Caption="Input de texto base con binding directo, placeholder y soporte de readonly/invalid.">
                <div class="ms-showcase-input-grid">
                    <MxTextField Label="Nombre" @bind-Value="_textFieldValue" HelperText="Visible en light/dark." Required="true" />
                    <MxTextField Label="Con placeholder" Placeholder="Escribe tu alias" Value="" />
                    <MxTextField Label="Deshabilitado" Value="No editable" Disabled="true" />
                    <MxTextField Label="Solo lectura" Value="Bloqueado para edición" ReadOnly="true" />
                    <MxTextField Label="Inválido" Value="###" Invalid="true" ValidationText="Solo se permiten letras y números." />
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="MxTextArea"
                                  Caption="TextArea multilinea con la misma semántica visual de MxTextField.">
                <div class="ms-showcase-input-grid">
                    <MxTextArea Label="Descripción" @bind-Value="_textAreaValue" HelperText="Máximo 500 caracteres." Required="true" />
                    <MxTextArea Label="Placeholder" Placeholder="Escribe un comentario" Value="" Rows="5" />
                    <MxTextArea Label="Deshabilitado" Value="Bloqueado" Disabled="true" />
                    <MxTextArea Label="Solo lectura" Value="Contenido de solo lectura" ReadOnly="true" />
                    <MxTextArea Label="Inválido" Value="Texto" Invalid="true" ValidationText="El comentario es obligatorio." />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="Controles booleanos y selección"
                         Description="MxCheckbox, MxRadio, MxSwitch y MxSelect con API mínima y extensible para formularios. ">
            <ShowcasePreviewBlock Title="MxCheckbox y MxSwitch"
                                  Caption="Estado booleano claro, foco visible e invalidación visual opcional.">
                <div class="ms-showcase-input-grid">
                    <MxCheckbox Label="Acepto términos" Description="Debes aceptar para continuar." @bind-Checked="_checkboxChecked" HelperText="Requerido para continuar." Required="true" />
                    <MxCheckbox Label="Inválido" Checked="false" Invalid="true" ValidationText="Debes aceptar antes de enviar." />
                    <MxCheckbox Label="Deshabilitado" Checked="true" Disabled="true" />

                    <MxSwitch Label="Notificaciones" Description="Toggle semántico para preferencias operativas." @bind-Checked="_switchChecked" HelperText="Activa avisos por email." />
                    <MxSwitch Label="Inválido" Checked="false" Invalid="true" ValidationText="Debes escoger una preferencia." />
                    <MxSwitch Label="Deshabilitado" Checked="true" Disabled="true" />
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="MxRadio y MxSelect"
                                  Caption="Selección única simple. MxSelect readonly se modela como disabled + aria-readonly.">
                <div class="ms-showcase-input-grid">
                    <div class="ms-showcase-stack-sm">
                        <MxRadio Name="channel" Label="Email" Description="Canal recomendado para auditoría." Value="email" @bind-SelectedValue="_radioValue" Required="true" />
                        <MxRadio Name="channel" Label="SMS" Value="sms" @bind-SelectedValue="_radioValue" />
                        <MxRadio Name="channel" Label="Push (deshabilitado)" Value="push" @bind-SelectedValue="_radioValue" Disabled="true" />
                    </div>

                    <MxSelect Label="Prioridad"
                              Placeholder="Selecciona prioridad"
                              Options="_selectOptions"
                              @bind-Value="_selectValue"
                              HelperText="Versión base de selección simple." />

                    <MxSelect Label="Estado inválido"
                              Placeholder="Selecciona estado"
                              Options="_selectOptions"
                              Invalid="true"
                              ValidationText="Este campo es obligatorio." />

                    <MxSelect Label="Readonly (comportamiento HTML equivalente a disabled)"
                              Value="high"
                              Options="_selectOptions"
                              ReadOnly="true"
                              HelperText="El select nativo no soporta readonly real." />
                </div>
            </ShowcasePreviewBlock>

            <ShowcasePreviewBlock Title="Límites actuales de inputs base"
                                  Caption="Se mantienen explícitos para evitar sobrediseño antes de la familia Selection avanzada.">
                <ul class="ms-showcase-notes-list">
                    <li>Radio: agrupación mínima por <code>Name</code>; no se agrega `RadioGroup` dedicado en esta fase.</li>
                    <li>Select: `ReadOnly` se representa como estado no interactivo (disabled + <code>aria-readonly</code>) por limitación nativa de HTML.</li>
                </ul>
            </ShowcasePreviewBlock>
        </ShowcaseSection>
    </>;

    private RenderFragment RenderSelectionFamily() => @<>
        <ShowcaseSection Title="MxAutocomplete"
                         Description="Búsqueda local asistida con sugerencias visibles, loading y estado sin resultados.">
            <ShowcasePreviewBlock Title="Básico y estados"
                                  Caption="API mínima: Value/SearchText + Items locales, con disabled/invalid y empty state.">
                <div class="ms-showcase-input-grid">
                    <MxAutocomplete Label="Cliente"
                                    Placeholder="Buscar cliente"
                                    Items="_selectionOptions"
                                    @bind-SearchText="_autocompleteText"
                                    @bind-Value="_autocompleteValue"
                                    HelperText="Selecciona una opción de la lista." />

                    <MxAutocomplete Label="Sin resultados"
                                    Placeholder="Escribe: omega"
                                    Items="_selectionOptions"
                                    SearchText="omega"
                                    NoResultsText="No se encontraron coincidencias." />

                    <MxAutocomplete Label="Cargando"
                                    Placeholder="Cargando..."
                                    Items="Array.Empty<MxInputOption>()"
                                    Loading="true"
                                    LoadingText="Consultando catálogo..." />

                    <MxAutocomplete Label="Deshabilitado"
                                    Placeholder="No editable"
                                    Items="_selectionOptions"
                                    Disabled="true"
                                    SearchText="Alpha" />

                    <MxAutocomplete Label="Inválido"
                                    Placeholder="Selecciona una opción"
                                    Items="_selectionOptions"
                                    Invalid="true"
                                    ValidationText="Debes escoger un elemento válido." />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="MxMultiSelect"
                         Description="Selección múltiple real con chips, filtro local y estado vacío/sin resultados.">
            <ShowcasePreviewBlock Title="Básico y selección múltiple"
                                  Caption="Lista multiselección sin select multiple nativo, preparada para evolución futura.">
                <div class="ms-showcase-input-grid">
                    <MxMultiSelect Label="Etiquetas"
                                   Options="_selectionOptions"
                                   @bind-SelectedValues="_multiSelected"
                                   @bind-SearchText="_multiSearch"
                                   HelperText="Puedes seleccionar varias opciones." />

                    <MxMultiSelect Label="Estado vacío"
                                   Options="_selectionOptions"
                                   SelectedValues="Array.Empty<string>()"
                                   Placeholder="Sin selección inicial" />

                    <MxMultiSelect Label="Sin resultados"
                                   Options="_selectionOptions"
                                   SearchText="inexistente"
                                   NoResultsText="No hay opciones para ese filtro." />

                    <MxMultiSelect Label="Deshabilitado"
                                   Options="_selectionOptions"
                                   SelectedValues="_multiSelected"
                                   Disabled="true" />

                    <MxMultiSelect Label="Inválido"
                                   Options="_selectionOptions"
                                   Invalid="true"
                                   ValidationText="Selecciona al menos una opción." />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>

        <ShowcaseSection Title="MxComboBox"
                         Description="Input + selector controlable para búsqueda y selección simple local.">
            <ShowcasePreviewBlock Title="Básico y búsqueda"
                                  Caption="Apertura/cierre por teclado o botón; pensado como puente entre Input y Select.">
                <div class="ms-showcase-input-grid">
                    <MxComboBox Label="Proyecto"
                                Placeholder="Buscar proyecto"
                                Items="_selectionOptions"
                                @bind-SearchText="_comboText"
                                @bind-Value="_comboValue"
                                HelperText="Escribe o abre el listado para escoger." />

                    <MxComboBox Label="Búsqueda sin resultados"
                                Placeholder="Escribe: omega"
                                Items="_selectionOptions"
                                SearchText="omega"
                                NoResultsText="No hay coincidencias disponibles." />

                    <MxComboBox Label="Deshabilitado"
                                Placeholder="No editable"
                                Items="_selectionOptions"
                                Disabled="true"
                                SearchText="Gamma" />

                    <MxComboBox Label="Inválido"
                                Placeholder="Selecciona una opción"
                                Items="_selectionOptions"
                                Invalid="true"
                                ValidationText="Debes seleccionar un valor válido." />
                </div>
            </ShowcasePreviewBlock>
        </ShowcaseSection>
    </>;

    private Task OnToastChanged(bool value)
    {
        _toastVisible = value;
        return Task.CompletedTask;
    }

    private Task OnSecondaryToastChanged(bool value)
    {
        _toastVisibleSecondary = value;
        return Task.CompletedTask;
    }

    private Task OnDialogChanged(bool value)
    {
        _dialogOpen = value;
        return Task.CompletedTask;
    }

    private Task OnPopupChanged(bool value)
    {
        _popupOpen = value;
        return Task.CompletedTask;
    }

    private Task OnDismissAlert()
    {
        _alertVisible = false;
        return Task.CompletedTask;
    }

    private Task OpenDialog(MouseEventArgs _)
    {
        _dialogOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseDialog(MouseEventArgs _)
    {
        _dialogOpen = false;
        return Task.CompletedTask;
    }

    private Task ShowToast(MouseEventArgs _)
    {
        _toastVisible = true;
        return Task.CompletedTask;
    }

    private Task ShowSecondaryToast(MouseEventArgs _)
    {
        _toastVisibleSecondary = true;
        return Task.CompletedTask;
    }

    private Task ToggleTooltipOpen(MouseEventArgs _)
    {
        _tooltipForcedOpen = !_tooltipForcedOpen;
        return Task.CompletedTask;
    }
}
