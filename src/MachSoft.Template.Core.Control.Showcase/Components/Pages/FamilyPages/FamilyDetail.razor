    private bool _popupOpen;
    private bool _toastVisible;
    private bool _toastVisibleSecondary;
    private bool _alertVisible = true;
    private bool _tooltipForcedOpen;

    private string? _textFieldValue = "Valor inicial";
    private string? _textAreaValue = "Notas iniciales del operador";
    private bool _checkboxChecked = true;
    private string? _radioValue = "email";
    private bool _switchChecked;
    private string? _selectValue;
    private string? _autocompleteValue;
    private string? _autocompleteText;
    private string? _comboValue;
    private string? _comboText;
    private string _multiSearch = string.Empty;
    private IReadOnlyList<string> _multiSelected = ["alpha", "gamma"];
    private DateOnly? _selectedDate = new(2026, 3, 25);
    private DateOnly? _dateRangeStart = new(2026, 3, 24);
    private DateOnly? _dateRangeEnd = new(2026, 3, 28);
    private TimeOnly? _selectedTime = new(9, 30);
    private string? _listboxSingle = "ops";
    private IReadOnlyList<string> _listboxMultiple = ["alpha", "release"];
    private bool _filterChipSelected = true;
    private bool _segmentChipSelected;
    private bool _chipRemoved;
    private bool _uploading;
    private IReadOnlyList<string> _uploadedFileNames = Array.Empty<string>();
    private bool _dataGridLoading;
    private IReadOnlyList<string> _selectedGridRows = Array.Empty<string>();
    private string _lastGridActionMessage = "Sin acciones ejecutadas.";

    private readonly IReadOnlyList<MxSelectOption> _selectOptions =
    [
        new("critical", "Crítico"),
        new("high", "Alta"),
        new("medium", "Media"),
        new("low", "Baja", true)
