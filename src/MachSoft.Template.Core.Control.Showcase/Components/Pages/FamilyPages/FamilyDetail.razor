@page "/families/{FamilyKey}"

<PageTitle>@PageTitleValue</PageTitle>

@if (CurrentFamily is null)
{
    <ShowcasePageTemplate Eyebrow="Catalog · Families"
                          Title="Familia no encontrada"
                          Description="La familia solicitada no existe en el registro actual del catálogo.">
        <ChildContent>
            <div class="ms-showcase-preview-block">
                <p>Vuelve a la vista de familias para continuar con la validación por categorías.</p>
                <MxButton Variant="MxButtonVariant.Outlined" Href="/families">Volver a familias</MxButton>
            </div>
        </ChildContent>
    </ShowcasePageTemplate>
}
else
{
    <ShowcasePageTemplate Eyebrow="Catalog · Families"
                          Title="@CurrentFamily.Name"
                          Description="@CurrentFamily.Description">
        <Metadata>
            <span class="ms-showcase-chip">@CurrentFamily.Status</span>
            <span class="ms-showcase-chip">@CurrentFamily.Scope</span>
            <span class="ms-showcase-chip">Template ready</span>
        </Metadata>
        <ChildContent>
            @if (string.Equals(CurrentFamily.Key, "actions", StringComparison.OrdinalIgnoreCase))
            {
                @RenderActionsFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "feedback", StringComparison.OrdinalIgnoreCase))
            {
                @RenderFeedbackFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "overlays", StringComparison.OrdinalIgnoreCase))
            {
                @RenderOverlaysFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "inputs", StringComparison.OrdinalIgnoreCase))
            {
                @RenderInputsFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "selection", StringComparison.OrdinalIgnoreCase))
            {
                @RenderSelectionFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "datetime", StringComparison.OrdinalIgnoreCase))
            {
                @RenderDateTimeFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "listing", StringComparison.OrdinalIgnoreCase))
            {
                @RenderListingFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "data", StringComparison.OrdinalIgnoreCase))
            {
                @RenderDataFamily()
            }
            else if (string.Equals(CurrentFamily.Key, "upload", StringComparison.OrdinalIgnoreCase))
            {
                @RenderUploadFamily()
            }
            else
            {
                <ShowcaseSection Title="Ejemplo base"
                                 Description="Espacio estándar para renderizar el caso principal de la familia.">
                    <ShowcasePreviewBlock Title="Escenario básico"
                                          Caption="Usa este bloque para validar markup, espaciado y comportamiento principal.">
                        <p>Área reservada para el primer ejemplo funcional de la familia <strong>@CurrentFamily.Name</strong>.</p>
                    </ShowcasePreviewBlock>
                </ShowcaseSection>
            }
        </ChildContent>
    </ShowcasePageTemplate>
}

