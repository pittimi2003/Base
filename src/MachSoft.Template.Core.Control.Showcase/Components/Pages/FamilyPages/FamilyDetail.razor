    private readonly IReadOnlyList<MxListBoxOption> _listBoxOptions =
    [
        new("ops", "Operaciones", "Vista principal", "⚙"),
        new("alpha", "Alpha", "Canal de pruebas", "🧪"),
        new("release", "Release", "Entorno productivo", "🚀"),
        new("legacy", "Legacy", "No disponible", "📦", true)
    ];

    private readonly IReadOnlyList<ShowcaseGridRow> _dataGridRows =
    [
        new("ORD-1042", "En preparación", "Alta", "Centro Norte", new DateTime(2026, 3, 25, 8, 40, 0)),
        new("ORD-1043", "En revisión", "Media", "Centro Sur", new DateTime(2026, 3, 25, 9, 15, 0)),
        new("ORD-1044", "Despachada", "Crítica", "Centro Andino", new DateTime(2026, 3, 25, 9, 58, 0)),
        new("ORD-1045", "Completada", "Baja", "Centro Pacífico", new DateTime(2026, 3, 25, 10, 22, 0))
    ];

    private readonly IReadOnlyList<MxDataGridColumn<ShowcaseGridRow>> _dataGridColumns =
    [
        new("Orden", row => row.OrderCode, Width: "12rem", Sortable: true, SortValueSelector: row => row.OrderCode, Key: "order"),
        new("Estado", row => row.Status, Width: "11rem", Sortable: true, SortValueSelector: row => row.Status, Key: "status"),
        new("Prioridad", row => row.Priority, Width: "9rem", Sortable: true, SortValueSelector: row => row.PriorityWeight, Key: "priority"),
        new("Centro", row => row.Site, Sortable: true, SortValueSelector: row => row.Site, Key: "site"),
        new("Actualizada", row => row.UpdatedAtLabel, Width: "15rem", Sortable: true, SortValueSelector: row => row.UpdatedAt, Key: "updated")
