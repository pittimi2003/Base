@page "/patterns/main-container"

<PageTitle>MainContainer · Patrón Tipo Grid</PageTitle>

<ShowcasePageTemplate Eyebrow="Catalog · Patterns"
                      Title="MainContainer · Vista Tipo Grid (Left / Middle / Right)"
                      Description="Patrón funcional explícito: herramientas compactas a la izquierda, MxDataGrid dominante al centro, estado de selección debajo del grid y detalle contextual a la derecha.">
    <Metadata>
        <span class="ms-showcase-chip">Pattern: Grid Workspace</span>
        <span class="ms-showcase-chip">Selection-driven detail</span>
        <span class="ms-showcase-chip">State owned by page</span>
    </Metadata>
    <ChildContent>
        <ShowcaseSection Title="Demo funcional Tipo Grid"
                         Description="La página controla selección y detalle. MainContainer solo compone Left / Middle / Right.">
            <MainContainer LeftMode="PanelDisplayMode.Inline"
                           RightMode="PanelDisplayMode.Inline"
                           ShowLeft="true"
                           ShowRight="true"
                           LeftWidth="9.5rem"
                           RightWidth="22rem"
                           Class="ms-showcase-main-container-demo">
                <LeftContent>
                    <div class="ms-showcase-main-container-actions" aria-label="Panel de herramientas compactas">
                        <h3>Herramientas</h3>

                        <MxTooltip Text="Crear registro" Placement="MxTooltipPlacement.Right">
                            <MxIconButton Icon="＋"
                                          AriaLabel="Crear registro"
                                          Variant="MxControlButtonVariant.Outlined"
                                          Size="MxButtonSize.Small"
                                          OnClick="CreateRecord" />
                        </MxTooltip>

                        <MxTooltip Text="Editar registro seleccionado" Placement="MxTooltipPlacement.Right">
                            <MxIconButton Icon="✎"
                                          AriaLabel="Editar registro seleccionado"
                                          Variant="MxControlButtonVariant.Outlined"
                                          Size="MxButtonSize.Small"
                                          Disabled="@(SelectedCount != 1)"
                                          OnClick="EditRecord" />
                        </MxTooltip>

                        <MxTooltip Text="Eliminar registros seleccionados" Placement="MxTooltipPlacement.Right">
                            <MxIconButton Icon="🗑"
                                          AriaLabel="Eliminar registros seleccionados"
                                          Variant="MxControlButtonVariant.Outlined"
                                          Size="MxButtonSize.Small"
                                          Disabled="@(SelectedCount == 0)"
                                          OnClick="DeleteRecords" />
                        </MxTooltip>

                        <p class="ms-showcase-inline-message">@ActionMessage</p>
                    </div>
                </LeftContent>

                <MiddleContent>
                    <div class="ms-showcase-main-container-grid-workspace">
                        <div class="ms-showcase-main-container-list">
                            <h3>Grid principal</h3>
                            <p class="ms-showcase-inline-message">Superficie principal de trabajo para selección simple o múltiple.</p>
                            <MxDataGrid TItem="MainContainerRecord"
                                        Columns="Columns"
                                        Items="Records"
                                        RowIdSelector="record => record.Id.ToString()"
                                        SelectionMode="MxDataGridSelectionMode.Multiple"
                                        SelectedRowIds="SelectedRowIds"
                                        SelectedRowIdsChanged="OnSelectedRowIdsChanged"
                                        AriaLabel="Registros de ejemplo del patrón Tipo Grid"
                                        Caption="Grid central dominante para operaciones del workspace"
                                        EmptyText="No hay registros disponibles para esta demo."
                                        EnableSorting="true" />
                        </div>

                        <section class="ms-showcase-main-container-selection-state" aria-live="polite" aria-label="Resumen de selección">
                            <div>
                                <h4>Selection status</h4>
                                <p class="ms-showcase-inline-message">@SelectionSummaryText</p>
                            </div>
                            @if (SelectedCount > 0)
                            {
                                <MxButton Variant="MxControlButtonVariant.Text" Size="MxButtonSize.Small" OnClick="ClearSelection">
                                    Limpiar selección
                                </MxButton>
                            }
                        </section>
                    </div>
                </MiddleContent>

                <RightContent>
                    <div class="ms-showcase-main-container-detail">
                        <h3>Detalle contextual</h3>

                        @if (SelectedCount == 0)
                        {
                            <div class="ms-showcase-main-container-empty-detail" role="status" aria-live="polite">
                                <p class="ms-showcase-inline-message">Sin selección activa. El detalle se habilita cuando eliges registros en el grid.</p>
                            </div>
                        }
                        else if (SelectedCount == 1)
                        {
                            var selected = SelectedRecords[0];
                            <dl>
                                <div>
                                    <dt>Id</dt>
                                    <dd>@selected.Id</dd>
                                </div>
                                <div>
                                    <dt>Name</dt>
                                    <dd>@selected.Name</dd>
                                </div>
                                <div>
                                    <dt>Status</dt>
                                    <dd>@selected.Status</dd>
                                </div>
                                <div>
                                    <dt>Type</dt>
                                    <dd>@selected.Type</dd>
                                </div>
                                <div>
                                    <dt>UpdatedAt</dt>
                                    <dd>@selected.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                                </div>
                            </dl>
                        }
                        else
                        {
                            <dl>
                                <div>
                                    <dt>Registros seleccionados</dt>
                                    <dd>@SelectedCount</dd>
                                </div>
                                <div>
                                    <dt>Id</dt>
                                    <dd>@MultiValueText</dd>
                                </div>
                                <div>
                                    <dt>Name</dt>
                                    <dd>@MultiValueText</dd>
                                </div>
                                <div>
                                    <dt>Status</dt>
                                    <dd>@MultiValueText</dd>
                                </div>
                                <div>
                                    <dt>Type</dt>
                                    <dd>@MultiValueText</dd>
                                </div>
                                <div>
                                    <dt>UpdatedAt</dt>
                                    <dd>@MultiValueText</dd>
                                </div>
                            </dl>
                        }
                    </div>
                </RightContent>
            </MainContainer>
        </ShowcaseSection>
    </ChildContent>
</ShowcasePageTemplate>

@code {
    private const string MultipleValuesText = "<Multiple values>";
    private const string MultiValueText = $"MultiValue ({MultipleValuesText})";

    private List<MainContainerRecord> Records { get; } =
    [
        new(101, "Contrato Norte", "Active", "Contract", new DateTime(2026, 3, 22, 9, 15, 0)),
        new(102, "Reporte Fiscal", "Draft", "Report", new DateTime(2026, 3, 23, 11, 45, 0)),
        new(103, "Proveedor Delta", "Archived", "Partner", new DateTime(2026, 3, 24, 14, 10, 0)),
        new(104, "Incidente 42", "Review", "Ticket", new DateTime(2026, 3, 25, 8, 35, 0))
    ];

    private IReadOnlyList<string> SelectedRowIds { get; set; } = Array.Empty<string>();

    private string ActionMessage { get; set; } = "Sin acciones ejecutadas.";

    private int SelectedCount => SelectedRowIds.Count;

    private string SelectionSummaryText => SelectedCount switch
    {
        0 => "Sin selección",
        1 => "Selected: 1",
        _ => $"Selected: {SelectedCount}"
    };

    private IReadOnlyList<MxControlDataGridColumn<MainContainerRecord>> Columns { get; } =
    [
        new("Id", record => record.Id.ToString(), Width: "5rem", Sortable: true, SortValueSelector: record => record.Id, Key: "id"),
        new("Name", record => record.Name, Width: "minmax(12rem, 1.6fr)", Sortable: true, SortValueSelector: record => record.Name, Key: "name"),
        new("Status", record => record.Status, Width: "8rem", Sortable: true, SortValueSelector: record => record.Status, Key: "status"),
        new("Type", record => record.Type, Width: "8rem", Sortable: true, SortValueSelector: record => record.Type, Key: "type"),
        new("UpdatedAt", record => record.UpdatedAt.ToString("yyyy-MM-dd HH:mm"), Width: "11rem", Sortable: true, SortValueSelector: record => record.UpdatedAt, Key: "updated-at")
    ];

    private List<MainContainerRecord> SelectedRecords =>
        Records.Where(record => SelectedRowIds.Contains(record.Id.ToString(), StringComparer.Ordinal)).ToList();

    private Task OnSelectedRowIdsChanged(IReadOnlyList<string> selectedRowIds)
    {
        SelectedRowIds = selectedRowIds;

        ActionMessage = selectedRowIds.Count switch
        {
            0 => "Sin selección activa.",
            1 => $"Registro seleccionado: {SelectedRecords[0].Name}.",
            _ => $"Selección múltiple activa ({selectedRowIds.Count} registros)."
        };

        return Task.CompletedTask;
    }

    private Task ClearSelection(MouseEventArgs _)
    {
        SelectedRowIds = Array.Empty<string>();
        ActionMessage = "Selección limpiada.";
        return Task.CompletedTask;
    }

    private Task CreateRecord(MouseEventArgs _)
    {
        var nextId = Records.Max(item => item.Id) + 1;
        var newRecord = new MainContainerRecord(nextId, $"Nuevo registro {nextId}", "Draft", "Task", DateTime.UtcNow);
        Records.Insert(0, newRecord);
        SelectedRowIds = [newRecord.Id.ToString()];
        ActionMessage = $"Se creó {newRecord.Name}.";
        return Task.CompletedTask;
    }

    private Task EditRecord(MouseEventArgs _)
    {
        if (SelectedRecords.Count != 1)
        {
            return Task.CompletedTask;
        }

        var selected = SelectedRecords[0];
        var index = Records.FindIndex(item => item.Id == selected.Id);

        if (index < 0)
        {
            return Task.CompletedTask;
        }

        var updated = selected with
        {
            Name = $"{selected.Name} (editado)",
            Status = "Review",
            UpdatedAt = DateTime.UtcNow
        };

        Records[index] = updated;
        ActionMessage = $"Se actualizó {updated.Name}.";
        return Task.CompletedTask;
    }

    private Task DeleteRecords(MouseEventArgs _)
    {
        if (SelectedRowIds.Count == 0)
        {
            return Task.CompletedTask;
        }

        var selectedIds = SelectedRowIds.ToHashSet(StringComparer.Ordinal);
        var removedCount = Records.RemoveAll(item => selectedIds.Contains(item.Id.ToString()));

        SelectedRowIds = Array.Empty<string>();
        ActionMessage = $"Se eliminaron {removedCount} registro(s).";
        return Task.CompletedTask;
    }

    private record MainContainerRecord(int Id, string Name, string Status, string Type, DateTime UpdatedAt);
}
