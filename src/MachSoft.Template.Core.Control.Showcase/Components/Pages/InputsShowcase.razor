@page "/showcase/inputs"
@page "/families/inputs"
@page "/families/selection"

<div class="ms-page-container">
    <MxPageHeader Title="Inputs avanzados — Bloque 1"
                  Description="Validación visual/funcional de MxTextArea, MxRadioGroup/MxRadio y MxSwitch sobre el Design System MachSoft." />

    <div class="showcase-grid">
        <MxTextArea Label="Descripción operativa"
                    Placeholder="Describe la incidencia"
                    Value="@Notes"
                    ValueChanged="@(v => Notes = v)"
                    HelperText="Incluye contexto funcional para el equipo de soporte." />

        <MxTextArea Label="Estado inválido"
                    Value="@InvalidNotes"
                    ValueChanged="@(v => InvalidNotes = v)"
                    Required="true"
                    ErrorText="Debes ingresar al menos 10 caracteres."
                    HelperText="Se muestra helper + error de forma consistente." />

        <MxTextArea Label="Deshabilitado"
                    Value="En revisión"
                    Disabled="true"
                    HelperText="Control bloqueado por permisos." />

        <MxTextArea Label="Solo lectura"
                    Value="Texto de auditoría"
                    ReadOnly="true"
                    HelperText="Visible y no editable." />
    </div>

    <div class="showcase-grid">
        <MxRadioGroup Label="Prioridad del ticket" HelperText="Selecciona una prioridad activa.">
            <MxRadio Name="priority" Label="Alta" Value="high" SelectedValue="@Priority" SelectedValueChanged="OnPriorityChanged" Description="Escalamiento inmediato" />
            <MxRadio Name="priority" Label="Media" Value="medium" SelectedValue="@Priority" SelectedValueChanged="OnPriorityChanged" Description="Gestión estándar" />
            <MxRadio Name="priority" Label="Baja" Value="low" SelectedValue="@Priority" SelectedValueChanged="OnPriorityChanged" />
        </MxRadioGroup>

        <MxRadioGroup Label="Estado inválido" Invalid="true" ErrorText="Selecciona una opción válida.">
            <MxRadio Name="invalid-priority" Label="Opción A" Value="a" SelectedValue="@InvalidPriority" SelectedValueChanged="OnInvalidPriorityChanged" />
            <MxRadio Name="invalid-priority" Label="Opción B" Value="b" SelectedValue="@InvalidPriority" SelectedValueChanged="OnInvalidPriorityChanged" Disabled="true" />
        </MxRadioGroup>

        <MxSwitch Label="Activar notificaciones" Checked="@NotificationsEnabled" CheckedChanged="@(v => NotificationsEnabled = v)" HelperText="Permite avisos en tiempo real." />
        <MxSwitch Label="Switch deshabilitado" Checked="true" Disabled="true" HelperText="Bloqueado por política." />
    </div>

    <h2>Comparativa light/dark</h2>
    <div class="showcase-grid showcase-grid--themes">
        <section class="showcase-theme-surface" data-mx-theme="light">
            <h3>Light</h3>
            <MxTextArea Label="Notas" Placeholder="Escribe aquí" HelperText="Tema light" Value="@LightNotes" ValueChanged="@(v => LightNotes = v)" />
            <MxSwitch Label="Modo automático" Checked="@LightSwitch" CheckedChanged="@(v => LightSwitch = v)" />
        </section>

        <section class="showcase-theme-surface" data-mx-theme="dark">
            <h3>Dark</h3>
            <MxTextArea Label="Notas" Placeholder="Escribe aquí" HelperText="Tema dark" Value="@DarkNotes" ValueChanged="@(v => DarkNotes = v)" />
            <MxSwitch Label="Modo automático" Checked="@DarkSwitch" CheckedChanged="@(v => DarkSwitch = v)" />
        </section>
    </div>
</div>

@code {
    private string? Notes { get; set; }
    private string? InvalidNotes { get; set; } = "corto";
    private string Priority { get; set; } = "medium";
    private string? InvalidPriority { get; set; }
    private bool NotificationsEnabled { get; set; } = true;
    private string? LightNotes { get; set; }
    private bool LightSwitch { get; set; }
    private string? DarkNotes { get; set; }
    private bool DarkSwitch { get; set; } = true;

    private Task OnPriorityChanged(string? value)
    {
        Priority = value ?? Priority;
        return Task.CompletedTask;
    }

    private Task OnInvalidPriorityChanged(string? value)
    {
        InvalidPriority = value;
        return Task.CompletedTask;
    }
}
