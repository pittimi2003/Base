@page "/packages"

<PageTitle>Packages</PageTitle>

<section class="page-panel">
    <h1>Package dependencies</h1>
    <p>This template references <code>MachSoft.Template.Core</code> for technical baseline and <code>MachSoft.Template.Core.Control</code> for official Mx* controls.</p>
    <ul>
        <li>Update <code>NuGet.config</code> with the corporate feed URL.</li>
        <li>Restore with <code>dotnet restore</code> after the feed is reachable.</li>
        <li>Keep Core and Core.Control versions aligned with the approved release train.</li>
    </ul>

    <div class="ms-inline-wrap">
        <MxButton Variant="MxControlButtonVariant.Filled"
                  Size="MxButtonSize.Small"
                  Style="min-width:12rem"
                  AdditionalAttributes="@_coreControlAttributes">
            Core.Control connected
        </MxButton>
        <MxButton Variant="MxControlButtonVariant.Outlined"
                  Size="MxButtonSize.Small"
                  Href="/"
                  AriaLabel="Volver a inicio desde Packages">
            Volver a inicio
        </MxButton>
        <MxButton Variant="MxControlButtonVariant.Text"
                  Size="MxButtonSize.Small"
                  Href="/"
                  Disabled="true"
                  AriaLabel="Inicio no disponible en estado bloqueado">
            Inicio bloqueado
        </MxButton>
    </div>
</section>

@code {
    private readonly IReadOnlyDictionary<string, object> _coreControlAttributes =
        new Dictionary<string, object>
        {
            ["data-host-check"] = "mxbutton"
        };
}
