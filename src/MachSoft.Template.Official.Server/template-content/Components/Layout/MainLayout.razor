@inherits LayoutComponentBase
@using MachSoft.Template.Core.Models

<AppShell BrandTitle="TemplateCompanyName"
          Title="TemplateRootNamespace"
          Subtitle="Official MachSoft server baseline for internal projects."
          FooterText="TemplateCompanyName · MachSoft.Template.Official.Server"
          NavigationItems="_items"
          ShowFooter="@ShowFooter">
    @Body
</AppShell>

@code {
    [Parameter] public bool ShowFooter { get; set; } = true;

    private static readonly IReadOnlyList<NavItem> _items =
    [
        new("Home", "/", "🏠"),
        new("Packages", "/packages", "📦")
    ];
}
