{{#if hasPorts}}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{name}}
spec:
  rules:
  - http:
      paths:
      - path: /{{name}}
        pathType: Exact
        backend:
          service:
            name: {{name}}
            port:
              {{#each ports}}
              number: {{internalPort}}
              {{/each}}
{{/if}}