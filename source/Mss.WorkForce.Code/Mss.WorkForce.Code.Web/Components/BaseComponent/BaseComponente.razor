    private IEnumerable<Warehouse> GetAvailableWarehouses(BaseModel property)
    {
        var allWarehouses = _contextConfig.GetWarehouses();

        var existingWarehouses = property.InitialValue.FirstOrDefault() as ICollection<Warehouse> ?? new List<Warehouse>();

        var availableWarehouses = allWarehouses.Where(w => !existingWarehouses.Any(existing => existing.Id == w.Id));

        return availableWarehouses;
    }

