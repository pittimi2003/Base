    private void ChangeValueToCatalogue(object currentModel, string propertyName, string propertyNameForDropDown, SelectItemComboBox value)
    {

        var propertyInfo = currentModel.GetType().GetProperty(propertyName);
        if (propertyInfo != null && value != null)
        {
            var emptyInstance = Activator.CreateInstance(propertyInfo.PropertyType);
            var nameProperty = propertyInfo.PropertyType.GetProperty("Name");
            var idProperty = propertyInfo.PropertyType.GetProperty("Id");

            if (nameProperty != null && nameProperty.CanWrite && nameProperty.PropertyType == typeof(string))
                nameProperty.SetValue(emptyInstance, value.Value);

            if (idProperty != null && idProperty.CanWrite)
                idProperty.SetValue(emptyInstance, value.Key);

            propertyInfo.SetValue(currentModel, emptyInstance);

        }
        else
        {
            var emptyInstance = Activator.CreateInstance(propertyInfo.PropertyType);
            propertyInfo.SetValue(currentModel, emptyInstance);
            var nameProperty = propertyInfo.PropertyType.GetProperty("Name");
            if (nameProperty != null && nameProperty.CanWrite && nameProperty.PropertyType == typeof(string))
                nameProperty.SetValue(emptyInstance, string.Empty);

        }
    }

    public Dictionary<string, DisplayAttributes> GetDisplayAttributes(PropertyInfo propertyInfo)
    {
        var displayAttributes = propertyInfo.GetCustomAttribute<DisplayAttributes>();
        return displayAttributes?.FieldType != Web.Model.Enums.ComponentType.None
            ? new Dictionary<string, DisplayAttributes> { { propertyInfo.Name, displayAttributes } }
            : new Dictionary<string, DisplayAttributes>();
    }

