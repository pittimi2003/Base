    private string GetEnumDescription(object value)
    {
        try
        {
            if (value != null && value.GetType().IsEnum)
            {
                var method = typeof(EnumHelper).GetMethod("GetItemDescription")
                                          .MakeGenericMethod(value.GetType());
                return (string)method.Invoke(null, new object[] { value });
            }

            return value.ToString();
        }
        catch (Exception)
        {
            return value.ToString();
        }
    }

    private string GetDropDownDisplayText(BaseModel property)
    {
        if (property.InitialValue == null || !property.InitialValue.Any())
            return string.Empty;

        if (property.InitialValue.Count() > 1)
            return multiplePhrase;

        var value = property.InitialValue.FirstOrDefault()?.ToString();

        if (string.IsNullOrEmpty(value))
            return string.Empty;

        return property.FieldType == ComponentType.DropDownLocalized 
             ? L.Loc(value) 
             : value;
    }

    private string FormatNumber(object value)
    {
        var culture = new System.Globalization.CultureInfo(UserFormat.CultureCode ?? "es-ES");
        culture.NumberFormat.NumberGroupSeparator = UserFormat.GroupSeparator.ToString();
        culture.NumberFormat.NumberDecimalSeparator = UserFormat.DecimalSeparator.ToString();

        double doubleValue = Convert.ToDouble(value);

        if (doubleValue % 1 == 0)
            return ((long)doubleValue).ToString("N0", culture);
        else
            return doubleValue.ToString("N", culture);
    }

    private bool IsProjectDesigner()
    {
        var genericType = this.GetType().GetGenericArguments().FirstOrDefault();
        if (genericType != null && typeof(IProject).IsAssignableFrom(genericType))
            return true;
        else
            return false;
    }

    void OnTextChanged(string value, BaseModel baseModel)
    {
        if (!string.IsNullOrEmpty(value) && baseModel.Required && ValidationErrors.TryGetValue(baseModel.FieldName, out var error))
            ValidationErrors.Remove(baseModel.FieldName);
    }

    public string SetErrorMultiselecDropdown(string fieldName, List<object> valueList)
    {
        if (valueList == null || !valueList.Any())
        {
            ValidationErrors[fieldName] = MANDATORYFIELD;
            return "";
        }

        dynamic firstItem = valueList[0];
        Guid firstId = firstItem.Id;

        for(int i =1;  i < valueList.Count(); i++)
        {
             dynamic currentItem = valueList[i];
              if (currentItem.Id != firstId)
                {
                    ValidationErrors[fieldName] = MANDATORYFIELD;
                    return ""; 
                }
        }
       return "";
    }
