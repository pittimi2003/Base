    private bool HasDisplayAttributes(PropertyInfo prop)
    {
        return prop.GetCustomAttribute<DisplayAttributes>() != null;
    }

    private IEnumerable<BaseModel> ProcessProperty(PropertyInfo prop)
    {
        var attribute = prop.GetCustomAttribute<DisplayAttributes>();
        var multiEditAttribute = prop.GetCustomAttribute<MultiEditAttributes>();

        var baseModel = CreateBaseModel(prop, attribute, multiEditAttribute);


        if (baseModel.InitialValue.FirstOrDefault() != null && IsComplexType(baseModel.InitialValue.FirstOrDefault()?.GetType()))
        {
            return new[] { baseModel }.Concat(ProcessComplexType(baseModel));
        }

        return new[] { baseModel };
    }

    private BaseModel CreateBaseModel(PropertyInfo prop, DisplayAttributes attribute, MultiEditAttributes? multiEditAttribute)
    {
        var initialValues = Models.Select(model => prop.GetValue(model) ?? "").ToList();
        var validationEditAttribute = prop.GetCustomAttribute<ValidationAttributes>();
        var cascadeAttribute = prop.GetCustomAttribute<DropDownCascadeAttribute>();

        return new BaseModel(attribute)
            {
                FieldName = prop.Name,
                InitialValue = initialValues,
                IsMultiEditable = multiEditAttribute?.IsMultiEditable ?? false,
                ValidationType = validationEditAttribute?.Validation ?? ValidationType.None,
                Options = (attribute.FieldType == ComponentType.DropDown 
                    || attribute.FieldType == ComponentType.DropDownLocalized)
                    ? GetValueCatalog(prop.PropertyType.Name, prop.Name, attribute.FieldType == ComponentType.DropDownLocalized)
                    : null,
                EnumItems = attribute.FieldType == ComponentType.DropDownEnum ? GetEnumValues(prop) : null,
                IsDropDownCascade = cascadeAttribute != null,
                DataSourceTypeCascade = cascadeAttribute?.DataSourceType ?? DataSourceDropdownType.Unknown,
                PropertyNameCascade = cascadeAttribute?.PropertyNameCascade ?? null,
                IsUnique = prop.GetCustomAttribute<UniqueAttributes>()?.IsUnique ?? false,
            };
    }

    private IEnumerable<BaseModel> ProcessComplexType(BaseModel baseModel)
    {
        var type = baseModel.InitialValue.FirstOrDefault()?.GetType();

        return type.GetProperties()
            .Where(HasDisplayAttributes)
            .Select(newAddProp =>
            {
                var attribute = newAddProp.GetCustomAttribute<DisplayAttributes>();
                var multiEditAttribute = newAddProp.GetCustomAttribute<MultiEditAttributes>();
                var validationEditAttribute = newAddProp.GetCustomAttribute<ValidationAttributes>(); // Obtener ValidationAttributes
                return CreateBaseModelForComplexType(baseModel, newAddProp, attribute, multiEditAttribute, validationEditAttribute);
            });
    }

    private BaseModel CreateBaseModelForComplexType(BaseModel baseModel, PropertyInfo newAddProp, DisplayAttributes attribute, MultiEditAttributes? multiEditAttribute, ValidationAttributes? validationEditAttribute)
    {
        var initialValues = Models.Select(model =>
        {
            var parentProperty = model.GetType().GetProperty(baseModel.FieldName)?.GetValue(model);
            return newAddProp.GetValue(parentProperty) ?? "";
        }).ToList();

        return new BaseModel(attribute)
            {
                FieldName = $"{baseModel.FieldName}.{newAddProp.Name}",
                InitialValue = initialValues,
                Options = (attribute.FieldType == ComponentType.DropDown || attribute.FieldType == ComponentType.DropDownLocalized) 
                    ? GetValueCatalog(newAddProp.PropertyType.Name, newAddProp.Name, attribute.FieldType == ComponentType.DropDownLocalized) 
                    : null,
                IsMultiEditable = multiEditAttribute?.IsMultiEditable ?? false,
                Group = baseModel.Group,
                ValidationType = validationEditAttribute?.Validation ?? ValidationType.None // Asignar ValidationType o valor predeterminado
            };
    }

    private static bool IsComplexType(Type type)
    {
        return !type.IsPrimitive && type != typeof(string) && type.IsClass;
    }

