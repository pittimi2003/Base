    public string GetAccordionItemClass(string key, int groupCount)
    {
        var classes = new List<string>();
        Columns = ColumnsSize;

        if (!string.IsNullOrEmpty(key))
            classes.Add("accordion-item");
        else
            return "";

        if (groupCount != 1 && groupCount < Columns){
            classes.Add("accordion-item-middle");
            Columns = groupCount;
        }
        else
            Columns = ColumnsSize;

        if (groupCount == 1 && key == "Alert")
            Columns = 1;

        return string.Join(" ", classes);
    }


