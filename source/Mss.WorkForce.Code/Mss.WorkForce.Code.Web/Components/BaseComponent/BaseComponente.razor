    private void SetDecimalValueProperty(string propertyName, object model, decimal newValue)
    {
        var propertyInfo = model.GetType().GetProperty(propertyName);
        if (propertyInfo != null)
        {
            Type propertyType = propertyInfo.PropertyType;
            if (propertyType == typeof(int))
                propertyInfo.SetValue(model, (int)newValue);
            else if (propertyType == typeof(decimal))
                propertyInfo.SetValue(model, newValue);
            else if (propertyType == typeof(float))
                propertyInfo.SetValue(model, (float)newValue);
            else if (propertyType == typeof(double))
                propertyInfo.SetValue(model, (double)newValue);
        }
    }

    public void SetPropertyValue(object model, string fieldName, object? value)
    {
        var propertyNames = fieldName.Split('.');
        SetPropertyValueNextLevel(propertyNames, value, model);
    }

    private void SetPropertyValueNextLevel(string[] propertyNames, object? value, object currentModel)
    {
        if (propertyNames.Length == 0 || currentModel == null)
            return;

        var propertyName = propertyNames[0];
        var propertyInfo = currentModel.GetType().GetProperty(propertyName);
        var propertyConfig = GetDisplayAttributes(propertyInfo);
        if (propertyInfo != null)
        {
            if (propertyNames.Length == 1)
            {
                SaveProperties(propertyName, currentModel);

                if (propertyConfig.Any() && (propertyConfig.First().Value.FieldType == ComponentType.DropDown || propertyConfig.First().Value.FieldType == ComponentType.DropDownLocalized))
                    SetCatalogValue(currentModel, propertyInfo.Name, value.ToString(), propertyInfo.PropertyType.Name);
                else if (propertyConfig.First().Value.FieldType == ComponentType.WarehouseGrid)
                {
                    if (value is List<Warehouse> warehouseList)
                    {
                        propertyInfo.SetValue(currentModel, warehouseList);
                    }
                }
                else if (propertyConfig.First().Value.FieldType == ComponentType.AlertFilter)
                {
                    if (value is List<AlertFilterDto> alertFilterDto)
                    {
                        propertyInfo.SetValue(currentModel, alertFilterDto);
                    }
                }
                else if (propertyConfig.First().Value.FieldType == ComponentType.AlertConfiguration)
                {
                    if (value is List<AlertConfigurationDto> alertConfigurationDto)
                    {
                        propertyInfo.SetValue(currentModel, alertConfigurationDto);
                    }
                }
                else if (propertyConfig.First().Value.FieldType == ComponentType.NumericSpin)
                    SetDecimalValueProperty(propertyName, currentModel, Convert.ToDecimal(value));
                else
                {
                    propertyInfo.SetValue(currentModel, value);
                }
            }
            else
            {
                var nestedModel = propertyInfo.GetValue(currentModel);
                if (nestedModel != null)
                    SetPropertyValueNextLevel(propertyNames.Skip(1).ToArray(), value, nestedModel);
            }
        }
    }

    public void SetCatalogValue(object target, string propertyName, string value, string propertyNameForDropDown = "")
    {
        if (GetValueCatalog(propertyNameForDropDown, propertyNameForDropDown).Any())
        {
            var Catalogs = GetValueCatalog(propertyNameForDropDown, propertyNameForDropDown).ToList();
            if (value != null)
            {
                SelectItemComboBox matchedItem = Catalogs.FirstOrDefault(x => x.Key.ToString() == value);
                ChangeValueToCatalogue(target, propertyName, propertyNameForDropDown, matchedItem);
            }
        }
    }

    private void SaveProperties(string propertyName, object currentModel)
    {
        var propertyInfo = currentModel.GetType().GetProperty(propertyName);
        if (!OriginalValues.ContainsKey(propertyName))
        {
            var originalValue = propertyInfo.GetValue(currentModel);
            OriginalValues[propertyName] = (CurrentModel: currentModel, NewValue: originalValue);
        }
    }

    private string LoadImag(object base64Data)
