    public bool Validate()
    {
        string pass = ValidationErrors.TryGetValue("Password", out var error) ? error : string.Empty;

        ValidationErrors.Clear();

        foreach (var property in GroupedProperties)
        {
            if (property.IsUnique)
            {
                var currentModel = Models.FirstOrDefault();
                var currentId = GetPropertyValue<Guid>(currentModel, "Id");

                if (IsDuplicate(property, currentModel, currentId))
                {
                    var caption = L.Loc(property.Caption);
                    ValidationErrors[property.FieldName] = L.Loc("* The {0} must be unique.", caption);
                    continue;
                }
            }

            if (property.Required && (property == null || string.IsNullOrEmpty(property.InitialValue[0]?.ToString().Trim())))
            {
                if (property.FieldName.EndsWith(nameof(AlertFilterDto.FilterReference)))
                {
                    var isFixedProp = GroupedProperties.FirstOrDefault(p => p.FieldName.EndsWith(nameof(AlertFilterDto.IsFixed)));
                    bool isFixed = isFixedProp?.InitialValue?.FirstOrDefault()?.ToString()?.ToLower() == "true";

                    if (isFixed)
                        continue; 
                }
                if (property.FieldName.EndsWith(nameof(AlertFilterDto.FilterFixedValue)))
                {
                    var isFixedProp = GroupedProperties.FirstOrDefault(p => p.FieldName.EndsWith(nameof(AlertFilterDto.IsFixed)));
                    bool isFixed = isFixedProp?.InitialValue?.FirstOrDefault()?.ToString()?.ToLower() == "false";

                    if (isFixed)
                        continue; 
                }

                ValidationErrors[property.FieldName] = MANDATORYFIELD;
                continue;
            }

            if (property.Required && property.FieldType == ComponentType.WarehouseGrid)
            {
                Guid? wareDefaultId = Guid.Empty;
                var warehouses = property.InitialValue[0] as IEnumerable<Warehouse>;

                if (Models[0] is UserDto user)
                {
                    wareDefaultId = user.WarehouseDefaultId;
                }

                if (!warehouses.Any())
                {
                    ValidationErrors[property.FieldName] = MANDATORYFIELD;
                    continue;
                }

                if (wareDefaultId == null || wareDefaultId == Guid.Empty)
                {
                    ValidationErrors[property.FieldName] = DEFAULTWAREHOUSE;
                    continue;
                }
            }

            if (property.IsMultiEditable 
                && property.InitialValue.Count > 1
                && (property.FieldType == ComponentType.DropDown || property.FieldType == ComponentType.DropDownLocalized))
            {
                SelectedFieldValues.TryGetValue(property.FieldName, out var selected);
                if (selected == null || selected.ToString() == Guid.Empty.ToString())
                {
                    ValidationErrors[property.FieldName] = MANDATORYFIELD;
                    continue;
                }
            }

            if (property.Required && property.FieldType == ComponentType.AlertConfiguration)
            {
                var alertconfig = property.InitialValue[0] as IEnumerable<AlertConfigurationDto>;

                if (!alertconfig.Any())
                {
                    ValidationErrors[property.FieldName] = MANDATORYFIELD;
                    continue;
                }
            }

            if (property.Required && !string.IsNullOrEmpty(property.InitialValue[0]?.ToString()) &&
                property.InitialValue[0].ToString().StartsWith(" "))
            {
                ValidationErrors[property.FieldName] = STARTWITHSPACE;
                continue;
            }

            if (property.FieldType == ComponentType.NumericSpin && property.InitialValue[0] is double numericValue)
            {
                property.Caption = L.Loc(property.Caption);

                if (numericValue < 0)
                {
                    ValidationErrors[property.FieldName] = L.Loc("{0} must be greater than 0.", property.Caption);
                    continue;
                }

                if (property.MinValue.HasValue && numericValue < property.MinValue.Value)
                {
                    ValidationErrors[property.FieldName] = L.Loc("The {0} can't be less than {1}.", property.Caption.ToLower(), property.MinValue.Value);
                    continue;
                }

                if (property.MaxValue.HasValue && numericValue > property.MaxValue.Value)
                {
                    ValidationErrors[property.FieldName] = L.Loc("The {0} can't be greater than {1}", property.Caption.ToLower(), property.MaxValue.Value);
                    continue;
                }
            }

            if (!string.IsNullOrEmpty(property.InitialValue[0]?.ToString()) && property.ValidationType == ValidationType.EmailMask)
            {
                string email = property.InitialValue[0].ToString();
                if (!IsValidEmail(email))
                {
                    ValidationErrors[property.FieldName] = INVALIDEMAIL;
                    continue;
                }
            }
        }

        if (pass != string.Empty)
        {
            ValidationErrors["Password"] = pass;
        }

        CustomValidation();

        EventServices.Publish(Container, new EventArguments(nameof(BaseComponent), EventActions.SaveValid, ValidationErrors.Any()));
        var formattedErrors = string.Join(", ", ValidationErrors.Select(kv => $"Key:{kv.Key} - Value:{kv.Value}"));
       #if DEBUG
           JS.InvokeVoidAsync("console.log", formattedErrors);
       #endif
       
        StateHasChanged();
        return !ValidationErrors.Any();
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch (Exception)
        {
            return false;
        }
    }

