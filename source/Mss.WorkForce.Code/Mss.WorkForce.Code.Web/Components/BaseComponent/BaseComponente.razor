@typeparam TModel
@using Mss.WorkForce.Code.Models
@using Mss.WorkForce.Code.Models.Attributtes
@using Mss.WorkForce.Code.Models.DTO
@using Mss.WorkForce.Code.Models.DTO.Designer
@using Mss.WorkForce.Code.Models.DTO.Enums
@using Mss.WorkForce.Code.Models.Common;
@using Mss.WorkForce.Code.Models.DTO.ExtraConfiguration
@using Mss.WorkForce.Code.Models.Enums
@using Mss.WorkForce.Code.Web.Code
@using Mss.WorkForce.Code.Web.Components.Shared
@using Mss.WorkForce.Code.Web.Model
@using System.ComponentModel
@using System.Reflection
@using Mss.WorkForce.Code.Web.Model.Enums
@using Mss.WorkForce.Code.Models.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using DevExpress.Blazor
@using Mss.WorkForce.Code.Web.Services
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using TimeZone = Mss.WorkForce.Code.Models.Models.TimeZone;
@inject IJSRuntime JS
@inject IEventServices EventServices
@inject IInitialDataService _InitialDataService
@inject SendParamService _SendParamService
@inject NavigationManager NavigationManager
@inject ILocalizationService L

<EditForm Model="Models.FirstOrDefault()">
    <DataAnnotationsValidator />
    @foreach (var group in GroupedProperties.Where(x => x.IsVisible).GroupBy(p => p.Group))
    {
        var IdTab = group.Key.Replace(" ","");
        <div class="@(string.IsNullOrEmpty(group.Key) ? "" : "accordion")">
            <div class="@GetAccordionItemClass(group.Key, group.Count())">
                @if (!string.IsNullOrEmpty(group.Key))
                {
                    <h2 class="accordion-header" id="idHead-@IdTab">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#idBody-@IdTab" aria-expanded="true" aria-controls="idBody-@IdTab">
                            <span class="mlx-title-h3">@L.Loc(group.Key)</span>
                        </button>
                    </h2>
                }
                <div id="idBody-@IdTab" class="accordion-collapse collapse show" aria-labelledby="idHead-@IdTab">
                    <div class="accordion-body" >

                        <div class="row">

                            @foreach (var property in group)
                            {
                                var alignmentClass = property.TextAlignment ? "text-Right-important" : "";
                                @switch (property.FieldType)
                                {
                                    case ComponentType.TextBox:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                            {

                                                string value = property.InitialValue.FirstOrDefault()?.ToString() ?? string.Empty;
                                                string mask = GetMaskForProperty(property);

                                                <DxMaskedInput Value="@value"
                                                ValueChanged="EventCallback.Factory.Create<string>(this, newValue => HandleMaskedInputChange(property, newValue))" 
                                                ValueExpression="(() => value)"
                                                CssClass="form-control input-control"
                                                Mask="@mask"
                                                MaskMode="MaskMode.RegEx"
                                                BindValueMode="BindValueMode.OnInput"
                                                autocomplete="off"></DxMaskedInput>
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>

                                            }
                                            else
                                            {
                                                <div class="container-label @alignmentClass">
                                                    <span class="title-details">@(property.InitialValue.Count() > 1 ? multiplePhrase : property.InitialValue.FirstOrDefault())</span>
                                                </div>
                                            }  
                                        </div>
                                        break;

                                    case ComponentType.Image:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            <div class="container-for-image">

                                                @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                                {
                                                    <InputFile @ref="FileInputRef"
                                                    OnChange="(e) => LoadFiles(e, property)"
                                                    multiple
                                                    ShowFileList="false"
                                                    accept="image/x-png,image/jpeg"
                                                    Width="100%"
                                                    ReadOnly="true"
                                                    style="display: none;" />

                                                    <div class="form-control img-control input-control img-control-heigth">
                                                        @if (!string.IsNullOrEmpty(imgSrc))
                                                        {
                                                            <img src="@imgSrc" class="img-thumbnail form-control img-control input-control" />
                                                        }
                                                    </div>
                                                    <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                                    <div style="padding-left:10px;">
                                                        <div class="ico-upload container-icon" @onclick="TriggerFileInput">
                                                            <span class="mlx-ico-upload-light"></span>
                                                        </div>
                                                        <div class="ico-trash container-icon" @onclick="(e) => ClearFile(property)">
                                                            <span class="mlx-ico-trash"></span>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @if (property.InitialValue.Count() > 1)
                                                    {
                                                        <div class="form-control img-control input-control">
                                                            <span class="text-muted">@multiplePhrase</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="form-control img-control input-control">
                                                            @if (!string.IsNullOrEmpty(property.InitialValue.FirstOrDefault()?.ToString()))
                                                            {
                                                                <img src="@LoadImag(property.InitialValue.FirstOrDefault())" class="img-thumbnail form-control img-control input-control" />
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                        break;

                                    case ComponentType.NumericSpin:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                            {
                                                decimal value = !string.IsNullOrWhiteSpace(property.InitialValue.FirstOrDefault().ToString()) ? Convert.ToDecimal(property.InitialValue.FirstOrDefault()) : 0;
                                                <DxSpinEdit Value="@value"
                                                Increment="1"
                                                MinValue="0"
                                                ValueExpression="@(() => value)"
                                                ValueChanged="@((Decimal newValue) => UpdateProperty(property, newValue))" Mask="n2"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                            }
                                            else
                                            {
                                                <div class="container-label @alignmentClass">
                                                    <span class="title-details">@(property.InitialValue.Count() > 1 ? multiplePhrase : FormatNumber(property.InitialValue.FirstOrDefault()))</span>
                                                </div>                                                            
                                            }
                                        </div>
                                        break;

                                    case ComponentType.DropDown:
                                    case ComponentType.DropDownLocalized:
                                        var options = property.Options as IEnumerable<SelectItemComboBox> ?? null;
                                        if (options != null)
                                        {

                                            var values = options.Select(o => o.Value).ToList();
                                            var initialValue = property.InitialValue;
                                            Guid selectedId = Guid.Empty;
                                            string selectedValue = string.Empty;
                                            if ((editMode) && property.InitialValue.Count() == 1)
                                            {
                                                if (!string.IsNullOrWhiteSpace(initialValue.FirstOrDefault().ToString()))
                                                {
                                                    selectedId = property.InitialValue.FirstOrDefault()?.GetType().GetProperty("Id")?.GetValue(property.InitialValue[0]) as Guid? ?? Guid.Parse(initialValue[0].ToString());
                                                    selectedValue = property.InitialValue.FirstOrDefault()?.GetType().GetProperty("Name")?.GetValue(property.InitialValue[0]).ToString();
                                                }
                                            }
                                            if (IsProjectDesigner())
                                            {
                                                 options = GetValueCatalog(property.FieldName, property.FieldName);
                                                 property.Options = options;
                                            }
                                            if (values != null)
                                            {
                                                <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;  position: relative;">
                                                    <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                                    @if ((editMode || newMode)  && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                                    {
                                                        <MlxComboBox Data="@options"
                                                        SearchMode="@ListSearchMode.AutoSearch"
                                                        AllowUserInput="true"
                                                        TextFieldName="@nameof(SelectItemComboBox.Value)"
                                                        ValueFieldName="@nameof(SelectItemComboBox.Key)"
                                                        Value="@selectedId"
                                                        ValueChanged="EventCallback.Factory.Create<Guid>(this, newValue => UpdateComboBoxValue(property, newValue))"
                                                        ValueExpression="(() => selectedId)"
                                                        CssClass="mlx-form-select"
                                                        NullText="@SELECTED"
                                                        TextChanged="EventCallback.Factory.Create<string>(this, inputValue => OnTextChanged(inputValue, property))"
                                                        ShowClearButton="true">
                                                        </MlxComboBox>
                                                        @if(property.IsMultiEditable)
                                                        {
                                                            @SetErrorMultiselecDropdown(property.FieldName, property.InitialValue)
                                                        }

                                                        <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                                        
                                                    }
                                                    else
                                                    {
                                                        <div class="container-label">
                                                            <span class="title-details">@GetDropDownDisplayText(property)</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        break;

                                    case ComponentType.DropDownEnum:
                                        var valueEnum = property.InitialValue[0];
                                        @if (property.IsDropDownCascade)
                                        {
                                            ReloadComboBoxCascade(property.PropertyNameCascade, property.FieldName, property);
                                        }

                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;  position: relative;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                            {
                                                <MlxComboBox  Data="@property.EnumItems"
                                                SearchMode="@ListSearchMode.None"
                                                AllowUserInput="false"
                                                TextFieldName="Text"
                                                ValueFieldName="Value"
                                                Value="@valueEnum"
                                                ValueChanged="EventCallback.Factory.Create<object>(this, newValue => UpdateComboBoxEnumValue(property, newValue))"
                                                ValueExpression="(() => valueEnum)"
                                                CssClass="mlx-form-select"
                                                NullText="SELECTED">
                                                </MlxComboBox>
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                            }
                                            else
                                            {
                                                <div class="container-label">
                                                    <span class="title-details">@(property.InitialValue.Count() > 1 ? multiplePhrase : GetEnumDescription(property.InitialValue.FirstOrDefault()))</span>
                                                </div>
                                            }
                                        </div>
                                        break;

                                    case ComponentType.Link:
                                        if (property.InitialValue.FirstOrDefault() is List<WarehouseDto> listWarehouses)
                                        {
                                            @foreach (var itemWh in listWarehouses.OrderBy(x => x.Name))
                                            {
                                                <td class="url-container">
                                                    <a @onclick="(e) => Goto(itemWh.Id)" class="url-list">@itemWh.Name</a>
                                                </td>
                                            }
                                        }
                                        break;

                                    case ComponentType.CommetText:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                            {
                                                string value = property.InitialValue.FirstOrDefault() as string;
                                                <DxMemo @bind-Text="value"
                                                CssClass="form-control input-control"
                                                ResizeMode="MemoResizeMode.Disabled"
                                                Rows="4"
                                                @onchange="(e) => UpdateProperty(property, e.Value.ToString())">
                                                </DxMemo>
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                            }
                                            else
                                            {
                                                @if (property.InitialValue.Count() > 1)
                                                {
                                                    <div class="container-label">
                                                        <span class="title-details text-muted">@multiplePhrase</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="container-label">
                                                        <span class="title-details" style="white-space: pre-wrap;">@property.InitialValue.FirstOrDefault()</span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        break;

                                    case ComponentType.PassWord:
                                        @* <div class="col-md-6"></div> *@
                                        <div class="col-md-@(12 / (newMode ? 2 : 1))" style="padding-bottom:10px;">
                                            @if (editMode)
                                            {
                                                @if (property.InitialValue.Count() == 1)
                                                {
                                                    string value = property.InitialValue.FirstOrDefault() as string;
                                                    <div class="accordion">
                                                        <div class="accordion-item">
                                                            <h2 class="accordion-header" id="idHead-password">
                                                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#idBody-password" aria-expanded="true" aria-controls="idBody-password">
                                                                    <span class="mlx-title-h3">@L.Loc("Password")</span>
                                                                </button>
                                                            </h2>
                                                            <div id="idBody-password" class="accordion-collapse collapse show" aria-labelledby="idHead-password">
                                                                <div class="accordion-body">
                                                                    <div class="row">
                                                                        <MlxInputPassword Password="@value"
                                                                        PasswordChanged="(newValue) => UpdateProperty(property, newValue)"
                                                                        ValidationChanged="(error) => HandleValidationError(property.FieldName, error)"
                                                                        InputId="user-password"
                                                                        RequestConfirm="true" />
                                                                        <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        break;

                                    case ComponentType.CheckBox:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                            @if (editMode && (property.IsMultiEditable || property.InitialValue.Count() == 1))
                                            {
                                                string value = property.InitialValue.FirstOrDefault()?.ToString() ?? string.Empty;
                                                string mask = GetMaskForProperty(property);
                                                <DxCheckBox CssClass="mlx-check-box"
                                                @bind-Checked="@value"
                                                @onchange="(e) => UpdateProperty(property, (bool)e.Value)">
                                                </DxCheckBox>
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                            }
                                            else
                                            {
                                                @if (property.InitialValue.Count() > 1)
                                                {
                                                    <div class="container-label">
                                                        <span class="title-details">@multiplePhrase</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    var initialValue = property.InitialValue;
                                                    <div class="container-label">
                                                        <span class="@((bool)initialValue[0] ? "mlx-ico-check" : "mlx-ico-close")"></span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        break;

                                    case ComponentType.WarehouseGrid:
                                        <div class="col-md-@(12 / (newMode ? 2 : 1))" style="padding-bottom:10px;">
                                            @if (property.InitialValue.Count() == 1)
                                            {
                                                var valuelist = Models.FirstOrDefault() as UserDto;
                                                Guid userid = Guid.Parse(valuelist.Id.ToString());
                                                var warehouses = property.InitialValue.FirstOrDefault() as ICollection<Warehouse>;

                                                if (warehouses == null)
                                                {
                                                    warehouses = new List<Warehouse>(); // Asegura que al menos haya una lista vacía
                                                }

                                                <div class="accordion" id="idPnlWarehouses">
                                                    <div class="accordion-item">
                                                        <h2 class="accordion-header" id="idHeadWarehouses">
                                                            <button class="accordion-button mlx-title-h4" type="button" data-bs-toggle="collapse" data-bs-target="#idBodyWarehouses" aria-expanded="true" aria-controls="idBodyWarehouses">
                                                                <span class="mlx-title-h3">@L.Loc("Warehouses")</span>
                                                            </button>
                                                        </h2>
                                                        <div id="idBodyWarehouses" class="accordion-collapse collapse show" aria-labelledby="idHeadWarehouses" data-bs-parent="#idPnlWarehouses">
                                                            <div class="accordion-body">
                                                                <MlxEditableGrid Warehouses="@warehouses"
                                                                editMode="@editMode"
                                                                WarehouseDefaultId="_currentWarehouseDefaultId"
                                                                AvailableWarehouses="@GetAvailableWarehouses(property)"
                                                                WarehousesChanged="(warehouses) => UpdateWarehouses(property, warehouses)"
                                                                DefaultWarehouseChanged="(defaultId) => UpdateDefaultWarehouse(property, defaultId)" />

                                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        break;

                                    case ComponentType.AlertFilter:
                                        @if (property.InitialValue.Count > 1)
                                        {
                                            <div class="container-label">
                                                <span class="title-details">@multiplePhrase</span>
                                            </div>
                                        }
                                        else
                                        {
                                            var alertFilters = property.InitialValue.FirstOrDefault() as ICollection<AlertFilterDto> ?? new List<AlertFilterDto>();
                                            <div class="col-md-12" style="padding-bottom:10px;">
                                                <MlxAlertFilter AlertFilters="@alertFilters"
                                                Columns="Columns"
                                                IsEditing="@editMode"
                                                EntityName="@GetValueReference(property.PropertyNameCascade)"
                                                AlertFilterChanged="(filters) => UpdateAlertFilters(property, alertFilters)"
                                                userFormat="userFormat"/>
                                            </div>
                                        }
                                        break;

                                    case ComponentType.AlertCondition:
                                        <div class="col-md-12" style="padding-bottom:10px;">
                                            @if (property.InitialValue.Count() >= 1)
                                            {
                                                var AlertCondition = property.InitialValue.FirstOrDefault() as AlertFilterDto;
                                                bool isMultiEdition = property.InitialValue.Count() > 1;
                                                <MlxAlert ModelFilter="@AlertCondition"
                                                EntityName="@GetValueReference(property.PropertyNameCascade)"
                                                IsMultiEdition="@isMultiEdition"
                                                Columns="Columns"
                                                IsEditing="@editMode"
                                                AlertFilterChanged="(AlertFilterDto) => UpdateAlertCondition(property, AlertCondition)" 
                                                userFormat="userFormat"/>
                                            }
                                        </div>
                                        break;

                                    case ComponentType.AlertConfiguration:
                                        @if (property.InitialValue.Count > 1)
                                        {
                                            <div class="container-label">
                                                <span class="title-details">@multiplePhrase</span>
                                            </div>
                                        }
                                        else
                                        {
                                            var alertConfigurations = property.InitialValue.FirstOrDefault() as ICollection<AlertConfigurationDto> ?? new List<AlertConfigurationDto>();
                                            <div class="col-md-12" style="padding-bottom:10px;">
                                                <MlxAlertConfiguration AlertConfigurations="@alertConfigurations"
                                                Columns="Columns"
                                                IsEditing="@editMode"
                                                EntityName="@GetValueReference(property.PropertyNameCascade)"
                                                AlertConfigurationChanged="(configurations) => UpdateAlertConfigurations(property, alertConfigurations)" />
                                                <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                            </div>
                                        }
                                        break;

                                    case ComponentType.ItemIcon:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <div>
                                                <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                                <div>
                                                    @if (property.InitialValue.Count > 1 && !editMode)
                                                    {

                                                        <div class="container-label">
                                                            <span class="title-details text-muted">@multiplePhrase</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        if (editMode)
                                                        {
                                                            if (Enum.TryParse<MessageStatus>(property.InitialValue.FirstOrDefault()?.ToString(), out var status))
                                                            {
                                                                <div class="col-md-6 d-flex gap-2">
                                                                    @foreach (var tipo in Enum.GetValues(typeof(MessageStatus)).Cast<MessageStatus>())
                                                                    {
                                                                        <span class="@GetIconMessageStatus(tipo.ToString())"></span>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                Enum.TryParse<AlertSeverity>(property.InitialValue.FirstOrDefault()?.ToString(), out var resultado);
                                                                activatedAlert = resultado;
                                                                <div class="col-md-6 d-flex gap-2">
                                                                    @foreach (var tipo in Enum.GetValues(typeof(AlertSeverity)).Cast<AlertSeverity>())
                                                                    {
                                                                        <button @onclick="() => ActivarSeverity(tipo, property)" class="@(activatedAlert == tipo ? "button-hide" : "") button-severity w-100">
                                                                            <span class="@GetIconTextDisabled((tipo.ToString()))"></span>
                                                                        </button>
                                                                        <button class="@(activatedAlert == tipo ? "" : "button-hide") button-severity  w-100">
                                                                            <span class="@GetIconText((tipo.ToString()))"></span>
                                                                        </button>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                        else{
                                                            
                                                            if (Enum.TryParse<MessageStatus>(property.InitialValue.FirstOrDefault()?.ToString(), out var status))
                                                            {
                                                                <span class="@GetIconMessageStatus((property.InitialValue.FirstOrDefault().ToString()))"></span>
                                                            }
                                                            else
                                                            {
                                                                <div class="container-label">
                                                                    <span class="@GetIconText((property.InitialValue.FirstOrDefault().ToString()))"></span>
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        break;

                                    case ComponentType.IdWareHouse:
                                        var warehouseDefaultId = property.InitialValue.FirstOrDefault() as Guid? ?? Guid.Empty;
                                        _currentWarehouseDefaultId = warehouseDefaultId;
                                        break;

                                    case ComponentType.Time:
                                        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                                            <div>
                                                <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>
                                                <div>    
                                                    @if (!editMode)
                                                    {                                           
                                                        <div class="container-label">
                                                            <span class="title-details">@(((TimeSpan)property.InitialValue.FirstOrDefault()).ToString(@"hh\:mm"))</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <MlxTimePicker Time="@GetPropertyValueTime(property.FieldName)"
                                                        TimeChanged="EventCallback.Factory.Create<TimeSpan>(this, newValue => UpdateProperty(property, newValue))" userFormat="userFormat"></MlxTimePicker>
                                                        <small class="text-danger">@GetValidationError(property.FieldName)</small>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        break;

                                    case ComponentType.ReadOnlyText:
                                        <div style="padding-bottom:10px;">
                                            <label class="mlx-form-label @(!editMode ? "mlx-form-label-uppercase" : "")">@L.Loc(property.Caption)</label>  
                                                <div class="container-label @alignmentClass">
                                                    <span class="title-details" style="white-space: pre-wrap;">
                                                         @(property.InitialValue != null && property.InitialValue.Any()
                                                             ? (property.InitialValue.Count() > 1 
                                                                 ? multiplePhrase 
                                                                 : property.InitialValue.First())
                                                             : string.Empty)
                                                    </span>
                                                </div>                                            
                                        </div>
                                    break;
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</EditForm>

<script>
    function triggerClick(element) {
    element.click();
    }
</script>

@code {
    [Parameter] public List<TModel> Models { get; set; } = new();
    [Parameter] public bool editMode { get; set; } = false;
    [Parameter] public bool newMode { get; set; } = false;
    [Parameter] public int ColumnsSize { get; set; } = 4;
    [Parameter] public string Container { get; set; }
    [Parameter] public UserFormatOptions UserFormat { get; set; } = new();

    [Inject]
    private IContextConfig _contextConfig { get; set; }
    private List<BaseModel> _groupedProperties;
    private Dictionary<string, object?> BoundFieldValues { get; set; } = new();
    private Dictionary<string, (object CurrentModel, object NewValue)> OriginalValues = new Dictionary<string, (object, object)>();
    private InputFile FileInputRef;
    private List<IBrowserFile> loadedFiles = new();
    public string imgSrc { get; set; } = string.Empty;
    private UserFormatOptions userFormat { get; set; } = new();

    private string ImagePreview;
    private string code = "Organization";
    private Dictionary<string, string> ValidationErrors { get; set; } = new();
