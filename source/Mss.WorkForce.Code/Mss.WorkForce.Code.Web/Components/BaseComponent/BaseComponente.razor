    private void HandleMaskedInputChange(BaseModel property, string newValue)
    {
        if (property.InitialValue.Any())
            property.InitialValue[0] = newValue;
        else
            property.InitialValue.Add(newValue);

        UpdateProperty(property, newValue);
    }

    private bool IsDuplicate(BaseModel property, object currentModel, Guid currentId)
    {
        var currentValue = property.InitialValue.FirstOrDefault()?.ToString() ?? string.Empty;

        switch (currentModel)
        {
            case UserDto:
                {
                    var users = _contextConfig.GetUsers();
                    return users.Any(u =>
                        GetPropertyValue<Guid>(u, "Id") != currentId &&
                        Normalize(GetPropertyValue<string>(u, property.FieldName)) == Normalize(currentValue)
                    );
                }

            case WarehouseDto:
                {
                    var warehouses = _contextConfig.GetWarehouses();
                    var field = property.FieldName;
                    return warehouses.Any(w =>
                        GetPropertyValue<Guid>(w, "Id") != currentId &&
                        Normalize(GetPropertyValue<string>(w, field)) == Normalize(currentValue)
                    );
                }

            default:
                return false;
        }
    }


    private string Normalize(string value)
    {
        return value?.Trim().ToLowerInvariant();
    }

    private T GetPropertyValue<T>(object obj, string propertyName)
    {
        if (obj == null || string.IsNullOrWhiteSpace(propertyName))
            return default;

        var propertyInfo = obj.GetType().GetProperty(propertyName);
        if (propertyInfo == null)
            return default;

        var value = propertyInfo.GetValue(obj);
        if (value == null)
            return default;

        return (T)value;
    }

