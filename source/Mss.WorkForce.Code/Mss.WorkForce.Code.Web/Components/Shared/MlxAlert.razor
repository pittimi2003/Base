@using DevExpress.Blazor
@using Mss.WorkForce.Code.Models.DTO
@using Mss.WorkForce.Code.Models.Models
@using Mss.WorkForce.Code.Web.Model
@using Mss.WorkForce.Code.Web.Services
@using Mss.WorkForce.Code.Models.Common
@inject ILocalizationService L

@if (IsEditing)
{
    <div class="mlx-row-header">
        <div class="row">
            <div class="col-md-@(12 / Columns)">
                <label for="idSelectWarehouse" class="mlx-form-label">@Field</label>
                @if (IsMultiEdition)
                {
                    <div class="container-label">
                        <span class="title-details">@multiplePhrase</span>
                    </div>
                }
                else
                {
                    <MlxComboBox Data="@Fields"
                                CssClass="mlx-form-select"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                Value="@ModelFilter.FilterField"
                                ValueChanged="@((string newValue) => OnFieldChanged(newValue))"
                                ValueExpression="() => ModelFilter.FilterField"
                                NullText="@SelectedField" />
                    <small class="text-danger">@GetValidationError(nameof(ModelFilter.FilterField))</small>
                }
            </div>

            <div class="col-md-@(12 / Columns)">
                <label for="idSelectWarehouse" class="mlx-form-label">@Operator</label>
                @if (IsMultiEdition)
                {
                    <div class="container-label">
                        <span class="title-details">@multiplePhrase</span>
                    </div>
                }
                else
                {
                    <DxComboBox Data="@Operators"
                                CssClass="mlx-form-select"
                                ValueFieldName="Value"
                                @bind-Value="@ModelFilter.Operator"
                                NullText="@SelectedOperator">

                        <ItemTemplate Context="item">
                            <span class="@GetOperatorIcon(item.Value)"></span>
                        </ItemTemplate>

                        <EditBoxTemplate Context="item">
                            <span class="@GetOperatorIcon(item.Value)"></span>
                        </EditBoxTemplate>
                    </DxComboBox>

                }
            </div>

            @if (ModelFilter.IsFixed)
            {
                <div class="col-md-@(12 / Columns)">
                    <label for="idFixedNumberValue" class="mlx-form-label">@ReferenceFixedValue</label>
                    @if (IsMultiEdition)
                    {
                        <div class="container-label">
                            <span class="title-details">@multiplePhrase</span>
                        </div>
                    }
                    else
                    {
                        @switch (FieldType)
                        {
                            case Models.Enums.FieldTypeEnum.None:
                            case Models.Enums.FieldTypeEnum.Text:
                                <DxTextBox CssClass="mlx-form-textbox"
                                           Text="@ModelFilter.FilterFixedValue"
                                           TextChanged="@(async (string newValue) => await SetProperty(newValue))"
                                           TextExpression="() => ModelFilter.FilterFixedValue" />
                                <small class="text-danger">@GetValidationError(nameof(ModelFilter.FilterFixedValue))</small>
                                break;
                            case Models.Enums.FieldTypeEnum.Number:
                                var valueDecimal = Decimal.Parse(ModelFilter.FilterFixedValue ?? "0");
                                <DxSpinEdit T="Decimal"
                                            Value="valueDecimal"
                                            Increment="1"
                                            MinValue="0"
                                            ValueExpression="@(() => valueDecimal)"
                                            ValueChanged="@((Decimal newValue) => SetProperty(newValue))" Mask="n2">
                                    <DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" />
                                </DxSpinEdit>
                                break;
                            case Models.Enums.FieldTypeEnum.Bool:
                                Boolean.TryParse(ModelFilter.FilterFixedValue, out bool valueBool);
                                <MlxComboBox CssClass="mlx-form-select"
                                            Data="@ListBoolOptions"
                                            TextFieldName="Value"
                                            ValueFieldName="Key"
                                            Value="valueBool"
                                            ValueExpression="@(() => valueBool)"
                                            ValueChanged="EventCallback.Factory.Create<bool>(this, newValue => SetProperty(newValue))" />

                                break;
                            case Models.Enums.FieldTypeEnum.Date:
                                var parsed = DateTime.TryParse(ModelFilter.FilterFixedValue, out var date);
                                var time = (parsed ? date : DateTime.Today).TimeOfDay;
                                <MlxTimePicker Time="@time"
                                               TimeChanged="EventCallback.Factory.Create<TimeSpan>(this, newValue => SetProperty(newValue))"
                                               ScrollContainerSelector=".accordion-container" userFormat="userFormat">
                                </MlxTimePicker>
                                break;
                        }
                    }
                </div>
            }
            else
            {
                <div class="col-md-@(12 / Columns)">
                    <label for="idSelectWarehouse" class="mlx-form-label">@Reference</label>
                    @if (IsMultiEdition)
                    {
                        <div class="container-label">
                            <span class="title-details">@multiplePhrase</span>
                        </div>
                    }
                    else
                    {
                        <div>
                            <MlxComboBox Data="@FieldReferences"
                                        CssClass="mlx-form-select"
                                        TextFieldName="Text"
                                        ValueFieldName="Value"
                                        Value="@ModelFilter.FilterReference"
                                        ValueChanged="@((string newValue) => OnReferenceChanged(newValue))"
                                        ValueExpression="() => ModelFilter.FilterReference"
                                        NullText="@SelectReference" />
                            <small class="text-danger">@GetValidationError(nameof(ModelFilter.FilterReference))</small>
                        </div>
                    }
                </div>
            }
            <div class="col-auto icon-add-align-center">
                @if (!IsMultiEdition)
                {
                    <DxCheckBox CssClass="mlx-check-box align-items-center"
                                Checked="@ModelFilter.IsFixed"
                                CheckedExpression="@(() => ModelFilter.IsFixed)"
                                CheckedChanged="@((bool newValue) => OnCheckFixedChanged(newValue))">@Fixed</DxCheckBox>
                }
            </div>
        </div>


    </div>
}
else
{
    <div class="row">
        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
            <label class="mlx-form-label mlx-form-label-uppercase">@Field</label>
            <div>
                @if (IsMultiEdition)
                {
                    <div class="container-label">
                        <span class="title-details">@multiplePhrase</span>
                    </div>
                }
                else
                {
                    <div class="container-label">
                        <span class="title-details">@FilterFieldLabel</span>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
            <label class="mlx-form-label mlx-form-label-uppercase">@Operator</label>
            <div>
                @if (IsMultiEdition)
                {
                    <div class="container-label">
                        <span class="title-details">@multiplePhrase</span>
                    </div>
                }
                else
                {
                    <div class="container-label">
                        <span class="title-details">@OperatorSymbol</span>
                    </div>
                }
            </div>
        </div>
        @if (!ModelFilter.IsFixed)
        {
            <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                <label class="mlx-form-label mlx-form-label-uppercase">@Reference</label>
                <div>
                    @if (IsMultiEdition)
                    {
                        <div class="container-label">
                            <span class="title-details">@multiplePhrase</span>
                        </div>
                    }
                    else
                    {
                        <div class="container-label">
                            <span class="title-details">@FilterReferenceLabel</span>
                        </div>
                    }
                </div>
            </div>
        }
        @if (ModelFilter.IsFixed)
        {
            <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
                <label class="mlx-form-label mlx-form-label-uppercase">@ReferenceFixedValue</label>
                <div>
                    @if (IsMultiEdition)
                    {
                        <div class="container-label">
                            <span class="title-details">@multiplePhrase</span>
                        </div>
                    }
                    else
                    {
                        <div class="container-label">
                            <span class="title-details">@FormatTimeValue(ModelFilter.FilterFixedValue)</span>
                        </div>
                    }
                </div>
            </div>
        }
        <div class="col-md-@(12 / Columns)" style="padding-bottom:10px;">
            <label class="mlx-form-label mlx-form-label-uppercase">@Fixed</label>
            <div>
                @if (IsMultiEdition)
                {
                    <div class="container-label">
                        <span class="title-details">@multiplePhrase</span>
                    </div>
                }
                else
                {
                    <div class="container-label">
                        <span class="@(ModelFilter.IsFixed ? "mlx-ico-check" : "mlx-ico-close")"></span>
                    </div>
                }
            </div>
        </div>
    </div>

}

<style>
    .mlx-ico-greater-than::before,
    .mlx-ico-less-than::before,
    .mlx-ico-equal::before,
    .mlx-ico-distinct::before,
    .mlx-ico-greater-than-or-equal-to::before,
    .mlx-ico-less-than-or-equal-to::before {
        font-size: 16px !important;
    }

    .dxbl-text-edit > .dxbl-text-edit-template:not(:first-child) {
        padding-top: 7px;
        padding-left: 25px;
    }
</style>

@code {


}
