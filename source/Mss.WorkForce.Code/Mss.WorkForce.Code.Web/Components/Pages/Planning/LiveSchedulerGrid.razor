@inherits Mss.WorkForce.Code.Web.Common.GanttOperations
@inject IToastNotificationService ToastService



<DxTabs CssClass="wl-tabs-root">



    <DxTabPage Text=@L.Loc("Order issues")>
        @{
            var filtered = VehicleMetrics?
            .Where(x => x.OTIF < 1 && x.MaxEnd >= ConvertFromUtc(DateTime.UtcNow, Offset))
            .ToList() ?? new List<VehicleMetricsDto>();
        }

        @if (filtered.Any())
        {
            @TabContent(filtered)
        }
    </DxTabPage>




@*     <DxTabPage Text="General status">
        @if (VehicleMetrics.Count() > 0)
        {
            @TabContent(VehicleMetrics)
        }
    </DxTabPage> *@

</DxTabs>






@code {
    RenderFragment<IEnumerable<VehicleMetricsDto>> TabContent => data =>
    @<div class="wl-tab-scroll" style="height: 83vh;">
        <div style="@(ShowPivotChar ? "display:block;" : "display:none;") height: 50%;">
        <DxChart Data="@data.OrderBy(x => x.MaxEnd)"
                 CssClass="wl-chart-full">

            <!-- ================= ARGUMENT AXIS (X) ================= -->
            <DxChartArgumentAxis ArgumentType="ChartAxisDataType.DateTime">
                <DxChartAxisRange StartValue="@GetChartStart(data)"
                                  EndValue="@GetChartEnd(data)" />

                <DxChartAxisLabel Format="ChartElementFormat.ShortTime" />

                <DxChartAxisTitle Text="@L.Loc("Hour")">
                </DxChartAxisTitle>
            </DxChartArgumentAxis>

            <!-- ================= VALUE AXIS IZQUIERDO ================= -->
            <DxChartValueAxis Name="TimeAxis"
                              Visible="true">
                <DxChartAxisTitle Text="@L.Loc("Time (minutes)")">
                </DxChartAxisTitle>
            </DxChartValueAxis>

            <!-- ================= VALUE AXIS DERECHO ================= -->
            <DxChartValueAxis Name="OTIFAxis"
                              Alignment="ChartAxisAlignment.Far">
                <DxChartAxisLabel Format="ChartElementFormat.Percent()" />

                <DxChartAxisTitle Text="@L.Loc("OTIF")">
                </DxChartAxisTitle>
            </DxChartValueAxis>

            <!-- ================= SERIES ================= -->
            <DxChartLineSeries T="VehicleMetricsDto"
                               TArgument="DateTime"
                               TValue="double"
                               Name=@L.Loc("OTIF")
                               Axis="OTIFAxis"
                               ArgumentField="m => m.MaxEnd"
                               ValueField="m => m.OTIF" />

            <DxChartLineSeries T="VehicleMetricsDto"
                               TArgument="DateTime"
                               TValue="double"
                               Name=@L.Loc("Delay")
                               Axis="TimeAxis"
                               ArgumentField="m => m.MaxEnd"
                               ValueField="m => m.DelayMinutes" />

            <DxChartLineSeries T="VehicleMetricsDto"
                               TArgument="DateTime"
                               TValue="double"
                               Name=@L.Loc("Slack")
                               Axis="TimeAxis"
                               ArgumentField="m => m.MaxEnd"
                               ValueField="m => m.SlackMinutes" >
                             
            </DxChartLineSeries>

            <DxChartLegend Position="RelativePosition.Outside" Visible="true" />

            <DxChartTooltip Enabled="true" Position="RelativePosition.Outside">
                <div class="m-2">
                    @FormatMinutes((double) context.Point.Value, true)
                </div>
            </DxChartTooltip>

        </DxChart>
        </div>
        <!-- ===================== GRID ===================== -->
        <div class="wl-grid-container" style="@(ShowPivotChar ? "height:48%;" : "height:99%;")">
            @GridContent(data)
        </div>

    </div>;

    RenderFragment<IEnumerable<VehicleMetricsDto>> GridContent => data =>
    @<DxGrid Data="data"
                 @ref="gridLoad"
                 KeyFieldName="VehicleCode"
                 CssClass="mlx-grid dxbl-grid-master no-top"
                 AllowSort="true"
                 ShowGroupPanel="true"
                 ShowFilterRow="true"
                 ShowGroupedColumns="true"
                 AllowGroup="true"
                 SelectionMode="GridSelectionMode.Multiple"
                 VirtualScrollingEnabled="true"
                 KeyboardNavigationEnabled="true"
                 CustomizeElement="OnCustomizeGridElement">

        <Columns>
            <DxGridDataColumn SortIndex="0"
                              SortOrder="GridColumnSortOrder.Descending"
                              FieldName="IsOut"
                              Caption="@L.Loc("FLOW")">

                <CellDisplayTemplate Context="cell">
                    @{
                bool value = cell.Value as bool? ?? false;
                var item = TypeBounds.First(x => x.Key == value);
                    }
                    @item.Html
                </CellDisplayTemplate>
                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <DxComboBox TData="FlowTypeDto"
                                    CssClass="mlx-form-spineditsettings"
                                    TValue="bool?"
                                    Data="@TypeBounds"
                                    ValueFieldName="Key"
                                    Value="@(context.FilterRowValue as bool?)"
                                    ValueChanged="@((bool? v) => context.FilterRowValue = v)"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                            <ItemDisplayTemplate Context="item">
                                @item.DataItem.Html
                            </ItemDisplayTemplate>
                        </DxComboBox>
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>
            </DxGridDataColumn>

            @*<DxGridDataColumn Caption="Status" Width="60px" Name="metrics" FieldName="Status">
                <CellDisplayTemplate Context="ctx">
                    @{
                var row = ctx.DataItem as VehicleMetricsDto;
                    }

                    @if (row != null)
                {
                if (row.Status)
                {
                    <div id="@($"metrics-{row.VehicleCode}")"
                         class="metrics-icon  mlx-ico-x-preview"
                         @onmouseenter="@(() => {})"
                         @onmouseleave="@(() =>  {})">
                    </div>
                }
                else
                {
                    <div id="@($"metrics-{row.VehicleCode}")"
                         class="metrics-icon mlx-ico-check-preview"
                         @onmouseenter="@(() => {})"
                         @onmouseleave="@(() =>  {})">
                    </div>
                }
                }
                </CellDisplayTemplate>
            </DxGridDataColumn>*@


            <DxGridDataColumn FieldName="VehicleCode"
                              Caption=@L.Loc("Vehicle")>
                 <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <DxTextBox Text="@((string)context.FilterRowValue)"
                                   TextChanged="v => context.FilterRowValue = v" />
                    </MlxFilterOperationType>
                 </FilterRowCellTemplate>
            </DxGridDataColumn>

            
        <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.VehicleTheoreticalDwellTime)"
                          Caption=@L.Loc("Theoretical dwell")
                          TextAlignment="GridTextAlignment.Right"
                          ShowInColumnChooser="true">
            <CellDisplayTemplate>
                <span>@context.DisplayText</span>
            </CellDisplayTemplate>
            <FilterRowCellTemplate Context="context">
                <MlxFilterOperationType FilterContext="context">
                    <DxTextBox Text="@((string)context.FilterRowValue)"
                               TextChanged="v => context.FilterRowValue = v" />
                </MlxFilterOperationType>
            </FilterRowCellTemplate>
        </DxGridDataColumn>

           

            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.MaxEnd)"
                              Caption=@L.Loc("Simulated departure")
                              DisplayFormat="@userFormat.HourFormatWithoutSeconds"
                              SortIndex="1"
                              SortOrder="GridColumnSortOrder.Ascending"
                              TextAlignment="GridTextAlignment.Right"
                              ShowInColumnChooser="true" >
                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <DxTimeEdit Time="@(context.FilterRowValue as DateTime?)"
                                    TimeChanged="@((DateTime? v) => context.FilterRowValue = v)"
                                    DisplayFormat="@userFormat.HourFormatWithoutSeconds"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>

            </DxGridDataColumn>

        <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.LoadTime)"
                          Caption=@L.Loc("Load time")
                          TextAlignment="GridTextAlignment.Right"
                          ShowInColumnChooser="true">
            <FilterRowCellTemplate Context="context">
                <MlxFilterOperationType FilterContext="context">
                    <TimeInput TNumber="int?"
                               IsFilter="true"
                               Format="hhmm"
                               Value="@(context.FilterRowValue as int?)"
                               ValueChanged="@((int? v) => context.FilterRowValue = v)" />
                </MlxFilterOperationType>
            </FilterRowCellTemplate>
            <CellDisplayTemplate>
                @{
                    var value = context.Value;
                }
                <TimeInput ReadOnly="true" Format="hhmm" Value="value" CssClass=" mlx-input-no-border" />
            </CellDisplayTemplate>
        </DxGridDataColumn>

            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.DelaySeconds)"
                              Caption=@L.Loc("Delay")
                              TextAlignment="GridTextAlignment.Right"
                              ShowInColumnChooser="true"
                              DisplayFormat="@userFormat.HourFormatWithoutSeconds">
                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <TimeInput TNumber="int?"
                                   IsFilter="true"
                                   Format="hhmm"
                                   Value="@(context.FilterRowValue as int?)"
                                   ValueChanged="@((int? v) => context.FilterRowValue = v)" ShowFormatHint="false"/>
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>
                <CellDisplayTemplate>
                    @{
                var value = context.Value;
                    }
                    <TimeInput ReadOnly="true" Format="hhmm" Value="value" CssClass=" mlx-input-no-border" ShowFormatHint="false" />
                </CellDisplayTemplate>

            </DxGridDataColumn>

            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.SlackSeconds)"
                              Caption=@L.Loc("Slack")
                              TextAlignment="GridTextAlignment.Right"
                              ShowInColumnChooser="true"
                              DisplayFormat="@userFormat.HourFormatWithoutSeconds">
                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <TimeInput TNumber="int?"
                                   IsFilter="true"
                                   Format="hhmm"
                                   Value="@(context.FilterRowValue as int?)"
                                   ValueChanged="@((int? v) => context.FilterRowValue = v)" ShowFormatHint="false"/>
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>
                <CellDisplayTemplate>
                    @{
                var value = context.Value;
                    }
                    <TimeInput ReadOnly="true" Format="hhmm" Value="value" CssClass=" mlx-input-no-border" ShowFormatHint="false"/>
                </CellDisplayTemplate>

            </DxGridDataColumn>

            <DxGridDataColumn FieldName="IncompleteOrders"
                              Caption=@L.Loc("Incomplete orders")>
                <CellDisplayTemplate Context="ctx">
                    @{
                int value = ctx.Value is int v ? v : 0;
                string css = value == 0 ? "circle-green" : "circle-red";
                    }
                    <div class="text-right">
                        <span class="@css">@value</span>
                    </div>
                </CellDisplayTemplate>
                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <DxSpinEdit TValue="double?"
                                    Value="@(context.FilterRowValue as double?)"
                                    ValueChanged="@( (double? v) => context.FilterRowValue = v )"
                                    ValueExpression="@(() => (double?)context.FilterRowValue)"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>
            </DxGridDataColumn>
             

            <DxGridDataColumn FieldName="OTIF"
                              Caption=@L.Loc("OTIF")
                              DisplayFormat="p1"
                              TextAlignment="GridTextAlignment.Right"
                              ShowInColumnChooser="true">

                <CellDisplayTemplate>
                    <div class="text-right">
                        @context.DisplayText
                    </div>
                </CellDisplayTemplate>

                <FilterRowCellTemplate Context="context">
                    <MlxFilterOperationType FilterContext="context">
                        <DxSpinEdit Value="@GetOtfFilterValue(context.FilterRowValue)"
                                    ValueChanged="@((double? v) => SetOtfFilterValue(context, v))"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </MlxFilterOperationType>
                </FilterRowCellTemplate>

            </DxGridDataColumn>

        </Columns>
        <DataColumnGroupRowTemplate Context="ctx">
            @{
        // Columna por la que se está agrupando en este nivel
        var col = ctx.DataColumn;
        var field_ = col?.FieldName;

            if (field_ == "IsOut")
        {
        // valor de grupo: true/false
        bool v = ctx.GroupValue is bool b && b;
        var item = TypeBounds.First(x => x.Key == v);

                <span class="dx-group-row-flow">
                    @item.Html
                </span>
        }
            else if (field_ == "Status")
        {
        bool status = ctx.GroupValue is bool b && b;

                <div class="group-status-container">
                    <span class="@((!status ? "metrics-icon mlx-ico-check-preview" : "metrics-icon mlx-ico-x-preview"))">
                    </span>
                </div>
        }

            else if (field_ == "IncompleteOrders")
        {
        int value = ctx.GroupValue is int v ? v : 0;
        string css = value == 0 ? "circle-green" : "circle-red";

                <span class="@css">@value</span>
        }


        else
        {
        // resto de columnas agrupadas → texto normal
                <span class="dx-group-row-default">
                    @ctx.GroupValueDisplayText
                </span>
        }
            }
        </DataColumnGroupRowTemplate>

        <DetailRowTemplate Context="load">
            @{
        var loadRow = load?.DataItem as VehicleMetricsDto;
            }
            <DxGrid Data="loadRow.OrderMetrics"
                    KeyFieldName="OrderCode"
                    ShowFilterRow="true"
                    CssClass="mlx-grid dxbl-grid-detail"
                    VirtualScrollingEnabled="true"
                    KeyboardNavigationEnabled="true">

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(OrderMetricsDto.OrderCode)"
                                      Caption=@L.Loc("Order code")
                                      ShowInColumnChooser="true">
                        <FilterRowCellTemplate Context="context">
                            <MlxFilterOperationType FilterContext="context">
                                <DxTextBox Text="@((string)context.FilterRowValue)"
                                           TextChanged="v => context.FilterRowValue = v" />
                            </MlxFilterOperationType>
                        </FilterRowCellTemplate>
                    </DxGridDataColumn>


                    <DxGridDataColumn FieldName="@nameof(OrderMetricsDto.DelaySeconds)"
                                      Caption=@L.Loc("Delay")
                                      TextAlignment="GridTextAlignment.Right"
                                      ShowInColumnChooser="true"
                                      DisplayFormat="@userFormat.HourFormat">
                        <FilterRowCellTemplate Context="context">
                            <MlxFilterOperationType FilterContext="context">
                                <TimeInput TNumber="int?"
                                           IsFilter="true"
                                           Format="hhmmss"
                                           Value="@(context.FilterRowValue as int?)"
                                           ValueChanged="@((int? v) => context.FilterRowValue = v)" ShowFormatHint="false"/>
                            </MlxFilterOperationType>
                        </FilterRowCellTemplate>
                        <CellDisplayTemplate>
                            @{
                        var value = context.Value;
                            }
                            <TimeInput ReadOnly="true" Format="hhmmss" Value="value" CssClass=" mlx-input-no-border" ShowFormatHint="false"/>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(OrderMetricsDto.SlackSeconds)"
                                      Caption=@L.Loc("Slack")
                                      TextAlignment="GridTextAlignment.Right"
                                      ShowInColumnChooser="true"
                                      DisplayFormat="@userFormat.HourFormat">
                        <FilterRowCellTemplate Context="context">
                            <MlxFilterOperationType FilterContext="context">
                                <TimeInput TNumber="int?"
                                           IsFilter="true"
                                           Format="hhmmss"
                                           Value="@(context.FilterRowValue as int?)"
                                           ValueChanged="@((int? v) => context.FilterRowValue = v)" ShowFormatHint="false"/>
                            </MlxFilterOperationType>
                        </FilterRowCellTemplate>
                        <CellDisplayTemplate>
                            @{
                        var value = context.Value;
                            }
                            <TimeInput ReadOnly="true" Format="hhmmss" Value="value" CssClass=" mlx-input-no-border" ShowFormatHint="false"/>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(OrderMetricsDto.OTIF)"
                                      Caption=@L.Loc("OTIF")
                                      DisplayFormat="p1"
                                      TextAlignment="GridTextAlignment.Right"
                                      ShowInColumnChooser="true">
                        <FilterRowCellTemplate Context="context">
                            <MlxFilterOperationType FilterContext="context">
                                <DxSpinEdit Value="@GetOtfFilterValue(context.FilterRowValue)"
                                            ValueChanged="@((double? v) => SetOtfFilterValue(context, v))"
                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                            </MlxFilterOperationType>
                        </FilterRowCellTemplate>
                        <CellDisplayTemplate>
                            <div class="text-right mlx-italic">
                                @context.DisplayText
                            </div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        </DetailRowTemplate>
        </DxGrid>
    ;



}

<style>

    .text-right {
        text-align: right;
    }

    .dxc-axes-group
    {
        display: block !important;
    }

    .dxbl-grid.mlx-grid.dxbl-grid-master {
        height: 100%;
        }

    .circle-green,
    .circle-red {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        font-size: 12px;
        font-weight: bold;
        color: white;
    }

    .circle-green {
        background-color: #06a77d; /* Verde */
    }

    .circle-red {
        background-color: #eb5160; /* Rojo */
    }


    .group-status-container {
        display: flex;
        align-items: center;
        justify-content: flex-start !important; /* A la izquierda */
    }

    .dxbl-grid-group-row > td {
        text-align: left !important; /* fuerza alineación izquierda de la fila */
    }


    .chart-title {
        color: #1B3580;
        font-style: italic;
        font-size: 20px;
    }

    .mlx-input-no-border {
        border: none !important;
    }

    #btnReloadPreview {
        width: 40px;
    }

    .mlx-ico-x-preview {
        cursor: pointer;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .mlx-ico-check-preview {
        cursor: pointer;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }


        .mlx-ico-check-preview:before {
            font-family: 'mlx_icons';
            font-size: larger;
            content: "\e982";
            color: #06a77d;
        }

    .mlx-ico-x-preview:before {
        font-family: 'mlx_icons';
        font-size: larger;
        content: "\e985";
        color: #eb5160;
    }

    .flyout-content-center {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center; /* centra horizontal */
        align-items: center; /* centra vertical */
    }



    .mlx-ico-chart::before {
        content: "📈";
    }



    .row-new td {
        background-color: #ffefd2 !important; /* naranja claro fuerte */
    }

    .modified-cell {
        background-color: #ffefd2 !important; /* naranja suave, ideal para cambios puntuales */
    }



    .dxbl-grid-group-panel-container > .dxbl-text {
        color: #c2c5c7 !important;
    }

    .mlx-grid .dxbl-grid-table > tbody > tr > .dxbl-grid-detail-cell {
        border-top: 3px solid #8ebde5 !important;
        padding: 16px 64px 32px 80px !important;
    }


    .dxbl-grid-group-panel-container {
        padding: 1px 0 !important; /* Alto relativo y compacto */
        background-color: #f5f6f7 !important;
        border-radius: 4px !important; /* Muy sutil */
        line-height: 0.8 !important;
        min-height: unset !important; /* Quita restricciones del theme */
    }


    .mlx-preview-section-simulation-data {
        flex-grow: 1;
        overflow-y: auto;
        transition: all 0.3s ease-in-out;
    }

    .mlx-preview-section-simulation-data-hidden {
        flex-basis: 0px;
        flex-grow: 0;
        overflow: hidden;
        max-height: 0;
        transition: all 0.3s ease-in-out;
    }

    .row-has-children-red {
        background-color: #ffebeb !important;
        border-left: 4px solid #d60000 !important;
    }

    .row-no-children-green {
        background-color: #eaffea !important;
        border-left: 4px solid #009400 !important;
    }

    /* ===== Layout general ===== */
    .wl-component-container {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .wl-header-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 12px 6px 22px;
        border-bottom: 1px solid #ddd;
        background: var(--gl-color-brand-400);
    }

    .wl-component-container > .wl-header-bar .toolbar-container > .toolbar-wrapper > .switch-bar {
        margin: 0px;
    }

    .wl-tabs-root {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .wl-tab-scroll {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 8px 8px 0;
        flex: 1;
        min-height: 0;
        overflow: auto;
    }

    .wl-status {
        font-size: 12px;
    }

    .wl-status-ok {
        color: #3c8c3c;
    }

    .wl-status-pending {
        color: #c27a00;
    }

    /* Sticky */
    .wl-sticky-top {
        position: sticky;
        top: 0;
        z-index: 3;
        background: #fafafa;
    }

    .wl-sticky-sub {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #fafafa;
        border-bottom: 1px solid #e5e7eb;
    }

    .wl-sticky-footer {
        position: sticky;
        bottom: 0;
        z-index: 4;
    }

    .wl-sticky-pager, .wl-pager-static {
        position: sticky;
        bottom: 0;
        z-index: 3;
        background: #fff;
        border-top: 1px solid #e5e7eb;
        padding: 6px 8px;
    }

    /* Densidad */
    .mlx-grid.dxbl-grid .dxbl-datacell,
    .mlx-grid.dxbl-grid .dxbl-headercell {
        padding: 6px 8px;
    }

    .styles-to-cells-step-grid .dxbl-grid-datacell {
        vertical-align: middle;
    }

    .mlx-panel-header {
        display: flex;
        align-items: center;
        padding: 6px 8px;
        border-bottom: 1px solid #e5e7eb;
        background: #fafafa;
    }

    .mlx-panel-bar-action {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .mlx-panel-bar-action > button {
            border: 0;
            background: transparent;
            padding: 4px 8px;
            cursor: pointer;
        }

            .mlx-panel-bar-action > button:disabled {
                opacity: .4;
                cursor: not-allowed;
            }

    .wl-pagesize {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-right: 8px;
    }

        .wl-pagesize > label {
            font-size: 12px;
            color: #555;
        }

    .wl-pagesize-select {
        min-width: 90px;
    }

    .mlx-right-sideBar-footer {
        display: flex;
        justify-content: center;
        gap: 8px;
        padding: 12px;
        border-top: 1px solid #ddd;
        background: #f9f9f9;
    }

    .mlx-pager-pager-layout {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 4px 6px;
    }

    .mlx-pager-left-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .mlx-pager-right-group {
        display: flex;
        align-items: center;
