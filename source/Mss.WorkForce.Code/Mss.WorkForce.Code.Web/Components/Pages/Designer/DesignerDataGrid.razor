    private IEnumerable<ITrackableRow> GetAllRows()
    {
        foreach (var p in Processes)
        {
            if (p is null) continue;
            yield return p;
            if (p.Directions != null)
                foreach (var d in p.Directions)
                    if (d is not null) yield return d;
        }

        foreach (var a in Areas)
        {
            if (a is null) continue;
            yield return a;

            if (a.Zones != null)
                foreach (var z in a.Zones)
                    if (z is not null) yield return z;

            if (a.Equipments != null)
                foreach (var e in a.Equipments)
                    if (e is not null) yield return e;

            if (a.Routes != null)
                foreach (var r in a.Routes)
                    if (r is not null) yield return r;
        }
    }

    private static (bool HasChanges, List<string> ChangedFields) DetectChanges(object? editModel, object? dataItem)
    {
        if (editModel == null || dataItem == null) return (false, new());

        var type = dataItem.GetType();
        if (editModel.GetType() != type) return (true, new());

        var changed = new List<string>();

        foreach (var prop in type.GetProperties(System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance))
        {
            if (!prop.CanRead || !prop.CanWrite) continue;
            if (prop.Name == "Id" || prop.Name == nameof(ITrackableRow.RowState) || prop.Name.EndsWith("Count", StringComparison.Ordinal)) continue;

            if (prop.PropertyType != typeof(string) &&
                typeof(System.Collections.IEnumerable).IsAssignableFrom(prop.PropertyType))
                continue;

            var oldValue = prop.GetValue(dataItem);
            var newValue = prop.GetValue(editModel);
            if (!Equals(oldValue, newValue)) changed.Add(prop.Name);
        }
        return (changed.Count > 0, changed);
    }

