        {
            if (e.Value is string type && !string.IsNullOrWhiteSpace(type))
                e.DisplayText = L.Loc(type);
        }
        else if (e.FieldName == nameof(AreaRow.Id)) // If you group by Id (Guid): display the Name of the area
        {
            if (e.Value is Guid guid)
            {
                var name = Areas?.FirstOrDefault(a => a.Id == guid)?.Name;
                if (!string.IsNullOrWhiteSpace(name))
                    e.DisplayText = name;
            }
        }
        RequestAreasPagerSync();
