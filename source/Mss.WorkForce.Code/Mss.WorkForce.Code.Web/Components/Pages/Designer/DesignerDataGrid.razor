                                    </div>

                                    <DxGrid TData="ZoneRow"
                                            CssClass="mlx-grid dxbl-grid-detail"
                                            Data="@GetZonesSorted(area)"                                            EditMode="GridEditMode.EditCell"
                                            ShowGroupPanel="false"
                                            ShowFilterRow="true"
                                            PageSize="@PageSizeDetailEffective"
                                            PageIndex="@(area?.PageIndex_Zones ?? 0)"
