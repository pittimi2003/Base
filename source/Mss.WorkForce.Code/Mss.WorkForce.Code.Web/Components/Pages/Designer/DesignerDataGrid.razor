                                                        <DxComboBox TData="LookupItem" TValue="Guid?"
                                                                    Data="@AreasLookupSorted"
                                                                    Value="@(context.FilterRowValue as Guid?)"
                                                                    ValueChanged="@( (Guid? v) => context.FilterRowValue = v )"
                                                                    ValueFieldName="Id"
                                                                    TextFieldName="Name"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>

                                            </DxGridDataColumn>


                                            <DxGridDataColumn FieldName="@nameof(RouteRow.TimeMin)" Caption="@L.Loc("Time duration")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                                <!-- DISPLAY -->
                                                <CellDisplayTemplate Context="ctx">
                                                    @{
                                                        int? value = ctx.Value as int?;
                                                        if (value is null && ctx.Value is int v)
                                                            value = v;
                                                    }

                                                    <span class="mlx-timeinput">
                                                        <TimeInput TNumber="int?"
                                                                   Value="@value"
                                                                   Format="hhmmss"
                                                                   DisplayOnly="true" />
                                                    </span>
                                                </CellDisplayTemplate>

                                                <!-- EDIT -->
                                                <CellEditTemplate Context="ctx">
                                                    @{
                                                        var r = ctx.EditModel as RouteRow;
                                                    }
                                                    @if (r is not null)
                                                    {
                                                        <span class="mlx-timeinput">
                                                            <TimeInput TNumber="int?"
                                                                       @bind-Value="r.TimeMin"
                                                                       Format="hhmmss" />
                                                        </span>
                                                    }
                                                </CellEditTemplate>

                                                <!-- FILTER -->
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <TimeInput TNumber="int?"
                                                                   Value="@(ctx.FilterRowValue as int?)"
                                                                   ValueChanged="@(v => ctx.FilterRowValue = v)"
                                                                   IsFilter="true"
                                                                   Format="hhmmss" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(RouteRow.Bidirectional)" Caption="@L.Loc("Bidirectional")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <DxComboBox TData="ComboGeneric<bool?>" TValue="bool?"
                                                                    Data="@_boolFilterItems"
                                                                    Value="(bool?)ctx.FilterRowValue"
                                                                    ValueChanged="@((bool? v) => ctx.FilterRowValue = v)"
                                                                    ValueFieldName="Value"
                                                                    TextFieldName="Description"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>
                                        </Columns>
                                    </DxGrid>
                                </div>
                            </DxTabPage>
                        </DxTabs>
                    </DetailRowTemplate>
                </DxGrid>

                <!-- Paginador sticky (Areas) -->
                <div class="mlx-pager-pager-layout wl-sticky-pager">
                    <div class="mlx-pager-left-group">
                        <DxPager PageCount="@PageCountAreas"
                                 ActivePageIndex="@ActivePageIndexAreas"
                                 SwitchToInputBoxButtonCount="4"
                                 NavigationMode="PagerNavigationMode.InputBox"
                                 ActivePageIndexChanged="@(EventCallback.Factory.Create<int>(this, OnActivePageIndexAreasChanged))" />
                        <DxComboBox TData="KeyValuePair<string,int>" TValue="int"
                                    Data="@PageSizeMainOptions"
                                    CssClass="mlx-form-select"
                                    Value="@PageSizeMain"
                                    ValueChanged="@(EventCallback.Factory.Create<int>(this, OnPageSizeChanged))"
                                    ValueFieldName="Value"
                                    TextFieldName="Key"
                                    AllowUserInput="false" />
                        <span class="mlx-pager-records">@PagerRecordsAreas</span>
                    </div>
                    <div class="mlx-pager-right-group">
                        @if (SelectedAreas.Any())
                        {
                            <button class="btn-mlx-grid-select"
                                    @onclick="@(EventCallback.Factory.Create(this, UnselectAllAreas))">
                                <span>@SelectedRecordsAreas</span>
                                <span class="mlx-separator"></span>
                                <i class="mlx-ico-close"></i>
                            </button>
                        }
                        else
                        {
                            <span class="mlx-grid-pager-no-selected">@SelectedRecordsAreas</span>
                        }
                    </div>
                </div>
            </div>
        </DxTabPage>
    </DxTabs>

    <!-- Footer único -->
    <div class="mlx-right-sideBar-footer wl-sticky-footer">
        <button type="button" class="btn-mlx btn-mlx-white-primary"
                disabled="@(!HasPendingChanges)"
                @onclick="@(EventCallback.Factory.Create(this, CancelButtonClick))">
            @L.Loc("Cancel")
        </button>
        <button type="button" class="btn-mlx btn-mlx-blue-primary"
                disabled="@isGlobalSaveDisabled"
                @onclick="@(EventCallback.Factory.Create(this, SaveEvent))">
            @L.Loc("Save")
        </button>
    </div>
</div>

<!-- ===== Modal de confirmación de borrado usando DialogComponent ===== -->
@if (showDeleteConfirmation)
{
    <DialogComponent Title="@DeleteTitle" CloseButtonClicked="@(HideDeleteConfirmation)">
        <BodyContent>
            <p class="margin-none">@DeleteMessage</p>

            @if (IsGlobalDelete && DeleteGroups?.Any() == true)
            {
                <div class="wl-modal-groups">
                    @foreach (var group in DeleteGroups)
                    {
                        if (group.Items == null || !group.Items.Any())
                        {
                            continue;
                        }
                        <div class="wl-modal-group">
                            <div class="wl-modal-group-header">
                                <span class="wl-modal-group-title">@group.Title</span>
                                <span class="wl-modal-group-count">(@group.Items.Count)</span>
                            </div>
                            <ul class="wl-modal-list">
                                @foreach (var s in group.Items.Take(8))
                                {
                                    <li>@s</li>
                                }
                                @if (group.Items.Count > 8)
                                {
                                    <li>… @L.Loc("{0} more…", group.Items.Count - 8)</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
            else if (DeletePreview?.Any() ?? false)
            {
                <ul class="wl-modal-list">
                    @foreach (var s in DeletePreview!.Take(8))
                    {
                        <li>@s</li>
                    }
                    @if (DeletePreview!.Count > 8)
                    {
                        <li>… @L.Loc("{0} more…", DeletePreview.Count - 8)</li>
                    }
                </ul>
            }

            <p class="wl-modal-hint">
                @L.Loc("Changes are pending. Confirm them using the Save button.")
            </p>
        </BodyContent>
        <FooterContent>
            <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="HideDeleteConfirmation">@L.Loc("No")</button>
            <button type="button" class="btn-mlx btn-mlx-blue-primary" @onclick="ConfirmDelete">@L.Loc("Yes")</button>
        </FooterContent>
    </DialogComponent>
}


