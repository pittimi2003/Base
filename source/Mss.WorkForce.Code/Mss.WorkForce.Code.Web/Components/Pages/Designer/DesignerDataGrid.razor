@* ===========================================================
   DesignerDataGrid.razor  
   * La agrupación por defecto a YES
   * Los campos que no son editables si que tiene que ser creables
   * Opción de búsqueda habilitada -> ShowFilterRow="true"
   * La agrupación de elementos deberia estar por name en vez de id
   * El borrado ; Debería preguntar confirmación de eliminar de la vista el elemento. dejando claro que no va a persistir el cambio hasta que guardes.
   * Los botones de eliminar vamos a cambiar el comportamiento
        Los quitamos de la barra de acciones
        Ponemos un solo botón a la izquierda del crear arriba que se vera cuando haya algo seleccionado
        Se eliminara (con modal de confirmación) todo lo seleccionado y tendrá cascada (tendremos que ver la forma de informar de la cascada - para mas adelante)
   * Opción de ALL en la paginación
   * La paginación solo abajo y fijada al footer encima de los botones con scroll dentro
   * Los numeros que son numeros, alineado a la derecha
   * Opción de All por defecto en la paginación
   * Eliminar la paginación de los elementos interiores (Process direction, equipment, ruta, zona) 
   * Eliminar la paginación que hay arriba a la derecha.
   * El botón de Suprimir del teclado debe activar de ser posible (tener algo seleccionado y no estar editando un campo) el botón de eliminar.
   * Los tipos de procesos así como el tipo de Área debe ser un enumerado.
     Para procesos el enumerado de tipo de proceso.
     Para área el enumerado de tipo de área, aquí tenemos que revisar que el tipo esta teniendo alguna cosa especial.
   =========================================================== *@
@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading.Tasks
@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop


@using Mss.WorkForce.Code.Models.DBContext
@using Mss.WorkForce.Code.Models.DTO.Designer
@using Mss.WorkForce.Code.Models.DTO.Enums.Designer
@using Mss.WorkForce.Code.Models.Models
@using Mss.WorkForce.Code.Models.DataAccess
@using Mss.WorkForce.Code.Web.Components.DesignerComponent
@using Mss.WorkForce.Code.Web.Components.Shared
@using Mss.WorkForce.Code.Web.Services
@using Mss.WorkForce.Code.Web.Services.Interfaces
@using System.Text.Json
@using static Mss.WorkForce.Code.Models.DTO.Enums.Designer.ObjectsTypes
@using Buffer = Mss.WorkForce.Code.Models.Models.Buffer;
@using System.Text.Json.Nodes

@inject DataAccess Da
@inject IGridService GridService
@inject ILocalizationService L
@inject IJSRuntime JS

<div class="wl-component-container"
     id="designer-root"
     tabindex="0"
     @onkeydown="HandleKeyDown">

    <!-- Header -->
    <div class="wl-header-bar">
        <div class="wl-left">
            <MlxSwitchBar IsSwitchOn="@IsSwitchOn"
                          TitleWhenOn="Canvas"
                          IconWhenOn=""
                          TitleWhenOff="Data"
                          IconWhenOff=""
                          IsSwitchOnChanged="@(EventCallback.Factory.Create<bool>(this, OnSwitchView))" />
        </div>
        <div class="wl-center">
            @if (HasPendingChanges)
            {
                <div class="warning-container">
                    <i class="mlx-ico-warning-bg-solid"></i>
                    <span class="wl-status wl-status-pending">
                        @L.Loc("There are {0} unsaved changes", @TotalPendingChanges)
                    </span>
                </div>
            }

            @if (ShowSaveSuccess)
            {
                <div class="success-container">
                    <i class="mlx-ico-success-bg-solid"></i>
                    <span class="wl-status wl-status-success">
                        @SuccessMessage
                    </span>
                </div>
            }
        </div>
        <div class="wl-right">
            <div class="mlx-panel-header wl-sticky-top">
                <div class="mlx-panel-bar-action">
                    <!-- Delete global (habilitado sólo si hay selección en cualquier grid) -->
                    @if(HasAnySelection){
                        <button name="action-delete-global"
                                title="@L.Loc("Delete selected")"
                                @onclick="OpenGlobalDeleteModal">
                            <i class="mlx-ico-trash"></i>
                        </button>
                    }

                    <button name="action-add" title="@L.Loc("Add")"
                            @onclick="AddCurrent">
                        <i class="mlx-ico-add"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <DxTabs CssClass="mlx-tabs"
            Position="TabPosition.Top"
            ActiveTabIndex="@ActiveTabIndex"
            ActiveTabIndexChanged="@(EventCallback.Factory.Create<int>(this, OnTabChanged))">

        <!-- ============================ -->
        <!-- TAB: PROCESSES -->
        <!-- ============================ -->
        <DxTabPage CssClass="mlx-tab-height" Text="@L.Loc("Processes")">
            <div class="wl-tab-scroll">
                <!-- Grid principal: Processes -->
                <div class="grid-container grid-host">
                    <DxGrid TData="ProcessRow"
                        @ref="ProcessGridRef"
                        CssClass="mlx-grid"
                        Data="@ProcessesSorted"
                        KeyFieldName="@nameof(ProcessRow.Id)"
                        EditMode="GridEditMode.EditCell"
                        ShowGroupPanel="true"
                        ShowGroupedColumns="true"
                        ShowFilterRow="true"
                        AllowSort="true"
                        AllowGroup="true"
                        PageSize="@PageSizeProcessesEffective"
                        PageIndex="@PageIndexProcesses"
                        PageIndexChanged="@(EventCallback.Factory.Create<int>(this, OnPageIndexProcessesChanged))"
                        PagerVisible="false"
                        SelectionMode="GridSelectionMode.Multiple"
                        AllowSelectRowByClick="false"
                        SelectedDataItems="@(SelectedProcesses.Cast<object>().ToList())"
                        SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, OnSelectedProcessesChanged))"
                        EditModelSaving="OnProcessEditModelSaving"
                        DataItemDeleting="OnProcessDataItemDeleting"
                        CustomizeElement="OnCustomizeGridElement"
                        CustomizeGroupValueDisplayText="OnProcessesCustomizeGroupValueDisplayText"
                        HighlightRowOnHover="true"
                        LayoutAutoSaving="OnProcessesLayoutAutoSaving"
                        EditOnKeyPress="true">

                        <Columns>
                            <DxGridSelectionColumn Width="40px" ShowInColumnChooser="false" AllowSelectAll="false" />

                            <DxGridDataColumn FieldName="@nameof(ProcessRow.Name)"
                                              Caption="@L.Loc("Name")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Contains">

                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <DxTextBox Text="@(ctx.FilterRowValue as string)"
                                                   TextChanged="@( (string v) => ctx.FilterRowValue = v )"
                                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                   NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>

                            <DxGridDataColumn FieldName="@nameof(ProcessRow.Type)"
                                              Caption="@L.Loc("Type")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <CellDisplayTemplate Context="ctx">
                                    @{

                                        var typeValue = ctx.Value as string;
                                    }
                                    @GetProcessTypeDisplay(typeValue)
                                </CellDisplayTemplate>

                                <CellEditTemplate Context="ctx">
                                    @{
                                        var m = (ProcessRow)ctx.EditModel;
                                    }

                                    @if (m.RowState == RowState.New)
                                    {
                                        <DxComboBox TData="ComboGeneric<string>" TValue="string"
                                                    Data="@ProcessTypeItems"
                                                    @bind-Value="m.Type"
                                                    ValueFieldName="Value"
                                                    TextFieldName="Description"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("Select...")" />
                                    }
                                    else
                                    {
                                        <!-- Si NO es nuevo, no renderices editor -->
                                        <span class="wl-cell-readonly">
                                            @GetProcessTypeDisplay(m.Type)
                                        </span>
                                    }
                                </CellEditTemplate>
                                  <!-- FILA DE FILTRO -->
                                <FilterRowCellTemplate Context="context">
                                    <MlxFilterOperationType FilterContext="context">
                                        <DxComboBox TData="ComboGeneric<string>" TValue="string"
                                                    Data="@ProcessTypeItems"
                                                    Value="(string?)context.FilterRowValue"
                                                    ValueChanged="@( (string? v) => context.FilterRowValue = v )"
                                                    ValueFieldName="Value"
                                                    TextFieldName="Description"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            
                                
                            </DxGridDataColumn>

                            <DxGridDataColumn FieldName="@nameof(ProcessRow.IsInitProcess)" Caption="@L.Loc("Is start process")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <DxComboBox TData="ComboGeneric<bool?>" TValue="bool?"
                                                    Data="@_boolFilterItems"
                                                    Value="(bool?)ctx.FilterRowValue"
                                                    ValueChanged="@( (bool? v) => ctx.FilterRowValue = v )"
                                                    ValueFieldName="Value"
                                                    TextFieldName="Description"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>

                            <!-- MinTime -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.MinTime)"
                                              Caption="@L.Loc("Processing time")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <!-- DISPLAY -->
                                <CellDisplayTemplate Context="ctx">
                                    @{
                                        int? value = ctx.Value as int?;

                                        // Si llega como int (no nullable) en algún caso
                                        if (value is null && ctx.Value is int v)
                                            value = v;
                                    }

                                    <span class="mlx-timeinput">
                                        <TimeInput TNumber="int?"
                                                   Value="@value"
                                                   Format="hhmmss"
                                                   DisplayOnly="true" />
                                    </span>
                                </CellDisplayTemplate>

                                <!-- EDICIÓN: EditModel -->
                                <CellEditTemplate Context="ctx">
                                    @{
                                        var row = ctx.EditModel as ProcessRow;
                                    }
                                    @if (row is not null)
                                    {
                                        <span class="mlx-timeinput">
                                            <TimeInput TNumber="int?"
                                                       Value="row.MinTime"
                                                       ValueChanged="@(v => row.MinTime = v ?? 0)"
                                                       Format="hhmmss" />
                                        </span>
                                    }
                                </CellEditTemplate>

                                <!-- FILA DE FILTRO -->
                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <TimeInput TNumber="int?"
                                                   IsFilter="true"
                                                   Value="@(ctx.FilterRowValue as int?)"
                                                   ValueChanged="@(v => ctx.FilterRowValue = v)"
                                                   Format="hhmmss" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>

                            <!-- PreprocessTime -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.PreprocessTime)" Caption="@L.Loc("Preprocess time")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <!-- DISPLAY -->
                                <CellDisplayTemplate Context="ctx">
                                    @{
                                        int? value = ctx.Value as int?;
                                        if (value is null && ctx.Value is int v)
                                            value = v;
                                    }

                                    <span class="mlx-timeinput">
                                        <TimeInput TNumber="int?"
                                                   Value="@value"
                                                   Format="mmss"
                                                   DisplayOnly="true" />
                                    </span>
                                </CellDisplayTemplate>

                                <!-- EDIT -->
                                <CellEditTemplate Context="ctx">
                                    @{
                                        var row = ctx.EditModel as ProcessRow;
                                    }
                                    @if (row is not null)
                                    {
                                        <span class="mlx-timeinput">
                                            <TimeInput TNumber="int?"
                                                       @bind-Value="row.PreprocessTime"
                                                       Format="mmss" />
                                        </span>
                                    }
                                </CellEditTemplate>

                                <!-- FILTER -->
                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <TimeInput TNumber="int?"
                                                   IsFilter="true"
                                                   Value="@(ctx.FilterRowValue as int?)"
                                                   ValueChanged="@(v => ctx.FilterRowValue = v)"
                                                   Format="mmss" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>

                            </DxGridDataColumn>


                            <!-- PostprocessTime -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.PostprocessTime)"
                                              Caption="@L.Loc("Postprocess time")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <!-- DISPLAY -->
                                <CellDisplayTemplate Context="ctx">
                                    @{
                                        int? value = ctx.Value as int?;
                                        if (value is null && ctx.Value is int v)
                                            value = v;
                                    }

                                    <span class="mlx-timeinput">
                                        <TimeInput TNumber="int?"
                                                   Value="@value"
                                                   Format="mmss"
                                                   DisplayOnly="true" />
                                    </span>
                                </CellDisplayTemplate>

                                <!-- EDIT -->
                                <CellEditTemplate Context="ctx">
                                    @{
                                        var row = ctx.EditModel as ProcessRow;
                                    }
                                    @if (row is not null)
                                    {
                                        <span class="mlx-timeinput">
                                            <TimeInput TNumber="int?"
                                                       @bind-Value="row.PostprocessTime"
                                                       Format="mmss"
                                                       OnEnterPressed="OnTimeInputEnter" />
                                        </span>
                                    }
                                </CellEditTemplate>

                                <!-- FILTER -->
                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <TimeInput TNumber="int?"
                                                   IsFilter="true"
                                                   Value="@(ctx.FilterRowValue as int?)"
                                                   ValueChanged="@(v => ctx.FilterRowValue = v)"
                                                   Format="mmss" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>


                            <!-- Flow -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.FlowId)"
                                              Caption="@L.Loc("Flow")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <!-- DISPLAY -->
                                <CellDisplayTemplate Context="ctx">
                                    @{
                                        Guid? flowId = null;
                                        if (ctx.Value is Guid g) flowId = g;

                                        var flow = (flowId is null)
                                        ? null
                                        : Flows.FirstOrDefault(f => f.Id == flowId.Value);
                                    }

                                    @if (flow is null)
                                    {
                                        <div>@L.Loc("Select...")</div>
                                    }
                                    else
                                    {
                                        var badgeClass = flow.Type switch
                                        {
                                            FlowType.Inbound => "wl-flow-badge wl-inbound",
                                            FlowType.Outbound => "wl-flow-badge wl-outbound",
                                            FlowType.Custom => "wl-flow-badge wl-custom",
                                            _ => "wl-flow-badge"
                                        };

                                        var iconClass = flow.Type switch
                                        {
                                            FlowType.Inbound => "mlx-ico-entrada",
                                            FlowType.Outbound => "mlx-ico-salida",
                                            FlowType.Custom => "mlx-ico-settings",
                                            _ => "mlx-ico-info"
                                        };

                                        <span class="@badgeClass" title="@flow.Name">
                                            <i class="@iconClass"></i>
                                            <span class="wl-flow-text">@flow.Name</span>
                                        </span>
                                    }
                                </CellDisplayTemplate>

                                <!-- EDIT -->
                                <CellEditTemplate Context="ctx">
                                    @{
                                        var row = (ProcessRow)ctx.EditModel;
                                    }

                                    @if (row.RowState == RowState.New)
                                    {
                                        <DxComboBox TData="LookupFlowItem" TValue="Guid?"
                                                    Data="@FlowsSorted"
                                                    @bind-Value="row.FlowId"
                                                    ValueFieldName="Id"
                                                    TextFieldName="Name"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("Select...")" />
                                    }
                                    else
                                    {
                                        // Mantiene apariencia de solo lectura cuando NO es New
                                        <span class="wl-cell-readonly">
                                            @{
                                                var flow = (row.FlowId is null) ? null : Flows.FirstOrDefault(f => f.Id == row.FlowId.Value);
                                            }
                                            @if (flow is null)
                                            {
                                                <span></span>
                                            }
                                            else
                                            {
                                                var badgeClass = flow.Type switch
                                                {
                                                    FlowType.Inbound => "wl-flow-badge wl-inbound",
                                                    FlowType.Outbound => "wl-flow-badge wl-outbound",
                                                    FlowType.Custom => "wl-flow-badge wl-custom",
                                                    _ => "wl-flow-badge"
                                                };

                                                var iconClass = flow.Type switch
                                                {
                                                    FlowType.Inbound => "mlx-ico-entrada",
                                                    FlowType.Outbound => "mlx-ico-salida",
                                                    FlowType.Custom => "mlx-ico-settings",
                                                    _ => "mlx-ico-info"
                                                };

                                                <span class="@badgeClass" title="@flow.Name">
                                                    <i class="@iconClass"></i>
                                                    <span class="wl-flow-text">@flow.Name</span>
                                                </span>
                                            }
                                        </span>
                                    }
                                </CellEditTemplate>

                                <!-- FILTER -->
                                <FilterRowCellTemplate Context="context">
                                    <MlxFilterOperationType FilterContext="context">
                                        <DxComboBox TData="LookupFlowItem" TValue="Guid?"
                                                    Data="@FlowsSorted"
                                                    Value="@(context.FilterRowValue is Guid g ? (Guid?)g : null)"
                                                    ValueChanged="@( (Guid? v) => context.FilterRowValue = v )"
                                                    ValueFieldName="Id"
                                                    TextFieldName="Name"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>

                            <!-- Area -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.AreaId)"
                                              Caption="@L.Loc("Area")"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <!-- DISPLAY -->
                                <CellDisplayTemplate Context="ctx">
                                    @{
                                        Guid? areaId = null;
                                        if (ctx.Value is Guid g) areaId = g;
                                        else if (ctx.Value is Guid gn) areaId = gn;

                                        var aid = areaId ?? Guid.Empty;
                                        var name = AreasLookup.FirstOrDefault(a => a.Id == aid)?.Name;
                                    }
                                    @if (name is null)
                                    {
                                        <div>@L.Loc("Select...")</div>
                                    }
                                    @name
                                </CellDisplayTemplate>

                                <!-- EDIT -->
                                <CellEditTemplate Context="ctx">
                                    @{
                                        var row = ctx.EditModel as ProcessRow;
                                    }
                                    @if (row is not null)
                                    {
                                        if (row.RowState == RowState.New)
                                        {
                                            <DxComboBox TData="LookupItem" TValue="Guid?"
                                                        Data="@AreasLookupSorted"
                                                        @bind-Value="row.AreaId"
                                                        ValueFieldName="Id"
                                                        TextFieldName="Name"
                                                        ValidationEnabled="false"
                                                        AllowUserInput="false"
                                                        NullText="@L.Loc("Select...")" />
                                        }
                                        else
                                        {
                                            <span class="wl-cell-readonly">
                                                @{
                                                    var aid = row.AreaId ?? Guid.Empty;
                                                    var name = AreasLookup.FirstOrDefault(a => a.Id == aid)?.Name;
                                                }
                                                @name
                                            </span>
                                        }
                                    }
                                </CellEditTemplate>

                                <!-- Fila de filtro: combo de Areas -->
                                <FilterRowCellTemplate Context="context">
                                    <MlxFilterOperationType FilterContext="context">
                                        <DxComboBox TData="LookupItem" TValue="Guid?"
                                                    Data="@AreasLookupSorted"
                                                    Value="@(context.FilterRowValue is Guid g ? (Guid?)g : null)"
                                                    ValueChanged="@( (Guid? v) => context.FilterRowValue = v )"
                                                    ValueFieldName="Id"
                                                    TextFieldName="Name"
                                                    AllowUserInput="false"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>
                            </DxGridDataColumn>


                            <!-- Contador (solo lectura) -->
                            <DxGridDataColumn FieldName="@nameof(ProcessRow.ProcessDirectionsCount)"
                                              Caption="@L.Loc("Total directions")"
                                              DataRowEditorVisible="false"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                <FilterRowCellTemplate Context="ctx">
                                    <MlxFilterOperationType FilterContext="ctx">
                                        <DxSpinEdit TValue="int?"
                                                    Value="@(ctx.FilterRowValue as int?)"
                                                    ValueChanged="@( (int? v) => ctx.FilterRowValue = v )"
                                                    MinValue="0"
                                                    ShowSpinButtons="true"
                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                    NullText="@L.Loc("All")" />
                                    </MlxFilterOperationType>
                                </FilterRowCellTemplate>

                            </DxGridDataColumn>
                        </Columns>

                        <!-- Subgrid: Directions -->
                        <DetailRowTemplate Context="detail">
                            @{
                                var process = detail?.DataItem as ProcessRow;
                                var totalDir = process?.Directions?.Count ?? 0;
                                var pageCountDir = GetPageCount(process?.Directions, PageSizeDetailEffective);
                            }

                            <div class="mlx-panel-header wl-sticky-sub">
                                <div class="mlx-panel-bar-action" style="margin-left:auto">
                                    <button name="action-add" title="@L.Loc("Add")"
                                            @onclick="@(EventCallback.Factory.Create(this, () => { if (process != null) AddDirection(process); }))">
                                        <i class="mlx-ico-add"></i>
                                    </button>
                                </div>
                            </div>

                            <DxGrid TData="ProcessDirectionRow"
                                    CssClass="mlx-grid dxbl-grid-detail"
                                    Data="@(process?.Directions)"
                                    EditMode="GridEditMode.EditCell"
                                    ShowGroupPanel="false"
                                    ShowFilterRow="true"
                                    PageSize="@PageSizeDetailEffective"
                                    PageIndex="@(process?.PageIndex_Dir ?? 0)"
                                    PageIndexChanged="@(EventCallback.Factory.Create<int>(this, (int i) => { if (process != null) OnPageIndexDirectionsChanged(process, i); }))"
                                    PagerVisible="false"
                                    SelectionMode="GridSelectionMode.Multiple"
                                    AllowSelectRowByClick="true"
                                    SelectedDataItems="@(process?.SelectedDirections?.Cast<object>().ToList() ?? new List<object>())"
                                    SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, (IReadOnlyList<object> newSel) => { if (process != null) OnSelectedDirectionsChanged(process, newSel); }))"
                                    EditModelSaving="OnProcessDirectionEditModelSaving"
                                    DataItemDeleting="OnProcessDirectionDataItemDeleting"
                                    CustomizeElement="OnCustomizeGridElement">

                                <Columns>
                                    <DxGridSelectionColumn Width="40px" ShowInColumnChooser="false" AllowSelectAll="false" />
                                    <DxGridDataColumn FieldName="@nameof(ProcessDirectionRow.EndProcessId)"
                                                      Caption="@L.Loc("Destination process")"
                                                      FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                        <!-- DISPLAY -->
                                        <CellDisplayTemplate Context="ctx">
                                            @{
                                                Guid? endId = null;
                                                if (ctx.Value is Guid g) endId = g;

                                                var name = (endId is null)
                                                ? null
                                                : Processes.FirstOrDefault(p => p.Id == endId.Value)?.Name;
                                            }
                                            @if (name is null)
                                            {
                                                <div>@L.Loc("Select...")</div>
                                            }
                                            @name
                                        </CellDisplayTemplate>

                                        <!-- EDIT -->
                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var dir = ctx.EditModel as ProcessDirectionRow;
                                                var options = GetDestinationProcessOptions(process);
                                            }

                                            @if (dir is not null)
                                            {
                                                <DxComboBox TData="ProcessRow" TValue="Guid?"
                                                            Data="@options"
                                                            @bind-Value="dir.EndProcessId"
                                                            ValueFieldName="Id"
                                                            TextFieldName="Name"
                                                            AllowUserInput="false"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            NullText="@L.Loc("Select...")" />
                                            }
                                        </CellEditTemplate>

                                        <!-- FILTER -->
                                        <FilterRowCellTemplate Context="ctx">
                                            @{
                                                var options = GetDestinationProcessOptions(process);
                                            }
                                            <MlxFilterOperationType FilterContext="ctx">
                                                <DxComboBox TData="ProcessRow" TValue="Guid?"
                                                            Data="@options"
                                                            Value="@(ctx.FilterRowValue as Guid?)"
                                                            ValueChanged="@( (Guid? v) => ctx.FilterRowValue = v )"
                                                            ValueFieldName="Id"
                                                            TextFieldName="Name"
                                                            AllowUserInput="false"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            NullText="@L.Loc("All")" />
                                            </MlxFilterOperationType>
                                        </FilterRowCellTemplate>
                                    </DxGridDataColumn>

                                    <DxGridDataColumn FieldName="@nameof(ProcessDirectionRow.Percentage)" Caption="@L.Loc("Percentage")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
                                        <FilterRowCellTemplate Context="ctx">
                                            <MlxFilterOperationType FilterContext="ctx">
                                                <DxSpinEdit TValue="int?"
                                                            Value="@(ctx.FilterRowValue as int?)"
                                                            ValueChanged="@((int? v) => ctx.FilterRowValue = v)"
                                                            MinValue="0"
                                                            MaxValue="100"
                                                            ShowSpinButtons="true"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
