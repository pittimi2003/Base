                                                ShowSpinButtons="true"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                NullText="@L.Loc("All")" />
                                </MlxFilterOperationType>
                            </FilterRowCellTemplate>
                        </DxGridDataColumn>

                        <DxGridDataColumn FieldName="@nameof(AreaRow.RoutesCount)" Caption="@L.Loc("Total routes")" DataRowEditorVisible="false" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
