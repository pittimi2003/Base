                                                        else
                                                        {
                                                            <span class="wl-cell-readonly">
                                                                @GetZoneTypeDisplay(row.Type)
                                                            </span>
                                                        }
                                                    }
                                                </CellEditTemplate>

                                                <!-- Fila de filtro: combo también restringido por Area.Type -->
                                                <FilterRowCellTemplate Context="context">
                                                    <MlxFilterOperationType FilterContext="context">
                                                        <DxComboBox TData="ComboGeneric<string>" TValue="string"
                                                                    Data="@GetZoneTypeItemsForArea(area)"
                                                                    Value="(string?)context.FilterRowValue"
                                                                    ValueChanged="@( (string? v) => context.FilterRowValue = v )"
                                                                    ValueFieldName="Value"
                                                                    TextFieldName="Description"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(ZoneRow.MaxContainers)" Caption="@L.Loc("Max containers")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <DxSpinEdit TValue="int?"
                                                                    Value="@(ctx.FilterRowValue as int?)"
                                                                    ValueChanged="@((int? v) => ctx.FilterRowValue = v)"
                                                                    MinValue="0"
                                                                    ShowSpinButtons="true"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn FieldName="@nameof(ZoneRow.MaxEquipments)" Caption="@L.Loc("Max equipments")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <DxSpinEdit TValue="int?"
                                                                    Value="@(ctx.FilterRowValue as int?)"
                                                                    ValueChanged="@((int? v) => ctx.FilterRowValue = v)"
                                                                    MinValue="0"
                                                                    ShowSpinButtons="true"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>
                                        </Columns>
                                    </DxGrid>
                                </div>
                            </DxTabPage>

                            <!-- Equipments -->
                            <DxTabPage Text="@($"{L.Loc("Equipments")} ({(area?.Equipments?.Count ?? 0)})")">
                                @{
                                    var totalEq = area?.Equipments?.Count ?? 0;
                                    var pageCountEq = GetPageCount(area?.Equipments, PageSizeDetailEffective);
                                }
                                <div class="wl-subtab-scroll">
                                    <div class="mlx-panel-header wl-sticky-sub">
                                        <div class="mlx-panel-bar-action" style="margin-left:auto">
                                            <button name="action-add" title="@L.Loc("Add")"
                                                    @onclick="@(EventCallback.Factory.Create(this, () => { if (area != null) AddEquipment(area); }))">
                                                <i class="mlx-ico-add"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <DxGrid TData="EquipmentGroupRow"
                                            CssClass="mlx-grid dxbl-grid-detail"
                                            Data="@GetEquipmentsSorted(area)"
                                            EditMode="GridEditMode.EditCell"
                                            ShowGroupPanel="false"
                                            ShowFilterRow="true"
                                            PageSize="@PageSizeDetailEffective"
                                            PageIndex="@(area?.PageIndex_Equipments ?? 0)"
                                            PageIndexChanged="@(EventCallback.Factory.Create<int>(this, (int i) => { if (area != null) OnPageIndexEquipmentsChanged(area, i); }))"
                                            PagerVisible="false"
                                            SelectionMode="GridSelectionMode.Multiple"
                                            AllowSelectRowByClick="true"
                                            SelectedDataItems="@(area?.SelectedEquipments?.Cast<object>().ToList() ?? new List<object>())"
                                            SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, (IReadOnlyList<object> newSel) => { if (area != null) OnSelectedEquipmentsChanged(area, newSel); }))"
                                            EditModelSaving="OnEquipmentEditModelSaving"
                                            DataItemDeleting="OnEquipmentDataItemDeleting"
                                            CustomizeElement="OnCustomizeGridElement"
                                            EditOnKeyPress="true">
                                        <Columns>
                                            <DxGridSelectionColumn Width="40px" ShowInColumnChooser="false" AllowSelectAll="false" />

                                            <DxGridDataColumn FieldName="@nameof(EquipmentGroupRow.Name)" Caption="@L.Loc("Name")" FilterRowOperatorType="GridFilterRowOperatorType.Contains">
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <DxTextBox Text="@(ctx.FilterRowValue as string)"
                                                                   TextChanged="@( (string v) => ctx.FilterRowValue = v )"
                                                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                   NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(EquipmentGroupRow.TypeEquipmentId)"
                                                              Caption="@L.Loc("Type")"
                                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                                <!-- DISPLAY -->
                                                <CellDisplayTemplate Context="ctx">
                                                    @{
                                                        Guid? typeId = null;
                                                        if (ctx.Value is Guid g) typeId = g;

                                                        var name = (typeId is null)
                                                        ? null
                                                        : TypeEquipments.FirstOrDefault(t => t.Id == typeId.Value)?.Name;
                                                    }
                                                    @if (name is null)
                                                    {
                                                        <div>@L.Loc("Select...")</div>
                                                    }
                                                    @name
                                                </CellDisplayTemplate>

                                                <!-- EDIT -->
                                                <CellEditTemplate Context="ctx">
                                                    @{
                                                        var eg = ctx.EditModel as EquipmentGroupRow;
                                                    }

                                                    @if (eg is not null)
                                                    {
                                                        <DxComboBox TData="LookupItem" TValue="Guid?"
                                                                    Data="@TypeEquipmentsSorted"
                                                                    @bind-Value="eg.TypeEquipmentId"
                                                                    ValueFieldName="Id"
                                                                    TextFieldName="Name"
                                                                    ValidationEnabled="false"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("Select...")" />
                                                    }
                                                </CellEditTemplate>

                                                <!-- Fila de filtro: combo con "All" + botón de limpiar -->
                                                <FilterRowCellTemplate Context="context">
                                                    <MlxFilterOperationType FilterContext="context">
                                                        <DxComboBox TData="LookupItem" TValue="Guid?"
                                                                    Data="@TypeEquipmentsSorted"
                                                                    Value="@(context.FilterRowValue as Guid?)"
                                                                    ValueChanged="@( (Guid? v) => context.FilterRowValue = v )"
                                                                    ValueFieldName="Id"
                                                                    TextFieldName="Name"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(EquipmentGroupRow.Quantity)" Caption="@L.Loc("Quantity")" FilterRowOperatorType="GridFilterRowOperatorType.Equal">
                                                <FilterRowCellTemplate Context="ctx">
                                                    <MlxFilterOperationType FilterContext="ctx">
                                                        <DxSpinEdit TValue="int?"
                                                                    Value="@(ctx.FilterRowValue as int?)"
                                                                    ValueChanged="@((int? v) => ctx.FilterRowValue = v)"
                                                                    MinValue="0"
                                                                    ShowSpinButtons="true"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="@L.Loc("All")" />
                                                    </MlxFilterOperationType>
                                                </FilterRowCellTemplate>
                                            </DxGridDataColumn>
                                        </Columns>
                                    </DxGrid>
                                </div>
                            </DxTabPage>

                            <!-- Routes -->
                            <DxTabPage Text="@($"{L.Loc("Routes")} ({(area?.Routes?.Count ?? 0)})")">
                                @{
                                    var totalRt = area?.Routes?.Count ?? 0;
                                    var pageCountRt = GetPageCount(area?.Routes, PageSizeDetailEffective);
                                }
                                <div class="wl-subtab-scroll">
                                    <div class="mlx-panel-header wl-sticky-sub">
                                        <div class="mlx-panel-bar-action" style="margin-left:auto">
                                            <button name="action-add" title="@L.Loc("Add")"
                                                    @onclick="@(EventCallback.Factory.Create(this, () => { if (area != null) AddRoute(area); }))">
                                                <i class="mlx-ico-add"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <DxGrid TData="RouteRow"
                                            CssClass="mlx-grid dxbl-grid-detail"
                                            Data="@(area?.Routes)"
                                            EditMode="GridEditMode.EditCell"
                                            ShowGroupPanel="false"
                                            ShowFilterRow="true"
                                            PageSize="@PageSizeDetailEffective"
                                            PageIndex="@(area?.PageIndex_Routes ?? 0)"
                                            PageIndexChanged="@(EventCallback.Factory.Create<int>(this, (int i) => { if (area != null) OnPageIndexRoutesChanged(area, i); }))"
                                            PagerVisible="false"
                                            SelectionMode="GridSelectionMode.Multiple"
                                            AllowSelectRowByClick="true"
                                            SelectedDataItems="@(area?.SelectedRoutes?.Cast<object>().ToList() ?? new List<object>())"
                                            SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, (IReadOnlyList<object> newSel) => { if (area != null) OnSelectedRoutesChanged(area, newSel); }))"
                                            EditModelSaving="OnRouteEditModelSaving"
                                            DataItemDeleting="OnRouteDataItemDeleting"
                                            CustomizeElement="OnCustomizeGridElement"
                                            EditOnKeyPress="true">
                                        <Columns>
                                            <DxGridSelectionColumn Width="40px" ShowInColumnChooser="false" AllowSelectAll="false" />

                                            <DxGridDataColumn FieldName="@nameof(RouteRow.ArrivalAreaId)"
                                                              Caption="@L.Loc("Arrival area")"
                                                              FilterRowOperatorType="GridFilterRowOperatorType.Equal">

                                                <!-- DISPLAY -->
                                                <CellDisplayTemplate Context="ctx">
                                                    @{
                                                        Guid? areaId = null;
                                                        if (ctx.Value is Guid g) areaId = g;

                                                        var name = (areaId is null)
                                                        ? null
                                                        : AreasLookup.FirstOrDefault(a => a.Id == areaId.Value)?.Name;
                                                    }
                                                    @if (name is null)
                                                    {
                                                        <div>@L.Loc("Select...")</div>
                                                    }
                                                    @name
                                                </CellDisplayTemplate>

                                                <!-- EDIT -->
                                                <CellEditTemplate Context="ctx">
                                                    @{
                                                        var r = ctx.EditModel as RouteRow;
                                                    }
                                                    @if (r is not null)
                                                    {
                                                        <DxComboBox TData="LookupItem" TValue="Guid?"
                                                                    Data="@AreasLookupSorted"
                                                                    @bind-Value="r.ArrivalAreaId"
                                                                    ValueFieldName="Id"
                                                                    TextFieldName="Name"
                                                                    ValidationEnabled="false"
                                                                    AllowUserInput="false"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
