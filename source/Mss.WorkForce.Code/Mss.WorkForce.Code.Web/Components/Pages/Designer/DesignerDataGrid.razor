    private async Task OnSaveAsync()
    {
        var layout = Da.GetLayoutByLayout(LayoutId);
        var warehouseId = layout.WarehouseId;

        var typeEquipmentEntities = Da.GetTypeEquipments(warehouseId).ToList();

        // ===================================================
        // MANAGERS
        // ===================================================
        var deleteManager = new DeleteManager(GridService.GetOperationDB(), Da);
        var saveManager = new SaveManager();

        // ===================================================
        // ========== ÁREAS ==================================
        // ===================================================
        var areaById = new Dictionary<Guid, Area>();

        foreach (var ar in Areas.Where(a => a.RowState is RowState.New or RowState.Modified or RowState.Unchanged))
        {
            bool isNew = ar.Id == Guid.Empty;
            ar.Id = isNew ? Guid.NewGuid() : ar.Id;

            Area? areaGlob = null;

            if (ar.RowState == RowState.Modified)
            {
                areaGlob = Da.GetAreaById(ar.Id);

                areaGlob.ViewPort = new ViewportExtensions()
                    .UpdateViewportName(areaGlob?.ViewPort, ar.Name);
            }

            var area = new Area
            {
                Id = areaGlob?.Id ?? ar.Id,
                Name = ar.Name,
                Type = areaGlob?.Type ?? ar.Type,
                IsAutomatic = areaGlob?.IsAutomatic ?? false,
                NarrowAisle = areaGlob?.NarrowAisle ?? false,
                LayoutId = areaGlob?.LayoutId ?? layout.Id,
                Layout = null,
                DelayedTimePerUnit = areaGlob?.DelayedTimePerUnit ?? 0,
                ViewPort = areaGlob?.ViewPort ?? null
            };

            areaById[area.Id] = area;

            if (ar.RowState is RowState.New or RowState.Modified)
                saveManager.AreasToSave.Add(area);
        }

        // ===================================================
        // ========== PROCESSES ===============================
        // ===================================================
        var processById = new Dictionary<Guid, Process>();

        foreach (var pr in Processes.Where(p => p.RowState != RowState.Deleted))
        {
            if (pr.Id == Guid.Empty)
                pr.Id = Guid.NewGuid();

            if (!pr.AreaId.HasValue || !areaById.TryGetValue(pr.AreaId.Value, out var areaRef))
                continue;

            var flowType = FlowType.Inbound;
            if (pr.FlowId is Guid fid && fid != Guid.Empty)
                flowTypeById.TryGetValue(fid, out flowType);

            var (isIn, isOut) = GetFlowFlags(flowType);

            var process = new Process
            {
                Id = pr.Id,
                Name = pr.Name,
                Type = pr.Type ?? string.Empty,
                MinTime = pr.MinTime ?? 0,
                PreprocessTime = pr.PreprocessTime,
                PostprocessTime = pr.PostprocessTime,
                IsWarehouseProcess = pr.IsWarehouseProcess,
                // IsWarehouseProcess = (pr.Type.ToString() == ProcessType.Replenishment.ToString() || pr.Type.ToString() == ProcessType.CustomProcess.ToString()) ? true : false, // TODO Ruben 28/01/2026: Se comenta hasta tener la definición completa. Revisar la consulta en DesignerServices.
                IsOut = isOut,
                IsIn = isIn,
                IsInitProcess = pr.IsInitProcess,
                AreaId = areaRef.Id,
                Area = null,
                IsEffective = true,
                FlowId = pr.FlowId ?? Guid.Empty
            };

            processById[process.Id] = process;

            if (pr.RowState is RowState.New or RowState.Modified)
                saveManager.ProcessesToSave.Add(process);
        }

        // Cambios de tipo de proceso
        var processTypeChangesToApply =
            PendingProcessTypeChanges
            .Where(c => processById.ContainsKey(c.ProcessId))
            .Select(c => (Process: processById[c.ProcessId], c.OldType, c.NewType))
            .ToList();

        if (processTypeChangesToApply.Any())
            saveManager.ProcessTypeChanges.AddRange(processTypeChangesToApply);

        // ===================================================
        // ========== DIRECTIONS =============================
        // ===================================================
        foreach (var pr in Processes.Where(p => p.RowState != RowState.Deleted))
        {
            if (!processById.TryGetValue(pr.Id, out var initProcess))
                continue;

            if (pr.Directions == null || pr.Directions.Count == 0)
                continue;

            var changedDirections = pr.Directions
                .Where(d => d.RowState is RowState.New or RowState.Modified)
                .ToList();

            foreach (var dr in changedDirections)
            {
                if (dr.Id == Guid.Empty)
                    dr.Id = Guid.NewGuid();

                var endProcess = initProcess;

                if (dr.EndProcessId.HasValue &&
                    processById.TryGetValue(dr.EndProcessId.Value, out var endFound))
                {
                    endProcess = endFound;
                }

                saveManager.DirectionsToSave.Add(new ProcessDirectionProperty
                {
                    Id = dr.Id,
                    Name = $"{initProcess.Name}->{endProcess.Name}",
                    InitProcessId = initProcess.Id,
                    InitProcess = initProcess,
                    EndProcessId = endProcess.Id,
                    EndProcess = endProcess,
                    Percentage = Convert.ToDouble(dr.Percentage),
                    IsEnd = dr.IsEnd
                });
            }
        }

        // ===================================================
        // ========== ZONES + SUBTIPOS ========================
        // ===================================================
        foreach (var ar in Areas.Where(a => a.RowState != RowState.Deleted))
        {
            if (!areaById.TryGetValue(ar.Id, out var areaEntity))
                continue;

            // ---------- ZONES ----------
            if (ar.Zones != null && ar.Zones.Any(z => z.RowState != RowState.Unchanged))
            {
                foreach (var z in ar.Zones.Where(z => z.RowState is RowState.New or RowState.Modified))
                {
                    Zone? zoneGlob = null;

                    if (z.RowState == RowState.Modified)
                    {
                        zoneGlob = Da.GetZoneByIdNoTracking(z.Id);                      

                        if (zoneGlob != null)
                        {
                            zoneGlob.ViewPort = new ViewportExtensions()
                                .UpdateViewportName(zoneGlob.ViewPort, z.Name);
                        }
                    }

                    var zoneEntity = new Zone
                    {
                        Id = zoneGlob?.Id ?? z.Id,
                        Name = z.Name,
                        Type = zoneGlob?.Type ?? z.Type,
                        MaxStockToBook = zoneGlob?.MaxStockToBook ?? 0,
                        IsLimitStock = zoneGlob?.IsLimitStock ?? false,
                        InitStockToBook = zoneGlob?.InitStockToBook ?? 0,
                        AreaId = zoneGlob?.AreaId ?? areaEntity.Id,
                        Area = null,
                        MaxContainers = z.MaxContainers ?? 0,
                        MaxEquipments = z.MaxEquipments ?? 0,
                        ViewPort = zoneGlob?.ViewPort ?? null
                    };

                    saveManager.ZonesToSave.Add((areaEntity.Id, zoneEntity));

                    // Subtipos
                    if (z.RowState == RowState.New)
                    {
                        switch (ZoneTypeGetMethods.GetStringZoneType(z.Type))
                        {
                            case ZoneType.Dock:
                                saveManager.DocksToSave.Add((areaEntity.Id, new Dock
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    MaxEquipments = 0,
                                    OperatesFromBuffer = false,
                                    MaxStockCrossdocking = 0,
                                    AllowInbound = false,
                                    AllowOutbound = false
                                }));
                                break;

                            case ZoneType.Buffer:
                                saveManager.BuffersToSave.Add((areaEntity.Id, new Buffer
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    EntryCapacity = 0,
                                    ExitCapacity = 0,
                                    CapacityByMaterial = false,
                                    Excess = false,
                                    MaxEquipments = 0
                                }));
                                break;

                            case ZoneType.Stage:
                                saveManager.StagesToSave.Add((areaEntity.Id, new Stage
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    MaxEquipments = 0,
                                    MixCarriers = false,
                                    IsIn = true,
                                    IsOut = true
                                }));
                                break;

                                // Nuevos

                            case ZoneType.Rack:
                                saveManager.RacksToSave.Add((areaEntity.Id, new Rack
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    Capacity = 0,
                                    NumCrossAisles = 1,
                                    NumShelves = 1,
                                    IsVertical = false,
                                    Bidirectional = false
                                }));
                                break;

                            case ZoneType.DriveIn:
                                saveManager.DriveInsToSave.Add((areaEntity.Id, new DriveIn
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    Capacity = 0,
                                    NumCrossAisles = 1,
                                    NumShelves = 1,
                                    IsVertical = false,
                                    Bidirectional = false
                                }));
                                break;

                            case ZoneType.ChaoticStorage:
                                saveManager.ChaoticStoragesToSave.Add((areaEntity.Id, new ChaoticStorage
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    Capacity = 0
                                }));
                                break;

                            case ZoneType.AutomaticStorage:
                                saveManager.AutomaticStoragesToSave.Add((areaEntity.Id, new AutomaticStorage
                                {
                                    Id = Guid.NewGuid(),
                                    ZoneId = zoneEntity.Id,
                                    Zone = null,
                                    Capacity = 0,
                                    NumCrossAisles =1,
                                    NumShelves = 0
                                }));
                                break;
                        }
                    }
                }
            }

            // ---------- EQUIPMENTS ----------
            if (ar.Equipments != null)
            {
                var modifiedEquips = ar.Equipments
                    .Where(e => e.RowState is RowState.New or RowState.Modified)
                    .ToList();

                foreach (var eg in modifiedEquips)
                {
                    if (eg.Id == Guid.Empty)
                        eg.Id = Guid.NewGuid();

                    if (!eg.TypeEquipmentId.HasValue || eg.TypeEquipmentId.Value == Guid.Empty)
                        continue;

                    var te = typeEquipmentEntities.FirstOrDefault(t => t.Id == eg.TypeEquipmentId.Value);
                    if (te == null)
                        continue;

                    saveManager.EquipmentsToSave.Add((areaEntity.Id, new EquipmentGroup
                    {
                        Id = eg.Id,
                        Name = eg.Name,
                        Equipments = eg.Quantity,
                        Area = null,
                        AreaId = areaEntity.Id,
                        TypeEquipmentId = eg.TypeEquipmentId.Value,
                        TypeEquipment = te
                    }));
                }
            }

            // ---------- ROUTES ----------
            if (ar.Routes != null)
            {
                var changedRoutes = ar.Routes
                    .Where(r => r.RowState is RowState.New or RowState.Modified)
                    .ToList();

                foreach (var r in changedRoutes)
                {
                    if (r.Id == Guid.Empty)
                        r.Id = Guid.NewGuid();

                    var departureArea = areaEntity;

                    var arrivalArea = departureArea;
                    var arrivalAreaId = departureArea.Id;

                    if (r.ArrivalAreaId.HasValue &&
                        r.ArrivalAreaId.Value != Guid.Empty &&
                        areaById.TryGetValue(r.ArrivalAreaId.Value, out var arr))
                    {
                        arrivalArea = arr;
                        arrivalAreaId = arr.Id;
                    }

                    saveManager.RoutesToSave.Add((areaEntity.Id, new Route
                    {
                        Id = r.Id,
                        Name = $"{departureArea.Name}->{arrivalArea.Name}",
                        TimeMin = r.TimeMin ?? 0,
                        Bidirectional = r.Bidirectional,
                        DepartureAreaId = departureArea.Id,
                        ArrivalAreaId = arrivalAreaId,
                        DepartureArea = null,
                        ArrivalArea = null
                    }));
                }
            }
        }

        // ===================================================
        // ========== APLICAR SAVE =============================
        // ===================================================
        saveManager.ApplyTo(GridService);

        // ===================================================
        // ========== APLICAR DELETE ===========================
        // ===================================================            
        ApplyDeletes(deleteManager);

        // ===================================================
        // ========== UN SOLO COMMIT ===========================
        // ===================================================
        await GridService.ExecuteAsync();

        // ===================================================
        // LIMPIEZA FINAL
        // ===================================================
        ClearAllPendingDeletes();
        RemoveDeletedRowsAndResetStates();
        ClearAllSelectionsAsync();
        ClearPendingUiChanges();
        RefreshAllBaseSnapshotsAfterSave();
        await ShowSaveSuccessForAsync(3000);
    }

    private static (bool IsIn, bool IsOut) GetFlowFlags(FlowType flowType) => flowType switch
    {
        FlowType.Inbound  => (true,  false),
        FlowType.Outbound => (false, true),
        FlowType.Custom   => (false, false),
        _ => (true, false)
    };

