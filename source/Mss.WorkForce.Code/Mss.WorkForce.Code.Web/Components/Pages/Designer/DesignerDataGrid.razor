    private void ApplyDeletes(DeleteManager deleteManager)
    {
        if (PendingDeleteProcessIds.Any())
            deleteManager.DeleteProcesses(PendingDeleteProcessIds);

        if (PendingDeleteAreaIds.Any())
            deleteManager.DeleteAreas(PendingDeleteAreaIds);

        if (PendingDeleteDirectionIds.Any())
            deleteManager.DeleteProcessDirections(PendingDeleteDirectionIds);

        if (PendingDeleteZoneIds.Any())
            deleteManager.DeleteZones(PendingDeleteZoneIds);

        if (PendingDeleteEquipmentIds.Any())
            deleteManager.DeleteEquipments(PendingDeleteEquipmentIds);

        if (PendingDeleteRouteIds.Any())
            deleteManager.DeleteRoutes(PendingDeleteRouteIds);
    }

    private void RequestProcessPagerSync()
    {
        _processSyncCts?.Cancel();
        _processSyncCts = new CancellationTokenSource();
        var token = _processSyncCts.Token;

        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(80, token);
                if (token.IsCancellationRequested) return;
                SyncProcessPagerFromGrid();
            }
            catch (TaskCanceledException) { }
        });
    }

    private Task OnProcessesLayoutAutoSaving(GridPersistentLayoutEventArgs e)
    {
        RequestProcessPagerSync();
        return Task.CompletedTask;
    }

    private void SyncProcessPagerFromGrid()
    {
        if (_processSyncInProgress) return;
        if (ProcessGridRef is null) return;

        _processSyncInProgress = true;
        try
        {
            var visible = ProcessGridRef.GetVisibleRowCount();
            var grouped = ProcessGridRef.GetGroupCount() > 0;

            int topGroups = 0;   // Only groups
            int dataRows = 0;   // In case there is no grouping

            for (int i = 0; i < visible; i++)
            {
                if (ProcessGridRef.IsGroupRow(i))
                {
                    // Main groups (does NOT change when expanded)
                    if (ProcessGridRef.GetRowLevel(i) == 0)
                        topGroups++;
                }
                else
                {
                    // Actual data rows (only for non-grouped mode)
                    if (ProcessGridRef.GetDataItem(i) is ProcessRow)
                        dataRows++;
                }
            }

            TotalItemsProcesses = grouped ? topGroups : dataRows;

            // PageCount based on what you decided to count
            var baseSize = (PageSizeMain == -1) ? Math.Max(1, TotalItemsProcesses) : BasePageSizeProcesses;
            PageCountProcesses = Math.Max(1, (int)Math.Ceiling((double)TotalItemsProcesses / baseSize));
            ActivePageIndexProcesses = Math.Clamp(ActivePageIndexProcesses, 0, PageCountProcesses - 1);
            PageIndexProcesses = ActivePageIndexProcesses;

            PagerRecordsProcesses = L.Loc("Page {0} of {1}, {2} Items", ActivePageIndexProcesses + 1, PageCountProcesses, TotalItemsProcesses);

            StateHasChanged();
        }
        finally
        {
            _processSyncInProgress = false;
        }
    }

    private void RequestAreasPagerSync()
    {
        _areasSyncCts?.Cancel();
        _areasSyncCts = new CancellationTokenSource();
        var token = _areasSyncCts.Token;

        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(80, token);
                if (token.IsCancellationRequested) return;
                SyncAreasPagerFromGrid();
            }
            catch (TaskCanceledException) { }
        });
    }

    private void SyncAreasPagerFromGrid()
    {
        if (_areasSyncInProgress) return;
        if (AreaGridRef is null) return;

        _areasSyncInProgress = true;
        try
        {
            var visible = AreaGridRef.GetVisibleRowCount();
            var dataRows = 0;
            var groupRowsLevel0 = 0;

            for (var i = 0; i < visible; i++)
            {
                if (AreaGridRef.IsGroupRow(i))
                {
                    if (AreaGridRef.GetRowLevel(i) == 0)
                        groupRowsLevel0++;

                    continue;
                }

                if (AreaGridRef.GetDataItem(i) is AreaRow)
                    dataRows++;
            }

            var total = groupRowsLevel0 > 0 ? groupRowsLevel0 : dataRows;
            TotalItemsAreas = total;
            var baseSize = (PageSizeMain == -1) ? Math.Max(1, TotalItemsAreas) : BasePageSizeAreas;
            PageCountAreas = Math.Max(1, (int)Math.Ceiling((double)TotalItemsAreas / baseSize));

            ActivePageIndexAreas = Math.Clamp(ActivePageIndexAreas, 0, PageCountAreas - 1);
            PageIndexAreas = ActivePageIndexAreas;
            PagerRecordsAreas = L.Loc("Page {0} of {1}, {2} Items",ActivePageIndexAreas + 1, PageCountAreas, TotalItemsAreas);

            StateHasChanged();
        }
        finally
        {
            _areasSyncInProgress = false;
        }
    }

    private Task OnAreasLayoutAutoSaving(GridPersistentLayoutEventArgs e)
    {
        RequestAreasPagerSync();
        return Task.CompletedTask;
    }
