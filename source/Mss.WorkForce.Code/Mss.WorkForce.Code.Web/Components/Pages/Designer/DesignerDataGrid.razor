    // ======== Paginación / selección: PRINCIPALES ========
    private void ReloadProcessesPager()
    {
        TotalItemsProcesses = Processes?.Count ?? 0;

        var size = PageSizeMain == -1 ? Math.Max(1, TotalItemsProcesses) : Math.Max(1, PageSizeMain);
        PageCountProcesses = Math.Max(1, (int)Math.Ceiling((double)TotalItemsProcesses / size));

        ActivePageIndexProcesses = Math.Clamp(ActivePageIndexProcesses, 0, PageCountProcesses - 1);
        PageIndexProcesses = ActivePageIndexProcesses;
        PagerRecordsProcesses = L.Loc("Page {0} of {1}, {2} Items", ActivePageIndexProcesses + 1, PageCountProcesses, TotalItemsProcesses);
        StateHasChanged();
    }

    private void ReloadAreasPagerFromGrid(bool callStateHasChanged = true)
    {
        if (AreaGridRef is null)
            return;

        TotalItemsAreas = CountVisibleAreaDataRows();

        var size = PageSizeMain == -1 ? Math.Max(1, TotalItemsAreas) : Math.Max(1, PageSizeMain);
        PageCountAreas = Math.Max(1, (int)Math.Ceiling((double)TotalItemsAreas / size));

        ActivePageIndexAreas = Math.Clamp(ActivePageIndexAreas, 0, PageCountAreas - 1);
        PageIndexAreas = ActivePageIndexAreas;

        PagerRecordsAreas = L.Loc("Page {0} of {1}, {2} Items",
            ActivePageIndexAreas + 1, PageCountAreas, TotalItemsAreas);

        if (callStateHasChanged) StateHasChanged();
    }

    private int CountVisibleAreaDataRows()
    {
        if (AreaGridRef is null) return 0;

        var visible = AreaGridRef.GetVisibleRowCount();
        var count = 0;

        for (var i = 0; i < visible; i++)
            if (AreaGridRef.GetDataItem(i) is AreaRow)
                count++;

        return count;
    }

    private void SyncAreasPageSizeExtraToGrouping()
    {
        if (AreaGridRef is null || PageSizeMain == -1)
            return;

        var baseSize = Math.Max(1, PageSizeMain);

        var start = PageIndexAreas * baseSize;
        var remaining = Math.Max(0, TotalItemsAreas - start);
        var expectedDataRows = Math.Min(baseSize, remaining);

        var dataRows = CountVisibleAreaDataRows();
        var delta = expectedDataRows - dataRows;

        ReloadAreasPagerFromGrid(callStateHasChanged: false);
        StateHasChanged();
    }

