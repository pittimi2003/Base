    private void ExecuteGlobalDelete()
    {
        // Processes
        if (SelectedProcesses.Any())
        {
            var toDelete = SelectedProcesses.ToList();
            foreach (var pr in toDelete)
            {
                if (pr.RowState != RowState.New) PendingDeleteProcessIds.Add(pr.Id);
                Processes.Remove(pr);
                SelectedProcesses.Remove(pr);
            }
            ReloadProcessesPager();
            SelectedRecordsProcesses = $"{L.Loc("Selected")}: {SelectedProcesses.Count}";
        }

        // Areas
        if (SelectedAreas.Any())
        {
            var toDelete = SelectedAreas.ToList();
            foreach (var ar in toDelete)
            {
                if (ar.RowState != RowState.New) PendingDeleteAreaIds.Add(ar.Id);
                Areas.Remove(ar);
                SelectedAreas.Remove(ar);
            }
            AreasLookup = Areas.Select(a => new LookupItem { Id = a.Id, Name = a.Name }).ToList();
            ReloadAreasPager();
            SelectedRecordsAreas = $"{L.Loc("Selected")}: {SelectedAreas.Count}";
        }

        // Directions
        foreach (var p in Processes)
        {
            if (p.Directions is null || !(p.SelectedDirections?.Any() ?? false)) continue;

            var toDeleteDir = p.SelectedDirections.ToList();
            foreach (var d in toDeleteDir)
            {
                if (d.RowState != RowState.New) PendingDeleteDirectionIds.Add(d.Id);
                p.Directions.Remove(d);
                p.SelectedDirections.Remove(d);
            }
        }

        // Zones / Equipments / Routes
        foreach (var a in Areas)
        {
            if (a.Zones is not null && (a.SelectedZones?.Any() ?? false))
            {
                var toDeleteZones = a.SelectedZones.ToList();
                foreach (var z in toDeleteZones)
                {
                    if (z.RowState != RowState.New) PendingDeleteZoneIds.Add(z.Id);
                    a.Zones.Remove(z);
                    a.SelectedZones.Remove(z);
                }
            }

            if (a.Equipments is not null && (a.SelectedEquipments?.Any() ?? false))
            {
                var toDeleteEquip = a.SelectedEquipments.ToList();
                foreach (var e in toDeleteEquip)
                {
                    if (e.RowState != RowState.New) PendingDeleteEquipmentIds.Add(e.Id);
                    a.Equipments.Remove(e);
                    a.SelectedEquipments.Remove(e);
                }
            }

            if (a.Routes is not null && (a.SelectedRoutes?.Any() ?? false))
            {
                var toDeleteRoutes = a.SelectedRoutes.ToList();
                foreach (var r in toDeleteRoutes)
                {
                    if (r.RowState != RowState.New) PendingDeleteRouteIds.Add(r.Id);
                    a.Routes.Remove(r);
                    a.SelectedRoutes.Remove(r);
                }
            }
        }
    }

    private void ConfirmDelete()
    {
        // 1) Caso especial: borrado GLOBAL (desde botón o tecla Supr)
        if (DeleteScope == DeleteScopeKind.Global)
        {
            // Reutilizamos la lógica ya existente que:
            // - quita elementos de las colecciones (Processes, Areas, etc.)
            // - rellena PendingDelete*Ids
            ExecuteGlobalDelete();

            // Cerrar modal y resetear estado del diálogo
            _ = HideDeleteConfirmation();
            StateHasChanged();
            return;
        }

        // 2) Resto de casos: borrados por ámbito (Processes, Areas, etc.)
        var items = SnapshotToDelete?.ToList() ?? new List<object>();

        switch (DeleteScope)
        {
            case DeleteScopeKind.Processes:
                foreach (var o in items)
                {
                    if (o is ProcessRow pr)
                    {
                        if (pr.RowState != RowState.New)
                            PendingDeleteProcessIds.Add(pr.Id);

                        Processes.Remove(pr);
                        SelectedProcesses.Remove(pr);
                    }
                }
                ReloadProcessesPager();
                SelectedRecordsProcesses = $"{L.Loc("Selected")}: {SelectedProcesses.Count}";
                break;

            case DeleteScopeKind.Areas:
                foreach (var o in items)
                {
                    if (o is AreaRow ar)
                    {
                        if (ar.RowState != RowState.New)
                            PendingDeleteAreaIds.Add(ar.Id);

                        Areas.Remove(ar);
                        SelectedAreas.Remove(ar);
                    }
                }
                AreasLookup = Areas.Select(a => new LookupItem { Id = a.Id, Name = a.Name }).ToList();
                ReloadAreasPager();
                SelectedRecordsAreas = $"{L.Loc("Selected")}: {SelectedAreas.Count}";
                break;

            case DeleteScopeKind.Directions:
                if (OwnerProcess is not null && OwnerProcess.Directions is not null)
                {
                    foreach (var o in items)
                    {
                        if (o is ProcessDirectionRow dr)
                        {
                            if (dr.RowState != RowState.New)
                                PendingDeleteDirectionIds.Add(dr.Id);

                            OwnerProcess.Directions.Remove(dr);
                            OwnerProcess.SelectedDirections.Remove(dr);
                        }
                    }
                }
                break;

            case DeleteScopeKind.Zones:
                if (OwnerArea is not null && OwnerArea.Zones is not null)
                {
                    foreach (var o in items)
                    {
                        if (o is ZoneRow z)
                        {
                            if (z.RowState != RowState.New)
                                PendingDeleteZoneIds.Add(z.Id);

                            OwnerArea.Zones.Remove(z);
                            OwnerArea.SelectedZones.Remove(z);
                        }
                    }
                }
                break;

            case DeleteScopeKind.Equipments:
                if (OwnerArea is not null && OwnerArea.Equipments is not null)
                {
                    foreach (var o in items)
                    {
                        if (o is EquipmentGroupRow e)
                        {
                            if (e.RowState != RowState.New)
                                PendingDeleteEquipmentIds.Add(e.Id);

                            OwnerArea.Equipments.Remove(e);
                            OwnerArea.SelectedEquipments.Remove(e);
                        }
                    }
                }
                break;

            case DeleteScopeKind.Routes:
                if (OwnerArea is not null && OwnerArea.Routes is not null)
                {
                    foreach (var o in items)
                    {
                        if (o is RouteRow r)
                        {
                            if (r.RowState != RowState.New)
                                PendingDeleteRouteIds.Add(r.Id);

                            OwnerArea.Routes.Remove(r);
                            OwnerArea.SelectedRoutes.Remove(r);
                        }
                    }
                }
                break;
        }

        // 3) Cerrar modal y refrescar UI
        _ = HideDeleteConfirmation();
        StateHasChanged();
    }

    // ===== Delete tecla suprimir =====
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Solo queremos reaccionar a la tecla Delete / Supr
        if (e.Key != "Delete")
            return;

        // Si ya hay un modal de confirmación abierto, no hacemos nada
        if (showDeleteConfirmation)
            return;

        // Si no hay nada seleccionado en ningún grid, no hay nada que borrar
        if (!HasAnySelection)
            return;

        // Preguntar a JS si es seguro manejar Delete
        // (es decir, no estamos escribiendo en un input/textarea/contentEditable)
        var canHandle = await JS.InvokeAsync<bool>("mssDesigner.canHandleDeleteKey");
        if (!canHandle)
            return;

        // MISMO flujo que el botón global
        OpenGlobalDeleteModal();
    }

