    private async Task ShowSaveSuccessForAsync(int milliseconds)
    {
        var token = ++_saveSuccessToken;

        ShowSaveSuccess = true;
        SuccessMessage = L.Loc("Changes saved"); // Text message
        StateHasChanged();

        await Task.Delay(milliseconds);

        if (token != _saveSuccessToken) return; // If there was another save, it is not hidden

        ShowSaveSuccess = false;
        StateHasChanged();
    }

    private void RemoveDeletedRowsAndResetStates()
    {
        foreach (var p in Processes.ToList())
        {
            if (p.RowState == RowState.Deleted) { Processes.Remove(p); continue; }
            p.RowState = RowState.Unchanged;

            if (p.Directions != null)
            {
                p.Directions.RemoveAll(d => d.RowState == RowState.Deleted);
                foreach (var d in p.Directions) d.RowState = RowState.Unchanged;
            }
            p.SelectedDirections.Clear();
            p.PageIndex_Dir = 0; p.ActivePageIndex_Dir = 0;
        }

        foreach (var a in Areas.ToList())
        {
            if (a.RowState == RowState.Deleted) { Areas.Remove(a); continue; }
            a.RowState = RowState.Unchanged;

            if (a.Zones != null)
            {
                a.Zones.RemoveAll(z => z.RowState == RowState.Deleted);
                foreach (var z in a.Zones) z.RowState = RowState.Unchanged;
            }

            if (a.Equipments != null)
            {
                a.Equipments.RemoveAll(e => e.RowState == RowState.Deleted);
                foreach (var e in a.Equipments) e.RowState = RowState.Unchanged;
            }

            if (a.Routes != null)
            {
                a.Routes.RemoveAll(r => r.RowState == RowState.Deleted);
                foreach (var r in a.Routes) r.RowState = RowState.Unchanged;
            }

            a.SelectedZones.Clear(); a.SelectedEquipments.Clear(); a.SelectedRoutes.Clear();
            a.PageIndex_Zones = 0; a.ActivePageIndex_Zones = 0;
            a.PageIndex_Equipments = 0; a.ActivePageIndex_Equipments = 0;
            a.PageIndex_Routes = 0; a.ActivePageIndex_Routes = 0;
        }

        AreasLookup = Areas.Select(a => new LookupItem { Id = a.Id, Name = a.Name }).ToList();

        ReloadProcessesPager();
        ReloadAreasPager();
    }

    private void ClearAllPendingDeletes()
    {
        PendingDeleteProcessIds.Clear();
        PendingDeleteAreaIds.Clear();
        PendingDeleteDirectionIds.Clear();
        PendingDeleteZoneIds.Clear();
        PendingDeleteEquipmentIds.Clear();
        PendingDeleteRouteIds.Clear();
    }

    private void ClearAllSelectionsAsync()
    {
        // Clean Process Case
        SelectedProcesses.Clear();
        SelectedRecordsProcesses = $"{L.Loc("Selected")}: 0";

        foreach (var p in Processes)
            p.SelectedDirections?.Clear();

        // Clean Area Case
        SelectedAreas.Clear();
        SelectedRecordsAreas = $"{L.Loc("Selected")}: 0";

        foreach (var a in Areas)
        {
            a.SelectedZones?.Clear();
            a.SelectedEquipments?.Clear();
            a.SelectedRoutes?.Clear();
        }
    }

    // ===== Delete global (agrupado por tipo) =====
    private void OpenGlobalDeleteModal()
    {
        var selectedProcesses = SelectedProcesses.ToList();
        var selectedAreas = SelectedAreas.ToList();

        var selectedDirections = new List<(ProcessRow Owner, ProcessDirectionRow Item)>();
        var selectedZones = new List<(AreaRow Owner, ZoneRow Item)>();
        var selectedEquipments = new List<(AreaRow Owner, EquipmentGroupRow Item)>();
        var selectedRoutes = new List<(AreaRow Owner, RouteRow Item)>();

        foreach (var p in Processes)
        {
            if (p.SelectedDirections?.Any() ?? false)
            {
                foreach (var d in p.SelectedDirections)
                {
                    selectedDirections.Add((p, d));
                }
            }
        }

        foreach (var a in Areas)
        {
            if (a.SelectedZones?.Any() ?? false)
            {
                foreach (var z in a.SelectedZones)
                {
                    selectedZones.Add((a, z));
                }
            }

            if (a.SelectedEquipments?.Any() ?? false)
            {
                foreach (var e in a.SelectedEquipments)
                {
                    selectedEquipments.Add((a, e));
                }
            }

            if (a.SelectedRoutes?.Any() ?? false)
            {
                foreach (var r in a.SelectedRoutes)
                {
                    selectedRoutes.Add((a, r));
                }
            }
        }

        var totalCount =
            selectedProcesses.Count +
            selectedAreas.Count +
            selectedDirections.Count +
            selectedZones.Count +
            selectedEquipments.Count +
            selectedRoutes.Count;

        if (totalCount == 0)
        {
            return;
        }

        IsGlobalDelete = true;
        DeleteScope = DeleteScopeKind.Global;
        OwnerProcess = null;
        OwnerArea = null;
        SnapshotToDelete.Clear();
        DeletePreview = null;

        DeleteGroups = new List<DeleteGroupInfo>();

        if (selectedProcesses.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Processes"),
                Items = selectedProcesses.Select(p => p.Name).ToList()
            });
        }

        if (selectedAreas.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Areas"),
                Items = selectedAreas.Select(a => a.Name).ToList()
            });
        }

        if (selectedDirections.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Directions"),
                Items = selectedDirections.Select(x =>
                {
                    var owner = x.Owner;
                    var d = x.Item;
                    var destName = Processes.FirstOrDefault(p => p.Id == (d.EndProcessId ?? Guid.Empty))?.Name ?? "-";
                    return $"{owner.Name} -> {destName}";
                }).ToList()
            });
        }

        if (selectedZones.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Zones"),
                Items = selectedZones.Select(x => x.Item.Name).ToList()
            });
        }

        if (selectedEquipments.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Equipments"),
                Items = selectedEquipments.Select(x => x.Item.Name).ToList()
            });
        }

        if (selectedRoutes.Any())
        {
            DeleteGroups.Add(new DeleteGroupInfo
            {
                Title = L.Loc("Routes"),
                Items = selectedRoutes.Select(x =>
                {
                    var areaOwner = x.Owner;
                    var r = x.Item;
                    var arrivalName = areaOwner.Name;
                    if (r.ArrivalAreaId.HasValue)
                    {
                        var arr = AreasLookup.FirstOrDefault(al => al.Id == r.ArrivalAreaId.Value);
                        if (arr != null) arrivalName = arr.Name;
                    }
                    return $"{areaOwner.Name} -> {arrivalName}";
                }).ToList()
            });
        }

        DeleteTitle = L.Loc("Delete");
        DeleteMessage = L.Loc("You are about to remove {0} selected items.", totalCount);

        showDeleteConfirmation = true;
    }

