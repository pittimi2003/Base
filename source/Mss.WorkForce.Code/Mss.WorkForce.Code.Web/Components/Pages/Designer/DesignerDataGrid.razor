    /// <summary>
    /// Devuelve la lista de ZoneType válidos para las zonas de un Area concreto,
    /// aplicando la regla:
    /// Dock   -> Dock
    /// Buffer -> Buffer
    /// Stage  -> Stage
    /// Storage -> Rack, DriveIn, ChaoticStorage, AutomaticStorage
    /// </summary>
    private IReadOnlyList<ComboGeneric<string>> GetZoneTypeItemsForArea(AreaRow? area)
    {
        if (area is null || string.IsNullOrWhiteSpace(area.Type))
            return ZoneTypeItemsAll
                .Select(x => new ComboGeneric<string>
                {
                    Value = x.Value,
                    Description = L.Loc(x.Description)
                })
                .OrderBy(x => x.Description, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

        ObjectsTypes.AreaType areaType;
        try
        {
            areaType = ObjectsTypes.GetAreaTypeEnum(area.Type);
        }
        catch
        {
            return ZoneTypeItemsAll
                .Select(x => new ComboGeneric<string>
                {
                    Value = x.Value,
                    Description = L.Loc(x.Description)
                })
                .OrderBy(x => x.Description, StringComparer.CurrentCultureIgnoreCase)
                .ToList();
        }

        if (!AllowedZoneTypeValuesByAreaType.TryGetValue(areaType, out var allowedValues))
            return ZoneTypeItemsAll
                .Select(x => new ComboGeneric<string>
                {
                    Value = x.Value,
                    Description = L.Loc(x.Description)
                })
                .OrderBy(x => x.Description, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

        var list = new List<ComboGeneric<string>>(allowedValues.Length);

        foreach (var val in allowedValues)
        {
            if (ZoneTypeItemByValue.TryGetValue(val, out var item))
            {
                list.Add(new ComboGeneric<string>
                {
                    Value = item.Value,
                    Description = L.Loc(item.Description) 
                });
            }
        }

        return list
            .OrderBy(x => x.Description, StringComparer.CurrentCultureIgnoreCase)
            .ToList();
    }

    /// <summary>
    /// Texto para mostrar en la columna Type de Zones.
    /// Intenta mapear el string almacenado a uno de los items conocidos y devolver su Description.
    /// Si no encaja, devuelve el string tal cual.
    /// </summary>
    private string GetZoneTypeDisplay(string? rawType)
    {
        if (string.IsNullOrWhiteSpace(rawType))
            return L.Loc("Select...");

        if (ZoneTypeItemByValue.TryGetValue(rawType, out var item))
            return L.Loc(item.Description);

        return rawType!;
    }



