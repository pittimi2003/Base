    // Centralize ALL this repeated logic
    private bool ApplyEditAndTrackCells<T>(GridEditModelSavingEventArgs e, T row, T edited) where T : class, ITrackableRow
    {
        var assignedId = Guid.Empty;
        if (e.IsNew)
        {
            TryEnsureRowId(row);
            assignedId = TryGetRowId(row);
        }

        var (hasChanges, changedFields) = DetectChanges(edited, row);
        if (!hasChanges)
        {
            return false;
        }

        e.CopyChangesToDataItem();

        if (e.IsNew && TryGetRowId(row) == Guid.Empty && assignedId != Guid.Empty)
            SetRowId(row, assignedId);

        var rowId = TryGetRowId(row);
        if (rowId != Guid.Empty)
        {
            foreach (var field in changedFields)
                _editedCells.Add((rowId, field));
        }

        if (e.IsNew)
            row.RowState = RowState.New;
        else if (row.RowState == RowState.Unchanged)
            row.RowState = RowState.Modified;

        return true;
    }

    private static bool TryEnsureRowId(object row)
    {
        var prop = GetIdProp(row.GetType());
        if (prop is null) return false;

        var id = (Guid)(prop.GetValue(row) ?? Guid.Empty);
        if (id != Guid.Empty) return true;

        prop.SetValue(row, Guid.NewGuid());
        return true;
    }

    private static Guid TryGetRowId(object row)
    {
        var prop = GetIdProp(row.GetType());
        if (prop is null) return Guid.Empty;

        return (Guid)(prop.GetValue(row) ?? Guid.Empty);
    }

    private static System.Reflection.PropertyInfo? GetIdProp(Type t)
    {
        return _idPropCache.GetOrAdd(t, static type =>
        {
            var p = type.GetProperty("Id");
            return (p?.PropertyType == typeof(Guid) && p.CanRead && p.CanWrite) ? p : null;
        });
    }

    private static void SetRowId(object row, Guid id)
    {
        var prop = GetIdProp(row.GetType());
        prop?.SetValue(row, id);
    }

