    /// <summary>
    /// Texto de display para la columna Type de Areas.
    /// Intenta mapear el string almacenado al enum AreaType y luego a su descripción.
    /// Si no encaja (valor legacy/inesperado), devuelve el string tal cual.
    /// </summary>
    private string GetAreaTypeDisplay(string? rawType)
    {
        if (string.IsNullOrWhiteSpace(rawType))
            return L.Loc("Select..."); // 👈 placeholder uniforme

        try
        {
            var enumVal = ObjectsTypes.GetAreaTypeEnum(rawType);
            return L.Loc(ObjectsTypes.GetAreaTypeString(enumVal));
        }
        catch
        {
            // No romper UI si llega algo raro de BBDD
            return rawType!;
        }
    }

