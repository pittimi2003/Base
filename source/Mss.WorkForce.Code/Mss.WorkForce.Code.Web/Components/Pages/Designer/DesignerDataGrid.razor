    // ======== Helpers ========
    private static bool IsNew(ITrackableRow? r) => r is not null && r.RowState == RowState.New;

    private int GetPageCount<T>(ICollection<T>? data, int pageSize)
    {
        var total = data?.Count ?? 0;
        if (pageSize <= 0 || pageSize == int.MaxValue) return 1; // "All"
        var size = Math.Max(1, pageSize);
        return Math.Max(1, (int)Math.Ceiling((double)total / size));
    }


    private string GetNextName<T>(
        IEnumerable<T> source,
        Func<T, string?> nameSelector,
        string baseName)
    {
        if (string.IsNullOrWhiteSpace(baseName))
            baseName = "New";

        var prefix = "." + baseName.Trim();

        var existing = (source ?? Enumerable.Empty<T>())
            .Select(nameSelector)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Select(n => n!.Trim())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        // Si "New" no existe, regresamos directo
        if (!existing.Contains(prefix))
            return prefix;

        // Buscar New1, New2, New3...
        var index = 1;
        while (existing.Contains(prefix + index))
        {
            index++;
        }

        return prefix + index;
    }

