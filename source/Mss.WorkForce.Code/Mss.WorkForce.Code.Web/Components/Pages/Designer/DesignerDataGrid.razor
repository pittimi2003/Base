    private static readonly HashSet<string> RightAlignFields =
        new(StringComparer.OrdinalIgnoreCase)
        {
            nameof(AreaRow.ZonesCount),
            nameof(AreaRow.RoutesCount),
            nameof(AreaRow.EquipmentsCount),
            nameof(ProcessRow.ProcessDirectionsCount),
            nameof(EquipmentGroupRow.Quantity),
            nameof(ZoneRow.MaxContainers),
            nameof(ZoneRow.MaxEquipments),
            nameof(ProcessRow.MinTime),
