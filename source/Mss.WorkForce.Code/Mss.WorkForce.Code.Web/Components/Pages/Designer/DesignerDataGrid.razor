    private void InitBaseSnapshot<TRow>(
        IEnumerable<TRow> rows,
        Dictionary<Guid, Dictionary<string, object?>> baseStore,
        IReadOnlyList<string> fields,
        bool clearEditedCells = false)
        where TRow : class, ITrackableRow
    {
        baseStore.Clear();
        if (clearEditedCells) _editedCells.Clear();

        foreach (var r in rows)
        {
            var dict = new Dictionary<string, object?>(StringComparer.Ordinal);
            foreach (var f in fields)
                dict[f] = GetPropValue(r, f);

            baseStore[r.Id] = dict;
        }
    }

    private void RecalcEditedCellsForRow<TRow>(
    TRow row,
    Dictionary<Guid, Dictionary<string, object?>> baseStore,
    IReadOnlyList<string> fields)
    where TRow : class, ITrackableRow
    {
        if (!baseStore.TryGetValue(row.Id, out var baseRow))
            return;

        _editedCells.RemoveWhere(x => x.RowId == row.Id);

        foreach (var field in fields)
        {
            baseRow.TryGetValue(field, out var baseValue);
            var currentValue = GetPropValue(row, field);

            if (!EqualsNormalized(baseValue, currentValue))
                _editedCells.Add((row.Id, field));
        }

        if (row.RowState != RowState.New)
            row.RowState = _editedCells.Any(x => x.RowId == row.Id) ? RowState.Modified : RowState.Unchanged;
    }


    private void CopyTrackedFields<TRow>(TRow from, TRow to, IReadOnlyList<string> fields)
    where TRow : class
    {
        foreach (var field in fields)
        {
            var prop = typeof(TRow).GetProperty(field);
            if (prop is null || !prop.CanRead || !prop.CanWrite) continue;
            prop.SetValue(to, prop.GetValue(from));
        }
    }

    private void RefreshAllBaseSnapshotsAfterSave()
    {
        InitBaseSnapshot(Areas, _baseAreas, AreaFields, clearEditedCells: true);
        InitBaseSnapshot(Processes, _baseProcesses, ProcessFields);

        InitBaseSnapshot(Areas.SelectMany(a => a.Zones ?? new List<ZoneRow>()), _baseZones, ZoneFields);
        InitBaseSnapshot(Areas.SelectMany(a => a.Routes ?? new List<RouteRow>()), _baseRoutes, RouteFields);
        InitBaseSnapshot(Areas.SelectMany(a => a.Equipments ?? new List<EquipmentGroupRow>()), _baseEquips, EquipFields);
        InitBaseSnapshot(Processes.SelectMany(p => p.Directions ?? new List<ProcessDirectionRow>()), _baseDirections, DirectionFields);
    }

    private static object? GetPropValue(object obj, string propName)
    {
        var p = obj.GetType().GetProperty(propName);
        return p?.GetValue(obj);
    }

    private static bool EqualsNormalized(object? a, object? b)
    {
        if (a is string sa && b is string sb)
            return string.Equals(sa, sb, StringComparison.Ordinal);

        return Equals(a, b);
    }

