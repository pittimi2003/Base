    private void OnCustomizeGridElement(GridCustomizeElementEventArgs e)
    {
        if (e.ElementType == GridElementType.DataRow)
        {
            var itemRow = e.Grid.GetDataItem(e.VisibleIndex) as ITrackableRow;
            if (itemRow is null) return;

            switch (itemRow.RowState)
            {
                case RowState.New: e.CssClass += " wl-row-new"; break;
                case RowState.Modified: e.CssClass += " wl-row-modified"; break;
                case RowState.Deleted: e.CssClass += " wl-row-deleted"; break;
            }
            return;
        }

        if (e.ElementType == GridElementType.DataCell && e.Column is DxGridDataColumn dataCol)
        {
            var item = e.Grid.GetDataItem(e.VisibleIndex) as ITrackableRow;

            if (dataCol.FieldName == nameof(AreaRow.ZonesCount) ||
                dataCol.FieldName == nameof(AreaRow.RoutesCount) ||
                dataCol.FieldName == nameof(AreaRow.EquipmentsCount) ||
                dataCol.FieldName == nameof(ProcessRow.ProcessDirectionsCount))
            {
                e.CssClass += " wl-cell-readonly";
            }
            else if (dataCol.FieldName == nameof(ProcessRow.Type) || 
                dataCol.FieldName == nameof(AreaRow.Type) || 
                dataCol.FieldName == nameof(ProcessRow.FlowId) || 
                dataCol.FieldName == nameof(ProcessRow.AreaId) || 
                dataCol.FieldName == nameof(ZoneRow.Type))
            {
                if (item?.RowState != RowState.New)
                    e.CssClass += " wl-cell-readonly";
            }

            var fieldName = dataCol.FieldName;
            if (!string.IsNullOrWhiteSpace(fieldName))
            {
                bool mustAlign = RightAlignFields.Contains(fieldName);

                if (!mustAlign)
                {
                    var dataItem = e.Grid.GetDataItem(e.VisibleIndex);
                    var prop = dataItem?.GetType().GetProperty(fieldName,
                        System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
                    var pType = prop is null ? null : Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;

                    if (pType is not null)
                    {
                        mustAlign =
                            pType == typeof(byte) || pType == typeof(sbyte) ||
                            pType == typeof(short) || pType == typeof(ushort) ||
                            pType == typeof(int) || pType == typeof(uint) ||
                            pType == typeof(long) || pType == typeof(ulong) ||
                            pType == typeof(float) || pType == typeof(double) ||
                            pType == typeof(decimal);
                    }
                }

                if (mustAlign)
                    e.CssClass += " wl-num-cell";
            }

            var fieldName2 = dataCol.FieldName;
            if (!string.IsNullOrWhiteSpace(fieldName2))
            {
                var dataItem = e.Grid.GetDataItem(e.VisibleIndex);
                Guid rowId = Guid.Empty;
            
                if (dataItem is ProcessRow pr) rowId = pr.Id;
                else if (dataItem is AreaRow ar) rowId = ar.Id;
                else if (dataItem is ProcessDirectionRow dr) rowId = dr.Id;
                else if (dataItem is ZoneRow zr) rowId = zr.Id;
                else if (dataItem is RouteRow rr) rowId = rr.Id;
                else if (dataItem is EquipmentGroupRow er) rowId = er.Id;
            
                if (rowId != Guid.Empty && _editedCells.Contains((rowId, fieldName2)))
                {
                    e.CssClass += " wl-cell-edited";
                }
            }
        }
    }

