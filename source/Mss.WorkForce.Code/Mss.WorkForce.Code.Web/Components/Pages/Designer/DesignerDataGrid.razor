    public class ViewportExtensions
    {
        public string? UpdateViewportName(string? viewportJson, string? newName)
        {
            // Si no hay JSON o el nombre nuevo está vacío, no hacemos nada
            if (string.IsNullOrWhiteSpace(viewportJson) || string.IsNullOrWhiteSpace(newName))
                return viewportJson;

            try
            {
                // Parseamos el JSON a un JsonObject dinámico
                var node = JsonNode.Parse(viewportJson) as JsonObject;
                if (node is null)
                    return viewportJson;

                // Actualizamos SOLO el campo Name
                node["Name"] = newName;

                // Volvemos a serializar
                return node.ToJsonString();
            }
            catch
            {
                // Si algo sale mal (JSON mal formado, etc.), regresamos el original
                return viewportJson;
            }
        }
    }

