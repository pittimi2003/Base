    [Parameter] public EventCallback<ObjectTypes> OnActionClick { get; set; }
    [Parameter] public EventCallback<(ObjectTypes type, object dto, Dictionary<string, object> meta)> OnActionObject { get; set; }

    [CascadingParameter] public object ObjectDto { get; set; } = new();

    private DesignerTabComponents? tabsComponent;
    private string? _pendingNavigationContext;

    Dictionary<Guid, ObjectsDto> newRecords = new();
    public AreaDto areaDto { get; set; } = new();
