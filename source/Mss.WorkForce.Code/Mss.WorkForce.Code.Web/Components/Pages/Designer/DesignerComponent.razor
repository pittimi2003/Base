                                                    <div class="flex-flow-row gap-10 align-items-center">
                                                        <DxTextBox CssClass="mlx-form-textbox width-100" Text="@ModalItemLocationZone.Area.Name" TextChanged="@((string? val) => OnNameChanged(val, () => ModalItemLocationZone.Area.Name, val => ModalItemLocationZone.Area.Name = val))" TextExpression="@(() => ModalItemLocationZone.Area.Name)" />
