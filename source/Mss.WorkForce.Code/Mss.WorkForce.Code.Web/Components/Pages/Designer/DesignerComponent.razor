                //quitar linea cuando se defina estructura de datos
                zoneDto.ZoneType = zoneDto.ZoneType == ZoneType.Unknown ? ZoneType.Shelf : zoneDto.ZoneType;
                switch (zoneDto.ZoneType)
                {
                    case ZoneType.Dock:
                        dockDto = _designer.GetDocksDtoByIdZoneAsNoTracking(zoneDto?.Id ?? Guid.Empty);
                        dockDto.Zone.Orientation = zoneDto.Orientation;
                        dockDto.Zone.Name = zoneDto.Name;
