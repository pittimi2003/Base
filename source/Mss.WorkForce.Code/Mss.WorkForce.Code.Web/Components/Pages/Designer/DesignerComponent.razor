    private void FillAreaComboBox(Guid layoutId, ObjectTypes objectTypes)
    {
        AreaType filterType;

        switch (objectTypes)
        {
            case ObjectTypes.Aisle:
            case ObjectTypes.Shelf:
                filterType = AreaType.Storage;
                break;

            case ObjectTypes.Buffer:
                filterType = AreaType.Buffer;
                break;

            case ObjectTypes.Stage:
                filterType = AreaType.Stage;
                break;

            default:
                filterType = GetAreaTypeFromObjectType(objectTypes);
                break;
        }

        AreaItems = _designer.GetAreasDtoByLayout(layoutId).Where(a => a.AreaType == filterType).ToList();

        // Specific settings by type
        if (objectTypes == ObjectTypes.Shelf)
        {
            ModalItemLocationZone.Quantity = 1;
            ModalItemLocationZone.Area ??= new();
            ModalItemLocationZone.Area.AreaType = filterType;
        }
        else if (objectTypes == ObjectTypes.Stage)
        {
            ModalItemStage.Area ??= new();
            ModalItemStage.Area.AreaType = filterType;
        }
        else if (objectTypes == ObjectTypes.Buffer || objectTypes == ObjectTypes.Aisle)
        {
            // Only when a new area is created
            if (ModalItemBuffer.Area != null)
                ModalItemBuffer.Area.AreaType = filterType;
        }
    }

