                        aisleDto.Zone.Orientation = zoneDto.Orientation;
                        aisleDto.Zone.StatusObject = zoneDto.StatusObject;
                        await ActionClick(ObjectTypes.Aisle); // Aisle click event handling
                        break;
                    case ZoneType.Buffer:
                        bufferDto = _designer.GetBufferDtoByIdZoneAsNoTracking(zoneDto?.Id ?? Guid.Empty);
                        bufferDto.Zone.Orientation = zoneDto.Orientation ?? OrientationType.None;
                        bufferDto.Zone.StatusObject = zoneDto.StatusObject;
