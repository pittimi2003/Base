    public RouteDto routeDto { get; set; } = new();
    public BufferDto bufferDto { get; set; } = new();
    public StageDto stageDto { get; set; } = new();
    public LayoutDto? layoutDto { get; set; } = new() { Viewport = string.Empty };
    public ModalBufferDto ModalItemBuffer { get; set; } = new();
    public ModalStageDto ModalItemStage { get; set; } = new(); // Property used to record and store data in modal Dock
    public ModalZoneDockDto ModalItemZoneDock { get; set; } = new();
    public ModalLocationZone ModalItemLocationZone { get; set; } = new();
    public ProcessDto processDto { get; set; } = new();
    public Object locationZone { get; set; } = new();
    public ProcessDirectionPropertyDto processDirectionPropertyDto { get; set; } = new();
    public FlowDto flowDto { get; set; } = new();
    private bool showModal = false;
    public bool hasRendered = false;
    private List<ComboBoxSelectItem<AreaType>> areaType { get; set; } = new();
    private List<ComboBoxSelectItem<DockType>> dockTypeList = new();
    private List<ComboBoxSelectItem<FlowType>> flowTypeList = new();
    private List<ComboBoxSelectItem<OrientationType>> orientationType = new();
    private List<ComboBoxSelectItem<LocationTypes>> locationTypes = new();
    private List<ComboBoxSelectItem<BufferType>> bufferTypes = new();
    private List<ComboBoxSelectItem<IsoutType>> Isinb = new();
    protected ObjectTypes objectType { get; set; } = new();
    private static readonly List<ObjectTypes> modalObjects = new() { ObjectTypes.Area, ObjectTypes.Route }; //List of cases that occupy the modal
    public DrawingBaseDesignerDto drawingDesignerDto { get; set; } = new();
    public bool isCreateNewArea = false;
    private bool isAddingNewArea = false;
    private bool isAddingShelfConfiguration = false;
    private ValidationMessageStore? messageStore;
    private bool _shouldRender = true;
    private IEnumerable<ParentFlowDto>? ParentFlowItems { get; set; }

    private bool showDeleteConfirmation = false;
    private bool showModalBackButton = false; // Used to show Back Button Modal
    private bool isActionBackButton = false; // Determines whether the Back button event is being used
    private bool showModalRevertButton = false; // Determines whether the Revert button event is being used
    private bool showModalInternalNavButton = false; // Determines whether the Revert button event is being used
    private bool _allowNextNavigation; // Flag that controls page break changes when you want to discard changes
    private string deleteMessage => L.Loc("Are you sure you want to delete the selected object?");
    private bool showToast;
    private string toastMessage = string.Empty;
    public UserFormatOptions userFormat { get; set; } = new();
    private bool _suppressNextToast;
    private DotNetObjectReference<DesignerComponent>? _dotNetRef;
    [Inject] private DesignerUiStateService UiState { get; set; } = default!;

    #region Modal

    private bool showUniversalModal = false;
    private ModalState modal = new();

    #endregion

    protected override bool ShouldRender()
    {
        return _shouldRender;
    }

    protected override async Task OnInitializedAsync()
    {
        processType = Enum.GetValues(typeof(ProcessType))
        .Cast<ProcessType>()
        .Select(pt => new ProcessDto
            {
                Type = pt,
                TypeName = L.Loc(GetProcessTypeString(pt))
            }).OrderBy(x => x.TypeName)
            .ToList();

        AllprocessTypes =
        Enum.GetValues(typeof(ProcessType))
           .Cast<ProcessType>()
           .Select(pt => new ProcessDto
                {
                    Type = pt,
                    TypeName = L.Loc(GetProcessTypeString(pt))
                }).OrderBy(x => x.TypeName)
               .ToList();


        dockTypeList = Enum.GetValues(typeof(DockType)).Cast<DockType>().Select(x => new ComboBoxSelectItem<DockType>(L) { Value = x, Text = GetDockTypeString(x) }).OrderBy(x => x.Text).ToList(); // Listing for the Dock combo of the Dock modal
        flowTypeList = Enum.GetValues(typeof(FlowType)).Cast<FlowType>().Select(x => new ComboBoxSelectItem<FlowType>(L) { Value = x, Text = GetFlowTypeString(x) }).OrderBy(x => x.Text).ToList(); // Listing for the Flow combo of the Flow modal
        orientationType = Enum.GetValues(typeof(OrientationType)).Cast<OrientationType>().Where(x => x != OrientationType.None).Select(x => new ComboBoxSelectItem<OrientationType>(L) { Value = x, Text = x.ToString() }).OrderBy(x => x.Text).ToList();
        locationTypes = Enum.GetValues(typeof(LocationTypes)).Cast<LocationTypes>().Select(x => new ComboBoxSelectItem<LocationTypes>(L) { Value = x, Text = GetStringFromLocationTypes(x) }).OrderBy(x => x.Text).ToList();
        bufferTypes = Enum.GetValues(typeof(BufferType)).Cast<BufferType>().Where(x => x != BufferType.None).Select(x => new ComboBoxSelectItem<BufferType>(L) { Value = x, Text = GetBufferTypeString(x) }).OrderBy(x => x.Text).ToList();
        Isinb = Enum.GetValues(typeof(IsoutType)).Cast<IsoutType>().Where(x => x != IsoutType.None).Select(x => new ComboBoxSelectItem<IsoutType>(L) { Value = x, Text = GetIsoutTypeString(x) }).OrderBy(x => x.Text).ToList();
        userFormat = _InitialDataService.GetUserFormat();
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync(
          "registerDesignerDotNetRef",
          _dotNetRef
      );
        if (editContext != null)
        {
            editContext.OnFieldChanged -= EditContext_OnFieldChanged;
            editContext.OnFieldChanged += EditContext_OnFieldChanged;
            ValidateCurrentModal(objectType); // First validation to determine whether Save starts enabled/disabled
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("registerBeforeUnload"); // Records the BeforeUnload event when the page starts up
        }
        if (!hasRendered && _shouldRender)
        {
            hasRendered = true;
            _shouldRender = false;

            await JS.InvokeVoidAsync("floatMenuActions");
            CreateCanvas(false);
            await JS.InvokeVoidAsync("SetdotnetHelper", DotNetObjectReference.Create(this));
            // Restaurar selección 
            await Task.Delay(300);
            await RestoreTabsBaseStateIfAnyAsync();
            await RestoreSelectionIfAnyAsync();
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("unregisterBeforeUnload"); // Clears the event BeforeUnload when the component is destroyed

            if (JS is not null)
                await JS.InvokeVoidAsync("unregisterDesignerDotNetRef");

        }
        catch
        {
            // si ya se está cerrando el circuito, ignora
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    public override async Task SetParametersAsync(ParameterView parameters)
    {
        hasRendered = false;
        await base.SetParametersAsync(parameters);
    }

    private class ModalState
    {
        public string? Title { get; set; }
        public string? Message { get; set; }
        public RenderFragment? Footer { get; set; }
        public Action? OnClose { get; set; }  // Event close
    }

    // Method for handling the click
    private async Task ActionClick(ObjectTypes objectTypes)
    {
        var dto = ObjectDataType(objectTypes); // We obtain the DTO to open
        await OnActionClick.InvokeAsync(objectTypes); // Notify Designer: “I'm going to open a grandchild.”
        await OnActionObject.InvokeAsync((objectTypes, dto, new Dictionary<string, object> // Send object + metadata to Designer
            {
                ["FromDesignerComponent"] = true,
                ["SourceComponent"] = nameof(DesignerComponent),
                ["RequestedType"] = objectTypes.ToString()
            })
        );
        await OnClickSideBar.InvokeAsync(); // Open Drawer (SideBar)
        if (modalObjects.Contains(objectTypes)) // If modal, close modal
        {
            CloseModal();
        }
        else
            _shouldRender = false;
    }

    private async Task HandleDeleteFromTab((Guid guid, FlowType flowType)data)
    {
        (Guid guid, FlowType flowType) = data;
        var (flowId, flowName) = _designer.GetFlowInfoFromType(data.guid, data.flowType); // Get the actual FlowId
        if (flowId == null)
            return;


        bool hasDependencies = _designer.HasProcessDependenciesToFlow(flowId.Value);

        // Has dependency
        if (hasDependencies)
        {
            ShowModal(
                title: L.Loc("NOTIFICATION"),
                message: string.Format(L.Loc("It is not possible to delete the {0} flow because it has linked processes."), flowName),
                footer: FooterCancel()
            );
            return;
        }

        // It has no dependency
        ShowModal(
            title: L.Loc("Confirm Delete"),
            message: string.Format(L.Loc("Are you sure you want to delete the {0} flow?"),flowName),
            footer: FooterNoYes(() => ConfirmDeleteFlow(flowId.Value, flowType))
        );
        await Task.CompletedTask;
    }

    private async Task ConfirmDeleteFlow(Guid flowId, FlowType type)
    {
        await _designer.DeleteFlowGraphAsync(flowId, type); // Delete the record
        tabsComponent?.RecalculateRelatedElements(); // Recalculate the tabs
        CreateCanvas(true); // Refresh the canvas
        RenderDataPage();
        HideModal(); // Close Modal
    }

    #region Back Button

    // Show Back Button modal
    [JSInvokable]
    public void ShowModalBackButton()
    {
        _shouldRender = true;
        showModalBackButton = true; // Show modal
        StateHasChanged();
        _shouldRender = false;
    }

    // Event to go to the Project view
    [JSInvokable]
    public void ExitDesignerPage()
    {
        ActionClickClear();
    }

    // Call the BackButtonValidateMessageSave function to evaluate if there is pending content to be saved
    private async Task OpenModalBackButton()
    {
        await JS.InvokeVoidAsync("BackButtonValidateMessageSave");
        _SendParamService.ActiveProjectName = null;
        _SendParamService.ReloadInitData = true;
    }

    //Action Save, close modal and Go to Project View
    private async Task SaveAndExit()
    {
        isActionBackButton = true;
        await JS.InvokeAsync<Task>("BackButtonSaveAndExit");
        CloseModalBackButton();
        ActionClickClear();
    }

    //Action close modal Back Button
    private void CloseModalBackButton()
    {
        showModalBackButton = false;
        RenderDataPage();
    }

    // Used to exit the view and clear data
    private async Task ActionClickClear()
    {
        await OnClickClear.InvokeAsync();
    }

    #endregion

    private Object ObjectDataType(ObjectTypes objectData)
    {
        ObjectDto = new();
        switch (objectData)
        {
            case ObjectTypes.Area:
                showModal = false; //Close modal
                ObjectDto = areaDto;
                break;
            case ObjectTypes.Aisle:
                ObjectDto = aisleDto;
                break;
            case ObjectTypes.Route:
                showModal = false; //Close modal
                ObjectDto = routeDto;
                break;
            case ObjectTypes.Dock:
                ObjectDto = dockDto;
                break;
            case ObjectTypes.Buffer:
                ObjectDto = bufferDto;
                break;
            case ObjectTypes.Shelf:
            case ObjectTypes.Rack:
            case ObjectTypes.DriveIn:
            case ObjectTypes.CaoticStorage:
            case ObjectTypes.AutomaticStorage:
                ObjectDto = locationZone;
                break;
            case ObjectTypes.Equipment:
                ObjectDto = equipmentDto;
                break;
            case ObjectTypes.Process:
                ObjectDto = processDto;
                break;
            case ObjectTypes.ProcessDirectionProperty:
                ObjectDto = processDirectionPropertyDto;
                break;
            case ObjectTypes.Flow:
                ObjectDto = flowDto;
                break;
            case ObjectTypes.Stage:
                ObjectDto = stageDto;
                break;
        }
        StateHasChanged();
        return ObjectDto;
    }

    private void ShowModal(DrawingBaseDesignerDto? objects)
    {
        ModalContentCase(objects);
        showModal = true;
        RenderDataPage();
    }

    private void ShowModal(ObjectTypes? objects)
    {
        ModalContentCase(objects);
        showModal = true;
        RenderDataPage();
    }

    private void CloseModal()
    {
        //Initializes objects on a case-by-case basis to avoid retaining data in the modal
        switch (objectType)
        {
            case ObjectTypes.Area:
                areaDto = new();
                break;
            case ObjectTypes.Route:
                routeDto = new();
                break;
            case ObjectTypes.Equipment:
                equipmentDto = new();
                equipmentModalDto = new();
                isAddingNewArea = false;
                break;
            case ObjectTypes.Dock:
                dockDto = new();
                ModalItemZoneDock = new();
                drawingDesignerDto = new();
                isAddingNewArea = false;
                break;
            case ObjectTypes.Aisle:
                aisleDto = new();
                ModalItemBuffer = new();
                drawingDesignerDto = new();
                isAddingNewArea = false;
                break;
            case ObjectTypes.Buffer:
                bufferDto = new();
                ModalItemBuffer = new();
                drawingDesignerDto = new();
                isAddingNewArea = false;
                break;
            case ObjectTypes.Process:
                processDto = new();
                break;
            case ObjectTypes.Shelf:
                locationZone = new();
                ModalItemLocationZone = new();
                drawingDesignerDto = new();
                isAddingNewArea = false;
                isAddingShelfConfiguration = false;
                break;
            case ObjectTypes.ProcessDirectionProperty:
                processDirectionPropertyDto = new();
                break;
            case ObjectTypes.Stage:
                stageDto = new();
                ModalItemStage = new();
                drawingDesignerDto = new();
                isAddingNewArea = false;
                break;
        }
        objectType = ObjectTypes.None; //SetDeault value
        showModal = false;
        tabsComponent?.RecalculateRelatedElements();
        RenderDataPage();
    }

    private void ModalContentCase(DrawingBaseDesignerDto? drawingBase)
    {
        if (null != drawingBase)
        {
            switch (drawingBase?.CanvasObjectType)
            {
                case "addArea":
                case "groupArea":
                    areaDto = MapperAreaDto(drawingBase);
                    InitModalAreaValues(); // Init method to Modal Combobox
                    break;
                case "addDock":
                    objectType = ObjectTypes.Dock;
                    drawingDesignerDto = drawingBase;
                    InitAreaInModalZoneDock();
                    break;
                case "addAisle":
                    objectType = ObjectTypes.Aisle;
                    drawingDesignerDto = drawingBase;
                    InitAreaInModalBufferZone();
                    break;
                case "addBuffer":
                    objectType = ObjectTypes.Buffer;
                    drawingDesignerDto = drawingBase;
                    InitAreaInModalBufferZone();
                    break;
                case "addShelf":
                    objectType = ObjectTypes.Shelf;
                    drawingDesignerDto = drawingBase;
                    InitModalShelf();
                    break;
                case "addStage":
                    objectType = ObjectTypes.Stage;
                    drawingDesignerDto = drawingBase;
                    InitAreaInModalStageZone();
                    break;
            }
        }
    }

    private void ModalContentCase(ObjectTypes? objectType)
    {
        switch (objectType)
        {
            case ObjectTypes.Route:
                routeDto = MapperRouteDto();
                InitModalRoutesValues();
                break;
            case ObjectTypes.Equipment:
                equipmentDto = MapperEquipmentDesignerDto();
                InitModalEquipmentValues();
                break;
            case ObjectTypes.Process:
                processType = AllprocessTypes.Where(x => !(x.Type == ProcessType.Replenishment)).ToList();
                processDto = MapperProcessDto();
                InitModalProcessValues();
                break;
            case ObjectTypes.ProcessDirectionProperty:
                processDirectionPropertyDto = MapperProcessDirectionPropertyDto();
                InitModalProcessDirectionPropertyValues();
                break;
            case ObjectTypes.Flow:
                flowDto = MapperFlowDto();
                InitModalFlow();
                break;
        }
    }

