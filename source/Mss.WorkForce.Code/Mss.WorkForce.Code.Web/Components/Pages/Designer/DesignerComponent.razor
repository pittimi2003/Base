    private async Task SaveProcessEvent()
    {
        try
        {
            if (!ValidateCurrentModal(objectType))
            {
                _shouldRender = true;
                await InvokeAsync(StateHasChanged);
                _shouldRender = false;

                return;
            }

            processDto.Id = Guid.NewGuid();
            processDto.TypeName = GetProcessTypeString(processDto.Type ?? ProcessType.CustomProcess);
            processDto.FlowId = processDto.Flow.Id;
            switch (processDto.Flow.Type)
            {
                case "Outbound":
                    processDto.IsOut = true;
                    processDto.IsIn = false;
                    break;
                case "Inbound":
                    processDto.IsIn = true;
                    processDto.IsOut = false;
                    break;
                case "Custom":
                    processDto.IsIn = false;
                    processDto.IsOut = false;
                    break;
            }

            switch (processDto.Type)
            {
                case (ProcessType.CustomProcess):
                    CustomProcessDto customProcess = CustomProcessDto.NewDto(processDto);
                    customProcess.Id = Guid.NewGuid();
                    customProcess.ProcessId = (Guid)processDto.Id;
                    await _designer.AddCustomProcess(customProcess);
                    break;
                case (ProcessType.Inbound):
                    InboundDto inboundDto = InboundDto.NewDto(processDto);
                    inboundDto.Id = Guid.NewGuid();
                    inboundDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddInbounds(inboundDto);
                    break;
                case (ProcessType.Loading):
                    LoadingDto loadingDto = LoadingDto.NewDto(processDto);
                    loadingDto.Id = Guid.NewGuid();
                    loadingDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddLoading(loadingDto);
                    break;
                case (ProcessType.Picking):
                    PickingDto PickingDto = PickingDto.NewDto(processDto);
                    PickingDto.Id = Guid.NewGuid();
                    PickingDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddPicking(PickingDto);
                    break;
                case (ProcessType.Putaway):
                    PutawayDto putawayDto = PutawayDto.NewDto(processDto);
                    putawayDto.Id = Guid.NewGuid();
                    putawayDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddPutaway(putawayDto);
                    break;
                case (ProcessType.Shipping):
                    ShippingDto shippingDto = ShippingDto.NewDto(processDto);
                    shippingDto.Id = Guid.NewGuid();
                    shippingDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddShipping(shippingDto);
                    break;
                case (ProcessType.Reception):
                    ReceptionDto receptionDto = ReceptionDto.NewDto(processDto);
                    receptionDto.Id = Guid.NewGuid();
                    receptionDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddReception(receptionDto);
                    break;
                case (ProcessType.Replenishment):
                    ReplenishmentDto replenishmentDto = ReplenishmentDto.NewDto(processDto);
                    replenishmentDto.Id = Guid.NewGuid();
                    replenishmentDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddReplenishment(replenishmentDto);
                    break;
                case (ProcessType.Packing):
                    PackingDto packingDto = PackingDto.NewDto(processDto);
                    packingDto.Id = Guid.NewGuid();
                    packingDto.ProcessId = (Guid)processDto.Id;
                    await _designer.AddPacking(packingDto);
                    break;
                default:
                    await _designer.AddProcess(processDto); //Add case
                    break;
            }

            var newViewport = _designer.GetVieportsByTypeObject(processDto.AreaId, "Area");
            await JS.InvokeVoidAsync("drawObjectsOnCanvas", newViewport);

            await tabsComponent.NotifyProcessCreated(processDto.Type!.Value);
            var areaType = _designer.GetAreasById(processDto.AreaId)!.AreaType;
            await tabsComponent.NotifyAreaCreated(areaType!.Value);

            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving the record: {ex.Message}");
        }
