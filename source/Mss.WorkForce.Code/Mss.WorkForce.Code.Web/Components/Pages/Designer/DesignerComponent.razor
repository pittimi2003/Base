                                                    <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Number of shelves")</label>
                                                        <DxSpinEdit CssClass="mlx-form-spinedit" MinValue="0" MaxValue="999" @bind-Value="ModalItemLocationZone.NumShelves" Mask="n0"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
                                                    </div>

                                                    <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Number of cross aisles")</label>
                                                        <DxSpinEdit CssClass="mlx-form-spinedit" MinValue="0" MaxValue="999" @bind-Value="ModalItemLocationZone.NumCrossAisles" Mask="n0"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
