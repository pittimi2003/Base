                                                    <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Orientation")</label>
                                                        <MlxComboBox Data="orientationType" CssClass="mlx-form-select width-100" Value="@ModalItemLocationZone.Orientation" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" ValueChanged="@((OrientationType? orientationType) => UpdateValidationMessageField(() => ModalItemLocationZone.Orientation, () => { ModalItemLocationZone.Orientation = orientationType; ModalItemLocationZone.IsVertical = orientationType == OrientationType.Vertical; }))" ValueExpression="@(() => ModalItemLocationZone.Orientation)" />
                                                        <ValidationMessage class="text-danger" For="@(() => ModalItemLocationZone.Orientation)" />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
