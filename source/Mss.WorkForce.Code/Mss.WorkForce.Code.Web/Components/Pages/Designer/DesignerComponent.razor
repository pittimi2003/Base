    private async Task SaveZoneEvent(ObjectTypes objectTypes)
    {
        try
        {
            Guid idObject = Guid.Empty;

            //Save records in Dock and Zone DB
            switch (objectTypes)
            {
                case ObjectTypes.Dock:
                    if (!ValidateCurrentModal(objectTypes))
                    {
                        _shouldRender = true;
                        await InvokeAsync(StateHasChanged);
                        _shouldRender = false;

                        return;
                    }
                    AreaDto? areaDto = MapModelValuesZoneArea(drawingDesignerDto, ModalItemZoneDock.Dock.Zone.Area);
                    (int nextInboundCount, int nextOutboundCount) = RangesInboundOutbound(areaDto.Id ?? Guid.Empty); // Create an area with minimal data
                    List<DockDto> dockDtoList = DockDto.NewDtoList(ModalItemZoneDock.Name, ModalItemZoneDock.Quantity, ModalItemZoneDock.Orientation, ModalItemZoneDock.Dock.AllowInbound, ModalItemZoneDock.Dock.AllowOutbound, objectTypes, areaDto, nextInboundCount, nextOutboundCount);
                    idObject = await _designer.AddDock(dockDtoList, isCreateNewArea);                 
                    break;
                case ObjectTypes.Aisle:
                    if (!ValidateCurrentModal(objectTypes))
                    {
                        _shouldRender = true;
                        await InvokeAsync(StateHasChanged);
                        _shouldRender = false;

                        return;
                    }
                    List<AisleDto> aisleDtoList = AisleDto.NewDtoList(ModalItemBuffer.Name, ModalItemBuffer.Quantity, objectTypes, MapModelValuesZoneArea(drawingDesignerDto, ModalItemBuffer.Area));
                    idObject = await _designer.AddAisle(aisleDtoList, isCreateNewArea);
                    break;
                case ObjectTypes.Buffer:
                    if (!ValidateCurrentModal(objectTypes))
                    {
                        _shouldRender = true;
                        await InvokeAsync(StateHasChanged);
                        _shouldRender = false;

                        return;
                    }
                    List<BufferDto> bufferDtoList = BufferDto.NewDtoList(ModalItemBuffer.Name, ModalItemBuffer.Quantity, objectTypes, MapModelValuesZoneArea(drawingDesignerDto, ModalItemBuffer.Area), ModalItemBuffer);
                    idObject = await _designer.AddBuffer(bufferDtoList, isCreateNewArea);                   
                    break;
                case ObjectTypes.Shelf:
                    if (!ValidateCurrentModal(objectTypes))
                    {
                        _shouldRender = true;
                        await InvokeAsync(StateHasChanged);
                        _shouldRender = false;

                        return;
                    }

                    //TODO: 26/03/25 RRV Por los momentos se representa un solo LocationStation
                    switch (ModalItemLocationZone.ZoneType)
                    {
                        case LocationTypes.Rack:
                            List<RackDto> rackDtoList = RackDto.NewDtoList(ModalItemLocationZone.Name, ModalItemLocationZone.Quantity, GetObjectTypeToLocationTypes(ModalItemLocationZone.ZoneType), MapModelValuesZoneArea(drawingDesignerDto, ModalItemLocationZone.Area), 0, 0, ModalItemLocationZone.IsVertical, ModalItemLocationZone.NumShelves, ModalItemLocationZone.NumCrossAisles, ModalItemLocationZone.Capacity ?? 0, ModalItemLocationZone.ZoneType ?? LocationTypes.Rack, ModalItemLocationZone.Orientation);
                            idObject = await _designer.AddRackList(rackDtoList, isCreateNewArea);
                            break;
                        case LocationTypes.DriveIn:
                            List<DriveInDto> driveInDtoList = DriveInDto.NewDtoList(ModalItemLocationZone.Name, ModalItemLocationZone.Quantity, GetObjectTypeToLocationTypes(ModalItemLocationZone.ZoneType), MapModelValuesZoneArea(drawingDesignerDto, ModalItemLocationZone.Area), ModalItemLocationZone.IsVertical, ModalItemLocationZone.NumShelves, ModalItemLocationZone.NumCrossAisles, ModalItemLocationZone.Capacity ?? 0, ModalItemLocationZone.Orientation);
                            idObject = await _designer.AddDriveInList(driveInDtoList, isCreateNewArea);
                            break;
                        case LocationTypes.CaoticStorage:
                            List<ChaoticStorageDto> chaoticStorages = ChaoticStorageDto.NewDtoList(ModalItemLocationZone.Name, ModalItemLocationZone.Quantity, GetObjectTypeToLocationTypes(ModalItemLocationZone.ZoneType), MapModelValuesZoneArea(drawingDesignerDto, ModalItemLocationZone.Area), ModalItemLocationZone.IsVertical, ModalItemLocationZone.NumShelves, ModalItemLocationZone.NumCrossAisles, ModalItemLocationZone.Capacity ?? 0);
                            idObject = await _designer.AddChaoticList(chaoticStorages, isCreateNewArea);
                            break;
                        case LocationTypes.AutomaticStorage:
                            List<AutomaticStorageDto> automaticStorageDtoList = AutomaticStorageDto.NewDtoList(ModalItemLocationZone.Name, ModalItemLocationZone.Quantity, GetObjectTypeToLocationTypes(ModalItemLocationZone.ZoneType), MapModelValuesZoneArea(drawingDesignerDto, ModalItemLocationZone.Area), ModalItemLocationZone.IsVertical, ModalItemLocationZone.NumShelves, ModalItemLocationZone.NumCrossAisles, ModalItemLocationZone.Capacity ?? 0, ModalItemLocationZone.Orientation);
                            idObject = await _designer.AddAutomaticStorageList(automaticStorageDtoList, isCreateNewArea);
                            break;
                    }

                    break;
                case ObjectTypes.Stage:
                    if (!ValidateCurrentModal(objectTypes))
                    {
                        _shouldRender = true;
                        await InvokeAsync(StateHasChanged);
                        _shouldRender = false;

                        return;
                    }
                    List<StageDto> stageDtoList = StageDto.NewDtoList(ModalItemStage.Name, ModalItemStage.Quantity, objectTypes, MapModelValuesZoneArea(drawingDesignerDto, ModalItemStage.Area), ModalItemStage.Stage.IsIn, ModalItemStage.Stage.IsOut);
                    idObject = await _designer.AddStage(stageDtoList, isCreateNewArea);
                    break;
            }
            if (idObject != Guid.Empty)
            {
                var areaType = GetAreaTypeFromObjectType(objectTypes);

                var newViewport = _designer.GetVieportsByTypeObject(idObject, "Area");
                await JS.InvokeVoidAsync("drawObjectsOnCanvas", newViewport);
                await tabsComponent!.NotifyAreaCreated(areaType);
            }
            await JS.InvokeVoidAsync("SaveOnPostback");
            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving the record: {ex.Message}");
        }
    }

