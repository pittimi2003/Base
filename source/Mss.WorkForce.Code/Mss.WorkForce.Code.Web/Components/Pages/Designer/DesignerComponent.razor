                    <BodyContent>
                        <div class="row overflow-hidden">
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Init process")</label>
                                <MlxComboBox Data="InitProcessItems" CssClass="mlx-form-select" Value="@processDirectionPropertyDto.InitProcess" ValueFieldName="Id" TextFieldName="@nameof(processDto.Name)" NullText="@L.Loc("Select...")" ValueChanged="@((ProcessDto p) => OnValueChangedProcess(p,
                                    () => processDirectionPropertyDto.InitProcessId, v => {
                                        processDirectionPropertyDto.InitProcess = v;
                                        processDirectionPropertyDto.InitProcessId = v.Id ?? Guid.Empty;
                                    },
                                    () => {
                                        if (processDirectionPropertyDto.EndProcess?.Id == p.Id)
                                        {
                                            processDirectionPropertyDto.EndProcess = null;
                                            processDirectionPropertyDto.EndProcessId = Guid.Empty;
                                        } }, 
                                    () => EndProcessItems))" ValueExpression="@(() => processDto)" TextExpression="@(() => processDto.Name)" />
                                <ValidationMessage class="text-danger" For="@(() => processDirectionPropertyDto.InitProcessId)" />
                            </div>
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("End process")</label>
                                <MlxComboBox Data="EndProcessItems" CssClass="mlx-form-select" Value="@processDirectionPropertyDto.EndProcess" ValueFieldName="Id" TextFieldName="@nameof(processDto.Name)" NullText="@L.Loc("Select...")" 
                                            ValueChanged="@((ProcessDto p) => OnValueChangedProcess(p,
                                                () => processDirectionPropertyDto.EndProcessId,
                                                v => {
                                                    processDirectionPropertyDto.EndProcess = v;
                                                    processDirectionPropertyDto.EndProcessId = v.Id ?? Guid.Empty;
                                                },
                                                () => {
                                                    if (processDirectionPropertyDto.InitProcess?.Id == p.Id)
                                                    {
                                                        processDirectionPropertyDto.InitProcess = null;
                                                        processDirectionPropertyDto.InitProcessId = Guid.Empty;
                                                    }
                                                },
                                                () => InitProcessItems
                                            ))" ValueExpression="@(() => processDto)" TextExpression="@(() => processDto.Name)" />
                                <ValidationMessage class="text-danger" For="@(() => processDirectionPropertyDto.EndProcessId)" />
                            </div>
                        </div>
                    </BodyContent>
