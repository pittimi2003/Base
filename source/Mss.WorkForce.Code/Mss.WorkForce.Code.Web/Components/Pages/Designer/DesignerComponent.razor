    public async Task DeleteItemsInDatabase(ItemsCanvasDto deleteItems)
    {
        //Deletion of selected routes.
        if (deleteItems.routes?.Count > 0)
        {
            IEnumerable<Models.Models.Route> routes = _designer.GetRoutesListByRouteDtoList(deleteItems.routes); //Gets records by Id to convert them into an IEnumerable list.
            await _designer.DeleteListRoutes(routes);
        }

        //Deletion of selected equipments.
        if (deleteItems.equipments?.Count > 0)
        {
            IEnumerable<EquipmentGroup> equipments = _designer.GetEquipmentGroupsListByEquipmentDesignerDtoList(deleteItems.equipments); //Gets records by Id to convert in EquipmentGroup type.
            await _designer.DeleteListEquipmentGroup(equipments);
        }

        //Deletion of selected shelfs.
        if (deleteItems.shelf?.Count > 0)
        {
            foreach (var item in deleteItems?.shelf)
            {
                // ShelfDto zoneViewport = JsonSerializer.Deserialize<ShelfDto>(item);
                var zone = _designer.GetZoneByIdNoTracking((Guid)item.ZoneId);
                if (null != zone)
                {
                    switch (item.LocationTypes)
                    {
                        case LocationTypes.Rack:
                            Rack rackDelete = _designer.GetRackByIdAsNoTracking((Guid)item.Id); //Gets records by Id to convert in Rack type.
                            await _designer.DeleteRack(rackDelete);
                            break;
                        case LocationTypes.DriveIn:
                            DriveIn driveInDelete = _designer.GetDriveInByIdAsNoTracking((Guid)item.Id); //Gets records by Id to convert in DriveIn type.
                            await _designer.DeleteDriveIn(driveInDelete);
                            break;
                        case LocationTypes.CaoticStorage:
                            ChaoticStorage chaoticDelete = _designer.GetChaoticByIdAsNoTracking((Guid)item.Id);
                            await _designer.DeleteChaotic(chaoticDelete);
                            break;
                        case LocationTypes.AutomaticStorage:
                            AutomaticStorage automaticDelete = _designer.GetAutomaticStorageByIdAsNoTracking((Guid)item.Id);
                            await _designer.DeleteAutomaticStorage(automaticDelete);
                            break;

                    }
                }
            }
        }

        //Deletion of selected process.
        if (deleteItems.process?.Count > 0)
        {
            IEnumerable<Process> processes = _designer.GetProcessListByProcessDtoList(deleteItems.process); //Gets records by Id to convert in Process type.
            if (null != processes && processes.Count() > 0)
            {
                foreach (var process in processes)
                {
                    IEnumerable<ProcessDirectionProperty> processDirectionsToDelete = _designer.GetProcessDirectionsByIdProcess(process.Id).ToList();
                    if (processDirectionsToDelete.Count() > 0)
                        await _designer.DeleteListProcessDirectionProperties(processDirectionsToDelete);
                }
                await _designer.DeleteListProcesses(processes); // Eliminates processes that match the area's Id
            }
        }

        //Deletion of selected processDirection.
        if (deleteItems.processDirections?.Count > 0)
        {
            IEnumerable<ProcessDirectionProperty> processDirections = _designer.GetProcessDirectionPropertyListByProcessDirectionPropertyDtoList(deleteItems.processDirections); //Gets records by Id to convert in processDirections type.
            if (null != processDirections && processDirections.Count() > 0)
                await _designer.DeleteListProcessDirectionProperties(processDirections);
        }

        if (deleteItems.zones?.Count > 0)
        {
            foreach (var item in deleteItems?.zones)
            {
                // Models.DTO.Designer.ZoneDto zoneViewport = JsonSerializer.Deserialize<Models.DTO.Designer.ZoneDto>(item);
                var zone = _designer.GetZoneByIdNoTracking((Guid)item.Id);
                if (null != zone)
                {
                    switch (item.ZoneType)
                    {
                        case ZoneType.Aisle:
                            Aisle aisleDelete = _designer.GetAisleByIdZoneAsNoTracking((Guid)item.Id);
                            await _designer.DeleteAisle(aisleDelete);
                            break;
                        case ZoneType.Dock:
                            Dock dockToDelete = _designer.GetDockByIdZoneAsNoTracking((Guid)zone.Id);
                            await _designer.DeleteDock(dockToDelete);
                            break;
                        case ZoneType.Buffer:
                            Buffer bufferToDelete = _designer.GetBufferByIdZoneAsNoTracking((Guid)zone.Id);
                            await _designer.DeleteBuffer(bufferToDelete);
                            break;
                        case ZoneType.Stage:
                            Stage stageToDelete = _designer.GetStagesByIdZoneAsNoTracking((Guid)zone.Id);
                            await _designer.DeleteStage(stageToDelete);
                            break;

                    }
                }
            }
        }

        //Deletion of area records.
        if (deleteItems.areas?.Count > 0)
        {
            List<AreaDto> areas = SetItemsInDatabase(deleteItems.areas);

            //Delete all elements related to areas
            foreach (var area in areas)
            {
                IEnumerable<Models.Models.Route?> routesToDelete = _designer.GetRoutesByIdArea((Guid)area.Id).ToList(); // Filters routes that have the area Id in InboundAreaId or OutboundAreaId
                if (routesToDelete.Count() > 0)
                    await _designer.DeleteListRoutes(routesToDelete); // Eliminates routes that match the area's Id

                IEnumerable<EquipmentGroup?> equipmentsToDelete = _designer.GetEquipmentGroupByIdArea((Guid)area.Id).ToList(); // Filters equipments that have the area Id in AreaId
                if (equipmentsToDelete.Count() > 0)
                    await _designer.DeleteListEquipmentGroup(equipmentsToDelete); // Eliminates equipments that match the area's Id

                IEnumerable<Aisle?> aislesToDelete = _designer.GetAislesByIdArea((Guid)area.Id).ToList();
                if (aislesToDelete.Count() > 0)
                    await _designer.DeleteListAisle(aislesToDelete);

                IEnumerable<Dock?> docksToDelete = _designer.GetDocksByIdAreaNoTracking((Guid)area.Id).ToList();
                if (docksToDelete.Count() > 0)
                    await _designer.DeleteListDock(docksToDelete);

                IEnumerable<Buffer?> buffersToDelete = _designer.GetBuffersByIdAreaNoTracking((Guid)area.Id).ToList();
                if (buffersToDelete.Count() > 0)
                    await _designer.DeleteListBuffer(buffersToDelete);

                IEnumerable<Rack?> racksToDelete = _designer.GetRacksByIdAreaNoTracking((Guid)area.Id).ToList();
                if (racksToDelete.Count() > 0)
                    await _designer.DeleteListRack(racksToDelete); // Eliminates shelfs that match the area's Id

                IEnumerable<DriveIn?> driveInsToDelete = _designer.GetDriveInsByIdAreaNoTracking((Guid)area.Id).ToList();
                if (driveInsToDelete.Count() > 0)
                    await _designer.DeleteListDriveIn(driveInsToDelete); // Eliminates driveIn that match the area's Id

                IEnumerable<ChaoticStorage?> chaoticStoragesToDelete = _designer.GetChaoticStoragesByIdAreaNoTracking((Guid)area.Id).ToList();
                if (chaoticStoragesToDelete.Count() > 0)
                    await _designer.DeleteListChaoticStorage(chaoticStoragesToDelete); // Eliminates chaoticStorage that match the area's Id

                IEnumerable<AutomaticStorage?> AutomaticsToDelete = _designer.GetAutomaticStoragesByIdAreaNoTracking((Guid)area.Id).ToList();
                if (AutomaticsToDelete.Count() > 0)
                    await _designer.DeleteListAutomaticStorage(AutomaticsToDelete); // Eliminates driveIn that match the area's Id

                IEnumerable<Process?> processesToDelete = _designer.GetProcessByIdAreaNoTracking((Guid)area.Id).ToList();
                if (processesToDelete.Count() > 0)
                {
                    foreach (var process in processesToDelete)
                    {
                        IEnumerable<ProcessDirectionProperty> processDirectionsToDelete = _designer.GetProcessDirectionsByIdProcess(process.Id).ToList();
                        if (processDirectionsToDelete.Count() > 0)
                            await _designer.DeleteListProcessDirectionProperties(processDirectionsToDelete);
                    }
                    await _designer.DeleteListProcesses(processesToDelete); // Eliminates processes that match the area's Id
                }

                IEnumerable<Stage?> stageToDelete = _designer.GetStagesByIdAreaNoTracking((Guid)area.Id).ToList();
                if (stageToDelete.Count() > 0)
                    await _designer.DeleteListStage(stageToDelete);
            }

            await _designer.DeleteListAreas(areas); // Delete areas in Data base
        }

        //Deletion of object records.
        if (deleteItems.objects?.Count > 0)
        {
            List<ObjectsDto> objects = SetItemsInDatabase(deleteItems.objects);
            await _designer.DeleteListObjects(objects);
        }
    }

    public async Task SetObjectsInDatabase(List<ObjectsDto> objectsList)
    {
        //Set LayoutId and Name in objects and return a new list
        List<ObjectsDto> newObjectsList = SetItemsInDatabase(objectsList);

        //Count if new list have files
        if (newObjectsList?.Count > 0)
        {
            //Generate list to add files in DB
            List<ObjectsDto>? objectListAdd = newObjectsList.Where(x => x.StatusObject == "Add").ToList();
            //Generate list to update files in DB
            List<ObjectsDto>? objectListUpdate = newObjectsList.Where(x => x.StatusObject == "Update").ToList();
            if (objectListAdd.Any())
            {
                //Register files in DB
                objectListAdd.ForEach(add => add.StatusObject = "StoredInBase");
                await _designer.AddListObjects(objectListAdd);
            }
            if (objectListUpdate.Any())
            {
                //Register files in DB
                objectListUpdate.ForEach(update => update.StatusObject = "StoredInBase");
                await _designer.UpdateListObjects(objectListUpdate);
            }
        }
    }

    //Verify if name is null and set LayoutId
    public List<T> SetItemsInDatabase<T>(List<T> objects) where T : class, new()
    {
        List<T> newObjects = new();

        foreach (T obj in objects)
        {
            var objType = typeof(T);

            // Verificar si la propiedad Name existe y es de tipo string
            var nameProperty = objType.GetProperty("Name");
            if (nameProperty != null && nameProperty.PropertyType == typeof(string))
            {
                string nameValue = (string)nameProperty.GetValue(obj) ?? string.Empty;
                nameProperty.SetValue(obj, nameValue);
            }

            // Verificar si la propiedad LayoutId existe y es de tipo int
            var layoutProperty = objType.GetProperty("LayoutId");
            if (layoutProperty != null && layoutProperty.PropertyType == typeof(Guid?))
            {
                layoutProperty.SetValue(obj, layoutDto.Id);
            }

            newObjects.Add(obj);
        }
        return newObjects;
    }

