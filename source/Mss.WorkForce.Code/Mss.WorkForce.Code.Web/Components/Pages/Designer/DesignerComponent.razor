    /// <summary>
    /// Event to Save/Delete items data in Canvas
    /// </summary>
    /// <param name="layoutDtoJson"></param>
    /// <param name="layoutDeleteJson"></param>
    /// <returns></returns>
    [JSInvokable]
    public async Task<bool> UpdateCanvas(string layoutDtoJson, string layoutDeleteJson, string layoutSelectJson)
    {
        try
        {
            ItemsCanvasDto deleteItems = new();
            ItemsCanvasDto? addUpdateItems = new();

            //Deserealize layout to get Viewport
            layoutDto = JsonSerializer.Deserialize<LayoutDto>(layoutDtoJson);

            //List to objects to Add or Update data
            addUpdateItems = JsonSerializer.Deserialize<ItemsCanvasDto>(layoutDto.Viewport);

            //Verify if any data needs to delete
            if (layoutDeleteJson != "[]" && layoutDeleteJson != "{\"Areas\":[],\"Objects\":[], \"Routes\": [], \"Equipments\": [], \"Stations\": [], \"Shelf\": [], \"Process\": [], \"ProcessDirections\": []}")
                deleteItems = JsonSerializer.Deserialize<ItemsCanvasDto>(layoutDeleteJson);

            //Add Update Section to objects
            if (addUpdateItems?.objects != null && addUpdateItems.objects.Count > 0)
                await SetObjectsInDatabase(addUpdateItems.objects);

            //Update Section Areas
            if (addUpdateItems?.areas != null && addUpdateItems.areas.Count > 0)
                await SetAreasInDatabase(addUpdateItems.areas);

            //Update Section Zones
            if (addUpdateItems?.zones != null && addUpdateItems.zones.Count > 0)
                await SetZonesInDatabase(addUpdateItems.zones);

            if (addUpdateItems?.shelf != null && addUpdateItems.shelf.Count > 0)
                await SetShelfsInDatabase(addUpdateItems.shelf);

            //Add Section Process Copy
            if (addUpdateItems?.process != null && addUpdateItems.process.Count > 0)
                await AddProcessesCopyInDatabase(addUpdateItems.process, addUpdateItems?.steps);

            //Update Section Routes
            if (addUpdateItems?.routes != null && addUpdateItems.routes.Count > 0)
                await UpdateRoutesInDatabase(addUpdateItems.routes);

            if (addUpdateItems?.equipments != null && addUpdateItems.equipments.Count > 0)
                await AddEqupmentsInDatabaseCopy(addUpdateItems.equipments);

            //Update Section Process Directions
            if (addUpdateItems?.processDirections != null && addUpdateItems.processDirections.Count > 0)
                await UpdateProcessDirectionsInDatabase(addUpdateItems.processDirections);

            //Delete items
            if (null != deleteItems?.areas || null != deleteItems?.objects || null != deleteItems?.routes ||
                null != deleteItems?.equipments || null != deleteItems?.zones || null != deleteItems?.shelf ||
                null != deleteItems?.process || null != deleteItems?.processDirections)
                await DeleteItemsInDatabase(deleteItems);

            await _designer.UpdateLayout(layoutDto);

            if (!isActionBackButton) // If the Back button save is pressed, the canvas construction is skipped
                CreateCanvas(true);

            await JS.InvokeVoidAsync("showHtmlToast", L.Loc("Changes saved successfully"), 3000);
            if (layoutSelectJson != string.Empty)
                HandleSelection(layoutSelectJson);
            return await Task.FromResult(true);
        }
        catch (Exception)
        {
            return false;
        }
    }

