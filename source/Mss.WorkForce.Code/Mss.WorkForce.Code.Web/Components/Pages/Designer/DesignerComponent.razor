    public async Task CopyProcessData(ProcessDto process, List<StepDto>? newStepsList)
    {
        var itemProcess = _designer.GetProcessDtoByIdNoTracking(process.IdOriginal ?? Guid.Empty); // Searches for the original process
        itemProcess.Id = process.Id; // Sets the new id in the process to be created

        // Creates the object of the process case type
        switch (itemProcess.Type)
        {
            case ProcessType.CustomProcess:
                CustomProcessDto? customProcessDto = _designer.GetCustomProcessDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                customProcessDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                customProcessDto.ProcessId = (Guid)itemProcess.Id;
                customProcessDto.Process = itemProcess;
                customProcessDto.Process.Name = process.Name;
                customProcessDto.Process.AreaId = process.AreaId;
                await _designer.AddCustomProcess(customProcessDto);
                break;
            case ProcessType.Inbound:
                InboundDto? inboundDto = _designer.GetInboundDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                inboundDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                inboundDto.ProcessId = (Guid)itemProcess.Id;
                inboundDto.Process = itemProcess;
                inboundDto.Process.Name = process.Name;
                inboundDto.Process.AreaId = process.AreaId;
                await _designer.AddInbounds(inboundDto);
                break;
            case ProcessType.Loading:
                LoadingDto? loadingDto = _designer.GetLoadingDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                loadingDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                loadingDto.ProcessId = (Guid)itemProcess.Id;
                loadingDto.Process = itemProcess;
                loadingDto.Process.Name = process.Name;
                loadingDto.Process.AreaId = process.AreaId;
                await _designer.AddLoading(loadingDto);
                break;
            case ProcessType.Picking:
                PickingDto? pickingDto = _designer.GetPickingDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                pickingDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                pickingDto.ProcessId = (Guid)itemProcess.Id;
                pickingDto.Process = itemProcess;
                pickingDto.Process.Name = process.Name;
                pickingDto.Process.AreaId = process.AreaId;
                await _designer.AddPicking(pickingDto);
                break;
            case ProcessType.Putaway:
                PutawayDto? putawayDto = _designer.GetPutawayDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                putawayDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                putawayDto.ProcessId = (Guid)itemProcess.Id;
                putawayDto.Process = itemProcess;
                putawayDto.Process.Name = process.Name;
                putawayDto.Process.AreaId = process.AreaId;
                await _designer.AddPutaway(putawayDto);
                break;
            case ProcessType.Shipping:
                ShippingDto? shippingDto = _designer.GetShippingDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                shippingDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                shippingDto.ProcessId = (Guid)itemProcess.Id;
                shippingDto.Process = itemProcess;
                shippingDto.Process.Name = process.Name;
                shippingDto.Process.AreaId = process.AreaId;
                await _designer.AddShipping(shippingDto);
                break;
            case ProcessType.Reception:
                ReceptionDto? receptionDto = _designer.GetReceptionDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                receptionDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                receptionDto.ProcessId = (Guid)itemProcess.Id;
                receptionDto.Process = itemProcess;
                receptionDto.Process.Name = process.Name;
                receptionDto.Process.AreaId = process.AreaId;
                await _designer.AddReception(receptionDto);
                break;
            case ProcessType.Replenishment:
                ReplenishmentDto? replenishmentDto = _designer.GetReplenishmentDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                replenishmentDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                replenishmentDto.ProcessId = (Guid)itemProcess.Id;
                replenishmentDto.Process = itemProcess;
                replenishmentDto.Process.Name = process.Name;
                replenishmentDto.Process.AreaId = process.AreaId;
                await _designer.AddReplenishment(replenishmentDto);
                break;
             case ProcessType.Packing:
                PackingDto? packingDto = _designer.GetPackingDtoByProcessId(process.IdOriginal ?? Guid.Empty);
                packingDto.Id = process.ProcessTypeId ?? Guid.NewGuid();
                packingDto.ProcessId = (Guid)itemProcess.Id;
                packingDto.Process = itemProcess;
                packingDto.Process.Name = process.Name;
                packingDto.Process.AreaId = process.AreaId;
                await _designer.AddPacking(packingDto);
                break;
        }

        var itemSteps = _designer.GetStepsDtoByProcessIdNoTracking(process.IdOriginal ?? Guid.Empty).ToList(); // Searches the Id of the original process if it has Steps
        if (itemSteps.Count() > 0 && newStepsList.Count() > 0 && newStepsList != null)
        {
            for (int i = 0; i < itemSteps.Count; i++)
            {
                itemSteps[i].Id = newStepsList?[i]?.Id ?? Guid.NewGuid();
                itemSteps[i].ProcessId = itemProcess.Id ?? Guid.Empty;

                if (i < newStepsList.Count)
                {
                    itemSteps[i].Name = newStepsList[i].Name;
                }
            }
        }
        await _designer.AddStepDtoList(itemSteps);
    }

