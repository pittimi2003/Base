    public async Task SetAreasInDatabase(List<AreaDto> areasList)
    {
        List<AreaDto> areas = SetItemsInDatabase(areasList);
        if (areasList.Count > 0)
        {
            List<AreaDto> areasListUpdate = areasList.Where(a => a.StatusObject == "Update").ToList();
            List<AreaDto> areasListAdd = areasList.Where(a => a.StatusObject == "Add").ToList();
            if (areasListUpdate.Any())
            {
                areasListUpdate.ForEach(add => add.StatusObject = "StoredInBase");
                await _designer.UpdateListAreas(areasListUpdate);
            }

            if (areasListAdd.Any())
            {
                areasListAdd.ForEach(add =>
                {
                    add.StatusObject = "StoredInBase";
                    add.AlternativeAreaId = null != add.AlternativeAreaId && add.AlternativeAreaId != Guid.Empty ? add.AlternativeAreaId : Guid.Empty;
                    add.AlternativeArea = null != add.AlternativeAreaId && add.AlternativeAreaId != Guid.Empty ? _designer.GetAreasById(add.AlternativeAreaId ?? Guid.Empty) : add.AlternativeArea;
                });
                await _designer.AddListAreas(areasListAdd);
            }
        }
    }

    public async Task SetZonesInDatabase(List<Models.DTO.Designer.ZoneDto> zonesList)
    {

        List<Models.DTO.Designer.ZoneDto> zonesListUpdate = zonesList.Where(a => a.StatusObject == "Update").ToList();
        List<Models.DTO.Designer.ZoneDto> zonesListAdd = zonesList.Where(a => a.StatusObject == "Add").ToList();

        if (zonesListUpdate.Any())
        {
            zonesListUpdate.ForEach(z => z.StatusObject = "StoredInBase");
            await _designer.UpdateListZones(zonesListUpdate);
        }

        if (zonesListAdd.Any())
        {
            ////
            foreach (var zone in zonesListAdd)
            {
                switch (zone.ZoneType)
                {
                    case ZoneType.Dock:
                        var zoneFound = _designer.GetZoneDtoById(zone.IdOriginal ?? Guid.Empty);
                        var dockFound = _designer.GetDocksDtoByIdZoneAsNoTracking(zone.IdOriginal ?? Guid.Empty);
                        (int nextInboundCount, int nextOutboundCount) = RangesInboundOutbound(zone.AreaId);

                        // Initialize counters (These will increase if there are several docks)
                        int inboundCounter = nextInboundCount;
                        int outboundCounter = nextOutboundCount;

                        zoneFound.Id = zone.Id ?? Guid.NewGuid();
                        zoneFound.AreaId = zone.AreaId;
                        zoneFound.Name = zone.Name;
                        zoneFound.X = zone.X;
                        zoneFound.Y = zone.Y;
                        zoneFound.Width = zone.Width;
                        zoneFound.Height = zone.Height;

                        var dock = new DockDto
                            {
                                Id = Guid.NewGuid(),
                                OperatesFromBuffer = dockFound.OperatesFromBuffer,
                                OverloadHandling = dockFound.OverloadHandling,
                                InboundRange = dockFound.AllowInbound ? inboundCounter++ : dockFound.InboundRange, // Increases the copied record if AllowInbound is true; otherwise, it retains its original value
                                OutboundRange = dockFound.AllowOutbound ? outboundCounter++ : dockFound.OutboundRange, // Increases the copied record if AllowOutbound is true; otherwise, it retains its original value
                                MaxStockCrossdocking = dockFound.MaxStockCrossdocking,
                                AllowInbound = dockFound.AllowInbound,
                                AllowOutbound = dockFound.AllowOutbound,
                                ZoneId = zoneFound.Id ?? Guid.Empty,
                                ViewPort = string.Empty,
                                Zone = zoneFound
                            };
                        await _designer.AddDockCopy(dock);
                        break;

                    case ZoneType.Buffer:
                        var zoneFoundBuffer = _designer.GetZoneDtoById(zone.IdOriginal ?? Guid.Empty);
                        var bufferFound = _designer.GetBuffersDtoByIdZoneAsNoTracking(zone.IdOriginal ?? Guid.Empty);

                        zoneFoundBuffer.Id = zone.Id ?? Guid.NewGuid();
                        zoneFoundBuffer.AreaId = zone.AreaId;
                        zoneFoundBuffer.Name = zone.Name;
                        zoneFoundBuffer.X = zone.X;
                        zoneFoundBuffer.Y = zone.Y;
                        zoneFoundBuffer.Width = zone.Width;
                        zoneFoundBuffer.Height = zone.Height;
                        zoneFoundBuffer.IsVertical = bufferFound.IsVertical;
                        zoneFoundBuffer.Orientation = bufferFound.Orientation;

                        var buffer = new BufferDto
                            {
                                Id = Guid.NewGuid(),
                                EntryCapacity = bufferFound.EntryCapacity,
                                ExitCapacity = bufferFound.ExitCapacity,
                                CapacityByMaterial = bufferFound.CapacityByMaterial,
                                Excess = bufferFound.Excess,
                                ZoneId = zoneFoundBuffer.Id ?? Guid.Empty,
                                ViewPort = string.Empty,
                                Zone = zoneFoundBuffer,
                                BufferType = bufferFound.BufferType,
                                NumShelves = bufferFound.NumShelves,
                                NumCrossAisles = bufferFound.NumCrossAisles,
                                IsVertical = bufferFound.IsVertical
                            };
                        await _designer.AddBufferCopy(buffer);
                        break;
                    case ZoneType.Stage:
                        var zoneFoundStage = _designer.GetZoneDtoById(zone.IdOriginal ?? Guid.Empty);
                        var stageFound = _designer.GetStagesDtoByIdZoneAsNoTracking(zone.IdOriginal ?? Guid.Empty);


                        zoneFoundStage.Id = zone.Id ?? Guid.NewGuid();
                        zoneFoundStage.AreaId = zone.AreaId;
                        zoneFoundStage.Name = zone.Name;
                        zoneFoundStage.X = zone.X;
                        zoneFoundStage.Y = zone.Y;
                        zoneFoundStage.Width = zone.Width;
                        zoneFoundStage.Height = zone.Height;

                        var stage = new StageDto
                            {
                                Id = Guid.NewGuid(),
                                EntryCapacity = stageFound.EntryCapacity,
                                ExitCapacity = stageFound.ExitCapacity,
                                MixCarriers = stageFound.MixCarriers,
                                ZoneId = zoneFoundStage.Id ?? Guid.Empty,
                                ViewPort = string.Empty,
                                Zone = zoneFoundStage,
                                IsIn = stageFound.IsIn,
                                IsOut = stageFound.IsOut,
                            };
                        var listAvailableDocks = _designer
                         .GetAvailableDocksPerStageDtoByZoneId(zone.IdOriginal ?? Guid.Empty)
                         .ToList(); // ToList nunca regresa null

                        Guid stageId = stageDto.Id; // el stage actual

                        var availableDocks = listAvailableDocks
                            .Select(x => new AvailableDocksPerStageDto
                                {
                                    Id = Guid.NewGuid(),     // o x.Id si quieres conservarlo
                                    DockId = x.DockId,       // toma el DockId del elemento de la lista
                                    StageId = stage.Id,       // forzamos al stage actual
                                    Name = x.Name
                                })
                            .ToList();



                        await _designer.AddStageCopy(stage);
                        await _designer.AddAvailableDocksPerStages(availableDocks);
                        break;

                }
            }
        }

    }

