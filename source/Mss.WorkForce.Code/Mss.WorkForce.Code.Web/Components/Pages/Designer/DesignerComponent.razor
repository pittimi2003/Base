                                <DxSpinEdit CssClass="mlx-form-spinedit" MinValue="0" MaxValue="999999" @bind-Value="ModalItemStage.Quantity" Mask="n0"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
                                <ValidationMessage class="text-danger" For="@(() => ModalItemStage.Quantity)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Type")</label>
                                <MlxComboBox Data="@Isinb" CssClass="mlx-form-select width-100" Value="@ModalItemStage.StageIsin" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" ValueChanged="@((IsoutType? v) => OnValueChangedEntity(v, () => ModalItemStage.StageIsin, val => ModalItemStage.StageIsin = val))" ValueExpression="@(() => ModalItemStage.StageIsin)" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemStage.StageIsin)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
