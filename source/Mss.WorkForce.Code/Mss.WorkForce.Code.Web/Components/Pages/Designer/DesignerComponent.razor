    public async Task SetShelfsInDatabase(List<ShelfDto> shelfList)
    {
        List<ShelfDto>? shelfListAdd = shelfList.Where(x => x.StatusObject == "Add").ToList();
        List<ShelfDto> shelfListUpdate = shelfList.Where(a => a.StatusObject == "Update").ToList();

        if (shelfListAdd.Any())
        {
            shelfListAdd.ForEach(add => add.StatusObject = "StoredInBase");
            foreach (var shelf in shelfListAdd)
            {
                switch (shelf.LocationTypes)
                {
                    case LocationTypes.Rack:
                        var rackDto = SetRackDtoDataCopy(shelf);
                        await _designer.AddRack(rackDto);
                        break;
                    case LocationTypes.DriveIn:
                        var driveInDto = SetDriveInDtoDataCopy(shelf);
                        await _designer.AddDriveIn(driveInDto);
                        break;
                    case LocationTypes.CaoticStorage:
                        var chaoticDto = SetChaoticStorageDtoDataCopy(shelf);
                        await _designer.AddChaoticStorage(chaoticDto);
                        break;
                    case LocationTypes.AutomaticStorage:
                        var automaticDto = SetAutomaticStorageDtoDataCopy(shelf);
                        await _designer.AddAutomaticStorage(automaticDto);
                        break;
                }
            }

        }

        if (shelfListUpdate.Any())
        {
            shelfListUpdate.ForEach(add => add.StatusObject = "StoredInBase");
            foreach (var shelf in shelfListUpdate)
            {
                switch (shelf.LocationTypes)
                {
                    case LocationTypes.Rack:
                        var rackDto = MapperShelfToRackDto(shelf);
                        await _designer.UpdateRack(rackDto);
                        break;
                    case LocationTypes.DriveIn:
                        var driveInDto = MapperShelfToDriveInDto(shelf);
                        await _designer.UpdateDriveIn(driveInDto);
                        break;
                    case LocationTypes.CaoticStorage:
                        var chaoticDto = MapperShelfToChaoticStorageDto(shelf);
                        await _designer.UpdateChaotic(chaoticDto);
                        break;
                    case LocationTypes.AutomaticStorage:
                        var automaticDto = MapperShelfToAutomaticDto(shelf);
                        await _designer.UpdateAutomaticStorage(automaticDto);
                        break;
                }
            }
        }
    }

