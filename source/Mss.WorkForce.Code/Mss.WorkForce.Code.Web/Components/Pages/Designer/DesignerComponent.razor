                Message = message,
                Footer = footer,
                OnClose = onClose
            };

        showUniversalModal = true;
        RenderDataPage();
    }

    private void HideModal()
    {
        showUniversalModal = false;
        modal.OnClose?.Invoke();
        RenderDataPage();
    }

    private RenderFragment FooterNoYes(Func<Task> yesAction) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "class", "btn-mlx btn-mlx-white-primary");
        builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, HideModal));
        builder.AddContent(3, L.Loc("No"));
        builder.CloseElement();

        builder.OpenElement(4, "button");
        builder.AddAttribute(5, "class", "btn-mlx btn-mlx-blue-primary");
        builder.AddAttribute(6, "onclick", EventCallback.Factory.Create(this, async () => await yesAction()));
        builder.AddContent(7, L.Loc("Yes"));
        builder.CloseElement();
    };

    private RenderFragment FooterCancel() => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "class", "btn-mlx btn-mlx-white-primary");
        builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, HideModal));
        builder.AddContent(3, L.Loc("Cancel"));
        builder.CloseElement();
    };
    [JSInvokable]
    public async Task OnCanvasRelationsModeChanged(bool isOn)
    {
        if (tabsComponent is null) return;

        if (isOn)
            await tabsComponent.ClearAllSelectionsForRelationsMode();
        else
            await tabsComponent.RestoreBaseSelectionState();
    }

    [JSInvokable]
    public Task OnCanvasAreaSelectionChanged(string? areaId)
    {
        if (Guid.TryParse(areaId, out var guid))
            UiState.SetSelectedArea(guid);
        else
            UiState.SetSelectedArea(null);

        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCanvasProcessSelectionChanged(string? processId)
    {
        if (Guid.TryParse(processId, out var guid))
            UiState.SetSelectedProcess(guid);
        else
            UiState.SetSelectedProcess(null);

        return Task.CompletedTask;
    }


    private async Task RestoreSelectionIfAnyAsync()
    {
        if (!IsSwitchOn) return; 

        if (UiState.Context.SelectedAreaId is not null)
        {
            await JS.InvokeVoidAsync(
                "selectAreaOnCanvasById",
                UiState.Context.SelectedAreaId.Value.ToString()
            );
            return; // prioridad a área
        }

        if (UiState.Context.SelectedProcessId is not null)
        {
            await JS.InvokeVoidAsync(
                "selectProcessOnCanvasById",
                UiState.Context.SelectedProcessId.Value.ToString()
            );
        }
    }

    public void CaptureUiStateBeforeLeave()
    {
        if (tabsComponent is null) return;

        tabsComponent.CaptureBaseSelectionState();

        UiState.SetTabsBaseState(tabsComponent.ExportBaseSelectionState());
    }

    private async Task RestoreTabsBaseStateIfAnyAsync()
    {
        if (tabsComponent is null) return;

        var baseState = UiState.GetTabsBaseState();
        if (baseState is null) return;

        tabsComponent.ImportBaseSelectionState(baseState);


        await tabsComponent.RestoreBaseSelectionState();
    }

    [JSInvokable]
    public void ClearCanvasSelectionState()
    {
        UiState.Context.SelectedAreaId = null;
        UiState.SetSelectedProcess(null);
    }

    public void OnProcessWarehouseChange(bool value)
    {
        processDto.IsWarehouseProcess = value;

        if(processDto.Type != ProcessType.CustomProcess)
        {
            processDto.Type = null;
        }

        if (value)
        {
            processType = AllprocessTypes.Where(x => (x.Type == ProcessType.CustomProcess || x.Type == ProcessType.Replenishment)).ToList();
        }
        else
        {
            processType = AllprocessTypes.Where(x => !(x.Type == ProcessType.Replenishment)).ToList();
        }

         StateHasChanged();
    }

    #endregion
}