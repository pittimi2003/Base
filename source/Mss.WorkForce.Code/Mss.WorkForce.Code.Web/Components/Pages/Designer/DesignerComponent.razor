    private async void CreateCanvas(bool reload, bool resetChanges = false)
    {
        if (reload)
        {
            await JS.InvokeVoidAsync("rememberView");
            Dto.Viewport = _designer.GetViewportsByLayoutId(Dto.Id, Dto.LayoutWarehouseDto.Id ?? Guid.Empty); //Update viewport from database
            await JS.InvokeVoidAsync("clearCanvas");
        }

        await JS.InvokeVoidAsync("SetSizeWorkArea", Dto);
        await JS.InvokeVoidAsync("reinitializeCanvas", reload, resetChanges);
        await JS.InvokeVoidAsync("StartWorkArea");
        await JS.InvokeVoidAsync("StartDrawCanvas", Dto.Viewport);
        tabsComponent?.RecalculateRelatedElements();
        await JS.InvokeVoidAsync("SaveOnPostback");
    }

    public void HandleSelection(string json)
    {
        var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

        var items = JsonSerializer.Deserialize<List<Dictionary<string, object>>>(json, options);

        foreach (var item in items)
        {
            if (item.TryGetValue("tab", out var tabObj) && item.TryGetValue("id", out var idObj))
            {
                string tab = tabObj?.ToString();
                if (Guid.TryParse(idObj?.ToString(), out Guid id))
                {
                    tabsComponent?.HandleClick(id, tab);
                }
            }
        }
    }

