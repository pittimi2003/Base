                                            Value="@flowDto.Type"
                                            ValueExpression="@(() => flowDto.Type)"
                                            ValueChanged="@((FlowType? ft) => OnValueChangedEntity(ft, () => flowDto.Type, v => flowDto.Type = v))"
                                            ValueFieldName="Value"
                                            TextFieldName="Text"
                                            NullText="@L.Loc("Select...")" />
                                <ValidationMessage class="text-danger" For="@(() => flowDto.Type)" />
                            </div>
                        </div>
                    </BodyContent>
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveFlowPropertyEvent())">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Stage:
            <EditForm EditContext="@editContext">
                <DialogComponent Title="@L.Loc("Create stage")" Text="@L.Loc("To create a zone, you must first create an area.")" CloseButtonClicked="@CloseModal">
