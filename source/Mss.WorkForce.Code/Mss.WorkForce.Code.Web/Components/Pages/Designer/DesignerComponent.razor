@if (showDeleteConfirmation)
{
    <DialogComponent Title="@L.Loc("Confirm Delete")" CloseButtonClicked="@(HideDeleteConfirmation)">
        <BodyContent>
            <p class="margin-none">@deleteMessage</p>
        </BodyContent>
        <FooterContent>
            <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="HideDeleteConfirmation">@L.Loc("Cancel")</button>
            <button type="button" class="btn-mlx btn-mlx-blue-primary" onclick="@(() => ConfirmDelete())">@L.Loc("Yes")</button>
        </FooterContent>
    </DialogComponent>
}

@* Back Button Modal *@
@if (showModalBackButton)
{
    <DialogComponent Title="@L.Loc("Unsaved modifications")" CloseButtonClicked="@(() => CloseModalBackButton())">
        <BodyContent>
            <p class="margin-none">@L.Loc("Do you want to save the changes before exiting?")</p>
        </BodyContent>
        <FooterContent>
            <button type="button" class="btn-mlx btn-mlx-white-primary" onclick="@(() => ActionClickClear())">@L.Loc("No")</button>
            <button type="button" class="btn-mlx btn-mlx-blue-primary" onclick="@(() => SaveAndExit())">@L.Loc("Yes")</button>
        </FooterContent>
    </DialogComponent>
}

@* Revert Button Modal *@
@if (showModalRevertButton)
{
    <DialogComponent Title="@L.Loc("Revert changes")" CloseButtonClicked="@(() => CloseModalRevertButton())">
        <BodyContent>
            <p class="margin-none">@L.Loc("Are you sure you want to revert the changes to the last saved point?")</p>
        </BodyContent>
        <FooterContent>
            <button type="button" class="btn-mlx btn-mlx-white-primary" onclick="@(() => CloseModalRevertButton())">@L.Loc("No")</button>
            <button type="button" class="btn-mlx btn-mlx-blue-primary" onclick="@(() => SaveModalRevert())">@L.Loc("Yes")</button>
        </FooterContent>
    </DialogComponent>
}

@* InternalNav Button Modal *@
@if (showModalInternalNavButton)
{
    <DialogComponent Title="@L.Loc("Unsaved modifications")" CloseButtonClicked="@(() => CancelNavigation())">
        <BodyContent>
            <p class="margin-none">@L.Loc("You have unsaved changes. Are you sure you want to leave and discard them?")</p>
        </BodyContent>
        <FooterContent>
            <button type="button" class="btn-mlx btn-mlx-white-primary" onclick="@(() => CancelNavigation())">@L.Loc("Cancel")</button>
            <button type="button" class="btn-mlx btn-mlx-blue-primary" onclick="@(() => ConfirmNavigation())">@L.Loc("Discard")</button>
        </FooterContent>
    </DialogComponent>
}

@if (showUniversalModal)
{
    <DialogComponent Title="@modal.Title" CloseButtonClicked="HideModal">
        <BodyContent>
            <p class="margin-none">@modal.Message</p>
        </BodyContent>
        <FooterContent>
            @modal.Footer
        </FooterContent>
    </DialogComponent>
}

