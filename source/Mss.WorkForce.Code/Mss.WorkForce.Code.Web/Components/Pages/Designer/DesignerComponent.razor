                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveProcessDirectionPropertyEvent())">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Flow:
