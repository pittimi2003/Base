    // Method that returns the result of the calculated Inbound Outbound increase
    private (int inbound, int outbound) RangesInboundOutbound(Guid areaId)
    {
        (int nextInbound, int nextOutbound) = _designer.GetNextDockRangesInboundOutbound(areaId);
        return NormalizeRangesInboundOutbound(nextInbound, nextOutbound);
    }

    // Set minimum values for Inbound/Outbound
    private (int inbound, int outbound) NormalizeRangesInboundOutbound(int inboundMax, int outboundMax)
    {
        int normalizedInbound = inboundMax < 1 ? 1 : inboundMax + 1;
        int normalizedOutbound = outboundMax < 1 ? 1 : outboundMax + 1;
        return (normalizedInbound, normalizedOutbound);
    }

