    private bool CanSave; //Flag to bottons save

    private bool ValidateCurrentModal(ObjectTypes objectType)
    {
        if (editContext == null) // Ensure that editContext exists
            return false;

        messageStore?.Clear(); // Clear messageStore
        bool isValid = editContext.Validate(); // Execute DataAnnotations
        isValid = isValid && ApplyCustomValidation(objectType); // Execute custom rules by modal
        editContext.NotifyValidationStateChanged();
        CanSave = isValid; // Status Button Save
        return isValid;
    }

    private bool ApplyCustomValidation(ObjectTypes objectType)
    {
        bool isValid = true;

        switch (objectType)
        {
            case ObjectTypes.Area:
                isValid &= ValidateRequired(() => areaDto.Name);
                isValid &= ValidateRequired(() => areaDto.AreaType);
                break;

            case ObjectTypes.Route:
                isValid &= ValidateRequired(() => routeDto.Name);
                isValid &= ValidateNotEmptyGuid(() => routeDto.OutboundAreaId);
                isValid &= ValidateNotEmptyGuid(() => routeDto.InboundAreaId);
                break;

            case ObjectTypes.Equipment:
                isValid &= ValidateRequired(() => equipmentModalDto.TypeEquipment);

                if (isAddingNewArea)
                {
                    isValid &= ValidateRequired(() => equipmentModalDto.Area.Name);
                    isValid &= ValidateRequired(() => equipmentModalDto.Area.AreaType);
                }
                else
                    isValid &= ValidateNotEmptyGuid(() => equipmentModalDto.AreaId);
                break;

            case ObjectTypes.Dock:
                isValid &= ValidateRequired(() => ModalItemZoneDock.Name);
                isValid &= ValidatePositive(() => ModalItemZoneDock.Quantity);
                isValid &= ValidateRequired(() => ModalItemZoneDock.FlowInOut);

                if (isAddingNewArea)
                    isValid &= ValidateRequired(() => ModalItemZoneDock.Dock.Zone.Area.Name);
                else
                    isValid &= ValidateNotEmptyGuid(() => ModalItemZoneDock.Dock.Zone.AreaId);

                break;

            case ObjectTypes.Buffer:
            case ObjectTypes.Aisle:
                isValid &= ValidateRequired(() => ModalItemBuffer.Name);
                isValid &= ValidatePositive(() => ModalItemBuffer.Quantity);
                isValid &= ValidateRequired(() => ModalItemBuffer.BufferType);

                if (isAddingNewArea)
                    isValid &= ValidateRequired(() => ModalItemBuffer.Area.Name);
                else
                    isValid &= ValidateNotEmptyGuid(() => ModalItemBuffer.AreaId);
                break;

            case ObjectTypes.Process:
                isValid &= ValidateRequired(() => processDto.Name);
                isValid &= ValidateNotEmptyGuid(() => processDto.AreaId);
                isValid &= ValidateRequired(() => processDto.Type);
                isValid &= ValidateRequired(() => processDto.Flow);
                break;

            case ObjectTypes.ProcessDirectionProperty:
                isValid &= ValidateNotEmptyGuid(() => processDirectionPropertyDto.InitProcessId);
                isValid &= ValidateNotEmptyGuid(() => processDirectionPropertyDto.EndProcessId);

                if (processDirectionPropertyDto.InitProcessId == processDirectionPropertyDto.EndProcessId)
                {
                    AddError(() => processDirectionPropertyDto.EndProcess, L.Loc("Init and End process can't be the same"));
                    isValid = false;
                }
                break;

            case ObjectTypes.Flow:
                isValid &= ValidateRequired(() => flowDto.Name);
                isValid &= ValidateRequired(() => flowDto.Type);
                break;

            case ObjectTypes.Stage:
                isValid &= ValidateRequired(() => ModalItemStage.Name);
                isValid &= ValidatePositive(() => ModalItemStage.Quantity);
                isValid &= ValidateRequired(() => ModalItemStage.StageIsin);

                if (isAddingNewArea)
                    isValid &= ValidateRequired(() => ModalItemStage.Area.Name);
                else
                    isValid &= ValidateNotEmptyGuid(() => ModalItemStage.AreaId);
                break;

            case ObjectTypes.Shelf:
                isValid &= ValidateRequired(() => ModalItemLocationZone.Name);
                isValid &= ValidateRequired(() => ModalItemLocationZone.ZoneType);

                if (isAddingNewArea)
                    isValid &= ValidateRequired(() => ModalItemLocationZone.Area.Name);
                else
                    isValid &= ValidateNotEmptyGuid(() => ModalItemLocationZone.AreaId);
                if (isAddingShelfConfiguration)
                    isValid &= ValidateNotDefaultEnum(() => ModalItemLocationZone.Orientation, OrientationType.None);
                break;
        }

        return isValid;
    }

    private bool ValidateRequired<T>(Expression<Func<T>> expression)
    {
        var field = FieldIdentifier.Create(expression);
        var value = expression.Compile().Invoke();

        if (value == null || (value is string s && string.IsNullOrWhiteSpace(s)))
        {
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            return false;
        }
        return true;
    }

    private bool ValidateNotEmptyGuid(Expression<Func<Guid?>> expression)
    {
        var field = FieldIdentifier.Create(expression);
        var value = expression.Compile().Invoke();

        if (value == null || value == Guid.Empty)
        {
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            return false;
        }
        return true;
    }

    private bool ValidateNotEmptyGuid(Expression<Func<Guid>> expression)
    {
        var field = FieldIdentifier.Create(expression);
        var value = expression.Compile().Invoke();

        if (value == null || value == Guid.Empty)
        {
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            return false;
        }
        return true;
    }

    private bool ValidatePositive(Expression<Func<int?>> expression)
    {
        var field = FieldIdentifier.Create(expression);
        var value = expression.Compile().Invoke();

        if (value == null || value <= 0)
        {
            messageStore?.Add(field, L.Loc("* Must be greater than 0"));
            return false;
        }
        return true;
    }

    private bool ValidatePositive(Expression<Func<int>> expression)
    {
        var field = FieldIdentifier.Create(expression);
        var value = expression.Compile().Invoke();

        if (value <= 0)
        {
            messageStore?.Add(field, L.Loc("* Must be greater than 0"));
            return false;
        }
        return true;
    }

    private bool ValidateNotDefaultEnum<TEnum>(Expression<Func<TEnum?>> expression, TEnum invalidValue) where TEnum : struct, Enum
    {
        var func = expression.Compile();
        var value = func();

        if (!value.HasValue || EqualityComparer<TEnum>.Default.Equals(value.Value, invalidValue))
        {
            AddError(expression, L.Loc("* Mandatory field"));
            return false;
        }
        return true;
    }

    private void AddError<T>(Expression<Func<T>> expression, string message)
    {
        var field = FieldIdentifier.Create(expression);
        messageStore?.Add(field, message);
    }

