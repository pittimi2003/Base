@inject ISimulateService backend
@using Mss.WorkForce.Code.Models.Common
@using Mss.WorkForce.Code.Models.DTO.Designer.LocationZones
@using Mss.WorkForce.Code.Models.DataAccess
@inject DataAccess dataAccess
@inject ILocalizationService L
@using Mss.WorkForce.Code.Models.DTO
@using Mss.WorkForce.Code.Models.DTO.Designer
@using Mss.WorkForce.Code.Models.DTO.Designer.Process
@using Mss.WorkForce.Code.Models.Models
@using Mss.WorkForce.Code.Web.Common
@using Mss.WorkForce.Code.Web.Components.DesignerComponent
@using DevExpress.Blazor
@using Mss.WorkForce.Code.Web.Model
@using Mss.WorkForce.Code.Web.Services
@using System.Text.Json
@using Mss.WorkForce.Code.Web.Components.Shared
@using System.Reflection
@using static Mss.WorkForce.Code.Models.DTO.Enums.Designer.ObjectsTypes
@using Buffer = Mss.WorkForce.Code.Models.Models.Buffer
@using System.ComponentModel.DataAnnotations
@using InboundFlowGraphDto = Mss.WorkForce.Code.Models.DTO.Designer.InboundFlowGraphDto;
@using OutboundFlowGraphDto = Mss.WorkForce.Code.Models.DTO.Designer.OutboundFlowGraphDto;
@using System.Linq.Expressions
@inject IInitialDataService _InitialDataService
@inject SendParamService _SendParamService 

@implements IAsyncDisposable

<style>
    .middle-content {
        overflow: hidden !important;
    }
</style>

@* Modal *@
@if (showModal)
{
    switch (objectType)
    {
        case ObjectTypes.Area:
            <EditForm EditContext="@editContext">
                <DataAnnotationsValidator />
                @*Area modal*@
                <DialogComponent Title="@L.Loc("Create area")" CloseButtonClicked="@CloseModal">
                    @*Area modal body*@
                    <BodyContent>
                        <div class="row">
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@areaDto.Name" />
                                <ValidationMessage class="text-danger" For="@(() => areaDto.Name)" />
                            </div>
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">
                                    @L.Loc("Type")

                                    @*Tooltip Section*@
                                    <TooltipComponent CssClass="btn-modal-info-button mlx-ico-info-bg-solid margin-left-6px" Position="FlyoutPosition.Right">
                                        <div class="custom-tooltip">
                                            @if (areaDto.AreaType is null)
                                            {
                                                @*Shows the list of types and their descriptions*@
                                                <ul>
                                                    @foreach (var item in TooltipExtensions.AreaTypes)
                                                    {
                                                        <li><b>@L.Loc(item.Name):</b> @L.Loc(item.Description)</li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                @*Show only the selected area type*@
                                                var info = TooltipExtensions.AreaTypes.FirstOrDefault(x => x.Type == areaDto.AreaType);
                                                <span><b>@L.Loc(info.Name):</b> @L.Loc(info.Description)</span>
                                            }
                                        </div>
                                    </TooltipComponent>
                                </label>
                                <MlxComboBox Data="@areaType" CssClass="mlx-form-select" @bind-Value="@areaDto.AreaType" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" />
                                <ValidationMessage class="text-danger" For="@(() => areaDto.AreaType)" />
                            </div>
                        </div>
                    </BodyContent>
                    @*Area modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveAreaEvent())">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Route:
            @*Route modal*@
            <EditForm EditContext="@editContext">
                <DataAnnotationsValidator />
                <DialogComponent Title="@L.Loc("Create route")" Text="@L.Loc("To create a route, you must first create an area.")" CloseButtonClicked="@CloseModal">
                    @*Route modal body*@
                    <BodyContent>
                        <div class="row">
                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@routeDto.Name" />
                                <ValidationMessage class="text-danger" For="@(() => routeDto.Name)" />
                            </div>
                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Outbound area")</label>
                                <MlxComboBox Data="@FilteredOutboundAreaItems()" CssClass="mlx-form-select" Value="@routeDto.OutboundArea" ValueFieldName="Id" TextFieldName="@nameof(routeDto.OutboundArea.Name)" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedArea(a, () => routeDto.OutboundAreaId, id => routeDto.OutboundAreaId = id, area => routeDto.OutboundArea = area))" ValueExpression="@(() => routeDto.OutboundArea)" TextExpression="@(() => routeDto.OutboundArea.Name)" />
                                <ValidationMessage class="text-danger" For="@(() => routeDto.OutboundAreaId)" />
                            </div>
                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Inbound area")</label>
                                <MlxComboBox Data="@FilteredInboundAreaItems()" CssClass="mlx-form-select" Value="@routeDto.InboundArea" ValueFieldName="Id" TextFieldName="@nameof(routeDto.InboundArea.Name)" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedArea(a, () => routeDto.InboundArea, id => routeDto.InboundAreaId = id, area => routeDto.InboundArea = area))" ValueExpression="@(() => routeDto.InboundArea)" TextExpression="@(() => routeDto.InboundArea.Name)" />
                                <ValidationMessage class="text-danger" For="@(() => routeDto.InboundAreaId)" />
                            </div>
                        </div>
                    </BodyContent>
                    @*Route modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveRouteEvent())">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Equipment:
            @*Equipment Modal*@
            <EditForm EditContext="@editContext">
                <DialogComponent Title="@L.Loc("Create equipment")" Text="@L.Loc("To create a equipment, you must first create an area.")" CloseButtonClicked="@CloseModal">
                    @*Equipment modal body*@
                    <BodyContent>
                        <div class="row align-items-center gx-2">
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Type")</label>
                                <MlxComboBox Data="TypeEquipment" CssClass="mlx-form-select" Value="@equipmentModalDto.TypeEquipment" ValueFieldName="Id" TextFieldName="Name" NullText="@L.Loc("Select...")" ValueChanged="@((TypeEquipment e) => OnValueChangedEntity(e, () => equipmentModalDto.TypeEquipment, v => { equipmentModalDto.TypeEquipment = v; equipmentModalDto.TypeEquipmentId = v?.Id ?? Guid.Empty; }))" ValueExpression="@(() => equipmentModalDto.TypeEquipment)" />
                                <ValidationMessage class="text-danger" For="@(() => equipmentModalDto.TypeEquipment)" />
                            </div>  @*AreaEquipmentItems*@
                            <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Area")</label>
                                <div class="flex-flow-row gap-10 align-items-center">
                                    <MlxComboBox Data="AreaEquipmentItems" CssClass="mlx-form-select width-100" Value="@equipmentModalDto.Area" ValueFieldName="Id" TextFieldName="Name" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedEntity(a, () => equipmentModalDto.Area, v => {equipmentModalDto.Area = v; equipmentModalDto.AreaId = v.Id ?? Guid.Empty;}))" ValueExpression="@(() => equipmentModalDto.Area)" Enabled="!isAddingNewArea" />
                                    <button type="button" class="addButton-circle-style @(isAddingNewArea ? "mlx-btn-action-disabled" : "mlx-btn-action-enabled")" @onclick="ToggleNewAreaGeneric" disabled="@(isAddingNewArea)"><span class="mlx-ico-add"></span></button>
                                </div>
                                <ValidationMessage class="text-danger" For="@(() => equipmentModalDto.AreaId)" />
                            </div>
                        </div>

                        @if (isAddingNewArea)
                        {
                            <div class="col-xl-12 col-sm-12" style="margin-top: 10px; ">
                                <div class="accordion">
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#idZoneArea" aria-expanded="true" aria-controls="idZoneArea">
                                                <span class="mlx-title-h3">@L.Loc("New Area")</span>
                                            </button>
                                        </h2>
                                        <div id="idZoneArea" class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                <div class="row gx-2 align-items-end">
                                                    <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Name")</label>
                                                        <DxTextBox CssClass="mlx-form-textbox" Text="@equipmentModalDto.Area.Name" TextChanged="((string? val) => OnNameChanged(val, () => equipmentModalDto.Area.Name, val => equipmentModalDto.Area.Name = val))" TextExpression="@(() => equipmentModalDto.Area.Name)" />
                                                        <ValidationMessage class="text-danger" For="@(() => equipmentModalDto.Area.Name)" />
                                                    </div>
                                                    <div class="col-xl-6 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Type")</label>
                                                        <div class="flex-flow-row gap-10 align-items-center">
                                                            <MlxComboBox Data="areaType" CssClass="mlx-form-select width-100" Value="@equipmentModalDto.Area.AreaType" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" ValueChanged="@((AreaType? v) => OnValueChangedEntity(v, () => equipmentModalDto.Area.AreaType, val => equipmentModalDto.Area.AreaType = val))" ValueExpression="@(() => equipmentModalDto.Area.AreaType)" />
                                                            <button type="button" class="trashButton-circle-style" @onclick="ToggleNewAreaGeneric"><span class="mlx-ico-trash"></span></button>
                                                        </div>
                                                        <ValidationMessage class="text-danger" For="@(() => equipmentModalDto.Area.AreaType)" />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </BodyContent>
                    @*Equipment modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveEquipmentEvent())">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Dock:
            <EditForm EditContext="@editContext">
                @{
                    var elementLocalized = L.Loc(GetObjectTypeString(objectType));
                }
                <DialogComponent Title="@L.Loc("Create dock")" Text="@L.Loc("To create a zone, you must first create an area.")" CloseButtonClicked="@CloseModal">
                    @*Dock modal body*@
                    <BodyContent>
                        <div class="row overflow-hidden">
                            <div class="col-xl-4 col-sm-12">
                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@ModalItemZoneDock.Name" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemZoneDock.Name)" />
                            </div>
                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Quantity")</label>
                                <DxSpinEdit CssClass="mlx-form-spinedit" MinValue="0" MaxValue="999999" @bind-Value="ModalItemZoneDock.Quantity" Mask="n0"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
                                <ValidationMessage class="text-danger" For="@(() => ModalItemZoneDock.Quantity)" />
                            </div>

                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Type")</label>
                                <MlxComboBox Data="@dockTypeList" CssClass="mlx-form-select width-100" Value="@ModalItemZoneDock.FlowInOut" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" ValueChanged="@((DockType? v) => OnValueChangedEntity(v, () => ModalItemZoneDock.FlowInOut, val => ModalItemZoneDock.FlowInOut = val))" ValueExpression="@(() => ModalItemZoneDock.FlowInOut)" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemZoneDock.FlowInOut)" />
                            </div>

                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Orientation")</label>
                                <MlxComboBox Data="orientationType" CssClass="mlx-form-select width-100" @bind-Value="@ModalItemZoneDock.Orientation" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" />
                            </div>

                            <div class="col-xl-4 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Area")</label>
                                <div class="flex-flow-row gap-10 align-items-center">
                                    <MlxComboBox Data="AreaItems" CssClass="mlx-form-select width-100" Value="@ModalItemZoneDock.Dock.Zone.Area" ValueFieldName="Id" TextFieldName="Name" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedEntity(a, () => ModalItemZoneDock.Dock.Zone.Area, v => {ModalItemZoneDock.Dock.Zone.Area = v; ModalItemZoneDock.Dock.Zone.AreaId = v?.Id ?? Guid.Empty;}))" ValueExpression="@(() => ModalItemZoneDock.Dock.Zone.Area)" TextExpression="@(() => ModalItemZoneDock.Dock.Zone.Area.Name)" Enabled="!isAddingNewArea" />
                                    <button type="button" class="addButton-circle-style @(isAddingNewArea ? "mlx-btn-action-disabled" : "mlx-btn-action-enabled")" @onclick="ToggleNewAreaGeneric" disabled="@(isAddingNewArea)"><span class="mlx-ico-add"></span></button>
                                </div>
                                <ValidationMessage class="text-danger" For="@(() => ModalItemZoneDock.Dock.Zone.AreaId)" />
                            </div>
                        </div>

                        @if (isAddingNewArea)
                        {
                            <div class="col-xl-12 col-sm-12" style="margin-top: 10px;">
                                <div class="accordion">
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#idZoneDockArea" aria-expanded="true" aria-controls="idZoneDockArea">
                                                <span class="mlx-title-h3">@L.Loc("New Dock Area")</span>
                                            </button>
                                        </h2>
                                        <div id="idZoneDockArea" class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                <div class="row">
                                                    <div class="col-xl-12 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Name")</label>
                                                        <div class="flex-flow-row gap-10 align-items-center">
                                                            <DxTextBox CssClass="mlx-form-textbox width-100" Text="@ModalItemZoneDock.Dock.Zone.Area.Name" TextChanged="@((string? val) => OnNameChanged(val, () => ModalItemZoneDock.Dock.Zone.Area.Name, v => ModalItemZoneDock.Dock.Zone.Area.Name = v))" TextExpression="@(() => ModalItemZoneDock.Dock.Zone.Area.Name)" />
                                                            <button type="button" class="trashButton-circle-style" @onclick="ToggleNewAreaGeneric"><span class="mlx-ico-trash"></span></button>
                                                        </div>
                                                        <ValidationMessage class="text-danger" For="@(() => ModalItemZoneDock.Dock.Zone.Area.Name)" />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </BodyContent>
                    @*Dock modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveZoneEvent(objectType))">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Aisle:
        case ObjectTypes.Buffer:
            <EditForm EditContext="@editContext">
                <DialogComponent Title="@L.Loc("Create buffer")" Text="@L.Loc("To create a zone, you must first create an area.")" CloseButtonClicked="@CloseModal">
                    @*Dock modal body*@
                    <BodyContent>
                        <div class="row overflow-hidden">
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@ModalItemBuffer.Name" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemBuffer.Name)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Quantity")</label>
                                <DxSpinEdit CssClass="mlx-form-spinedit" MinValue="0" MaxValue="999999" @bind-Value="ModalItemBuffer.Quantity" Mask="n0"><DxNumericMaskProperties Culture="userFormat.BuildCultureFromSeparators()" /></DxSpinEdit>
                                <ValidationMessage class="text-danger" For="@(() => ModalItemBuffer.Quantity)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Type")</label>
                                <MlxComboBox Data="bufferTypes" CssClass="mlx-form-select width-100" Value="@ModalItemBuffer.BufferType" ValueFieldName="Value" TextFieldName="Text" NullText="@L.Loc("Select...")" ValueChanged="@((BufferType? v) => OnValueChangedEntity(v, () => ModalItemBuffer.BufferType, val => ModalItemBuffer.BufferType = val))" ValueExpression="@(() => ModalItemBuffer.BufferType)" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemBuffer.BufferType)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Area")</label>
                                <div class="flex-flow-row gap-10 align-items-center">
                                    <MlxComboBox Data="AreaItems" CssClass="mlx-form-select width-100" Value="@ModalItemBuffer.Area" ValueFieldName="Id" TextFieldName="@nameof(ModalItemBuffer.Area.Name)" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedEntity(a,() => ModalItemBuffer.Area,v =>{ModalItemBuffer.Area = v; ModalItemBuffer.AreaId = v?.Id ?? Guid.Empty;}))" ValueExpression="@(() => ModalItemBuffer.Area)" Enabled="!isAddingNewArea" />
                                    <button type="button" class="addButton-circle-style @(isAddingNewArea ? "mlx-btn-action-disabled" : "mlx-btn-action-enabled")" @onclick="ToggleNewAreaGeneric" disabled="@(isAddingNewArea)"><span class="mlx-ico-add"></span></button>
                                </div>
                                <ValidationMessage class="text-danger" For="@(() => ModalItemBuffer.AreaId)" />
                            </div>
                        </div>

                        @if (isAddingNewArea)
                        {
                            <div class="col-xl-12 col-sm-12" style="margin-top: 10px;">
                                <div class="accordion">
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#idZoneArea" aria-expanded="true" aria-controls="idZoneArea">
                                                <span class="mlx-title-h3">@L.Loc("New Buffer Area")</span>
                                            </button>
                                        </h2>
                                        <div id="idZoneArea" class="accordion-collapse collapse show">
                                            <div class="accordion-body">
                                                <div class="row">
                                                    <div class="col-xl-12 col-sm-12 control-space-to-validation-message">
                                                        <label class="mlx-form-label">@L.Loc("Name")</label>
                                                        <div class="flex-flow-row gap-10 align-items-center">
                                                            <DxTextBox CssClass="mlx-form-textbox width-100" Text="@ModalItemBuffer.Area.Name" TextChanged="((string? val) => OnNameChanged(val, () => ModalItemBuffer.Area.Name, val => ModalItemBuffer.Area.Name = val))" TextExpression="@(() => ModalItemBuffer.Area.Name)" />
                                                                <button type="button" class="trashButton-circle-style" @onclick="ToggleNewAreaGeneric"><span class="mlx-ico-trash"></span></button>
                                                        </div>
                                                        <ValidationMessage class="text-danger" For="@(() => ModalItemBuffer.Area.Name)" />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </BodyContent>
                    @*Dock modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
                        <button type="button" class="btn-mlx btn-mlx-blue-primary" disabled="@(!CanSave)" @onclick="@(() => SaveZoneEvent(objectType))">@L.Loc("Save")</button>
                    </FooterContent>
                </DialogComponent>
            </EditForm>
            break;
        case ObjectTypes.Process:
            <EditForm EditContext="@editContext">
                <DialogComponent Title="@L.Loc("Create process")" Text=@(null != AreaProcessItems && AreaProcessItems.Count() > 0 ? "" : @L.Loc("To create a process, you must first create an area.")) CloseButtonClicked="@CloseModal">
                    <BodyContent>
                        <div class="row overflow-hidden">
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@processDto.Name" />

                                <!-- Mensaje de validación específico para el campo Name -->
                                <ValidationMessage class="text-danger" For="@(() => processDto.Name)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Area")</label>
                                <MlxComboBox Data="AreaProcessItems" CssClass="mlx-form-select width-100" Value="@processDto.AreaDto" ValueFieldName="Id" TextFieldName="@nameof(processDto.AreaDto.Name)" NullText="@L.Loc("Select...")" ValueChanged="@((AreaDto a) => OnValueChangedEntity(a, () => processDto.AreaDto, v => { processDto.AreaDto = v; processDto.AreaId = v?.Id ?? Guid.Empty;}))" ValueExpression="@(() => processDto.AreaDto)" TextExpression="@(() => processDto.AreaDto.Name)" />
                                <ValidationMessage class="text-danger" For="@(() => processDto.AreaId)" />
                            </div>
                            <div class="col-xl-2 col-sm-12 control-space-to-validation-message">
                                    <label class="mlx-form-label">@L.Loc("IS_WAREHOUSE_PROCESS")</label>
                                   <DxCheckBox CssClass="mlx-check-box align-items-center"
                                                CheckedChanged="@((bool value)=> OnProcessWarehouseChange(value))"
                                                Checked="@processDto.IsWarehouseProcess"
                                                CheckedExpression="@(() => processDto.IsWarehouseProcess)">
                                    </DxCheckBox>
                            </div>
                            <div class="col-xl-2 col-sm-12 control-space-to-validation-message">
                                <label class="mlx-form-label">@L.Loc("Type")</label>
                                <MlxComboBox Data="@processType" CssClass="mlx-form-select" @bind-Value="@processDto.Type" ValueFieldName="Type" TextFieldName="TypeName" NullText="@L.Loc("Select...")" />
                                <ValidationMessage class="text-danger" For="@(() => processDto.Type)" />
                            </div>
                            <div class="col-xl-2 col-sm-12">
                                <label class="mlx-form-label">@L.Loc("Flow")</label>
                                <MlxComboBox Data="@ParentFlowItems" CssClass="mlx-form-select" @bind-Value="@processDto.Flow" ValueFieldName="Id" TextFieldName="@nameof(processDto.Flow.Name)" NullText="@L.Loc("Select...")" />
                                <ValidationMessage class="text-danger" For="@(() => processDto.Flow)" />
                            </div>
                        </div>
                    </BodyContent>
                    @*Dock modal footer*@
                    <FooterContent>
                        <button type="button" class="btn-mlx btn-mlx-white-primary" @onclick="@(() => CloseModal())">@L.Loc("Cancel")</button>
