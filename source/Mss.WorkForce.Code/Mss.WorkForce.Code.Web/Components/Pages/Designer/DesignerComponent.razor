                                <label class="mlx-form-label">@L.Loc("Name")</label>
                                <DxTextBox CssClass="mlx-form-textbox" @bind-Text="@ModalItemStage.Name" />
                                <ValidationMessage class="text-danger" For="@(() => ModalItemStage.Name)" />
                            </div>
                            <div class="col-xl-3 col-sm-12 control-space-to-validation-message">
