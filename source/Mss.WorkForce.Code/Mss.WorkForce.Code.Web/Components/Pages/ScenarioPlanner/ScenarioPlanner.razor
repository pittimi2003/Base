@page "/scenario-planner"

@inject ILogger<ScenarioPlanner> Logger
@using Mss.WorkForce.Code.Models.ModelGantt
@using Mss.WorkForce.Code.Models.DataAccess
@using Mss.WorkForce.Code.Models.ModelUpdate
@using Mss.WorkForce.Code.Models.Models
@using Mss.WorkForce.Code.Models.Common
@using Mss.WorkForce.Code.Web.Components.Gantt
@using Mss.WorkForce.Code.Web.Components.Pages.Planning
@using Mss.WorkForce.Code.Web.Components.Pages.Preview.Components
@using DevExpress.Blazor
@using Mss.WorkForce.Code.Web.Components.Shared
@using Mss.WorkForce.Code.Web.Services
@using Mss.WorkForce.Code.Web.Model
@using System.Text.Json
@using Mss.WorkForce.Code.Models.DTO
@using Mss.WorkForce.Code.Models.DTO.Enums
@using Newtonsoft.Json
@using static Mss.WorkForce.Code.Web.Components.Pages.Preview.Components.Temporalidad
@using Mss.WorkForce.Code.Web.Components.Pages.Preview;
@using Mss.WorkForce.Code.Web.Components.Dialog
@using Mss.WorkForce.Code.Web.Common
@using Mss.WorkForce.Code.Models
@using Mss.WorkForce.Code.Models.DTO.Preview
@inject ILocalizationService L
@inherits Mss.WorkForce.Code.Web.Common.GanttOperations
@attribute [Authorize]

<ConfirmDialog></ConfirmDialog>

<div class="mlx-preview-container">
    <div class="mlx-preview-section-header">
        <div class="row mt-1">
            <div class="col-auto">
                <SitePreview ValueChanged="OnSiteSeleccionadaChanged" />
            </div>
            <div class="col-auto">
                <Temporalidad @ref="temporalityComponent" siteModelId="CurrentSite.Id" Temps="temps" TempSelected="temporalidadSeleccionada" ValueChanged="OnTemporalidadSeleccionadaChanged" ValueRemoved="OnTemporalidadSeleccionadaRemoved" userFormat="userFormat" />
            </div>
        </div>
    </div>

    <div class="mlx-preview-section-gantt">
        <div class="row">
            <div class="col">
                <div id="GanttContainer" class="mlx-container-gantt-40">
                    <GanttComponent TModel="TaskData" LoadPanelVisible="LoadPanelVisible" BackgroundShading="BackGroudShading" GanttSetup="GanttSetup" GanttTasksData="DataSimulation" UserFormat="userFormat" Properties="GanttProperties"></GanttComponent>
                </div>
            </div>
        </div>
    </div>

    <div class="mlx-preview-section-button-chevron">
        <div class="mlx-row-chevron">
            <button id="btnDrawerInfoPreview" class="mlx-btn-action-enabled mlx-btn-chevron" @onclick='() => ChangeGanttRepaint(!ShowInfoDrawer)' disabled>
                <span class="@(ShowInfoDrawer ? "mlx-ico-chevron-down" : "mlx-ico-chevron-up") "></span>
            </button>
        </div>
    </div>

    <div class="@(ShowInfoDrawer ? "mlx-preview-section-simulation-data" : "mlx-preview-section-simulation-data-hidden" )">
        <div class="row w-100">
            <div class="col-md-4">
                <div class="mlx-panel" style="overflow:auto">
                    <div class="mlx-panel-header no-background">
                        <div class="mlx-panel-title">
                            @l.Loc("SCHEDULE_PREVIEW")
                        </div>
                        <div class="mlx-panel-actions">
                            <button class="btn-mlx-white-primary mlx-btn-circle-preview" @onclick="OpenWhatIfDistributionModal">
                                <span class="mlx-ico-details"></span>
                            </button>
                        </div>
                    </div>
                    <div class="mlx-panel-body">
                        <div class="row">
                            <DxGrid Data="@Shifts"
                                    KeyFieldName="id"
                                    EditMode="GridEditMode.EditCell"
                                    VirtualScrollingEnabled="true"
                                    KeyboardNavigationEnabled="true"
                                    EditModelSaving="OnShiftEditModelSaving"
                                    SelectedDataItems="@(SelectedShift.Cast<object>().ToList())"
                                    CustomizeElement="OnCustomizeGridElement"
                                    SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, OnSelectedShiftChanged))"
                                    CssClass="mlx-grid no-top">

                                <Columns>
                                    <!-- SHIFT (no editable, cursiva) -->
                                    <DxGridDataColumn FieldName="name"
                                                      Caption="@Name"
                                                      ReadOnly="true"
                                                      DataRowEditorVisible="false">
                                        <CellDisplayTemplate>
                                            <span class="mlx-italic">@context.DisplayText</span>
                                        </CellDisplayTemplate>
                                    </DxGridDataColumn>

                                    <!-- INIT HOUR (editable) -->
                                    <DxGridDataColumn FieldName="initHour" Name="initHour"
                                                      Caption="@Shift_start"
                                                      SortIndex="0"
                                                      SortOrder="GridColumnSortOrder.Ascending">
                                        <CellDisplayTemplate>
                                            @((context.Value is TimeSpan ts) ? ts.ToString(@"hh\:mm") : "")
                                        </CellDisplayTemplate>

                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = (ShiftRolDto)ctx.EditModel;
                                            }

                                            <div class="shift-edit-cell">
                                                <MlxTimePicker Time="row.initHour"
                                                               TimeChanged="@(v => row.initHour = v)"
                                                               InputId="@($"initHour_{Guid.NewGuid():N}")"
                                                               ScrollContainerSelector=".dxbl-grid-table"
                                                               userFormat="userFormat" />
                                            </div>
                                        </CellEditTemplate>

                                    </DxGridDataColumn>


                                    <!-- END HOUR (editable) -->
                                    <DxGridDataColumn FieldName="endHour" Name="endHour"
                                                      Caption="@Shift_end">
                                        <CellDisplayTemplate>
                                            @((context.Value is TimeSpan ts) ? ts.ToString(@"hh\:mm") : "")
                                        </CellDisplayTemplate>

                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = (ShiftRolDto)ctx.EditModel;
                                            }
                                            <div class="shift-edit-cell">
                                                <MlxTimePicker Time="row.endHour"
                                                               TimeChanged="@(v => row.endHour = v)"
                                                               InputId="@($"endHour_{Guid.NewGuid():N}")"
                                                               ScrollContainerSelector=".dxbl-grid-table"
                                                               userFormat="userFormat" />
                                            </div>
                                            
                                        </CellEditTemplate>
                                    </DxGridDataColumn>

                                </Columns>

                                <!-- Detalle con los roles -->
                                <DetailRowTemplate Context="shift">
                                    @{
                                        var shiftRow = shift?.DataItem as ShiftRolDto;
                                    }
                                    <DxGrid Data="shiftRow.workersInRol"
                                            KeyFieldName="id"
                                            CssClass="mlx-grid dxbl-grid-detail"
                                            EditMode="GridEditMode.EditCell"
                                            CustomizeElement="OnCustomizeGridElement"
                                            KeyboardNavigationEnabled="true"
                                            EditModelSaving="@(e => OnWorkerEditModelSaving(e, shiftRow))">

                                        <Columns>
                                            <!-- ROLE (no editable, cursiva) -->
                                            <DxGridDataColumn FieldName="name"
                                                              Caption="@Role"
                                                              ReadOnly="true"
                                                              DataRowEditorVisible="false">
                                                <CellDisplayTemplate>
                                                    <span class="mlx-italic">@context.DisplayText</span>
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>

                                            <!-- WORKERS (editable) -->
                                            <DxGridDataColumn FieldName="Workers" Name="Workers"
                                                              Caption="@Operators">
                                                <CellDisplayTemplate>
                                                    <div class="text-right">
                                                        @context.DisplayText
                                                    </div>
                                                </CellDisplayTemplate>

                                                <EditSettings>
                                                    <DxSpinEditSettings CssClass="mlx-form-spineditsettings-border"
                                                                        MinValue="0"
                                                                        MaxValue="9999"
                                                                        Increment="1" />
                                                </EditSettings>
                                            </DxGridDataColumn>


                                        </Columns>
                                    </DxGrid>
                                </DetailRowTemplate>
                            </DxGrid>


                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="mlx-panel" style="overflow:auto">
                    <div class="mlx-panel-header no-background">
                        <div class="mlx-panel-title">
                            @Workload
                        </div>
                        @*                         <button title="@L.Loc("Show/Hide group panel")"
                                @onclick="@(EventCallback.Factory.Create(this, ToggleGroupPanelProcesses))">
                            <i class="mlx-ico-tile-config"></i>
                        </button> *@
                        <div class="mlx-panel-bar-action">

                            @if (HasAnySelection)
                            {
                                <button name="action-delete-global"
                                        title="@Delete_selected"
                                        @onclick="DeleteSelectedLoads">
                                    <i class="mlx-ico-trash"></i>
                                </button>
                            }

                            <button name="action-edit"
                                    title="@Create_new"
                                    class="mlx-component-visible"
                                    @onclick="CreateNewLoad">
                                <i class="mlx-ico-add"></i>
                            </button>


                        </div>
                    </div>
                    <div class="mlx-panel-body">
                        <div class="row">
                            <DxGrid Data="@Load"
                                    @ref="gridLoad"
                                    KeyFieldName="id"
                                    EditMode="GridEditMode.EditCell"
                                    CssClass="mlx-grid no-top"
                                    AllowSort="true"
                                    ShowGroupPanel="@ShowGroupPanelLoad"
                                    ShowGroupedColumns="true"
                                    AllowGroup="true"
                                    SelectionMode="GridSelectionMode.Multiple"
                                    VirtualScrollingEnabled="true"
                                    KeyboardNavigationEnabled="true"
                                    SelectedDataItems="@(SelectedLoad.Cast<object>().ToList())"
                                    CustomizeElement="OnCustomizeGridElement"
                                    SelectedDataItemsChanged="@(EventCallback.Factory.Create<IReadOnlyList<object>>(this, OnSelectedLoadChanged))"
                                    EditModelSaving="OnLoadEditModelSaving">

                                <Columns>
                                    <DxGridSelectionColumn Width="40px" ShowInColumnChooser="false" AllowSelectAll="false" />
                                    <DxGridDataColumn FieldName="isOut"
                                                      Caption="@Flow"
                                                      SortIndex="0"
                                                      SortOrder="GridColumnSortOrder.Ascending">

                                        <!-- Cómo se ve la celda en modo display -->
                                        <CellDisplayTemplate>
                                            @{
                                                bool value = (bool)(context.Value ?? false);
                                                var item = TypeBounds.First(x => x.Key == value);
                                            }
                                            @item.Html
                                        </CellDisplayTemplate>



                                        <!-- Editor: ComboBox -->
                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var model = ctx.EditModel as VehicleLoadDto;
                                            }

                                            <DxComboBox CssClass="mlx-form-spineditsettings-border" TData="FlowTypeDto"
                                                        TValue="bool"
                                                        Data="@TypeBounds"
                                                        @bind-Value="model.isOut"
                                                        ValueFieldName="Key"
                                                        TextFieldName="Text"
                                                        AllowUserInput="false">

                                                <ItemDisplayTemplate>
                                                    @context.DataItem.Html
                                                </ItemDisplayTemplate>

                                            </DxComboBox>
                                        </CellEditTemplate>



                                    </DxGridDataColumn>


                                    <DxGridDataColumn FieldName="load" Name="load"
                                                      Caption="@Load_Text"
                                                      FilterRowOperatorType="GridFilterRowOperatorType.Contains">

                                        <!-- Display -->
                                        <CellDisplayTemplate Context="ctx">
                                            @{
                                                var row = ctx.DataItem as VehicleLoadDto;
                                            }
                                            @row?.load
                                        </CellDisplayTemplate>

                                        <!-- Editor -->
                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = ctx.EditModel as VehicleLoadDto;
                                            }

                                            @if (row != null)
                                            {
                                                <DxComboBox CssClass="mlx-form-spineditsettings-border"
                                                            TData="LoadType"
                                                            TValue="string"
                                                            Data="@loadTypes"
                                                            Value="@row.load"
                                                            ValueChanged="@((string newValue) => OnLoadChanged(row, newValue))"
                                                            ValueExpression="@(() => row.load)"
                                                            ValueFieldName="Name"
                                                            TextFieldName="Name"
                                                            AllowUserInput="false"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            NullText="@Select">
                                                </DxComboBox>
                                            }
                                        </CellEditTemplate>

                                    </DxGridDataColumn>


                                    <DxGridDataColumn FieldName="vehicle" Name="vehicle"
                                                      Caption="@Vehicle"
                                                      FilterRowOperatorType="GridFilterRowOperatorType.Contains">

                                        <!-- Display -->
                                        <CellDisplayTemplate Context="ctx">
                                            @{
                                                var row = ctx.DataItem as VehicleLoadDto;
                                            }
                                            @row?.vehicle
                                        </CellDisplayTemplate>

                                        <!-- Editor -->
                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = ctx.EditModel as VehicleLoadDto;
                                            }

                                            @if (row != null)
                                            {
                                                <DxComboBox CssClass="mlx-form-spineditsettings-border"
                                                            TData="VehicleType"
                                                            TValue="string"
                                                            Data="@vehicleTypes"
                                                            Value="@row.vehicle"
                                                            ValueChanged="@((string newValue) => OnVehicleChanged(row, newValue))"
                                                            ValueExpression="@(() => row.vehicle)"
                                                            ValueFieldName="Name"
                                                            TextFieldName="Name"
                                                            AllowUserInput="false"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            NullText="@Select">
                                                </DxComboBox>
                                            }
                                        </CellEditTemplate>

                                    </DxGridDataColumn>

                                    <!-- NUMBER VEHICLE -->
                                    <DxGridDataColumn FieldName="numberVehicle" Name="numberVehicle"
                                                      Caption="@N_Vehicles"
                                                      Width="105px">

                                        <CellDisplayTemplate>
                                            <div class="text-right">
                                                @context.DisplayText
                                            </div>
                                        </CellDisplayTemplate>

                                        <EditSettings>
                                            <DxSpinEditSettings CssClass="mlx-form-spineditsettings-border" MinValue="0d"
                                                                MaxValue="9999d"
                                                                Increment="1d" />
                                        </EditSettings>

                                    </DxGridDataColumn>




                                    <!-- HOUR -->
                                    <DxGridDataColumn FieldName="hour" Name="hour" Caption="@Start"
                                                      SortIndex="1"
                                                      SortOrder="GridColumnSortOrder.Ascending">

                                        <CellDisplayTemplate Context="ctx">
                                            @((ctx.Value is TimeSpan ts) ? ts.ToString(@"hh\:mm") : "")
                                        </CellDisplayTemplate>

                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = (VehicleLoadDto)ctx.EditModel;
                                            }
                                            
                                            <MlxTimePicker Time="row.hour"
                                                           TimeChanged="@(value => row.hour = value)"
                                                           ScrollContainerSelector=".dxbl-grid-table"
                                                           userFormat="userFormat"/>
                                            
                                        </CellEditTemplate>

                                    </DxGridDataColumn>

                                    
                                    <!-- END HOUR -->
                                    <DxGridDataColumn FieldName="endHour"
                                                      Name="endHour"
                                                      Caption="@End">

                                        <CellDisplayTemplate Context="ctx">
                                            @((ctx.Value is TimeSpan ts) ? ts.ToString(@"hh\:mm") : "")
                                        </CellDisplayTemplate>

                                        <CellEditTemplate Context="ctx">
                                            @{
                                                var row = (VehicleLoadDto)ctx.EditModel;
                                            }

                                            <MlxTimePicker Time="row.endHour"
                                                           TimeChanged="@(value => row.endHour = value)"
                                                           ScrollContainerSelector=".dxbl-grid-table"
                                                           userFormat="userFormat" />
                                        </CellEditTemplate>

                                    </DxGridDataColumn>


                                    <DxGridDataColumn Caption="@Status" Width="65px" Name="metrics" FieldName="MetricsStatus" DataRowEditorVisible="false">
                                        <CellDisplayTemplate Context="ctx">
                                            @{
                                                var row = ctx.DataItem as VehicleLoadDto;
                                            }

                                            @if (row != null)
                                            {
                                                <div id="@($"metrics-{row.id}")"
                                                     class="metrics-icon"
                                                     @onmouseenter="@(() => OpenFlyout(row))"
                                                     @onmouseleave="@(() => CloseFlyout())">
                                                </div>
                                            }
                                        </CellDisplayTemplate>
                                    </DxGridDataColumn>




                                </Columns>

                                <DataColumnGroupRowTemplate Context="ctx">
                                    @{
                                        // Columna por la que se está agrupando en este nivel
                                        var col = ctx.DataColumn;
                                        var field = col?.FieldName;

                                        if (field == "isOut")
                                        {
                                            // valor de grupo: true/false
                                            bool v = ctx.GroupValue is bool b && b;
                                            var item = TypeBounds.First(x => x.Key == v);

                                            <span class="dx-group-row-flow">
                                                @item.Html
                                            </span>
                                        }
                                        else if (field == "MetricsStatus")
                                        {
                                            var status = ctx.GroupValue?.ToString();
                                            var iconClass = status == "Error" ? "mlx-ico-x-preview" : "mlx-ico-check-preview";
                                            <span class="@iconClass">
                                                <i class="metrics-icon"></i>
                                            </span>
                                        }
                                        else
                                        {
                                            // resto de columnas agrupadas → texto normal
                                            <span class="dx-group-row-default">
                                                @ctx.GroupValueDisplayText
                                            </span>
                                        }
                                    }
                                </DataColumnGroupRowTemplate>


                                <!-- Detalle con los roles -->
                                <DetailRowTemplate Context="load">
                                    @{
                                        var shiftRow = load?.DataItem as VehicleLoadDto;
                                    }
                                    <DxGrid Data="shiftRow.Errors"
                                            KeyFieldName="id"
                                            CssClass="mlx-grid dxbl-grid-detail"
                                            VirtualScrollingEnabled="true"
                                            KeyboardNavigationEnabled="true">

                                        <Columns>
                                            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.VehicleTheoreticalDwellTime)"
                                                              Caption="@Theoretical_dwell"
                                                              TextAlignment="GridTextAlignment.Right"
                                                              ShowInColumnChooser="true">
                                                <CellDisplayTemplate>
                                                    <span class="mlx-italic">@context.DisplayText</span>
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.MaxEnd)"
                                                              Caption="@Departure"
                                                              DisplayFormat="HH:mm"
                                                              TextAlignment="GridTextAlignment.Right"
                                                              ShowInColumnChooser="true">
                                                <CellDisplayTemplate>
                                                    <span class="mlx-italic">@context.DisplayText</span>
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.DelaySeconds)"
                                                              Caption="@Delay"
                                                              TextAlignment="GridTextAlignment.Right"
                                                              ShowInColumnChooser="true">

                                                <CellDisplayTemplate>
                                                    @{
                                                        var value = context.Value; // O el tipo que sea Delay
                                                    }
                                                    <TimeInput ReadOnly="true" Format="hhmmss" Value="value" CssClass=" mlx-input-no-border" InputCssClass="mlx-italic" />
                                                </CellDisplayTemplate>

                                            </DxGridDataColumn>

                                            <DxGridDataColumn FieldName="@nameof(VehicleMetricsDto.OTIF)"
                                                              Caption="@OTIF"
                                                              DisplayFormat="p1"
                                                              TextAlignment="GridTextAlignment.Right"
                                                              ShowInColumnChooser="true">
                                                <CellDisplayTemplate>
                                                    <div class="text-right mlx-italic">
                                                        @context.DisplayText
                                                    </div>
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>

                                        </Columns>
                                    </DxGrid>
                                </DetailRowTemplate>

                            </DxGrid>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="@(ShowInfoDrawer ? "mlx-preview-section-button-action" : "mlx-preview-section-simulation-data-hidden" )">
        <div class="mlx-footer-button @(ShowInfoDrawer ? "container-buttons preview-seccion" : "")">
            <button id="btnCancelPreview" type="button" disabled="@(!IsDirty)" class="btn-mlx btn-mlx-white-primary" @onclick="CancelDataPreview">@Cancel</button>
            <button id="btnSavePreview" type="button" disabled="@(!IsDirty)" class="btn-mlx btn-mlx-blue-primary" @onclick="SaveDataPreview">@Save</button>
            <button id="btnReloadPreview" type="button" class="btn-mlx-blue-primary mlx-btn-action-enabled" @onclick="ReloadGanttSetupData" title="@CaptionSimulation">
                <span class="mlx-ico-reload"></span>
            </button>
            <button id="btnWhatIfPreview" type="button" class="btn-mlx-blue-primary mlx-btn-circle" @onclick="LoadWhatIf" title="@WhatIfTitleToolTip">
                <span class="mlx-ico-magin-wand"></span>
            </button>
        </div>
    </div>
</div>

<DxFlyout @ref="MetricsFlyout"
          @bind-IsOpen="IsFlyoutOpen"
          PositionTarget="@FlyoutTargetSelector"
          Position="FlyoutPosition.Auto"
          Width="700"
          Height="400"
          CloseOnOutsideClick="false"
          StopOutsideClickPropagation="true">

    <BodyContentTemplate>
        <div class="flyout-content-center">
            @if (SelectedMetricsRow?.AllMetrics == null ||
            SelectedMetricsRow.AllMetrics.Count == 0)
            {
                <div style="padding:12px;">No metrics available.</div>
            }
            else
            {
                <DxChart Data="@SelectedMetricsRow.AllMetrics"
                         Width="650px"
                         Height="350px">

                    <!-- X: horas -->
                    <DxChartArgumentAxis Visible="true" ArgumentType="ChartAxisDataType.String">
                        <DxChartAxisTitle Text="Hour" />
                    </DxChartArgumentAxis>

                    <!-- Y1: Slack/Delay -->
                    <DxChartValueAxis Name="TimeAxis" Visible="true">
                        <DxChartAxisTitle Text="Time (minutes)" />
                    </DxChartValueAxis>

                    <!-- Y2: OTIF -->
                    <DxChartValueAxis Name="OTIFAxis"
                                      Visible="true"
                                      Alignment="ChartAxisAlignment.Far">
                        <DxChartAxisLabel Format="ChartElementFormat.Percent()" />
                        <DxChartAxisTitle Text="OTIF" />
                    </DxChartValueAxis>

                    <DxChartLineSeries T="VehicleMetricsDto"
                                       TArgument="string"
                                       TValue="double"
                                       Name="@OTIF"
                                       Axis="OTIFAxis"
                                       ArgumentField="@(m => m.Hour)"
                                       ValueField="@(m => m.OTIF)" />

                    <DxChartLineSeries T="VehicleMetricsDto"
                                       TArgument="string"
                                       TValue="double"
                                       Name="@Slack"
                                       Axis="TimeAxis"
                                       ArgumentField="@(m => m.Hour)"
                                       ValueField="@(m => m.SlackMinutes)" />

                    <DxChartLineSeries T="VehicleMetricsDto"
                                       TArgument="string"
                                       TValue="double"
                                       Name="@Delay_Text"
                                       Axis="TimeAxis"
                                       ArgumentField="@(m => m.Hour)"
                                       ValueField="@(m => m.DelayMinutes)" />

                    <DxChartLegend Visible="true" />
                    <DxChartTooltip Enabled="true" />

                </DxChart>
            }
        </div>
    </BodyContentTemplate>

</DxFlyout>

<WhatIfModal Logs="WhatIfLogs"
             Opened="ShowWhatIfModal"
             OpenedChanged="OnWhatIfModalChanged"
             Shifts="@ShiftsWhatIf"
             AceptChange="ApplyWhatIf" />


<WhatIfDistribution Logs="WorkersDistribution"
                    Opened="ShowWhatIDistributionfModal"
                    OpenedChanged="OnWhatIfDistributionModalChanged" />


@code {
    // Referencia al flyout
    private DxFlyout? MetricsFlyout;

    // Controla si está abierto
    private bool IsFlyoutOpen { get; set; }

    // Selector CSS del elemento objetivo (el icono de la fila)
    private string? FlyoutTargetSelector { get; set; }

    // Fila seleccionada para el chart
    private VehicleLoadDto? SelectedMetricsRow { get; set; }

    private void OpenFlyout(VehicleLoadDto row)
    {
        ShowHidePanel(false, false);
        SelectedMetricsRow = row;
        FlyoutTargetSelector = $"#metrics-{row.id}";
        IsFlyoutOpen = true;
    }

    private void CloseFlyout()
    {
        IsFlyoutOpen = false;
        ShowHidePanel(false, false);
    }
}

<style>
    tr:has(.mlx-chart.mlx-ico-check-preview) .dxbl-grid-expand-button-cell > button {
        pointer-events: none !important;
        opacity: 0.4 !important;
        filter: grayscale(1) !important;
    }

    tr:has(.mlx-chart.mlx-ico-x-preview) .dxbl-grid-expand-button-cell > button {
        pointer-events: auto !important;
        opacity: 1 !important;
        filter: none !important;
    }

    .dxc-axes-group {
        display: block !important;
    }

    .chart-title {
        color: #1B3580;
        font-style: italic;
        font-size: 20px;
    }

    .mlx-input-no-border {
        border: none !important;
    }

    #btnReloadPreview {
        width: 40px;
    }

    .mlx-chart > .metrics-icon {
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .mlx-ico-check-preview > .metrics-icon:before {
        font-family: 'mlx_icons';
        font-style: normal;
        font-size: larger;
        content: "\ead1";
        color: #06a77d;
    }

    .mlx-ico-x-preview > .metrics-icon:before {
        font-family: 'mlx_icons';
        font-style: normal;
        font-size: larger;
        content: "\ead0";
        color: #eb5160;
    }

    .flyout-content-center {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }



    .mlx-ico-chart::before {
        content: "📈";
    }



    .row-new td {
