    private void HandleProcessValidationChanged(object? sender, ValidationStateChangedEventArgs e)
    {
        UpdateSaveButtonState(); // Recalculate _hasErrors
        InvokeAsync(StateHasChanged);
    }

    private bool HasFormValidationErrors()
    {
        if (editContextProcess is null)
            return false;

        return editContextProcess.GetValidationMessages().Any(); // If there is an active validation message, the form is not valid.
    }
    #endregion

    #endregion

    #region ToolBar Grid
    private async Task ResetState()
    {
        isEditing = false;
        showEditButton = true;
        showReadOnlyButton = false;
        showSaveButton = false;
        showDeleteButton = false;
        showNewElementForm = false;
        showAddButton = true;
        isFormValid = false;

        stepDto = StepDto.NewDto();
        messageStore.Clear();
        EditingBuffer.Clear();
        ModifiedFields.Clear();
        SelectedRows.Clear();
        DeletedStepsBuffer.Clear();
        UpdateErrors.Clear();
        LockedEditingRowId = null;

        var sourceList = (ResetStepList != null && ResetStepList.Any()) ? ResetStepList : OriginalStepList;
        StepList = sourceList.Select(s => s.Clone()).ToList(); // Restore the version from the last point saved in memory
        UpdateDirtyFlag();
        await InvokeAsync(StateHasChanged);
    }

    private StepDto CloneStep(StepDto s) => new StepDto
        {
            Id = s.Id,
            Name = s.Name,
            TimeMin = s.TimeMin,
            Order = s.Order,
            InitProcess = s.InitProcess,
            EndProcess = s.EndProcess,
            ProcessId = s.ProcessId,
            ViewPort = s.ViewPort
        };

    private void OnRowChecked(bool isChecked, StepDto model)
    {
        if (isChecked)
        {
            if (!SelectedRows.Contains(model))
                SelectedRows.Add(model);
        }
        else
            SelectedRows.Remove(model);

        if(SelectedRows.Count == 0)
            ExecuteEditMode();
        else
            ShowDeleteButton();

        StateHasChanged();
    }

    private void ShowDeleteButton()
    {
        showAddButton = false;
        showEditButton = false;
        showSaveButton = true;
        showDeleteButton = true;
        showReadOnlyButton = true;
    }

    #region ExecuteModes

    private void ExecuteStateAdd()
    {
        isEditing = false;
        showNewElementForm = true;
        showAddButton = false;
        showEditButton = false;
        showDeleteButton = false;
        showSaveButton = true;
        showReadOnlyButton = true;

        stepDto = StepDto.NewDto();
        SetupEditContext();
    }

    private void ExecuteEditMode()
    {
        EditingBuffer.Clear();

        // Create snapshot of all rows
        foreach (var row in StepList)
            EditingBuffer[row.Id] = CloneStep(row);
        isEditing = true;
        showNewElementForm = false;
        showAddButton = false;
        showEditButton = false;
        showReadOnlyButton = true;
        showSaveButton = true;
        showDeleteButton = false;
        ResetStepList = StepList.Select(s => s.Clone()).ToList();
        editContextProcess.NotifyValidationStateChanged();
    }

    private async Task ExecuteDeleteMode()
    {
        if (SelectedRows?.Any() != true)
            return;

        var selectedRowList = SelectedRows.ToList();

        foreach (var step in selectedRowList)
        {
            EditingBuffer.Remove(step.Id);
            UpdateErrors.Remove(step.Id);
            ModifiedFields.Remove(step.Id);
            StepList.Remove(step);

            if (OriginalStepList.Any(o => o.Id == step.Id))
            {
                DeletedStepsBuffer.Add(step);
            }
            else
            {
                // If the record was created in memory, it counts as a “local change” to enable the Save button
                if (!ModifiedFields.ContainsKey(step.Id))
                    ModifiedFields[step.Id] = new HashSet<string> { nameof(StepDto.Id) };
            }
        }

        // Recalculate validations for the “order” after deleting the remaining items
        foreach (var row in StepList)
        {
            UpdateDuplicateOrderErrors(row.Id);
        }

        SelectedRows.Clear();

        if (!UpdateErrors.Any())
            LockedEditingRowId = null;

        if (!StepList.Any())
            ExecuteEditMode();

        StepList = StepList.ToList(); // Recalculate internally to update the grid data internally

        isEditing = true;
        showNewElementForm = false;
        showAddButton = false;
        showEditButton = false;
        showReadOnlyButton = true;
        showSaveButton = true;
        showDeleteButton = false;
        editContextProcess.NotifyValidationStateChanged();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExecuteSaveMode()
    {
        foreach (var fields in ModifiedFields)
        {
            var rowId = fields.Key;
            if (!EditingBuffer.TryGetValue(rowId, out var bufferRow))
                continue;

            var targetRow = StepList.FirstOrDefault(r => r.Id == rowId);
            if (targetRow == null)
                continue;

            foreach (var prop in fields.Value)
            {
                var newValue = bufferRow.GetType().GetProperty(prop)?.GetValue(bufferRow);
                targetRow.GetType().GetProperty(prop)?.SetValue(targetRow, newValue);
            }
        }

        if (DeletedStepsBuffer.Any())
        {
            foreach (var deleted in DeletedStepsBuffer)
            {
                StepList.RemoveAll(s => s.Id == deleted.Id);
            }
        }

        ResetStepList = StepList.Select(s => s.Clone()).ToList(); // Refreshes the data in the ResetStepList memory

        // Cleans buffers and errors
        EditingBuffer.Clear();
        ModifiedFields.Clear();
        DeletedStepsBuffer.Clear();
        UpdateErrors.Clear();
        SelectedRows.Clear();

        isEditing = false;
        showNewElementForm = false;
        showAddButton = true;
        showSaveButton = false;
        showReadOnlyButton = false;
        showEditButton = true;
        showDeleteButton = false;
        UpdateDirtyFlag();
        editContextProcess.NotifyValidationStateChanged();

        await InvokeAsync(StateHasChanged);
    }

    #endregion

    #region Validation Grid
    private void OnValueChanged(string propertyName, object? value, StepDto originalRow)
    {
        var rowId = originalRow.Id;

        // Check if the row exists in the temporary list
        if (!EditingBuffer.ContainsKey(rowId))
            EditingBuffer[rowId] = CloneStep(originalRow);

        var bufferRow = EditingBuffer[rowId];

        // We assign the value of the cell in the temporary list
        SetPropertyValue(bufferRow, propertyName, value);

        if (propertyName == nameof(StepDto.TimeMin))
        {
            double parsed = Convert.ToDouble(value ?? 0);
            if (parsed <= 0)
            {
                if (!UpdateErrors.ContainsKey(rowId))
                    UpdateErrors[rowId] = new();
                UpdateErrors[rowId][propertyName] = L.Loc("* Activity time must be greater than 0"); // The message is set because if it is done from the model, the model does not know what values the error list has
            }
            else
            {
                // Cleaned if there is no error
                if (UpdateErrors.ContainsKey(rowId))
                {
                    UpdateErrors[rowId].Remove(propertyName);
                    if (UpdateErrors[rowId].Count == 0)
                        UpdateErrors.Remove(rowId);
                }
            }
        }

        // -- Cell validation section --

        var context = new ValidationContext(bufferRow);
        var results = new List<ValidationResult>();

        Validator.TryValidateObject(bufferRow, context, results, validateAllProperties: true);

        // We initialize the error list for the row
        if (!UpdateErrors.ContainsKey(rowId))
            UpdateErrors[rowId] = new();

        UpdateErrors[rowId].Remove(propertyName); // We clean up the error list

        foreach (var result in results.Where(r => r.MemberNames != null && r.MemberNames.Contains(propertyName)))
        {
            UpdateErrors[rowId][propertyName] = result.ErrorMessage ?? L.Loc("* Mandatory field");
        }

        UpdateDuplicateOrderErrors(rowId);

        // If the error has been corrected, it is removed from the list
        if (UpdateErrors.TryGetValue(rowId, out var dict) && dict.Count == 0)
            UpdateErrors.Remove(rowId);

        // --- Evaluate modified fields ---
        var origVal = originalRow.GetType().GetProperty(propertyName)?.GetValue(originalRow);
        var newVal = bufferRow.GetType().GetProperty(propertyName)?.GetValue(bufferRow);
        if (!Equals(origVal, newVal))
        {
            if (!ModifiedFields.ContainsKey(rowId))
                ModifiedFields[rowId] = new HashSet<string>();
            ModifiedFields[rowId].Add(propertyName);
        }
        else if (ModifiedFields.TryGetValue(rowId, out var set))
        {
            set.Remove(propertyName);
            if (set.Count == 0)
                ModifiedFields.Remove(rowId);
        }

        // Blocks all rows in the grid except the one being edited
        if (UpdateErrors.ContainsKey(rowId))
            LockedEditingRowId = rowId;
        else
        {
            // If the error is corrected, the rows are unlocked in edit mode
            if (UpdateErrors.Count == 0)
                LockedEditingRowId = null;
        }
        InvokeAsync(StateHasChanged);
    }

    private void SetPropertyValue(object target, string propertyName, object? value)
    {
        var prop = target.GetType().GetProperty(propertyName);
        if (prop == null) return;

        var targetType = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;

        object? converted = null;
        if (value == null || string.IsNullOrEmpty(value.ToString()))
            converted = null;
        else if (targetType == typeof(string))
            converted = value.ToString();
        else if (targetType.IsEnum)
            converted = Enum.Parse(targetType, value.ToString()!);
        else if (targetType == typeof(Guid))
            converted = Guid.Parse(value.ToString()!);
        else
            converted = Convert.ChangeType(value, targetType);

        prop.SetValue(target, converted);
    }

    private void UpdateDuplicateOrderErrors(Guid currentRowId)
    {
        // We obtain the values of the current row
        if (!EditingBuffer.TryGetValue(currentRowId, out var currentRow))
            return;

        var currentOrder = currentRow.Order;
        bool duplicateExists = EditingBuffer.Where(kvp => kvp.Key != currentRowId).Any(kvp => kvp.Value.Order == currentOrder); // Search if the Order is repeated

        // We initialize the error list in case it does not exist
        if (!UpdateErrors.ContainsKey(currentRowId))
            UpdateErrors[currentRowId] = new();

        // If there is a duplicate in the order, the text in the cell is set
        if (duplicateExists)
            UpdateErrors[currentRowId]["Order"] = L.Loc("* The order number is already in use.");
        else
        {
            // If there is no error in the order, it is cleared
            UpdateErrors[currentRowId].Remove("Order");
            if (UpdateErrors[currentRowId].Count == 0)
                UpdateErrors.Remove(currentRowId);
        }
    }

    // Method that sets error messages in cells
    private string GetValidationError(string propertyName, object dataItem)
    {
        if (dataItem is StepDto stepDto)
        {
            return UpdateErrors.TryGetValue(stepDto.Id, out var fieldErrors) && fieldErrors.TryGetValue(propertyName, out var error) ? error : string.Empty;
        }
        return string.Empty;
    }

