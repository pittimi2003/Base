    #region Button Validate Methods

    public void CaptureBaseline()
    {
        _baselineFingerprint = BuildFingerprint();
        _isDirty = false;
        _hasErrors = false;
    }

    private string BuildFingerprint()
    {
        var flowId = DesignerDto?.Flow?.Id ?? DesignerDto?.FlowId ?? Guid.Empty;

        return string.Join("|",
            DesignerDto?.Name ?? string.Empty,
            flowId,
            DesignerDto?.Type ?? 0,
            DesignerDto?.MinTime ?? 0,
            DesignerDto?.PreprocessTime ?? 0,
            DesignerDto?.PostprocessTime ?? 0,
            DesignerDto?.IsInitProcess ?? false,
            DesignerDto?.PercentageInitProcess ?? 0,
            DesignerDto?.IsIn ?? false,
            DesignerDto?.IsOut ?? false,
            DesignerDto?.IsWarehouseProcess ?? false,

            // CUSTOM
            DesignerDto?.Type == ProcessType.CustomProcess ? customProcess?.InitHour ?? 0 : 0,
            DesignerDto?.Type == ProcessType.CustomProcess ? customProcess?.EndHour ?? 0 : 0,
            DesignerDto?.Type == ProcessType.CustomProcess ? customProcess?.NumPossibleTimes ?? 0 : 0,
            DesignerDto?.Type == ProcessType.CustomProcess ? customProcess?.Percentage ?? 0 : 0,

            DesignerDto?.Type == ProcessType.Picking ? pickingDto?.PickingRoadTime ?? 0 : 0,
            DesignerDto?.Type == ProcessType.Replenishment ? replenishmentDto?.Percentage ?? 0 : 0,

            // PACKING
            DesignerDto?.Type == ProcessType.Packing
                ? BuildPackingKey(packingDto?.PackModes)
                : string.Empty,

            // STEPS
            BuildStepsKey(StepList)
        );
    }


    private string BuildPackingKey(IEnumerable<PackModeDto> packModes)
    {
        if (packModes == null)
            return string.Empty;

        return string.Join(";",
            packModes
                .OrderBy(p => p.PackName)
                .Select(p => $"{p.PackName}:{p.PackQty}")
        );
    }


    public void MarkDirty()
    {
        _isDirty = true;
        UpdateSaveButtonState();
        StateHasChanged();
    }

    private void UpdateDirtyFlag()
    {
        var current = BuildFingerprint();
        _isDirty = current != _baselineFingerprint;

        UpdateSaveButtonState();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateSaveButtonState()
    {
        _hasErrors = (editContextProcess?.GetValidationMessages().Any() ?? false) || UpdateErrors.Any() || !ValidateGridSteps();
    }

    // Builds a deterministic key used to detect committed changes in Steps (avoids expensive JSON or reflection)
    private string BuildStepsKey(IEnumerable<StepDto> steps)
    {
        if (steps == null) return string.Empty;

        // Keep a stable order for comparison purposes (Id is the sorting key)
        var ordered = steps
            .OrderBy(s => s.Id)
            .Select(s =>
            {
                var id = s.Id;
                var name = s.Name ?? string.Empty;
                var tm = s.TimeMin;
                var ord = s.Order;
                var ini = s.InitProcess;
                var end = s.EndProcess;
                return $"{id}|{name}|{tm}|{ord}|{ini}|{end}";
            });

        // Join all rows into a single string; if any record changes (add, update, delete), the key changes
        return string.Join("||", ordered);
    }

    #endregion

    private void OnProcessTypeChanged(ProcessType? newValue)
    {
        if (DesignerDto.Type == newValue)
            return;

        DesignerDto.Type = newValue;
        ApplyProcessTypePolicy(newValue);
        UpdateDirtyFlag();
        editContextProcess.NotifyValidationStateChanged();
        UpdateSaveButtonState();
    }

    private void OnCustomProcessChanged(Action setter)
    {
        setter.Invoke();
        UpdateDirtyFlag(); // recalculate dirty
        editContextProcess.NotifyValidationStateChanged();
        UpdateSaveButtonState();
    }

    private void ApplyProcessTypePolicy(ProcessType? type)
    {
        ShowInitProcessToggle = type.HasValue && type.Value != ProcessType.CustomProcess;
        if (!ShowInitProcessToggle)
            ClearInitProcessState();
    }

    private void ClearInitProcessState()
    {
        DesignerDto.IsInitProcess = false;
        DesignerDto.PercentageInitProcess = 0;
        IsVisibleStartProcess = false;
    }


    private void OnProcessWarehouseChange(bool value)
    {
        DesignerDto.IsWarehouseProcess = value;

        if (value)
        {
            lstProcessType = lstAllProcessType
                .Where(x => x.Type == ProcessType.CustomProcess || x.Type == ProcessType.Replenishment)
                .ToList();
        }
        else
        {
            lstProcessType = lstAllProcessType
                .Where(x => x.Type != ProcessType.Replenishment)
                .ToList();
        }

        if (!lstProcessType.Any(x => x.Type == DesignerDto.Type))
        {
            OnProcessTypeChanged(null);
        }

        UpdateDirtyFlag();
        editContextProcess.NotifyValidationStateChanged();
    }


