    private void AddStep()
    {
        stepDto.Siblings = StepList;

        // -------- Validate --------
        if (!editContextSteps.Validate())
        {
            isFormValid = false;
            StateHasChanged();
            return;
        }
        // -------------------------------           

        // Ensures the logic of exclusion: only one can be true
        bool isInit = stepDto.StepInitEnd == StepInitEndType.Before;
        bool isEnd = stepDto.StepInitEnd == StepInitEndType.After;

        // Create a stepDto item
        var newStep = new StepDto
            {
                Id = Guid.NewGuid(),
                Name = stepDto.Name,
                TimeMin = stepDto.TimeMin,
                InitProcess = isInit,
                EndProcess = isEnd,
                Order = stepDto.Order,
                ProcessId = DesignerDto?.Id ?? Guid.Empty
            };

        if (!EditingBuffer.ContainsKey(newStep.Id))
            EditingBuffer[newStep.Id] = newStep;

        ModifiedFields[newStep.Id] = new HashSet<string>
        {
            nameof(StepDto.Name),
            nameof(StepDto.TimeMin),
            nameof(StepDto.Order),
            nameof(StepDto.StepInitEnd)
        };

        StepList = StepList.Append(newStep).ToList(); // Forces the loading of the listing

        foreach (var s in StepList)
            s.Siblings = StepList;

        stepDto = StepDto.NewDto(); // Clear the form
        SetupEditContext();
        isFormValid = false;
        editContextProcess.NotifyValidationStateChanged();
        StateHasChanged();
    }

    // Describes when the component is restarted (It is important to avoid duplicate messages)
    public void Dispose()
    {
        if (editContextProcess is not null){
            editContextProcess.OnFieldChanged -= HandleProcessFieldChanged;
            editContextProcess.OnValidationStateChanged -= HandleProcessValidationChanged;
        }

        if (editContextSteps is not null)
        {
            editContextSteps.OnValidationRequested -= ValidateForm;
            editContextSteps.OnFieldChanged -= HandleFieldChanged;
        }

        messageStore?.Clear();
    }

    // Validates whether there are errors in the cells being edited in Grid Steps
    private bool ValidateGridSteps()
    {
        // If there are no records, it is valid
        if (StepList == null || StepList.Count == 0)
            return true;

        bool isValid = true;
        // We validate whether the error list contains anything
        if (UpdateErrors.Count > 0)
            isValid = false;

        return isValid;
    }

    // Devuelve todos los mensajes actuales de validación
    private IEnumerable<string> GetGridErrors()
    {
        var ec = grid?.GetEditContext();

        if (ec?.Model is StepDto row)
            row.Siblings = StepList;

        return ec is null ? Enumerable.Empty<string>() : ec.GetValidationMessages();
    }

    // Devuelve los mensajes agrupados por campo
    private Dictionary<string, List<string>> GetGridErrorsByField()
    {
        var result = new Dictionary<string, List<string>>();

        var ec = grid?.GetEditContext();

        if (ec is null) 
            return result;

        if (ec.Model is StepDto row)
            row.Siblings = StepList;

        // Recorremos las columnas de datos visibles para consultar sus mensajes
        foreach (var col in grid.GetDataColumns().OfType<DxGridDataColumn>())
        {
            if (string.IsNullOrWhiteSpace(col.FieldName)) continue;

            var fi = new FieldIdentifier(ec.Model, col.FieldName);
            var msgs = ec.GetValidationMessages(fi).ToList();
            if (msgs.Count > 0)
                result[col.FieldName] = msgs;
        }
        return result;
    }
