    private Task ToggleIsOut(bool? value)
    {
        var checkedValue = value ?? false;

        // Si se activa IsOut, desactiva IsIn
        if (checkedValue)
        {
            DesignerDto.IsOut = true;
            DesignerDto.IsIn = false;
        }
        else
        {
            // Si se intenta desmarcar IsOut, se marca IsIn
            DesignerDto.IsOut = false;
            DesignerDto.IsIn = true;
        }

        return Task.CompletedTask;
    }

    private Task ToggleIsIn(bool? value)
    {
        var checkedValue = value ?? false;

        if (checkedValue)
        {
            DesignerDto.IsIn = true;
            DesignerDto.IsOut = false;
        }
        else
        {
            DesignerDto.IsIn = false;
            DesignerDto.IsOut = true;
        }

        return Task.CompletedTask;
    }

