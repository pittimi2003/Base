    // Initializes the DTO contexts, initializes the custom validation message, and activates field validation listeners for StepsDto
    private void SetupEditContext()
    {
        if (editContextSteps != null)
        {
            editContextSteps.OnValidationRequested -= ValidateForm;
            editContextSteps.OnFieldChanged -= HandleFieldChanged;
        }

        editContextSteps = new EditContext(stepDto);
        messageStore = new ValidationMessageStore(editContextSteps);
        editContextSteps.OnValidationRequested += ValidateForm;
        editContextSteps.OnFieldChanged += HandleFieldChanged;
    }

    private void HandleFieldChanged(object sender, FieldChangedEventArgs e)
    {
        isFormValid = editContextSteps.Validate(); // This validates the whole form each time
    }

    private void ValidateForm(object sender, ValidationRequestedEventArgs args)
    {
        messageStore.Clear();
        stepDto.Siblings = StepList;

        // Check if the ‘Order’ already exists in another Step
        bool orderRepetido = StepList.Any(x => x.Order == stepDto.Order);

        if (orderRepetido)
        {
            messageStore.Add(() => stepDto.Order, L.Loc("* The order number is already in use."));
        }
        isFormValid = !orderRepetido;
        InvokeAsync(StateHasChanged);
    }

