@code {

    #region Parameters
    [Parameter]
    public EventCallback OnClickSideBar { get; set; }
    [Parameter]
    public BufferDto DesignerDto { get; set; }
    [Parameter] 
    public UserFormatOptions UserFormat { get; set; } = new();
    [Parameter]
    public Dictionary<string, object>? Metadata { get; set; }
    [Parameter]
    public EventCallback<Dictionary<string, object>?> OnChildCancel { get; set; }
    [Parameter]
    public EventCallback<Dictionary<string, object>?> OnChildSaved { get; set; }
    #endregion

    #region Properties
    [Inject] private IDesignerServices _designer { get; set; }

    [Inject] private IJSRuntime JS { get; set; }
    #endregion

    #region Interfaces

    public bool IsSidebarDirty => _isDirty;
    public bool HasErrors => _hasErrors;
    public Task SaveEvent() => SaveEventInternal();

    #endregion

    private EditContext editContext;
    private ValidationMessageStore? messageStore;

    private string jsonResult { get; set; }

    private IEnumerable<ZoneType> _filteredZoneTypes = Enum.GetValues(typeof(ZoneType)).Cast<ZoneType>().Where(x => x != ZoneType.Unknown);
    private List<ComboBoxSelectItem<OrientationType>> orientationType = new();
    private List<ComboBoxSelectItem<BufferType>> bufferTypes = new();

    #region Save Status Button

    private string? _baselineFingerprint;
    private bool _isDirty = false;
    private bool _hasErrors = false;
    private bool CanSave => _isDirty && !_hasErrors;

    #endregion

    // Method for handling the click
    private async Task CancelButtonClick()
    {
        await OnChildCancel.InvokeAsync(Metadata);
    }

    // Combo box
    private IEnumerable<AreaDto>? AreaItems { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Inicializar datos manuales
        editContext = new EditContext(DesignerDto);
        messageStore = new ValidationMessageStore(editContext);
        FillComboBox();
        CaptureBaseline();
        editContext.OnFieldChanged += HandleFieldChanged;
        editContext.OnValidationStateChanged += OnValidationChanged;
    }

    private void FillComboBox()
    {
        List<AreaDto>? areas = _designer.GetAreasDtoByLayout(DesignerDto?.Zone?.Area?.LayoutId ?? Guid.Empty)?.ToList() ?? new List<AreaDto>();
        AreaItems = areas.Any() && DesignerDto?.Zone?.Area != null ? areas.Where(i => i.Id != DesignerDto.Id).ToList() : new List<AreaDto>();

        orientationType = Enum.GetValues(typeof(OrientationType))
        .Cast<OrientationType>()
        .Where(x => x != OrientationType.None)
        .Select(x => new ComboBoxSelectItem<OrientationType>(L)
            {
                Value = x,
                Text = GetOrientationTypeString(x)
            }).OrderBy(o => o.Text)
        .ToList();

        bufferTypes = Enum.GetValues(typeof(BufferType))
            .Cast<BufferType>()
            .Where(x => x != BufferType.None)
            .Select(x => new ComboBoxSelectItem<BufferType>(L)
                {
                    Value = x,
                    Text = GetBufferTypeString(x)
                }).OrderBy(o => o.Text)
            .ToList();
    }

    private async Task SaveEventInternal()
    {
        if (editContext == null || DesignerDto.Zone == null)
            return;
        bool isValid = ValidateSideBar();
        MarkDirty();
        _hasErrors = !isValid;

        if (!isValid || !_isDirty)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            DesignerDto.Zone.IsVertical = DesignerDto.IsVertical; // Update the IsVertical data for Zones
            DesignerDto.Zone.Orientation = DesignerDto.Orientation; // Update the Orientation data for Zones

            //Update case
            await _designer.UpdateBuffer(DesignerDto);

            List<Models.DTO.Designer.ZoneDto> zoneList = new();
            IEnumerable<Zone> zoneEnumerable = _designer.GetZonesByAreaNoTracking(DesignerDto?.Zone?.Area?.Id ?? Guid.Empty);

            foreach (var zone in zoneEnumerable)
            {
                if (null != zone && zone.Id != Guid.Empty)
                    zoneList.Add(_designer.GetZoneDtoById(zone.Id));
            }

            List<StepDto> stepDtoList = new();
            List<ProcessDto> processDtoList = _designer.GetProcesByType(DesignerDto?.Zone?.Area?.Id ?? Guid.Empty).ToList(); // Obtains the processes related to the area

            foreach(var process in processDtoList)
            {
                stepDtoList.AddRange(_designer.GetStepsDtoByProcessIdNoTracking(process.Id ?? Guid.Empty).ToList());
            }

            var newViewport = _designer.GetVieportsByTypeObject(DesignerDto?.Zone.AreaId ?? Guid.NewGuid(), "Area");
            await JS.InvokeVoidAsync("drawObjectsOnCanvas", newViewport);
            await JS.InvokeVoidAsync("SaveOnPostback");
        }

        catch (Exception ex)
        {
            Console.WriteLine($"Error saving the record: {ex.Message}");
        }
        CaptureBaseline();
        await InvokeAsync(StateHasChanged);
        if (OnChildSaved.HasDelegate)
            await OnChildSaved.InvokeAsync(Metadata);
    }

    // Method for handling the click
    private async Task CloseSideBarButton()
    {
        await OnClickSideBar.InvokeAsync();
    }

    private void OnValidationMessageChanged<T>(Expression<Func<T>> propertyExpression, T value, Action<T> assignAction)
    {
        assignAction(value); // Assign the new value
        var field = FieldIdentifier.Create(propertyExpression); // Create the field identifier for validation
        messageStore?.Clear(field); // Clear previous validations
        editContext.NotifyFieldChanged(field); // Notify EditContext
        bool isValid = editContext.Validate();
        _hasErrors = !isValid;
        StateHasChanged();
    }

    #region Validations

    // Event Save
    private bool ValidateSideBar()
    {
        messageStore?.Clear(); // Clears previous validations
        bool isValid = editContext.Validate(); // Validates the decorators of the attributes of the model assigned in the editContext

        if (DesignerDto.BufferType == null || DesignerDto.BufferType == BufferType.None)
        {
            var field = FieldIdentifier.Create(() => DesignerDto.BufferType);
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            isValid = false;
        }

        if (DesignerDto.Orientation == null || DesignerDto.Orientation == OrientationType.None)
        {
            var field = FieldIdentifier.Create(() => DesignerDto.Orientation);
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            isValid = false;
        }

        var fieldName = FieldIdentifier.Create(() => DesignerDto.Zone.Name);

        // Validate required field
        if (string.IsNullOrWhiteSpace(DesignerDto.Zone?.Name))
        {
            messageStore?.Add(fieldName, L.Loc("* Mandatory field"));
            isValid = false;
        }
        else
        {
            var (itsUnique, suggestions) = _designer.CalculateNameToValidations(DesignerDto.Zone.Name, DesignerDto.Zone.AreaId, DesignerDto.Zone.Id); // Validate duplicates and suggest names
            if (!itsUnique)
            {
                var mensaje = L.Loc("The name is already in use. Suggestions: {0}", string.Join(", ", suggestions));
                messageStore?.Add(fieldName, mensaje);
                isValid = false;
            }
        }

        // // MaxContainers validation
        // if (DesignerDto.Zone.MaxContainers <= 0)
        // {
        //     var fieldMaxContainers = FieldIdentifier.Create(() => DesignerDto.Zone.MaxContainers);
        //     messageStore?.Add(fieldMaxContainers, L.Loc("* Must be greater than 0"));
        //     isValid = false;
        // }

        // // MaxEquipments validation
        // if (DesignerDto.Zone.MaxEquipments <= 0)
        // {
        //     var fieldMaxEquipments = FieldIdentifier.Create(() => DesignerDto.Zone.MaxEquipments);
        //     messageStore?.Add(fieldMaxEquipments, L.Loc("* Must be greater than 0"));
        //     isValid = false;
        // }

        editContext.NotifyValidationStateChanged(); // Updates the editContext with the messages of manual validations
        return isValid;
    }

    // Name OnBlur Event
    private void OnNameEvent(string? name)
    {
        DesignerDto.Zone.Name = name;
        var field = FieldIdentifier.Create(() => DesignerDto.Zone.Name);
        messageStore?.Clear(field);

        // Required
        if (string.IsNullOrWhiteSpace(DesignerDto.Zone?.Name))
        {
            messageStore?.Add(field, L.Loc("* Mandatory field"));
            _hasErrors = true;
            editContext.NotifyValidationStateChanged();
            MarkDirty();
            InvokeAsync(StateHasChanged);
            return;
        }
        var (itsUnique, suggestions) = _designer.CalculateNameToValidations(DesignerDto.Zone.Name, DesignerDto.Zone.AreaId, DesignerDto.Zone.Id); // Unique
        if (!itsUnique)
        {
            messageStore?.Add(field, L.Loc("The name is already in use. Suggestions: {0}", string.Join(", ", suggestions)));
            _hasErrors = true;
        }
        else
            _hasErrors = !string.IsNullOrEmpty(editContext.GetValidationMessages(field).FirstOrDefault()); // Clears errors ONLY if there are no longer any validation messages in the context

        editContext.NotifyValidationStateChanged();
        MarkDirty();
        InvokeAsync(StateHasChanged);
    }

    #endregion

    #region Save Button Status

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        MarkDirty();
        InvokeAsync(StateHasChanged);
    }

    private void OnValidationChanged(object? sender, ValidationStateChangedEventArgs e)
    {
        _hasErrors = editContext.GetValidationMessages().Any();
        InvokeAsync(StateHasChanged);
    }

    public void CaptureBaseline()
    {
        _baselineFingerprint = BuildFingerprint();
        _isDirty = false;
        _hasErrors = false;
    }
    
    public void MarkDirty()
    {
        _isDirty = BuildFingerprint() != _baselineFingerprint;
    }
    
    private string BuildFingerprint()
    {
        return string.Join("|",
            DesignerDto?.Id,
            DesignerDto?.Zone?.Id,
            DesignerDto?.Zone?.Name,
            DesignerDto?.Zone?.X,
            DesignerDto?.Zone?.Y,
            DesignerDto?.Zone?.Width,
            DesignerDto?.Zone?.Height,
            DesignerDto?.Zone?.MaxContainers,
            DesignerDto?.Zone?.MaxEquipments,
            DesignerDto?.BufferType,
            DesignerDto?.Orientation
        );
    }
    
    // Útil cuando el usuario da "Discard"
    public void ResetBaseline()
    {
        CaptureBaseline();
    }
    
    public void RestoreOriginalState()
    {
        if (DesignerDto.Id != null)
        {
            var refreshed = _designer.GetBufferDtoByIdNoTracking(DesignerDto.Id);
            if (refreshed != null)
            {
                DesignerDto = refreshed;
                CaptureBaseline();
            }
        }
    
        StateHasChanged();
    }
    #endregion

}